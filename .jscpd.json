{
  "threshold": 0,
  "minTokens": 50,
  "reporters": ["console"],
  "absolute": true,
  "gitignore": true,
  "formatsExts": {
    "typescript": ["ts"],
    "tsx": ["tsx"],
    "javascript": ["js", "mjs", "cjs"]
  },
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-desktop/**",
    "**/coverage/**",
    "**/*.svg",
    "**/*.html",
    "**/*.css"
  ]
}
