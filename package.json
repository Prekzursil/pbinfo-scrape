{
  "name": "pbinfo-scrape",
  "version": "0.1.1",
  "private": true,
  "author": "Prekzursil",
  "repository": {
    "type": "git",
    "url": "https://github.com/Prekzursil/pbinfo-scrape.git"
  },
  "type": "module",
  "main": "dist-desktop/gui/main/index.js",
  "description": "Problem Archive Crawler - PBInfo archival operator console.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:desktop": "tsc -p tsconfig.desktop.json --noEmit",
    "test": "vitest run",
    "test:desktop-electron": "npm run desktop:build && cross-env PBINFO_INCLUDE_ELECTRON_SMOKE=1 vitest run tests/gui/desktop-electron-smoke.test.ts",
    "test:watch": "vitest",
    "start": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "verify": "npm run typecheck && npm run typecheck:desktop && npm run test && npm run build",
    "desktop:assets": "node scripts/generate-brand-assets.mjs",
    "desktop:clean": "node scripts/clean-desktop-output.mjs",
    "desktop:renderer:dev": "vite --config vite.desktop.config.ts",
    "desktop:renderer:build": "vite build --config vite.desktop.config.ts",
    "desktop:main:build": "tsc -p tsconfig.desktop.json",
    "desktop:electron:dev": "wait-on tcp:5173 && cross-env PBINFO_DESKTOP_DEV_SERVER=http://127.0.0.1:5173 node scripts/run-desktop-electron.mjs dist-desktop/gui/main/index.js",
    "desktop:dev": "concurrently -k \"npm:desktop:renderer:dev\" \"npm:desktop:electron:dev\"",
    "desktop:build": "npm run desktop:assets && npm run desktop:clean && npm run desktop:renderer:build && npm run desktop:main:build",
    "desktop:start": "node scripts/run-desktop-electron.mjs dist-desktop/gui/main/index.js",
    "desktop:pack": "npm run desktop:build && electron-builder --config electron-builder.json --win portable --x64",
    "smoke:desktop-packaged": "tsx scripts/smoke-packaged-desktop.ts",
    "verify:canonical-snapshot": "tsx scripts/verify-canonical-snapshot.ts",
    "mirror:build": "tsx src/cli.ts build-mirror",
    "acceptance:crawl": "tsx src/cli.ts crawl all --acceptance",
    "publish:repo": "tsx src/cli.ts publish"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "overrides": {
    "undici": "7.24.2",
    "yauzl": "3.2.1"
  },
  "dependencies": {
    "age-encryption": "^0.3.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.2",
    "express": "^5.1.0",
    "fetch-cookie": "^3.1.0",
    "mime-types": "^3.0.1",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tough-cookie": "^6.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.3",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4"
  }
}
