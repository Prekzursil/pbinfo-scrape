# Remember hook logs — keep directory tracked via .gitkeep, ignore actual log payloads.
.remember/logs/*.log
.remember/logs/*.jsonl
!.remember/logs/.gitkeep

# Ad-hoc Electron user-data snapshots from local smoke runs. The screenshot
# artifacts themselves (library-shell-live.png) are tracked, but the Electron
# per-run cache directory is per-machine ephemeral state.
docs/superpowers/screenshots/user-data/
docs/superpowers/screenshots/smoke-report.json

