{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "react"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "archive/**",
    "assets/**",
    "docs/**",
    "dist/**",
    "dist-desktop/**",
    "node_modules/**"
  ],
  "rules": {
    "no-unused-vars": "error",
    "react/react-in-jsx-scope": "off"
  }
}
