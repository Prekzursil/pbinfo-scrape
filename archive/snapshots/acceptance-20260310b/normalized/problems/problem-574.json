  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine câte grafuri <strong>orientate</strong> complete cu <code>n</code> noduri există.</p>",
      "text": "Să se determine câte grafuri orientate complete cu n noduri există."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>C</code>, reprezentând valoarea cerută.</p>",
      "text": "Programul va afișa pe ecran numărul C, reprezentând valoarea cerută."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 100</code></li>\n\t<li>numărul de grafuri poate fi destul de mare</li>\n</ul>",
      "text": "2 ≤ n ≤ 100 numărul de grafuri poate fi destul de mare"
    },
    {
      "title": "Exemplu",
      "html": "<p><strong>Intrare</strong></p><pre>2</pre><p><strong>Ieșire</strong></p><pre>3</pre><p><strong>Intrare</strong></p><pre>4</pre><p><strong>Ieșire</strong></p><pre>729</pre>",
      "text": "Intrare2Ieșire3Intrare4Ieșire729"
    }
  ],
