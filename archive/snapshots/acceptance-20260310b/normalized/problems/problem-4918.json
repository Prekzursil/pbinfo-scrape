  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>O persoana are de urcat <code>n</code> trepte. Ştiind că poate păşi pe treapta urmatoare sau poate sări peste o treapta, aflaţi in câte moduri poate urca cele <code>n</code> trepte.</p>",
      "text": "O persoana are de urcat n trepte. Ştiind că poate păşi pe treapta urmatoare sau poate sări peste o treapta, aflaţi in câte moduri poate urca cele n trepte."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>c</code>, reprezentând numărul de moduri in care poate urca cele <code>n</code> trepte.</p>",
      "text": "Programul va afișa pe ecran numărul c, reprezentând numărul de moduri in care poate urca cele n trepte."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 60</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 60"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4</pre><p><strong>Ieșire</strong></p><pre>5</pre>",
      "text": "Intrare4Ieșire5"
    }
  ],
  "examples": [
    {
      "input": "4",
      "output": "5"
    }
  ],
