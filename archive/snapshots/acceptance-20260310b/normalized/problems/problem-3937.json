  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă <code>N</code> și un vector de <code>N</code> elemente numere întregi, găsiți suma maximă a unei subsecvențe (elemente adiacente) cu lungimile cuprinse între <code>K</code> și <code>W</code> (<code>K ≤ lungime ≤ W</code>).</p>",
      "text": "Se dă N și un vector de N elemente numere întregi, găsiți suma maximă a unei subsecvențe (elemente adiacente) cu lungimile cuprinse între K și W (K ≤ lungime ≤ W)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>N, K, W</code> iar apoi un vector de <code>N</code> numere întregi.</p>",
      "text": "Programul citește de la tastatură numerele N, K, W iar apoi un vector de N numere întregi."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>S</code>, reprezentând suma maxima a unei subsecvențe care respectă condițiile din enunț.</p>",
      "text": "Programul va afișa pe ecran numărul S, reprezentând suma maxima a unei subsecvențe care respectă condițiile din enunț."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ K ≤ W ≤ N ≤ 1.000.000</code></li>\n\t<li>cele <code>N</code> numere citite vor fi din intervalul <code>[-1.000.000.000, 1.000.000.000]</code>.</li>\n</ul>",
      "text": "1 ≤ K ≤ W ≤ N ≤ 1.000.000 cele N numere citite vor fi din intervalul [-1.000.000.000, 1.000.000.000]."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>6 3 4\n5 4 -10 1 2 3</pre><p><strong>Ieșire</strong></p><pre>6</pre><h3>Explicație</h3><p>Secvența căutată este <code>[4, 6]</code> cu suma <code>1 + 2 + 3 = 6</code>.</p>",
      "text": "Intrare6 3 4 5 4 -10 1 2 3Ieșire6ExplicațieSecvența căutată este [4, 6] cu suma 1 + 2 + 3 = 6."
    }
  ],
  "examples": [
