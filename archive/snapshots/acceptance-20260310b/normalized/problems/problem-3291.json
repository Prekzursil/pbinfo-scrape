  "tags": [
    "Bitset"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citesc numere naturale cuprinse între <code>1</code> și <code>30.000.000</code> până la întâlnirea numărului <code>0</code>. Să se afișeze valoarea duplicat.</p>",
      "text": "Se citesc numere naturale cuprinse între 1 și 30.000.000 până la întâlnirea numărului 0. Să se afișeze valoarea duplicat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură maxim <code>1.000.000</code> de numere cuprinse între <code>1</code> și <code>30.000.000</code>.</p>",
      "text": "Programul citește de la tastatură maxim 1.000.000 de numere cuprinse între 1 și 30.000.000."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>d</code>, reprezentând valoarea duplicată.</p>",
      "text": "Programul va afișa pe ecran numărul d, reprezentând valoarea duplicată."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>între numerele citite se află cu siguranță un număr duplicat</li>\n</ul>",
      "text": "între numerele citite se află cu siguranță un număr duplicat"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>12 3 8 10 5 8 2 0</pre><p><strong>Ieșire</strong></p><pre>8</pre><h3>Explicație</h3><p>Valoarea <code>8</code> apare de doua ori.</p>",
      "text": "Intrare12 3 8 10 5 8 2 0Ieșire8ExplicațieValoarea 8 apare de doua ori."
    }
  ],
  "examples": [
    {
      "input": "12 3 8 10 5 8 2 0",
      "output": "8",
      "explanation": "Valoarea 8 apare de doua ori."
    }
  ],
  "constraints": [
    "între numerele citite se află cu siguranță un număr duplicat"
  ],
