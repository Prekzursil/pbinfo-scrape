    "Bitset"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un vector cu <code>n</code> elemente, numere naturale nenule. Afișați termenii în ordine crescătoare.</p><p><b>Termenii care apar de mai multe ori se vor afișa o singură dată.</b></p>",
      "text": "Se dă un vector cu n elemente, numere naturale nenule. Afișați termenii în ordine crescătoare.Termenii care apar de mai multe ori se vor afișa o singură dată."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale nenule, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale nenule, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul afișează elementele vectorului, în ordine crescătoare, separate prin spații, respectând cerința cerută.</p>",
      "text": "Programul afișează elementele vectorului, în ordine crescătoare, separate prin spații, respectând cerința cerută."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n\t<li>cele <code>n</code> numere citite vor fi mai mici sau egale cu <code>300.000</code></li>\n\t<li><b>Atenție la limita de memorie!</b></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000 cele n numere citite vor fi mai mici sau egale cu 300.000 Atenție la limita de memorie!"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>7 \n9 8 8 8 1 2 8</pre><p><strong>Ieșire</strong></p><pre>1 2 8 9</pre><h3>Explicație</h3><p>Elementele distincte care apar in vectorul inițial sunt: <code>9</code>, <code>8</code>, <code>1</code>, <code>2</code></p><p>După sortare, vectorul se va reprezenta ca: <code>1</code>, <code>2</code>, <code>8</code>, <code>9</code></p>",
      "text": "Intrare7 9 8 8 8 1 2 8Ieșire1 2 8 9ExplicațieElementele distincte care apar in vectorul inițial sunt: 9, 8, 1, 2După sortare, vectorul se va reprezenta ca: 1, 2, 8, 9"
    }
  ],
  "examples": [
    {
      "input": "7 \n9 8 8 8 1 2 8",
      "output": "1 2 8 9",
      "explanation": "Elementele distincte care apar in vectorul inițial sunt: 9, 8, 1, 2"
    }
  ],
