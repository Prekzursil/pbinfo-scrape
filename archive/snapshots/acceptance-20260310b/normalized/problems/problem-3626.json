  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Tocmai ai primit cadou un șir <code>a</code><sub><code>1</code></sub>, <code>a</code><sub><code>2</code></sub>, …, <code>a</code><sub><code>n</code></sub> de numere întregi și – cireașa de pe tort! – încă un număr întreg <code>S</code>. Trebuie să determini, în caz că există, lungimea minimă a unei secvențe din șir care are suma elementelor egală cu <code>S</code>.</p>",
      "text": "Tocmai ai primit cadou un șir a1, a2, …, an de numere întregi și – cireașa de pe tort! – încă un număr întreg S. Trebuie să determini, în caz că există, lungimea minimă a unei secvențe din șir care are suma elementelor egală cu S."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> și <code>S</code>, iar apoi numerele naturale <code>a</code><sub><code>1</code></sub>, <code>a</code><sub><code>2</code></sub>, …, <code>a</code><sub><code>n</code></sub> separate prin câte un spațiu.</p>",
      "text": "Programul citește de la tastatură numerele n și S, iar apoi numerele naturale a1, a2, …, an separate prin câte un spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>L</code>, reprezentând lungimea minimă a secvenței, sau mesajul <code>nu exista</code> în caz că nu există nicio secvență de sumă <code>S</code>.</p>",
      "text": "Programul va afișa pe ecran numărul L, reprezentând lungimea minimă a secvenței, sau mesajul nu exista în caz că nu există nicio secvență de sumă S."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 50.000</code></li>\n\t<li><code>-30.000 ≤ a</code><sub><code>i</code></sub> <code>≤ 30.000</code></li>\n\t<li>o secvență este formată din unul sau mai multe elemente aflate pe poziții consecutive în șir</li>\n</ul>",
      "text": "1 ≤ n ≤ 50.000 -30.000 ≤ ai ≤ 30.000 o secvență este formată din unul sau mai multe elemente aflate pe poziții consecutive în șir"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>8 10\n5 -2 9 3 4 1 1 1</pre><p><strong>Ieșire</strong></p><pre>3</pre><h3>Explicație</h3><p>Secvența <code>-2 9 3</code> are suma elementelor egală cu <code>10</code> și are lungimea <code>3</code>. Mai există și secvența <code>3 4 1 1 1</code> care are tot suma <code>10</code>, dar este mai lungă.</p>",
      "text": "Intrare8 10 5 -2 9 3 4 1 1 1Ieșire3ExplicațieSecvența -2 9 3 are suma elementelor egală cu 10 și are lungimea 3. Mai există și secvența 3 4 1 1 1 care are tot suma 10, dar este mai lungă."
    }
  ],
  "examples": [
    {
      "input": "8 10\n5 -2 9 3 4 1 1 1",
      "output": "3",
      "explanation": "Secvența -2 9 3 are suma elementelor egală cu 10 și are lungimea 3. Mai există și secvența 3 4 1 1 1 care are tot suma 10, dar este mai lungă."
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 50.000",
    "-30.000 ≤ ai ≤ 30.000",
    "o secvență este formată din unul sau mai multe elemente aflate pe poziții consecutive în șir"
  ],
