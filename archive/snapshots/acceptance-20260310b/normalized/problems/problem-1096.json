  "tags": [],
  "sections": [
    {
      "title": "Cerinţă",
      "html": "<p>Scrieţi un program care să aşeze două operaţii de înmulţire şi <code>N-3</code> operaţii de adunare între cele <code>N</code> valori date astfel încât valoarea expresiei obţinute să fie maximă. </p>",
      "text": "Scrieţi un program care să aşeze două operaţii de înmulţire şi N-3 operaţii de adunare între cele N valori date astfel încât valoarea expresiei obţinute să fie maximă."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>expresie8.in</code> are următoarea structură:</p><ul>\n\t<li>Pe prima linie se află un număr natural <code>N</code>, reprezentând numărul elementelor date.</li>\n\t<li>Pe următoarele linii se află cele <code>N</code> numere naturale date, fiecare pe câte o linie.</li>\n</ul>",
      "text": "Fișierul de intrare expresie8.in are următoarea structură: Pe prima linie se află un număr natural N, reprezentând numărul elementelor date. Pe următoarele linii se află cele N numere naturale date, fiecare pe câte o linie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>expresie8.out</code> va conține pe prima linie valoarea maximă obţinută prin evaluarea expresiei.</p>",
      "text": "Fișierul de ieșire expresie8.out va conține pe prima linie valoarea maximă obţinută prin evaluarea expresiei."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>4 &lt;= N &lt;= 1000</code></li>\n\t<li>Numerele date sunt numere naturale între <code>1</code> şi <code>10000</code></li>\n</ul>",
      "text": "4 <= N <= 1000 Numerele date sunt numere naturale între 1 şi 10000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>expresie8.in</code></p><pre>5\n4\n7\n1\n5\n3</pre><p><code>expresie8.out</code></p><pre>44</pre>",
      "text": "expresie8.in5 4 7 1 5 3expresie8.out44"
    },
    {
      "title": "Explicație",
      "html": "<p>Valoarea maximă se obţine prin aşezarea operaţiilor sub forma: <code>4 * 7 + 1 + 5*3</code>.</p>",
      "text": "Valoarea maximă se obţine prin aşezarea operaţiilor sub forma: 4 * 7 + 1 + 5*3."
    }
  ],
