  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se trei numere, <code>R</code>, <code>G</code> și <code>B</code>, verificați dacă acestea pot reprezenta o culoare sau o nuanță de gri. O culoare se consideră nuanță de gri dacă și numai dacă diferența dintre oricare două coduri ce reprezintă culorile primare nu depășește <code>10</code>.</p>",
      "text": "Dându-se trei numere, R, G și B, verificați dacă acestea pot reprezenta o culoare sau o nuanță de gri. O culoare se consideră nuanță de gri dacă și numai dacă diferența dintre oricare două coduri ce reprezintă culorile primare nu depășește 10."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură trei numere întregi, <code>R</code>, <code>G</code> și <code>B</code>.</p>",
      "text": "Programul citește de la tastatură trei numere întregi, R, G și B."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran:</p><ul>\n\t<li><code>NU E CULOARE</code> dacă <code>R</code>, <code>G</code> și <code>B</code> nu pot reprezenta o culoare;</li>\n\t<li><code>CULOARE</code> dacă <code>R</code>, <code>G</code> și <code>B</code> pot reprezenta o culoare, dar nu o nuanță de gri;</li>\n\t<li><code>GRI</code> dacă <code>R</code>, <code>G</code> și <code>B</code> pot reprezenta o nuanță de gri;</li>\n</ul>",
      "text": "Programul va afișa pe ecran: NU E CULOARE dacă R, G și B nu pot reprezenta o culoare; CULOARE dacă R, G și B pot reprezenta o culoare, dar nu o nuanță de gri; GRI dacă R, G și B pot reprezenta o nuanță de gri;"
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>-1000 ≤ R, G, B ≤ 1000</code>;</li>\n\t<li><code>0 ≤ Rv, Gv, Bv ≤ 255</code> – unde <code>v</code> înseamnă <strong>valid</strong>.</li>\n</ul>",
      "text": "-1000 ≤ R, G, B ≤ 1000; 0 ≤ Rv, Gv, Bv ≤ 255 – unde v înseamnă valid."
    },
    {
      "title": "Exemple",
      "html": "<h3>Exemplul 1:</h3><p><strong>Intrare</strong></p><pre>0 128 256</pre><p><strong>Ieșire</strong></p><pre>NU E CULOARE</pre><h3>Exemplul 2:</h3><p><strong>Intrare</strong></p><pre>118 128 255</pre><p><strong>Ieșire</strong></p><pre>CULOARE</pre><h3>Exemplul 3:</h3><p><strong>Intrare</strong></p><pre>118 119 120</pre><p><strong>Ieșire</strong></p><pre>GRI</pre>",
      "text": "Exemplul 1:Intrare0 128 256IeșireNU E CULOAREExemplul 2:Intrare118 128 255IeșireCULOAREExemplul 3:Intrare118 119 120IeșireGRI"
    }
  ],
  "examples": [
    {
      "input": "118 119 120",
      "output": "GRI"
    }
  ],
  "constraints": [
    "-1000 ≤ R, G, B ≤ 1000;",
    "0 ≤ Rv, Gv, Bv ≤ 255 – unde v înseamnă valid."
  ],
