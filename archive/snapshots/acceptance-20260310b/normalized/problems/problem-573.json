  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă lista arcelor unui graf orientat. Să se determine nodurile care au gradul exterior egal cu gradul interior.</p>",
      "text": "Se dă lista arcelor unui graf orientat. Să se determine nodurile care au gradul exterior egal cu gradul interior."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code> de noduri și numărul <code>m</code> de arce, iar apoi lista arcelor, formată din <code>m</code> perechi de forma <code>i j</code>, cu semnificația că există arc orientat de la <code>i</code> la <code>j</code>.</p>",
      "text": "Programul citește de la tastatură numărul n de noduri și numărul m de arce, iar apoi lista arcelor, formată din m perechi de forma i j, cu semnificația că există arc orientat de la i la j."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>C</code>, reprezentând numărul de noduri care au gradul interior egal cu cel exterior, iar pe linie următoare afișează aceste noduri, ordonate crescător, separate prin exact un spațiu.</p>",
      "text": "Programul va afișa pe ecran numărul C, reprezentând numărul de noduri care au gradul interior egal cu cel exterior, iar pe linie următoare afișează aceste noduri, ordonate crescător, separate prin exact un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>6 9\n1 2\n1 3\n1 5\n3 5\n4 1\n3 4\n5 1\n6 1\n6 3</pre><p><strong>Ieșire</strong></p><pre>3\n1 3 4</pre>",
      "text": "Intrare6 9 1 2 1 3 1 5 3 5 4 1 3 4 5 1 6 1 6 3Ieșire3 1 3 4"
    }
  ],
