  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Date fiind numerele <code>A</code> și <code>B</code>, să se afișeze numărul de numere triprime din intervalul <code>[A, B]</code> (inclusiv <code>A</code> și <code>B</code>).</p>",
      "text": "Date fiind numerele A și B, să se afișeze numărul de numere triprime din intervalul [A, B] (inclusiv A și B)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>triprime.in</code> conține pe prima linie două numere naturale <code>A</code> și <code>B</code>, despărțite printr-un<br>\nsingur spațiu.</p>",
      "text": "Fișierul de intrare triprime.in conține pe prima linie două numere naturale A și B, despărțite printr-un singur spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>triprime.out</code> va conține numărul de numere triprime din intervalul <code>[A, B]</code>.</p>",
      "text": "Fișierul de ieșire triprime.out va conține numărul de numere triprime din intervalul [A, B]."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ A ≤ B ≤ 390.000.000</code></li>\n\t<li>Pentru 18 puncte, <code>1 ≤ B ≤ 1.500.000</code></li>\n\t<li>Pentru 6 puncte, <code>1.500.000 &lt; B ≤ 2.500.000</code></li>\n\t<li>Pentru 20 puncte, <code>2.500.000 &lt; B ≤ 4.500.000</code></li>\n\t<li>Pentru 31 puncte, <code>4.500.000 &lt; B ≤ 35.000.000</code></li>\n\t<li>Pentru 25 puncte, nu există alte restricții</li>\n</ul>",
      "text": "1 ≤ A ≤ B ≤ 390.000.000 Pentru 18 puncte, 1 ≤ B ≤ 1.500.000 Pentru 6 puncte, 1.500.000 < B ≤ 2.500.000 Pentru 20 puncte, 2.500.000 < B ≤ 4.500.000 Pentru 31 puncte, 4.500.000 < B ≤ 35.000.000 Pentru 25 puncte, nu există alte restricții"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>triprime.in</code></p><pre>1 50</pre><p><code>triprime.out</code></p><pre>2</pre><h3>Explicație</h3><p>Sunt două numere triprime de la <code>1</code> la <code>50</code>: <code>30 = 2 × 3 × 5</code> și <code>42 = 2 × 3 × 7</code>.</p>",
      "text": "triprime.in1 50triprime.out2ExplicațieSunt două numere triprime de la 1 la 50: 30 = 2 × 3 × 5 și 42 = 2 × 3 × 7."
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>triprime.in</code></p><pre>50 105</pre><p><code>triprime.out</code></p><pre>5</pre><h3>Explicație</h3><p>Sunt cinci numere triprime de la <code>50</code> la <code>105</code>: <code>66 = 2 × 3 × 11</code>, <code>70 = 2 × 5 × 7</code>, <code>78 = 2 × 3 × 13</code>, <code>102 = 2 × 3 × 17</code> și <code>105 = 3 × 5 × 7</code>.</p>",
      "text": "triprime.in50 105triprime.out5ExplicațieSunt cinci numere triprime de la 50 la 105: 66 = 2 × 3 × 11, 70 = 2 × 5 × 7, 78 = 2 × 3 × 13, 102 = 2 × 3 × 17 și 105 = 3 × 5 × 7."
    },
    {
      "title": "Exemplul 3:",
      "html": "<p><code>triprime.in</code></p><pre>1000 3000</pre><p><code>triprime.out</code></p><pre>348</pre><h3>Explicație</h3><p>Sunt <code>348</code> de numere triprime în intervalul <code>[1000, 3000]</code>.</p>",
      "text": "triprime.in1000 3000triprime.out348ExplicațieSunt 348 de numere triprime în intervalul [1000, 3000]."
    }
  ],
