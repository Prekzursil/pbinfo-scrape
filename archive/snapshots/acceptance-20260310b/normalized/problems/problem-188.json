  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se modifice <code>s</code>, înlocuind fiecare apariţie a cuvântului <code>a</code> cu cuvântul <code>b</code>.</p>",
      "text": "Să se modifice s, înlocuind fiecare apariţie a cuvântului a cu cuvântul b."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>inlocuirecuvant.in</code> conţine pe prima linie cuvintele <code>a</code> şi <code>b</code>, separate printr-un spaţiu, iar pe a doua linie propoziţia <code>s</code>.</p>",
      "text": "Fişierul de intrare inlocuirecuvant.in conţine pe prima linie cuvintele a şi b, separate printr-un spaţiu, iar pe a doua linie propoziţia s."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>inlocuirecuvant.out</code> va conţine pe prima linie propoziţia <code>s</code>, modificată în conformitate cu cerinţa.</p>",
      "text": "Fişierul de ieşire inlocuirecuvant.out va conţine pe prima linie propoziţia s, modificată în conformitate cu cerinţa."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>propoziţia <code>s</code> va avea cel mult <code>100</code> caractere</li>\n\t<li>cuvintele <code>a</code> şi <code>b</code> vor avea cel mult <code>10</code> caractere</li>\n\t<li>cuvintele sunt formate numai din litere mici ale alfabetului englez</li>\n</ul>",
      "text": "propoziţia s va avea cel mult 100 caractere cuvintele a şi b vor avea cel mult 10 caractere cuvintele sunt formate numai din litere mici ale alfabetului englez"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>inlocuirecuvant.in</code></p><pre>dar insa\ndar nu trebuie dar e mai bine astfel</pre><p><code>inlocuirecuvant.out</code></p><pre>insa nu trebuie insa e mai bine astfel</pre>",
      "text": "inlocuirecuvant.indar insa dar nu trebuie dar e mai bine astfelinlocuirecuvant.outinsa nu trebuie insa e mai bine astfel"
    }
  ],
