  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se scrie un program care să determine cel mai mare punctaj care se poate obţine jucând şotron după regulile stabilite. </p>",
      "text": "Să se scrie un program care să determine cel mai mare punctaj care se poate obţine jucând şotron după regulile stabilite."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>sotron1.in</code> are pe prima linie dimensiunea <code>n</code> a şotronului, iar pe următoarele <code>n</code> linii câte <code>n</code> numere separate de câte un spaţiu, reprezentând numerele scrise în şotron.</p>",
      "text": "Fişierul de intrare sotron1.in are pe prima linie dimensiunea n a şotronului, iar pe următoarele n linii câte n numere separate de câte un spaţiu, reprezentând numerele scrise în şotron."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>sotron1.out</code> va conţine pe prima linie un singur număr reprezentând punctajul maxim care se poate obţine jucând şotron.</p>",
      "text": "Fişierul de ieşire sotron1.out va conţine pe prima linie un singur număr reprezentând punctajul maxim care se poate obţine jucând şotron."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 240</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 240"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>sotron1.in</code></p><pre>5\n0 -6 -5 -17 2\n1 -4 7 10 5\n-3 -2 3 -8 -8\n-20 3 5 3 -5\n-10 -15 2 2 -4  </pre><p><code>sotron1.out</code></p><pre>21</pre><h3>Explicație</h3><p><img alt=\"\" src=\"https://www.pbinfo.ro/resurse/dcee6e/sotron.gif\"></p><p>Punctajul obţinut este <code>3+(-2)+3+7+10=21</code></p>",
      "text": "sotron1.in5 0 -6 -5 -17 2 1 -4 7 10 5 -3 -2 3 -8 -8 -20 3 5 3 -5 -10 -15 2 2 -4 sotron1.out21ExplicațiePunctajul obţinut este 3+(-2)+3+7+10=21"
    }
  ],
