  ],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Calculaţi numărul de divizori ai lui <code>n</code>.</p>",
      "text": "Calculaţi numărul de divizori ai lui n."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>nrdiv.in</code> conţine pe prima linie numărul <code>n</code></p>",
      "text": "Fişierul de intrare nrdiv.in conţine pe prima linie numărul n"
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>nrdiv.out</code> va conţine pe prima linie numărul <code>rez</code>, reprezentând numărul de divizori ai lui <code>n</code>.</p>",
      "text": "Fişierul de ieşire nrdiv.out va conţine pe prima linie numărul rez, reprezentând numărul de divizori ai lui n."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n ≤ 100.000</code></li>\n</ul>",
      "text": "0 < n ≤ 100.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>nrdiv.in</code></p><pre>6</pre><p><code>nrdiv.out</code></p><pre>4</pre>",
      "text": "nrdiv.in6nrdiv.out4"
    },
    {
      "title": "Explicații:",
      "html": "<p>Pentru numărul <code>6</code> avem divizorii <code>1</code>, <code>2</code>, <code>3</code>, <code>6</code> deci numărul acestora este egal cu <code>4</code>. \n\t\t</p>",
      "text": "Pentru numărul 6 avem divizorii 1, 2, 3, 6 deci numărul acestora este egal cu 4."
    }
  ],
  "examples": [],
  "constraints": [
    "0 < n ≤ 100.000"
  ],
