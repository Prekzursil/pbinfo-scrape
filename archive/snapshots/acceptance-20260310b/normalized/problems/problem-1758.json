  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând numărul de bile lăsate să cadă de pe fiecare celulă a primei linii şi poziţia obstacolelor, determinaţi numărul de bile ajunse în fiecare celulă a ultimei linii. Poziţiile obstacolelor sunt indicate prin linia şi coloana lor (colţul din stânga sus corespunde liniei <code>1</code> şi coloanei <code>1</code>). </p>",
      "text": "Cunoscând numărul de bile lăsate să cadă de pe fiecare celulă a primei linii şi poziţia obstacolelor, determinaţi numărul de bile ajunse în fiecare celulă a ultimei linii. Poziţiile obstacolelor sunt indicate prin linia şi coloana lor (colţul din stânga sus corespunde liniei 1 şi coloanei 1)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul <code>bile.in</code> conţine pe prima linie, separate prin câte un spaţiu, numerele naturale <code>m</code>, <code>n</code> şi <code>p</code> (numărul de linii, numărul de coloane şi numărul de obstacole).  Următoarele <code>p</code> linii conţin câte două numere, separate de câte un spaţiu, reprezentând poziţiile celor <code>p</code> obstacole. Ultimele <code>n</code> linii conţin câte un număr natural, reprezentând numărul bilelor lansate din fiecare celulă a primei linii (începând cu prima celulă de pe linie).</p>",
      "text": "Fişierul bile.in conţine pe prima linie, separate prin câte un spaţiu, numerele naturale m, n şi p (numărul de linii, numărul de coloane şi numărul de obstacole). Următoarele p linii conţin câte două numere, separate de câte un spaţiu, reprezentând poziţiile celor p obstacole. Ultimele n linii conţin câte un număr natural, reprezentând numărul bilelor lansate din fiecare celulă a primei linii (începând cu prima celulă de pe linie)."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>bile.out</code> va conţine <code>n</code> linii cu câte un număr, acesta reprezentând numărul de bile din fiecare celulă a ultimei linii (începând cu prima celulă de pe această linie).</p>",
      "text": "Fişierul de ieşire bile.out va conţine n linii cu câte un număr, acesta reprezentând numărul de bile din fiecare celulă a ultimei linii (începând cu prima celulă de pe această linie)."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ m,n ≤ 2000</code></li>\n\t<li><code>0 ≤ p ≤ 10.000</code></li>\n\t<li>Se lansează maximum <code>1000</code> de bile din fiecare celulă;</li>\n\t<li>Pe prima şi ultima linie, respectiv prima şi ultima coloană, nu există obstacole;</li>\n\t<li>Nu există două obstacole alăturate pe linie, coloană sau diagonală.</li>\n</ul>",
      "text": "2 ≤ m,n ≤ 2000 0 ≤ p ≤ 10.000 Se lansează maximum 1000 de bile din fiecare celulă; Pe prima şi ultima linie, respectiv prima şi ultima coloană, nu există obstacole; Nu există două obstacole alăturate pe linie, coloană sau diagonală."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>bile.in</code></p><pre>6 7 5\n2 3\n2 5\n4 2\n4 4\n5 6\n4\n6 \n4 \n5 \n8 \n3\n5 </pre><p><code>bile.out</code></p><pre>8\n0\n10\n0\n9\n0\n8</pre><h3>Explicație</h3><p></p><br><table class=\"table table-bordered\">\n\t\t<tbody><tr>\n\t\t\t<th>4 </th>\n\t\t\t<th>6 </th>\n\t\t\t<th>4 </th>\n\t\t\t<th>5 </th>\n\t\t\t<th>8 </th>\n\t\t\t<th>3 </th>\n\t\t\t<th>5 </th>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td> 4 </td>\n\t\t\t<td> 8 </td>\n\t\t\t<td> – </td>\n\t\t\t<td> 11 </td>\n\t\t\t<td> – </td>\n\t\t\t<td> 7 </td>\n\t\t\t<td> 5 </td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td> 4 </td>\n\t\t\t<td> 8 </td>\n\t\t\t<td> 0 </td>\n\t\t\t<td> 11 </td>\n\t\t\t<td> 0 </td>\n\t\t\t<td> 7 </td>\n\t\t\t<td> 5 </td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td> 8 </td>\n\t\t\t<td> – </td>\n\t\t\t<td> 10 </td>\n\t\t\t<td> – </td>\n\t\t\t<td> 5 </td>\n\t\t\t<td> 7 </td>\n\t\t\t<td> 5 </td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td> 8 </td>\n\t\t\t<td> 0 </td>\n\t\t\t<td> 10 </td>\n\t\t\t<td> 0 </td>\n\t\t\t<td> 9 </td>\n\t\t\t<td> – </td>\n\t\t\t<td> 8 </td>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td> 8 </td>\n\t\t\t<td> 0 </td>\n\t\t\t<td> 10 </td>\n\t\t\t<td> 0 </td>\n\t\t\t<td> 9 </td>\n\t\t\t<td> 0 </td>\n\t\t\t<td> 8 </td>\n\t\t</tr>\n</tbody></table><p></p>",
      "text": "bile.in6 7 5 2 3 2 5 4 2 4 4 5 6 4 6 4 5 8 3 5 bile.out8 0 10 0 9 0 8Explicație 4 6 4 5 8 3 5 4 8 – 11 – 7 5 4 8 0 11 0 7 5 8 – 10 – 5 7 5 8 0 10 0 9 – 8 8 0 10 0 9 0 8"
    }
