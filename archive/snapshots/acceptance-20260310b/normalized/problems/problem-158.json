  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se insereze pe poziția <code>p</code> în șir valoarea <code>X</code>.</p>",
      "text": "Să se insereze pe poziția p în șir valoarea X."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul va citi de la tastatură trei valori <code>n</code>, <code>X</code>, <code>p</code>, cu semnificația precizată, apoi <code>n</code> numere întregi reprezentând elementele șirului.</p>",
      "text": "Programul va citi de la tastatură trei valori n, X, p, cu semnificația precizată, apoi n numere întregi reprezentând elementele șirului."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul va afișa pe ecran <code>n+1</code> valori întregi, separate printr-un spațiu, reprezentând elementele șirului după inserare.</p>",
      "text": "Programul va afișa pe ecran n+1 valori întregi, separate printr-un spațiu, reprezentând elementele șirului după inserare."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ p ≤ n ≤ 25</code></li>\n\t<li>valoarea <code>X</code> și elementele șirului vor fi cuprinse între <code>-1.000.000</code> și <code>1.000.000</code></li>\n\t<li>elementele șirului vor avea indici între <code>1</code> și <code>n</code>.</li>\n</ul>",
      "text": "1 ≤ p ≤ n ≤ 25 valoarea X și elementele șirului vor fi cuprinse între -1.000.000 și 1.000.000 elementele șirului vor avea indici între 1 și n."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>5 10 2\n7 3 9 1 6</pre><p><strong>Date de ieșire</strong></p><pre>7 10 3 9 1 6</pre>",
      "text": "Date de intrare5 10 2 7 3 9 1 6Date de ieșire7 10 3 9 1 6"
    }
  ],
  "examples": [
    {
      "input": "5 10 2\n7 3 9 1 6",
      "output": "7 10 3 9 1 6"
    }
  ],
  "constraints": [
    "1 ≤ p ≤ n ≤ 25",
    "valoarea X și elementele șirului vor fi cuprinse între -1.000.000 și 1.000.000",
