  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieţi un program care să determine “numărul <code>xyz</code>” pentru <code>x y z</code> numere naturale date.</p>",
      "text": "Scrieţi un program care să determine “numărul xyz” pentru x y z numere naturale date."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>xyz.in</code> are pe prima sa linie <code>3</code> numere naturale <code>x y z</code> separate prin spatii.</p>",
      "text": "Fişierul de intrare xyz.in are pe prima sa linie 3 numere naturale x y z separate prin spatii."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>xyz.out</code> va conţine, pe prima linie, “numărul <code>xyz</code>” determinat.</p>",
      "text": "Fişierul de ieşire xyz.out va conţine, pe prima linie, “numărul xyz” determinat."
    },
    {
      "title": "Restricții și precizări",
      "html": "<p><code>  • 1 ≤ x, y ≤ 9</code><br>\n<code>  • 0 ≤ z ≤ 9</code></p>",
      "text": "• 1 ≤ x, y ≤ 9 • 0 ≤ z ≤ 9"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>xyz.in</code></p><pre>5 4 3</pre><p><code>xyz.out</code></p><pre>43333</pre><h3>Explicație</h3><p>Numărul are 5 cifre, prima cifră este 4 iar celelalte cifre sunt egale cu 3.</p>",
      "text": "xyz.in5 4 3xyz.out43333ExplicațieNumărul are 5 cifre, prima cifră este 4 iar celelalte cifre sunt egale cu 3."
    }
  ],
