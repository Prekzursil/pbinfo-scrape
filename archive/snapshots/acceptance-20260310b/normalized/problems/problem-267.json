  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dau <code>n</code> numere numere naturale cu cel mult două cifre fiecare. Să se determine acele numere care apar o singură dată.</p>",
      "text": "Se dau n numere numere naturale cu cel mult două cifre fiecare. Să se determine acele numere care apar o singură dată."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>unice.in</code> conţine pe prima linie numărul <code>n</code>; urmează <code>n</code> numere naturale cu cel mult două cifre fiecare, dispuse pe mai multe linii şi separate prin spaţii.</p>",
      "text": "Fişierul de intrare unice.in conţine pe prima linie numărul n; urmează n numere naturale cu cel mult două cifre fiecare, dispuse pe mai multe linii şi separate prin spaţii."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>unice.out</code> va conţine pe prima linie, în ordine crescătoare, valorile care apar o singură dată, separate printr-un spaţiu.</p>",
      "text": "Fişierul de ieşire unice.out va conţine pe prima linie, în ordine crescătoare, valorile care apar o singură dată, separate printr-un spaţiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>unice.in</code></p><pre>7\n3 5 2 1\n5 23 1</pre><p><code>unice.out</code></p><pre>2 3 23</pre>",
      "text": "unice.in7 3 5 2 1 5 23 1unice.out2 3 23"
    }
  ],
  "examples": [],
