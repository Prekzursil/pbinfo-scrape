  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se scrie un program care citește <code>N</code>, lungimea modelului și afișează numărul de variante de realizare a modelului, modulo <code>1000003</code>.</p>",
      "text": "Să se scrie un program care citește N, lungimea modelului și afișează numărul de variante de realizare a modelului, modulo 1000003."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>protection.in</code> conţine pe primul rând numărul <code>N</code> reprezentând lungimea modelului.</p>",
      "text": "Fișierul de intrare protection.in conţine pe primul rând numărul N reprezentând lungimea modelului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>protection.out</code> va conține numărul de modele de terminat, modulo <code>1000003</code>.</p>",
      "text": "Fișierul de ieșire protection.out va conține numărul de modele de terminat, modulo 1000003."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 2 000 000 000</code></li>\n\t<li>pentru <code>15%</code> din teste, <code>N ≤ 15</code></li>\n\t<li>pentru <code>35%</code> din teste, <code>N ≤ 200000</code></li>\n\t<li>pentru <code>50%</code> din teste, <code>N ≤ 2000000000</code></li>\n\t<li>Nu se trece de doua ori la rând prin același punct</li>\n</ul>",
      "text": "1 ≤ N ≤ 2 000 000 000 pentru 15% din teste, N ≤ 15 pentru 35% din teste, N ≤ 200000 pentru 50% din teste, N ≤ 2000000000 Nu se trece de doua ori la rând prin același punct"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>protection.in</code></p><pre>3</pre><p><code>protection.out</code></p><pre>200</pre>",
      "text": "protection.in3protection.out200"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>protection.in</code></p><pre>2</pre><p><code>protection.out</code></p><pre>40</pre>",
      "text": "protection.in2protection.out40"
    }
  ],
