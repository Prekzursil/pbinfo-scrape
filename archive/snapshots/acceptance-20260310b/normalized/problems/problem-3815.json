  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n</code> numere naturale. Aflati daca acestea pot fi laturile unui poligon cu <code>n</code> laturi.</p>",
      "text": "Se dau n numere naturale. Aflati daca acestea pot fi laturile unui poligon cu n laturi."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran mesajul <code>DA</code>, daca numerele date pot fi laturile unui poligon, altfel se afiseaza mesajul <code>NU</code>.</p>",
      "text": "Programul va afișa pe ecran mesajul DA, daca numerele date pot fi laturile unui poligon, altfel se afiseaza mesajul NU."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000000</code></li>\n\t<li>cele <code>n</code> numere citite vor fi mai mici decât <code>1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1000000 cele n numere citite vor fi mai mici decât 1.000.000.000"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n1 2 3 4 5</pre><p><strong>Ieșire</strong></p><pre>DA</pre>",
      "text": "Intrare5 1 2 3 4 5IeșireDA"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>4\n4 5 10 19</pre><p><strong>Ieșire</strong></p><pre>NU</pre>",
      "text": "Intrare4 4 5 10 19IeșireNU"
    }
  ],
  "examples": [
    {
      "input": "5\n1 2 3 4 5",
      "output": "DA"
    },
    {
      "input": "4\n4 5 10 19",
      "output": "NU"
    }
  ],
  "constraints": [
