  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dă un număr natural <code>n</code>. Afișați în ordine crescătoare primele <code>n</code> numere naturale nenule.</p>",
      "text": "Se dă un număr natural n. Afișați în ordine crescătoare primele n numere naturale nenule."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran în ordine crescătoare primele <code>n</code> numere naturale nenule, separate prin exact un spațiu.</p>",
      "text": "Programul afișează pe ecran în ordine crescătoare primele n numere naturale nenule, separate prin exact un spațiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>5</pre><p><strong>Date de ieșire</strong></p><pre>1 2 3 4 5</pre>",
      "text": "Date de intrare5Date de ieșire1 2 3 4 5"
    }
  ],
