  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citește un număr <code>p</code> și un șir de caractere <code>s</code>, șirul conține cel mult <code>255</code> de litere mici ale alfabetului englez. Să se afișeze toate șirurile rezultate din eliminarea, pe rând, a fiecărei secvențe de <code>p</code> caractere din <code>s</code>.</p>",
      "text": "Se citește un număr p și un șir de caractere s, șirul conține cel mult 255 de litere mici ale alfabetului englez. Să se afișeze toate șirurile rezultate din eliminarea, pe rând, a fiecărei secvențe de p caractere din s."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>p</code> pe prima linie și șirul <code>s</code> pe cea de-a doua linie.</p>",
      "text": "Programul citește de la tastatură numărul p pe prima linie și șirul s pe cea de-a doua linie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran pe câte o linie, toate șirurile rezultate din eliminarea, pe rând, a fiecărei secvență de <code>p</code> caractere din <code>s</code>.</p>",
      "text": "Programul va afișa pe ecran pe câte o linie, toate șirurile rezultate din eliminarea, pe rând, a fiecărei secvență de p caractere din s."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ p ≤ 255</code></li>\n\t<li>eliminările se fac de la stânga la dreapta</li>\n</ul>",
      "text": "1 ≤ p ≤ 255 eliminările se fac de la stânga la dreapta"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>3\nadina</pre><p><strong>Ieșire</strong></p><pre>na\naa\nad</pre>",
      "text": "Intrare3 adinaIeșirena aa ad"
    }
  ],
  "examples": [
    {
      "input": "3\nadina",
      "output": "na\naa\nad"
    }
  ],
