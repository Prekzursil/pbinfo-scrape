      "title": "Cerinţă",
      "html": "<p>Calculaţi suma cifrelor numărului dat.</p>",
      "text": "Calculaţi suma cifrelor numărului dat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul va citi de la tastatură un număr natural.</p>",
      "text": "Programul va citi de la tastatură un număr natural."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul va afişa pe ecran suma cifrelor numărului citit.</p>",
      "text": "Programul va afişa pe ecran suma cifrelor numărului citit."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>numărul citit va fi mai mic decât <code>2.000.000.000</code></li>\n</ul>",
      "text": "numărul citit va fi mai mic decât 2.000.000.000"
    },
