  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n</code> numere naturale. Aflaţi câte dintre acestea au un număr prim de divizori.</p>",
      "text": "Se dau n numere naturale. Aflaţi câte dintre acestea au un număr prim de divizori."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>prim013.in</code> conține pe prima linie numărul <code>n</code>, iar pe a doua linie <code>n</code> numere naturale nenule separate prin spații.</p>",
      "text": "Fișierul de intrare prim013.in conține pe prima linie numărul n, iar pe a doua linie n numere naturale nenule separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>prim013.out</code> va conține pe prima linie numărul de numere care au un număr prim de divizori.</p>",
      "text": "Fișierul de ieșire prim013.out va conține pe prima linie numărul de numere care au un număr prim de divizori."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n\t<li>numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât <code>10.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000 numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât 10.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>prim013.in</code></p><pre>5\n1 3 6 9 625</pre><p><code>prim013.out</code></p><pre>3</pre><h3>Explicație</h3><p>Numerele <code>3,9,625</code> au <code>2,3</code> respectiv <code>5</code> divizori, numărul divizorilor fiind prim. În total sunt <code>3</code> numere cu numărul divizorilor prim.</p>",
      "text": "prim013.in5 1 3 6 9 625prim013.out3ExplicațieNumerele 3,9,625 au 2,3 respectiv 5 divizori, numărul divizorilor fiind prim. În total sunt 3 numere cu numărul divizorilor prim."
    }
  ],
