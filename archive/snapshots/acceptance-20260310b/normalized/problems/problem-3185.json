  "sections": [
    {
      "title": "Cerința",
      "html": "<p>La un concurs pot participa copii cu vârste între <code>a</code> și <code>b</code> ani, inclusiv. Gigel are <code>n</code> ani. Stabiliți dacă poate participa la concurs.</p>",
      "text": "La un concurs pot participa copii cu vârste între a și b ani, inclusiv. Gigel are n ani. Stabiliți dacă poate participa la concurs."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele naturale <code>a b n</code>.</p>",
      "text": "Programul citește de la tastatură numerele naturale a b n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul afișează pe ecran mesajul <code>DA</code>, dacă numărul Gigel poate participa la concurs, respectiv <code>NU</code> în caz contrar.</p>",
      "text": "Programul afișează pe ecran mesajul DA, dacă numărul Gigel poate participa la concurs, respectiv NU în caz contrar."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ a,b,n ≤ 1000</code></li>\n\t<li><code>a ≤ b</code></li>\n</ul>",
      "text": "1 ≤ a,b,n ≤ 1000 a ≤ b"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4 9 8</pre><p><strong>Ieșire</strong></p><pre>DA</pre>",
      "text": "Intrare4 9 8IeșireDA"
    }
  ],
  "examples": [
    {
      "input": "4 9 8",
      "output": "DA"
    }
  ],
