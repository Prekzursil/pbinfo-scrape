  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se reordoneze elementele de pe fiecare linie astfel încât numerele impare să se afle în ordine crescătoare la începutul liniei, iar numerele pare, de asemenea în ordine crescătoare, la sfârșitul liniei.</p>",
      "text": "Să se reordoneze elementele de pe fiecare linie astfel încât numerele impare să se afle în ordine crescătoare la începutul liniei, iar numerele pare, de asemenea în ordine crescătoare, la sfârșitul liniei."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> și <code>m</code>, iar apoi de pe fiecare din următoarele <code>n</code> linii se citesc câte <code>m</code> numere reprezentând elementele acelei linii.</p>",
      "text": "Programul citește de la tastatură numerele n și m, iar apoi de pe fiecare din următoarele n linii se citesc câte m numere reprezentând elementele acelei linii."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran matricea după reordonare.</p>",
      "text": "Programul va afișa pe ecran matricea după reordonare."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n, m ≤ 50</code></li>\n\t<li>numerele din matrice vor fi cuprinse între <code>0</code> și <code>1000</code></li>\n</ul>",
      "text": "1 ≤ n, m ≤ 50 numerele din matrice vor fi cuprinse între 0 și 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 5\n6 2 5 3 1\n8 2 4 6 0\n9 7 5 3 1\n9 7 8 1 3\n4 2 6 3 1</pre><p><strong>Ieșire</strong></p><pre>1 3 5 2 6\n0 2 4 6 8\n1 3 5 7 9\n1 3 7 9 8\n1 3 2 4 6</pre>",
      "text": "Intrare5 5 6 2 5 3 1 8 2 4 6 0 9 7 5 3 1 9 7 8 1 3 4 2 6 3 1Ieșire1 3 5 2 6 0 2 4 6 8 1 3 5 7 9 1 3 7 9 8 1 3 2 4 6"
    }
  ],
  "examples": [
    {
      "input": "5 5\n6 2 5 3 1\n8 2 4 6 0\n9 7 5 3 1\n9 7 8 1 3\n4 2 6 3 1",
      "output": "1 3 5 2 6\n0 2 4 6 8\n1 3 5 7 9\n1 3 7 9 8\n1 3 2 4 6"
    }
  ],
