  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citește un număr <code>N</code>, un număr <code>K</code> și apoi un șir cu <code>N</code> numere naturale. Determinați câte secvențe de lungime exact <code>K</code> au elementele distincte. Prin secvență înțelegem un set de elemente aflate pe poziții consecutive.</p>",
      "text": "Se citește un număr N, un număr K și apoi un șir cu N numere naturale. Determinați câte secvențe de lungime exact K au elementele distincte. Prin secvență înțelegem un set de elemente aflate pe poziții consecutive."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Pe prima linie a fișierului <code>secv_fb.in</code> se găsesc două numere naturale, separate prin exact un spațiu, <code>N</code> și <code>K</code>. Pe linia a doua se găsesc cele <code>N</code> numere ale șirului, separate prin câte un spațiu.</p>",
      "text": "Pe prima linie a fișierului secv_fb.in se găsesc două numere naturale, separate prin exact un spațiu, N și K. Pe linia a doua se găsesc cele N numere ale șirului, separate prin câte un spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Pe prima linie a fișierului <code>secv_fb.out</code> se găsește un număr natural ce reprezintă valoarea cerută.</p>",
      "text": "Pe prima linie a fișierului secv_fb.out se găsește un număr natural ce reprezintă valoarea cerută."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ N ≤ 100.000</code>;</li>\n\t<li>Pentru <code>20</code> de puncte <code>K = 2</code>;</li>\n\t<li>Pentru alte <code>20</code> de puncte <code>K = 3</code>;</li>\n\t<li>Pentru alte <code>20</code> de puncte <code>4 ≤ K ≤ 10</code>;</li>\n\t<li>Pentru alte <code>20</code> de puncte, <code>10 &lt; K ≤ n-1</code> și valorile din șir <code>≤ 100.000</code>;</li>\n\t<li>Pentru restul testelor <code>10 &lt; K ≤ n-1</code> și valorile din șir <code>≤ 2.000.000.000</code>;</li>\n</ul>",
      "text": "2 ≤ N ≤ 100.000; Pentru 20 de puncte K = 2; Pentru alte 20 de puncte K = 3; Pentru alte 20 de puncte 4 ≤ K ≤ 10; Pentru alte 20 de puncte, 10 < K ≤ n-1 și valorile din șir ≤ 100.000; Pentru restul testelor 10 < K ≤ n-1 și valorile din șir ≤ 2.000.000.000;"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>secv_fb.in</code></p><pre>8 3\n3 2 4 3 4 5 6 7</pre><p><code>secv_fb.out</code></p><pre>5</pre>",
      "text": "secv_fb.in8 3 3 2 4 3 4 5 6 7secv_fb.out5"
    }
  ],
  "examples": [],
