  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau două șiruri cu câte <code>n</code>, respectiv <code>m</code> elemente. Dacă înmulțim fiecare element din primul șir cu fiecare element din al doilea șir, să se afle câte produse sunt mai mici decât <code>p</code>. </p>",
      "text": "Se dau două șiruri cu câte n, respectiv m elemente. Dacă înmulțim fiecare element din primul șir cu fiecare element din al doilea șir, să se afle câte produse sunt mai mici decât p."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> și <code>p</code>, iar apoi <code>n</code> numere naturale, separate prin spații, reprezentând elementele primului șir, după care citește numărul <code>m</code> urmat de  <code>m</code> numere naturale, reprezentând elementele celui de-al doilea șir.  </p>",
      "text": "Programul citește de la tastatură numerele n și p, iar apoi n numere naturale, separate prin spații, reprezentând elementele primului șir, după care citește numărul m urmat de m numere naturale, reprezentând elementele celui de-al doilea șir."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>nr</code>, reprezentând numărul produselor mai mici decât <code>p</code>.</p>",
      "text": "Programul va afișa pe ecran numărul nr, reprezentând numărul produselor mai mici decât p."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ p ≤ 200.000</code></li>\n\t<li><code>1 ≤ n , m ≤ 50.000</code></li>\n\t<li>elementele celor două șiruri sunt numere naturale mai mici decât <code>10.000</code></li>\n</ul>",
      "text": "1 ≤ p ≤ 200.000 1 ≤ n , m ≤ 50.000 elementele celor două șiruri sunt numere naturale mai mici decât 10.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 99\n1 2 3 4 5\n2\n25 34</pre><p><strong>Ieșire</strong></p><pre>5</pre>",
      "text": "Intrare5 99 1 2 3 4 5 2 25 34Ieșire5"
    },
    {
      "title": "Explicație",
      "html": "<p>Efectuând înmulțirile dintre elementele primului șir și ale celui de-al doilea obținem rezultatele: <code>25</code>, <code>34</code>, <code>50</code>, <code>68</code>, <code>75</code>, <code>102</code>, <code>100</code>, <code>136</code>, <code>125</code>, <code>170</code>. Dintre acestea <code>5</code> sunt mai mici decât <code>99</code>.</p>",
      "text": "Efectuând înmulțirile dintre elementele primului șir și ale celui de-al doilea obținem rezultatele: 25, 34, 50, 68, 75, 102, 100, 136, 125, 170. Dintre acestea 5 sunt mai mici decât 99."
    }
  ],
  "examples": [
    {
      "input": "5 99\n1 2 3 4 5\n2\n25 34",
      "output": "5"
    }
  ],
  "constraints": [
    "1 ≤ p ≤ 200.000",
    "1 ≤ n , m ≤ 50.000",
    "elementele celor două șiruri sunt numere naturale mai mici decât 10.000"
  ],
