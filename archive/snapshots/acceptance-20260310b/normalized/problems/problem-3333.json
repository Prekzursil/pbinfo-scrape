  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n</code> numere naturale nenule. Pentru fiecare număr dat <code>a</code> să se calculeze suma divizorilor lui <code>a</code><sup><code>2</code></sup>.</p>",
      "text": "Se dau n numere naturale nenule. Pentru fiecare număr dat a să se calculeze suma divizorilor lui a2."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>bookface.in</code> conține pe prima linie numărul <code>n</code>, iar pe a doua linie cele <code>n</code> numere naturale.  </p>",
      "text": "Fișierul de intrare bookface.in conține pe prima linie numărul n, iar pe a doua linie cele n numere naturale."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>bookface.out</code> va conține pe linia <code>i</code> suma cerută pentru cel de-al <code>i</code>-lea număr.</p>",
      "text": "Fișierul de ieșire bookface.out va conține pe linia i suma cerută pentru cel de-al i-lea număr."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 50.000</code></li>\n\t<li>cele <code>n</code> numere date sunt nenule, mai mici decât <code>1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 50.000 cele n numere date sunt nenule, mai mici decât 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>bookface.in</code></p><pre>3\n2 4 3</pre><p><code>bookface.out</code></p><pre>7\n31\n13</pre><h3>Explicație</h3><p>Suma divizorilor numerelor <code>4, 16, 9</code> este <code>7, 31</code>, respectiv <code>13</code>.</p>",
      "text": "bookface.in3 2 4 3bookface.out7 31 13ExplicațieSuma divizorilor numerelor 4, 16, 9 este 7, 31, respectiv 13."
    }
  ],
