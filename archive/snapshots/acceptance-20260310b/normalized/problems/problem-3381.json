  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieţi un program care citeşte o valoare <code>k</code> şi afişează al <code>k</code>-lea termen al şirului de mai sus.</p>",
      "text": "Scrieţi un program care citeşte o valoare k şi afişează al k-lea termen al şirului de mai sus."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>ksir.in</code> conţine pe prima linie numărul natural <code>k</code>.</p>",
      "text": "Fișierul de intrare ksir.in conţine pe prima linie numărul natural k."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>ksir.out</code> va conţine o singură linie pe care va fi scris un număr natural ce reprezintă al <code>k</code>-lea element din şir.</p>",
      "text": "Fișierul de ieșire ksir.out va conţine o singură linie pe care va fi scris un număr natural ce reprezintă al k-lea element din şir."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ k ≤ 20.000.000.000</code></li>\n\t<li>Poziţiile termenilor din şir sunt numerotate începând cu <code>1</code>.</li>\n</ul>",
      "text": "1 ≤ k ≤ 20.000.000.000 Poziţiile termenilor din şir sunt numerotate începând cu 1."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>ksir.in</code></p><pre>8</pre><p><code>ksir.out</code></p><pre>3</pre><h3>Explicație</h3><p>Al <code>8</code>-lea element din şir este <code>3</code>. </p>",
      "text": "ksir.in8ksir.out3ExplicațieAl 8-lea element din şir este 3."
    }
  ],
