  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Fie un număr natural <code>s</code> și un șir de <code>n</code> numere naturale nenule. Să se determine suma maximă posibilă, mai mică sau egală cu <code>s</code> ce se poate obține dintr-un subșir al șirului.</p>",
      "text": "Fie un număr natural s și un șir de n numere naturale nenule. Să se determine suma maximă posibilă, mai mică sau egală cu s ce se poate obține dintr-un subșir al șirului."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code> și <code>s</code>, apoi <code>n</code> numere naturale, separate prin spații, reprezentând elementele șirului.</p>",
      "text": "Programul citește de la tastatură numărul n și s, apoi n numere naturale, separate prin spații, reprezentând elementele șirului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>M</code>, reprezentând suma maximă posibilă, mai mică sau egală cu <code>s</code> ce se poate obține dintr-un subșir al șirului.</p>",
      "text": "Programul va afișa pe ecran numărul M, reprezentând suma maximă posibilă, mai mică sau egală cu s ce se poate obține dintr-un subșir al șirului."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ n ≤ 40</code></li>\n\t<li><code>1 ≤ s ≤ 2.000.000.000</code></li>\n\t<li>Șirul va conține numere naturale nenule mai mici decât <code>50.000.001</code>.</li>\n\t<li>Toate elementele șirului vor fi mici sau egale decât <code>s</code>.</li>\n</ul>",
      "text": "3 ≤ n ≤ 40 1 ≤ s ≤ 2.000.000.000 Șirul va conține numere naturale nenule mai mici decât 50.000.001. Toate elementele șirului vor fi mici sau egale decât s."
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>5 20\n5 10 6 8 3</pre><p><strong>Ieșire</strong></p><pre>19</pre><h3>Explicație</h3><p>Suma maximă mai mică sau egală decât <code>20</code> este <code>19</code> și se formează din <code>10</code>, <code>6</code> și <code>3</code>.</p>",
      "text": "Intrare5 20 5 10 6 8 3Ieșire19ExplicațieSuma maximă mai mică sau egală decât 20 este 19 și se formează din 10, 6 și 3."
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>5 20\n17 16 10 12 14</pre><p><strong>Ieșire</strong></p><pre>17</pre><h3>Explicație</h3><p>Suma maximă mai mică sau egală decât <code>20</code> este <code>17</code> și se formează doar din numărul <code>17</code>.</p>",
      "text": "Intrare5 20 17 16 10 12 14Ieșire17ExplicațieSuma maximă mai mică sau egală decât 20 este 17 și se formează doar din numărul 17."
    }
  ],
