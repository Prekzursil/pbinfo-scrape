  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieţi un program care să determine cel mai mare număr natural <strong>sstabil</strong> care se poate obţine dintr-un număr natural dat, aplicând una sau mai multe operaţii de înlocuire de tipul menţionat.</p>",
      "text": "Scrieţi un program care să determine cel mai mare număr natural sstabil care se poate obţine dintr-un număr natural dat, aplicând una sau mai multe operaţii de înlocuire de tipul menţionat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>sstabil.in</code> conţine pe prima linie un număr natural <code>n</code>, reprezentând numărul de cifre al numărului dat, iar pe linia a doua, separate prin câte un spaţiu, cifrele acestui număr.</p>",
      "text": "Fişierul de intrare sstabil.in conţine pe prima linie un număr natural n, reprezentând numărul de cifre al numărului dat, iar pe linia a doua, separate prin câte un spaţiu, cifrele acestui număr."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>sstabil.out</code> va conţine pe o linie numărul <strong>sstabil</strong> maxim obţinut.</p>",
      "text": "Fişierul de ieşire sstabil.out va conţine pe o linie numărul sstabil maxim obţinut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1000000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>sstabil.in</code></p><pre>5\n1 0 4 5 1</pre><p><code>sstabil.out</code></p><pre>191</pre><h3>Explicație</h3><p>10451 → 1091 → 191.</p>",
      "text": "sstabil.in5 1 0 4 5 1sstabil.out191Explicație10451 → 1091 → 191."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>sstabil.in</code></p><pre>5\n5 2 8 3 2</pre><p><code>sstabil.out</code></p><pre>785</pre><h3>Explicație</h3><p><code>52832 → 7832 → 785</code>.</p>",
      "text": "sstabil.in5 5 2 8 3 2sstabil.out785Explicație52832 → 7832 → 785."
    }
  ],
