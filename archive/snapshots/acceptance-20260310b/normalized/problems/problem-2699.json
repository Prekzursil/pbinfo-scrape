  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citesc <code>2</code> numere, <code>n</code> și <code>p</code>, afișați în ordine crescătoare toate puterile lui <code>n</code> care sunt mai mici sau egale cu <code>p</code>. </p>",
      "text": "Se citesc 2 numere, n și p, afișați în ordine crescătoare toate puterile lui n care sunt mai mici sau egale cu p."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code>, și <code>p</code>, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numerele n, și p, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran în ordine crescătoare, toate puterile lui <code>n</code> mai mici sau egale cu <code>p</code>, separate prin exact un spațiu.</p>",
      "text": "Programul va afișa pe ecran în ordine crescătoare, toate puterile lui n mai mici sau egale cu p, separate prin exact un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 10</code></li>\n\t<li><code>1 ≤ p ≤ 1.000.000.000.000</code></li>\n</ul>",
      "text": "2 ≤ n ≤ 10 1 ≤ p ≤ 1.000.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4 120</pre><p><strong>Ieșire</strong></p><pre>1 4 16 64</pre>",
      "text": "Intrare4 120Ieșire1 4 16 64"
    }
  ],
