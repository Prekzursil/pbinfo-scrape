  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Vreți să îl ajutați pe Alex să găsească acest cod de acces pentru un număr <code>n</code> primit? Scrieți un program care determină și afișează codul de acces al jocului. Puteți primi 100 de puncte.</p>",
      "text": "Vreți să îl ajutați pe Alex să găsească acest cod de acces pentru un număr n primit? Scrieți un program care determină și afișează codul de acces al jocului. Puteți primi 100 de puncte."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>codjoc.in</code> conține pe prima linie un număr n, reprezentând numărul arătat lui Alex  de tatăl lui.</p>",
      "text": "Fișierul de intrare codjoc.in conține pe prima linie un număr n, reprezentând numărul arătat lui Alex de tatăl lui."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>codjoc.out</code> va conține  numărul ce reprezintă codul de acces al jocului lui Alex.</p>",
      "text": "Fișierul de ieșire codjoc.out va conține numărul ce reprezintă codul de acces al jocului lui Alex."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>•\t<code>0 &lt; n ≤ 2.000.000.000</code>, <code>n</code> număr natural</li>\n</ul>",
      "text": "• 0 < n ≤ 2.000.000.000, n număr natural"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>codjoc.in</code></p><pre>123456</pre><p><code>codjoc.out</code></p><pre>150886</pre><h3>Explicație</h3><p>Suma numerelor <code>123456</code>, <code>23456</code>, <code>3456</code>, <code>456</code>, <code>56</code>, <code>6</code> este egală cu <code>150886</code>.</p>",
      "text": "codjoc.in123456codjoc.out150886ExplicațieSuma numerelor 123456, 23456, 3456, 456, 56, 6 este egală cu 150886."
    }
  ],
