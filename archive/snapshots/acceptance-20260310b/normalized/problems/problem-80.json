  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se citesc numere naturale de la tastatură până la apariția lui zero. Să se determine câte perechi de numere citite consecutiv sunt prime între ele.</p>",
      "text": "Se citesc numere naturale de la tastatură până la apariția lui zero. Să se determine câte perechi de numere citite consecutiv sunt prime între ele."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numere naturale. Citirea se încheie la introducerea valorii <code>0</code>.</p>",
      "text": "Programul citește de la tastatură numere naturale. Citirea se încheie la introducerea valorii 0."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran numărul <code>C</code>, reprezentând numărul de perechi citite care respectă condiția cerută.</p>",
      "text": "Programul afișează pe ecran numărul C, reprezentând numărul de perechi citite care respectă condiția cerută."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>numerele citite aparțin intervalului <code>[0 ; 1.000.000.000)</code></li>\n\t<li>valoarea zero, care încheie citirile, nu se va prelucra</li>\n</ul>",
      "text": "numerele citite aparțin intervalului [0 ; 1.000.000.000) valoarea zero, care încheie citirile, nu se va prelucra"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>15 63 43 129 55 15 4 0</pre><p><strong>Ieșire</strong></p><pre>3</pre>",
      "text": "Intrare15 63 43 129 55 15 4 0Ieșire3"
    },
    {
      "title": "Explicație",
      "html": "<p>Perechile care respectă condiția cerută sunt: <code>(63,43)</code>, <code>(129,55)</code>, <code>(15,4)</code>.</p>",
      "text": "Perechile care respectă condiția cerută sunt: (63,43), (129,55), (15,4)."
    }
  ],
  "examples": [
