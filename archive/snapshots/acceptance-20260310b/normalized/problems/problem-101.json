  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se scrie un program care citește o propoziţie şi afişează cuvintele din propoziţie ordonate alfabetic.</p>",
      "text": "Să se scrie un program care citește o propoziţie şi afişează cuvintele din propoziţie ordonate alfabetic."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>sortcuv.in</code> conține pe prima linie o propoziție alcătuită din litere mici ale alfabetului englez și spații.</p>",
      "text": "Fișierul de intrare sortcuv.in conține pe prima linie o propoziție alcătuită din litere mici ale alfabetului englez și spații."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fișierul de ieșire <code>sortcuv.out</code> va conține cuvintele din propoziție, ordonate alfabetic, fiecare pe câte o linie.</p>",
      "text": "Fișierul de ieșire sortcuv.out va conține cuvintele din propoziție, ordonate alfabetic, fiecare pe câte o linie."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>propoziția va conține cel mult <code>250</code> de caractere;</li>\n\t<li>fiecare cuvânt din propoziție are cel mult <code>20</code> litere</li>\n</ul>",
      "text": "propoziția va conține cel mult 250 de caractere; fiecare cuvânt din propoziție are cel mult 20 litere"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>sortcuv.in</code></p><pre>dreptunghiul este un paralelogram cu un unghi drept</pre><p><code>sortcuv.out</code></p><pre>cu\ndrept\ndreptunghiul\neste\nparalelogram\nun\nun\nunghi</pre>",
      "text": "sortcuv.indreptunghiul este un paralelogram cu un unghi dreptsortcuv.outcu drept dreptunghiul este paralelogram un un unghi"
    }
  ],
