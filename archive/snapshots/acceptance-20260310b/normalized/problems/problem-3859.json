  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă <code>N</code>, în câte moduri putem plasa <code>2</code> cai pe o tablă de șah de <code>N</code> pe <code>N</code> astfel încât să nu se atace?</p>",
      "text": "Se dă N, în câte moduri putem plasa 2 cai pe o tablă de șah de N pe N astfel încât să nu se atace?"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>N</code>.</p>",
      "text": "Programul citește de la tastatură numărul N."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>X</code>, răspunsul la întrebarea din enunț.</p>",
      "text": "Programul va afișa pe ecran numărul X, răspunsul la întrebarea din enunț."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 10.000</code>.</li>\n\t<li>Caii nu se pot afla pe același pătrat.</li>\n</ul>",
      "text": "1 ≤ n ≤ 10.000. Caii nu se pot afla pe același pătrat."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>2</pre><p><strong>Ieșire</strong></p><pre>6</pre><h3>Explicație</h3><p>Oricum am plasa caii aceștia nu se vor ataca.</p>",
      "text": "Intrare2Ieșire6ExplicațieOricum am plasa caii aceștia nu se vor ataca."
    }
  ],
