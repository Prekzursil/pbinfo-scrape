      "name": "Cifrele unui număr",
      "slug": "cifrele-unui-num-r",
      "href": "/?pagina=probleme-lista&tag=5"
    }
  ],
  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un număr natural <code>n</code> care are cifrele distincte. Să se afișeze a doua cea mai mare cifră a sa și a doua cea mai mică cifră a sa.</p>",
      "text": "Se dă un număr natural n care are cifrele distincte. Să se afișeze a doua cea mai mare cifră a sa și a doua cea mai mică cifră a sa."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran cele două numere cerute, separate printr-un spațiu.</p>",
      "text": "Programul va afișa pe ecran cele două numere cerute, separate printr-un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1234 ≤ n ≤ 2.000.000.000</code></li>\n\t<li><code>n</code> are cifrele distincte</li>\n</ul>",
      "text": "1234 ≤ n ≤ 2.000.000.000 n are cifrele distincte"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>6937045</pre><p><strong>Ieșire</strong></p><pre>7 3</pre>",
      "text": "Intrare6937045Ieșire7 3"
    }
  ],
  "examples": [
    {
      "input": "6937045",
      "output": "7 3"
    }
  ],
  "constraints": [
    "1234 ≤ n ≤ 2.000.000.000",
    "n are cifrele distincte"
  ],
