  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine lungimea maximă <code>L</code> pe care o poate obține pentru cel puțin <code>A</code> araci tăind bambușii.</p>",
      "text": "Să se determine lungimea maximă L pe care o poate obține pentru cel puțin A araci tăind bambușii."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> și <code>A</code>, iar apoi <code>n</code> numere naturale, separate prin spații, reprezentând dimensiunile tulpinilor de bambus.</p>",
      "text": "Programul citește de la tastatură numerele n și A, iar apoi n numere naturale, separate prin spații, reprezentând dimensiunile tulpinilor de bambus."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <code>L</code>, reprezentând lungimea maximă posibilă a celor cel puțin <code>A</code> araci.</p>",
      "text": "Programul va afișa pe ecran L, reprezentând lungimea maximă posibilă a celor cel puțin A araci."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ n ≤ 100.000</code></li>\n\t<li><code>1 ≤ d</code><sub><code>i</code></sub> <code>≤ 30.000</code></li>\n\t<li><code>d</code><sub><code>1</code></sub>, <code>d</code><sub><code>2</code></sub>, …, <code>d</code><sub><code>n</code></sub>, <code>L</code> și <code>A</code> sunt numere naturale nenule.</li>\n\t<li>Este garantat că se pot obține araci de lungime cel puțin <code>1</code>.</li>\n</ul>",
      "text": "3 ≤ n ≤ 100.000 1 ≤ di ≤ 30.000 d1, d2, …, dn, L și A sunt numere naturale nenule. Este garantat că se pot obține araci de lungime cel puțin 1."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 7\n10 12 4 2 16</pre><p><strong>Ieșire</strong></p><pre>5</pre><h3>Explicație</h3><p>Cei <code>7</code> araci se pot tăia de dimensiune maximă <code>5</code>: din bambusul de dimensiune <code>10</code> pot obține <code>2</code> araci, din cel de dimensiune <code>12</code> încă <code>2</code> araci, iar din cel de dimensiune <code>16</code> încă <code>3</code> araci. <code>2 + 2 + 3 = 7</code>.</p>",
      "text": "Intrare5 7 10 12 4 2 16Ieșire5ExplicațieCei 7 araci se pot tăia de dimensiune maximă 5: din bambusul de dimensiune 10 pot obține 2 araci, din cel de dimensiune 12 încă 2 araci, iar din cel de dimensiune 16 încă 3 araci. 2 + 2 + 3 = 7."
    }
  ],
  "examples": [
    {
      "input": "5 7\n10 12 4 2 16",
      "output": "5",
      "explanation": "Cei 7 araci se pot tăia de dimensiune maximă 5: din bambusul de dimensiune 10 pot obține 2 araci, din cel de dimensiune 12 încă 2 araci, iar din cel de dimensiune 16 încă 3 araci. 2 + 2 + 3 = 7."
    }
  ],
  "constraints": [
    "3 ≤ n ≤ 100.000",
    "1 ≤ di ≤ 30.000",
    "d1, d2, …, dn, L și A sunt numere naturale nenule.",
    "Este garantat că se pot obține araci de lungime cel puțin 1."
  ],
