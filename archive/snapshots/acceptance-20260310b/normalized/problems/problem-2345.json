  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Câți câștigatori au existat?</p>",
      "text": "Câți câștigatori au existat?"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>magic3.in</code> conţine pe prima linie variabila <code>n</code> cu indicația din enunț, iar pe a doua linie cele n numere naturale <code>v[1],v[2],...,v[n]</code> , separate prin câte un spațiu, reprezentând numerele extrase la tombolă.</p>",
      "text": "Fişierul de intrare magic3.in conţine pe prima linie variabila n cu indicația din enunț, iar pe a doua linie cele n numere naturale v[1],v[2],...,v[n] , separate prin câte un spațiu, reprezentând numerele extrase la tombolă."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>magic3.out</code> conţine o singură valoare care reprezintă numărul de câștigatori.</p>",
      "text": "Fişierul de ieşire magic3.out conţine o singură valoare care reprezintă numărul de câștigatori."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000</code></li>\n\t<li><code>0 &lt; v[i] ≤ 1.000.000.000</code></li>\n\t<li>Numerele se pot repeta în această tombolă</li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000 0 < v[i] ≤ 1.000.000.000 Numerele se pot repeta în această tombolă"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>magic3.in</code></p><pre>8 \n12 5 10 7 32 2 4 99</pre><p><code>magic3.out</code></p><pre>3</pre><h3>Explicație</h3><p>Numărul minim de divizori este 2. Și avem 3 numere care au doar 2 divizori.</p>",
      "text": "magic3.in8 12 5 10 7 32 2 4 99magic3.out3ExplicațieNumărul minim de divizori este 2. Și avem 3 numere care au doar 2 divizori."
    }
  ],
