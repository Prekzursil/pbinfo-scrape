  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine câte secvențe valide sunt în șir.</p>",
      "text": "Să se determine câte secvențe valide sunt în șir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>nrseq.in</code> conține pe prima linie numărul <code>n</code>, iar pe a doua linie <code>n</code> numere întregi separate prin spații.</p>",
      "text": "Fișierul de intrare nrseq.in conține pe prima linie numărul n, iar pe a doua linie n numere întregi separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>nrseq.out</code> va conține pe prima linie numărul <code>S</code>, reprezentând numărul secvențelor valide.</p>",
      "text": "Fișierul de ieșire nrseq.out va conține pe prima linie numărul S, reprezentând numărul secvențelor valide."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n\t<li>numerele de pe a doua linie a fișierului de intrare sunt de tip <code>int</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000 numerele de pe a doua linie a fișierului de intrare sunt de tip int"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>nrseq.in</code></p><pre>7\n40 -7 15 120 40 -3 22</pre><p><code>nrseq.out</code></p><pre>10</pre><h3>Explicație</h3><p>Cele <code>10</code> secvențe sunt:<br>\n<code>-7 15</code><br>\n<code>40 -7 15 120</code><br>\n<code>-7 15 120</code><br>\n<code>15 120</code><br>\n<code>-7 15 120 40</code><br>\n<code>15 120 40</code><br>\n<code>-7 15 120 40 -3</code><br>\n<code>-7 15 120 40 -3 22</code><br>\n<code>15 120 40 -3 22</code><br>\n<code>-3 22</code></p>",
      "text": "nrseq.in7 40 -7 15 120 40 -3 22nrseq.out10ExplicațieCele 10 secvențe sunt: -7 15 40 -7 15 120 -7 15 120 15 120 -7 15 120 40 15 120 40 -7 15 120 40 -3 -7 15 120 40 -3 22 15 120 40 -3 22 -3 22"
    }
  ],
