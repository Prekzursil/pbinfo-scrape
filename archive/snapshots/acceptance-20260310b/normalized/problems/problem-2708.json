  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citesc <code>n</code> numere naturale. Determinați  pentru fiecare dintre ele dacă este par sau impar.</p>",
      "text": "Se citesc n numere naturale. Determinați pentru fiecare dintre ele dacă este par sau impar."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <code>n</code> valori <code>0</code> sau <code>1</code>, separate prin spații. Dacă numărul corespunzător este par se va afișa <code>0</code>, iar dacă este impar se va afișa <code>1</code>.</p>",
      "text": "Programul va afișa pe ecran n valori 0 sau 1, separate prin spații. Dacă numărul corespunzător este par se va afișa 0, iar dacă este impar se va afișa 1."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n\t<li>cele <code>n</code> numere citite se pot reprezenta pe 64 de biți, fără semn;</li>\n\t<li>se recomandă utilizarea operațiilor pe biți</li>\n</ul>",
      "text": "1 ≤ n ≤ 1000 cele n numere citite se pot reprezenta pe 64 de biți, fără semn; se recomandă utilizarea operațiilor pe biți"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n1 2 3 4 5</pre><p><strong>Ieșire</strong></p><pre>1 0 1 0 1</pre>",
      "text": "Intrare5 1 2 3 4 5Ieșire1 0 1 0 1"
    }
  ],
  "examples": [
    {
      "input": "5\n1 2 3 4 5",
      "output": "1 0 1 0 1"
    }
  ],
