  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Descoperiţi regula de inscripţionare a tăbliţelor şi pentru numărul găsit pe a cincea tăbliţă, determinaţi din ce grupă face parte.</p>",
      "text": "Descoperiţi regula de inscripţionare a tăbliţelor şi pentru numărul găsit pe a cincea tăbliţă, determinaţi din ce grupă face parte."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>tablita.in</code> conţine pe prima linie un număr natural <code>N</code>, ce reprezintă numărul care era înscris pe a cincea tăbliţă descoperită de Adrian.</p>",
      "text": "Fişierul de intrare tablita.in conţine pe prima linie un număr natural N, ce reprezintă numărul care era înscris pe a cincea tăbliţă descoperită de Adrian."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>tablita.out</code> va conţine un număr natural ce reprezintă grupa în care se află numărul <code>N</code>, înscris pe a cincea tabliţă găsită.</p>",
      "text": "Fişierul de ieşire tablita.out va conţine un număr natural ce reprezintă grupa în care se află numărul N, înscris pe a cincea tabliţă găsită."
    },
    {
      "title": "Restricții și precizări",
      "html": "<p>Un număr înscris pe o tăbliţă este nenul şi conţine <code>cel mult 8 cifre</code>;</p>",
      "text": "Un număr înscris pe o tăbliţă este nenul şi conţine cel mult 8 cifre;"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>tablita.in</code></p><pre>100</pre><p><code>tablita.out</code></p><pre>14</pre><h3>Explicație</h3><p>Numărul <code>100</code> ce apare pe a cincea tăbliţă face parte din grupa <code>14</code>.</p>",
      "text": "tablita.in100tablita.out14ExplicațieNumărul 100 ce apare pe a cincea tăbliţă face parte din grupa 14."
    }
  ],
