  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Un șir de biți se numește alternant dacă nu conține doi biți de <code>1</code> consecutivi. De exemplu, șirul <code>001001</code> este alternant, iar șirul <code>001101</code> nu este alternant. Să se determine numărul de șiruri de biți de lungime <code>n</code> care au proprietatea că sunt alternante.</p>",
      "text": "Un șir de biți se numește alternant dacă nu conține doi biți de 1 consecutivi. De exemplu, șirul 001001 este alternant, iar șirul 001101 nu este alternant. Să se determine numărul de șiruri de biți de lungime n care au proprietatea că sunt alternante."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>c</code>, reprezentând numărul de șiruri de biți de lungime <code>n</code> care au proprietatea că sunt alternante.</p>",
      "text": "Programul va afișa pe ecran numărul c, reprezentând numărul de șiruri de biți de lungime n care au proprietatea că sunt alternante."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 90</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 90"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4</pre><p><strong>Ieșire</strong></p><pre>8</pre>",
      "text": "Intrare4Ieșire8"
    },
    {
      "title": "Explicație:",
      "html": "<p>Șirurile formate din 4 biți care au proprietatea că sunt alternante sunt: 0000, 0001, 0010, 0100, 0101, 1000, 1001 și 1010.   </p>",
      "text": "Șirurile formate din 4 biți care au proprietatea că sunt alternante sunt: 0000, 0001, 0010, 0100, 0101, 1000, 1001 și 1010."
    }
  ],
  "examples": [
    {
      "input": "4",
      "output": "8"
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 90"
