  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând tipul <code>T</code> al jocului, numărul <code>G</code> al game-urilor, respectiv valoarea de pornire pentru fiecare game, să se răspundă pentru fiecare caz în parte, dacă jucătorul A va câștiga (<code>1</code>) sau va pierde (<code>0</code>).</p>",
      "text": "Cunoscând tipul T al jocului, numărul G al game-urilor, respectiv valoarea de pornire pentru fiecare game, să se răspundă pentru fiecare caz în parte, dacă jucătorul A va câștiga (1) sau va pierde (0)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul standard de intrare va conține pe prima linie două numere naturale <code>T</code> și <code>G</code> separate prin spațiu, reprezentând tipul tuturor jocurilor (<code>1</code> sau <code>2</code>) respectiv numărul de game-uri. Următoarele <code>G</code> linii vor conține câte un număr natural ce reprezintă câte o valoare de pornire.</p>",
      "text": "Fișierul standard de intrare va conține pe prima linie două numere naturale T și G separate prin spațiu, reprezentând tipul tuturor jocurilor (1 sau 2) respectiv numărul de game-uri. Următoarele G linii vor conține câte un număr natural ce reprezintă câte o valoare de pornire."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul standard de ieșire va conține <code>G</code> linii, pe fiecare linie se va scrie valoarea <code>1</code> – dacă numărul este câștigător pentru jucătorul A, sau valoarea <code>0</code> – dacă numărul este pierzător pentru jucătorul A, în ordinea citirii valorilor din fișierul de intrare.</p>",
      "text": "Fișierul standard de ieșire va conține G linii, pe fiecare linie se va scrie valoarea 1 – dacă numărul este câștigător pentru jucătorul A, sau valoarea 0 – dacă numărul este pierzător pentru jucătorul A, în ordinea citirii valorilor din fișierul de intrare."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>T</code> poate fi <code>1</code> sau <code>2</code>;</li>\n\t<li><code>0 &lt; G &lt; 10</code>;</li>\n\t<li><code>1 &lt; valoare de pornire &lt; 2.000.000.000</code>.</li>\n</ul>",
      "text": "T poate fi 1 sau 2; 0 < G < 10; 1 < valoare de pornire < 2.000.000.000."
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>1 4\n2\n3\n4\n2019</pre><p><strong>Ieșire</strong></p><pre>0\n1\n1\n1</pre><h3>Explicație</h3><p>avem joc de tipul <code>T = 1</code>,<br>\nmeciul este format din <code>G = 4</code> game-uri<br>\n<code>2</code> – pierzător pentru A (<code>0</code>)<br>\n<code>3</code> – câștigător pentru A (<code>1</code>)<br>\n<code>4</code> – câștigător pentru A (<code>1</code>)<br>\n<code>2019</code> – câștigător pentru A (<code>1</code>)</p>",
      "text": "Intrare1 4 2 3 4 2019Ieșire0 1 1 1Explicațieavem joc de tipul T = 1, meciul este format din G = 4 game-uri 2 – pierzător pentru A (0) 3 – câștigător pentru A (1) 4 – câștigător pentru A (1) 2019 – câștigător pentru A (1)"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>2 4\n2\n3\n4\n123456789</pre><p><strong>Ieșire</strong></p><pre>1\n1\n0\n1</pre><h3>Explicație</h3><p>avem joc de tip <code>T = 2</code> și <code>G = 4</code><br>\n<code>2</code> – câștigător<br>\n<code>3</code> – câștigător<br>\n<code>4</code> – pierzător<br>\n<code>123456789</code> – câștigător</p>",
      "text": "Intrare2 4 2 3 4 123456789Ieșire1 1 0 1Explicațieavem joc de tip T = 2 și G = 4 2 – câștigător 3 – câștigător 4 – pierzător 123456789 – câștigător"
    }
  ],
  "examples": [
    {
      "input": "1 4\n2\n3\n4\n2019",
      "output": "0\n1\n1\n1",
      "explanation": "avem joc de tipul T = 1, meciul este format din G = 4 game-uri 2 – pierzător pentru A (0) 3 – câștigător pentru A (1) 4 – câștigător pentru A (1) 2019 – câștigător pentru A (1)"
    },
    {
      "input": "2 4\n2\n3\n4\n123456789",
      "output": "1\n1\n0\n1",
      "explanation": "avem joc de tip T = 2 și G = 4 2 – câștigător 3 – câștigător 4 – pierzător 123456789 – câștigător"
    }
  ],
  "constraints": [
    "T poate fi 1 sau 2;",
    "0 < G < 10;",
    "1 < valoare de pornire < 2.000.000.000."
  ],
