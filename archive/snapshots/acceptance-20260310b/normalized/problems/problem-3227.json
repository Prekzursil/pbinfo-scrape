  "sections": [
    {
      "title": "Enunt",
      "html": "<p>Timp de <code>t</code> zile <i>Cebîșev</i> a numărat in drum spre școală <code>x</code> mașini și <code>y</code> tramvaie. Se știe că numărul de tramvaie este egal cu numărul de numere mai mici sau egale cu <code>x</code> si prime cu acesta.</p>",
      "text": "Timp de t zile Cebîșev a numărat in drum spre școală x mașini și y tramvaie. Se știe că numărul de tramvaie este egal cu numărul de numere mai mici sau egale cu x si prime cu acesta."
    },
    {
      "title": "Cerința",
      "html": "<p>Știindu-se numărul de zile si numărul de mașini numărate în fiecare zi, calculați pentru fiecare zi numărul de tramvaie numărate de <i>Cebîșev</i>.</p>",
      "text": "Știindu-se numărul de zile si numărul de mașini numărate în fiecare zi, calculați pentru fiecare zi numărul de tramvaie numărate de Cebîșev."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare este <code>tramvaie.in</code><br>\nAcesta conține pe primul rând un număr natural <code>t</code>, reprezentând numărul de zile.<br>\nPe a doua linie a fișierului de intrare se găsesc <code>t</code> numere, reprezentând numarul de masini văzute în fiecare zi de <i>Cebîșev</i>.</p>",
      "text": "Fișierul de intrare este tramvaie.in Acesta conține pe primul rând un număr natural t, reprezentând numărul de zile. Pe a doua linie a fișierului de intrare se găsesc t numere, reprezentând numarul de masini văzute în fiecare zi de Cebîșev."
    },
    {
      "title": "Date de iesire",
      "html": "<p>Fișierul de ieșire este <code>tramvaie.out</code><br>\nAcesta conține <code>t</code> numere reprezentând numărul de tramvaie văzute de <i>Cebîșev</i> în fiecare zi.</p>",
      "text": "Fișierul de ieșire este tramvaie.out Acesta conține t numere reprezentând numărul de tramvaie văzute de Cebîșev în fiecare zi."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 &lt; x, y, t &lt; 1 000 006</code></li>\n\t<li>Se consideră că orice număr este prim cu <code>1</code>.</li>\n</ul>",
      "text": "0 < x, y, t < 1 000 006 Se consideră că orice număr este prim cu 1."
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>tramvaie.in</code></p><pre>2\n2 3</pre><p><code>tramvaie.out</code></p><pre>1 2</pre>",
      "text": "tramvaie.in2 2 3tramvaie.out1 2"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>tramvaie.in</code></p><pre>3\n102 898 1243</pre><p><code>tramvaie.out</code></p><pre>32 448 1120</pre>",
      "text": "tramvaie.in3 102 898 1243tramvaie.out32 448 1120"
    }
  ],
  "examples": [],
