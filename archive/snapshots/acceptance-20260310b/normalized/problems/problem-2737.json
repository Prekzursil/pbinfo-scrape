  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n</code> numere naturale. Să se afișeze numărul de divizori al produsului tuturor celor <code>n</code> numere citite <code>MODULO 1.000.000.007</code>.</p>",
      "text": "Se dau n numere naturale. Să se afișeze numărul de divizori al produsului tuturor celor n numere citite MODULO 1.000.000.007."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește din fișierul <code>nrdivprod.in</code> numărul <code>n</code>, iar apoi <code>n</code> numere naturale, separate prin spații.</p>",
      "text": "Programul citește din fișierul nrdivprod.in numărul n, iar apoi n numere naturale, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va scrie în fișierul <code>nrdivprod.out</code> numărul de divizori al produsului celor <code>n</code> numere <code>MODULO 1.000.000.007</code>.</p>",
      "text": "Programul va scrie în fișierul nrdivprod.out numărul de divizori al produsului celor n numere MODULO 1.000.000.007."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n\t<li>cele <code>n</code> numere citite vor fi mai mici decât <code>1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000 cele n numere citite vor fi mai mici decât 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>nrdivprod.in</code></p><pre>3\n2 3 4</pre><p><code>nrdivprod.out</code></p><pre>8</pre><h3>Explicație</h3><p><code>2*3*4=24, nrdiv(24)=8</code></p>",
      "text": "nrdivprod.in3 2 3 4nrdivprod.out8Explicație2*3*4=24, nrdiv(24)=8"
    }
  ],
