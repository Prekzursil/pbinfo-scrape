  "tags": [
    "Cifrele unui număr"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau cel mult <code>1000</code> numere naturale mai mici decât <code>100.000.000</code>. Să se stabilească despre fiecare număr dacă este sau nu curat.</p>",
      "text": "Se dau cel mult 1000 numere naturale mai mici decât 100.000.000. Să se stabilească despre fiecare număr dacă este sau nu curat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>nrcurat.in</code> conține pe prima linie cel mult <code>1000</code> numere naturale mai mici decât <code>100.000.000</code>, separate prin spații.</p>",
      "text": "Fișierul de intrare nrcurat.in conține pe prima linie cel mult 1000 numere naturale mai mici decât 100.000.000, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>nrcurat.out</code> va conține pe prima linie pentru fiecare număr <code>x</code> din fișierul de intrare valoarea <code>1</code> dacă <code>x</code> este curat sau <code>0</code> în caz contrar. Valorile sunt separate prin câte un spațiu.</p>",
      "text": "Fișierul de ieșire nrcurat.out va conține pe prima linie pentru fiecare număr x din fișierul de intrare valoarea 1 dacă x este curat sau 0 în caz contrar. Valorile sunt separate prin câte un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>în fișier sunt cel mult <code>1000</code> de numere naturale mai mici decât <code>100.000.000</code></li>\n</ul>",
      "text": "în fișier sunt cel mult 1000 de numere naturale mai mici decât 100.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>nrcurat.in</code></p><pre>345 18 53 986310 467 1638</pre><p><code>nrcurat.out</code></p><pre>0 1 0 1 0 1</pre><h3>Explicație</h3><p>Numerele <code>18</code>, <code>986310</code> și <code>1638</code> sunt numere curate.</p>",
      "text": "nrcurat.in345 18 53 986310 467 1638nrcurat.out0 1 0 1 0 1ExplicațieNumerele 18, 986310 și 1638 sunt numere curate."
    }
  ],
  "examples": [
