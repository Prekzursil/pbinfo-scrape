  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă o matrice pătratică de dimensiune <code>n</code>. Să se ordoneze crescător fiecare linie a matricei, apoi să se ordoneze crescător fiecare coloană a acesteia.</p>",
      "text": "Se dă o matrice pătratică de dimensiune n. Să se ordoneze crescător fiecare linie a matricei, apoi să se ordoneze crescător fiecare coloană a acesteia."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi elementele matricei. Fiecare linie se află pe câte un rând, elementele fiecărei linii fiind separate prin câte un spațiu.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi elementele matricei. Fiecare linie se află pe câte un rând, elementele fiecărei linii fiind separate prin câte un spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran matricea modificată, câte o linie a matricei pe o linie a ecranului, elementele fiecărei linii fiind separate prin câte un spațiu.</p>",
      "text": "Programul va afișa pe ecran matricea modificată, câte o linie a matricei pe o linie a ecranului, elementele fiecărei linii fiind separate prin câte un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n\t<li>elementele matricei vor fi mai mici decât <code>1.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100 elementele matricei vor fi mai mici decât 1.000"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>3\n4 1 3\n9 6 8\n5 2 7</pre><p><strong>Ieșire</strong></p><pre>1 3 4 \n2 5 7 \n6 8 9 </pre>",
      "text": "Intrare3 4 1 3 9 6 8 5 2 7Ieșire1 3 4 2 5 7 6 8 9"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>4\n12 7 1 8\n20 9 11 2\n15 4 5 13\n3 18 10 6</pre><p><strong>Ieșire</strong></p><pre>1 5 8 12 \n2 6 10 15 \n3 7 11 18 \n4 9 13 20 </pre>",
      "text": "Intrare4 12 7 1 8 20 9 11 2 15 4 5 13 3 18 10 6Ieșire1 5 8 12 2 6 10 15 3 7 11 18 4 9 13 20"
    }
  ],
  "examples": [
    {
      "input": "3\n4 1 3\n9 6 8\n5 2 7",
      "output": "1 3 4 \n2 5 7 \n6 8 9"
    },
