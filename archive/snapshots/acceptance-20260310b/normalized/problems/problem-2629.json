  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Determină lungimea maximă cerută și anul viitor vei mai primi un șir!</p>",
      "text": "Determină lungimea maximă cerută și anul viitor vei mai primi un șir!"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, apoi șirul de <code>n</code> numere naturale, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, apoi șirul de n numere naturale, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran lungimea maximă a secvenței de valori distincte.</p>",
      "text": "Programul va afișa pe ecran lungimea maximă a secvenței de valori distincte."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n\t<li><code>0 ≤ a[i] ≤ 1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000 0 ≤ a[i] ≤ 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>9\n1 2 1 2 5 6 7 2 9</pre><p><strong>Ieșire</strong></p><pre>5</pre><h3>Explicație</h3><p>Secvența de lungime maximă <code>5</code> este <code>1 2 5 6 7</code>.</p>",
      "text": "Intrare9 1 2 1 2 5 6 7 2 9Ieșire5ExplicațieSecvența de lungime maximă 5 este 1 2 5 6 7."
    }
  ],
  "examples": [
    {
      "input": "9\n1 2 1 2 5 6 7 2 9",
      "output": "5",
      "explanation": "Secvența de lungime maximă 5 este 1 2 5 6 7."
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 1.000.000",
    "0 ≤ a[i] ≤ 1.000.000.000"
