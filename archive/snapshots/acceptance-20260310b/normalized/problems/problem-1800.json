  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Dat fiind <code>N</code> şi <code>K</code> operaţii, să se execute fiecare în ordinea citirii.</p>",
      "text": "Dat fiind N şi K operaţii, să se execute fiecare în ordinea citirii."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>matop.in</code> va conţine pe prima linie două numere naturale <code>N</code>, <code>K</code> reprezentând dimensiunile matricei şi numărul de operaţii care trebuie efectuate. Pe următoarele <code>K</code> linii se află descrierea unei operaţii în formatul precizat mai sus.</p>",
      "text": "Fişierul de intrare matop.in va conţine pe prima linie două numere naturale N, K reprezentând dimensiunile matricei şi numărul de operaţii care trebuie efectuate. Pe următoarele K linii se află descrierea unei operaţii în formatul precizat mai sus."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul <code>matop.out</code> ​va conţine pentru fiecare operaţie de tip <code>3</code> şi <code>4</code> din fişierul de intrare răspunsul opeaţiei corespunzătoare.</p>",
      "text": "Fişierul matop.out ​va conţine pentru fiecare operaţie de tip 3 şi 4 din fişierul de intrare răspunsul opeaţiei corespunzătoare."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 25.000</code></li>\n\t<li><code>1 ≤ K ≤ 100.000</code></li>\n\t<li><code>1 ≤ LIN ≤ N</code></li>\n\t<li><code>1 ≤ COL ≤ N</code></li>\n\t<li><code>0 ≤ VAL ≤ 100.000</code></li>\n\t<li>Pentru 40% din teste <code>1 ≤ N, K ≤ 100</code></li>\n</ul>",
      "text": "1 ≤ N ≤ 25.000 1 ≤ K ≤ 100.000 1 ≤ LIN ≤ N 1 ≤ COL ≤ N 0 ≤ VAL ≤ 100.000 Pentru 40% din teste 1 ≤ N, K ≤ 100"
    },
    {
      "title": "Exemplu",
      "html": "<p><code>matop.in</code></p><pre>5 11\n1 1 1\n2 2 3\n3 1 4\n2 3 9\n1 5 2\n1 4 4\n3 4 3\n3 1 2\n1 1 10\n3 1 3\n4</pre><p><code>matop.out</code></p><pre>1\n9\n3\n10\n28</pre>",
      "text": "matop.in5 11 1 1 1 2 2 3 3 1 4 2 3 9 1 5 2 1 4 4 3 4 3 3 1 2 1 1 10 3 1 3 4matop.out1 9 3 10 28"
    },
    {
      "title": "Explicaţie",
      "html": "<p>Dupa primele <code>2</code> operaţii matricea este:</p><pre>1 3 1 1 1\n0 3 0 0 0\n0 3 0 0 0\n0 3 0 0 0\n0 3 0 0 0</pre><p>ș.a.m.d.</p>",
      "text": "Dupa primele 2 operaţii matricea este:1 3 1 1 1 0 3 0 0 0 0 3 0 0 0 0 3 0 0 0 0 3 0 0 0ș.a.m.d."
    }
  ],
