  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Medeea vă roagă să o ajutați să rezolve tema transformând fracția zecimală primită în fracție ordinară şi să o aduceți la forma ireductibilă. </p>",
      "text": "Medeea vă roagă să o ajutați să rezolve tema transformând fracția zecimală primită în fracție ordinară şi să o aduceți la forma ireductibilă."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>dec2ord.in</code> conține pe prima linie partea întreaga a numărului, pe a doua linie se află partea zecimală neperiodică, iar pe a treia partea periodică.</p>",
      "text": "Fişierul de intrare dec2ord.in conține pe prima linie partea întreaga a numărului, pe a doua linie se află partea zecimală neperiodică, iar pe a treia partea periodică."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>dec2ord.out</code> conține pe o singură linie o fracție ordinară ireductibilă de forma numărător/numitor.</p>",
      "text": "Fişierul de ieşire dec2ord.out conține pe o singură linie o fracție ordinară ireductibilă de forma numărător/numitor."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>Fiecare parte are maximum <code>5</code> cifre</li>\n\t<li>Se garantează că fracția dată are cel puțin o zecimală</li>\n\t<li>Dacă fracția nu are parte periodică sau zecimală neperiodică, pe linia aferentă se va afla <code>-1</code>.</li>\n\t<li>Pentru <code>70%</code> din teste fracțiile nu au perioadă</li>\n</ul>",
      "text": "Fiecare parte are maximum 5 cifre Se garantează că fracția dată are cel puțin o zecimală Dacă fracția nu are parte periodică sau zecimală neperiodică, pe linia aferentă se va afla -1. Pentru 70% din teste fracțiile nu au perioadă"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>dec2ord.in</code></p><pre>125\n9\n6</pre><p><code>dec2ord.out</code></p><pre>3779/30</pre><h3>Explicație</h3><p><code>125,9(6) = 3779/30</code>.</p>",
      "text": "dec2ord.in125 9 6dec2ord.out3779/30Explicație125,9(6) = 3779/30."
    }
  ],
