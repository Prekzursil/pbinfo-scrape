  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se consideră şirul <code>1, 2,1, 3,2,1, 4,3,2,1, ...</code>, în care prima grupă este formată din numărul <code>1</code>, a doua grupă este formată din numerele <code>2,1</code>, …, a <code>k</code>-a grupă este formată din numerele <code>k,k-1,...,2,1</code>.</p><p>Pentru un număr natural dat <code>n</code>, să se determine al <code>n</code>-lea termen din şir.</p>",
      "text": "Se consideră şirul 1, 2,1, 3,2,1, 4,3,2,1, ..., în care prima grupă este formată din numărul 1, a doua grupă este formată din numerele 2,1, …, a k-a grupă este formată din numerele k,k-1,...,2,1.Pentru un număr natural dat n, să se determine al n-lea termen din şir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citeşte de la tastatură numărul <code>n</code></p>",
      "text": "Programul citeşte de la tastatură numărul n"
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul va afişa pe ecran numărul <code>x</code>, reprezentând al <code>n</code>-lea termen din şir.</p>",
      "text": "Programul va afişa pe ecran numărul x, reprezentând al n-lea termen din şir."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>14</pre><p><strong>Date de ieşire</strong></p><pre>2</pre>",
      "text": "Date de intrare14Date de ieşire2"
    }
  ],
  "examples": [
    {
      "input": "2",
      "output": ""
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 1.000.000.000"
  ],
