  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Afisați dupa fiecare operație elementul din vârful stivei.<br>\nSe garantează:<br>\n1. că nu se va efectua operația de tip 2 dacă nu există cel puțin două elemente în stivă;<br>\n2. că prima operatie va fi de tipul 0</p>",
      "text": "Afisați dupa fiecare operație elementul din vârful stivei. Se garantează: 1. că nu se va efectua operația de tip 2 dacă nu există cel puțin două elemente în stivă; 2. că prima operatie va fi de tipul 0"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>izi.in</code> conține pe prima linie un număr natural <code>T</code>, iar pe următoarele <code>T</code> linii operațiile efectuate asupra stivei.</p>",
      "text": "Fișierul de intrare izi.in conține pe prima linie un număr natural T, iar pe următoarele T linii operațiile efectuate asupra stivei."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>izi.out</code> va conține <code>T</code> linii, reprezentând elementele din vârful stivei dupa fiecare operație.</p>",
      "text": "Fișierul de ieșire izi.out va conține T linii, reprezentând elementele din vârful stivei dupa fiecare operație."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ T ≤ 1.000.000</code><br>\n• <code>-1000 ≤ add ≤ 1000</code><br>\n• Pentru operațiile de tip 1, <code>-1000 ≤ x ≤ 1000</code>, iar pentru operatiile de tip 2 numărul elementelor aflate în stivă este mai mare ca <code>y</code><br>\n• Pentru 36 puncte: <code>1 ≤ T ≤ 1000</code><br>\n• Pentru alte 33 puncte: Toate operatiile de tip 2 se vor afla la finalul fișierului de intrare</li>\n</ul>",
      "text": "1 ≤ T ≤ 1.000.000 • -1000 ≤ add ≤ 1000 • Pentru operațiile de tip 1, -1000 ≤ x ≤ 1000, iar pentru operatiile de tip 2 numărul elementelor aflate în stivă este mai mare ca y • Pentru 36 puncte: 1 ≤ T ≤ 1000 • Pentru alte 33 puncte: Toate operatiile de tip 2 se vor afla la finalul fișierului de intrare"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>izi.in</code></p><pre>7\n0 1\n1 1 1 2\n0 2\n1 1 2 3\n2\n0 4\n2</pre><p><code>izi.out</code></p><pre>1\n3\n2\n5\n6\n4\n6</pre>",
      "text": "izi.in7 0 1 1 1 1 2 0 2 1 1 2 3 2 0 4 2izi.out1 3 2 5 6 4 6"
    }
  ],
