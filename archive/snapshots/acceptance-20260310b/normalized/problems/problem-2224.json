  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se <code>N</code> operații, trebuie să afișați răspunsul la fiecare operație de tip <code>3</code>.</p>",
      "text": "Dându-se N operații, trebuie să afișați răspunsul la fiecare operație de tip 3."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>mset.in</code> conține pe prima linie <code>N</code>. Pe următoarele <code>N</code> linii sunt date cele <code>N</code> operații.</p>",
      "text": "Fișierul de intrare mset.in conține pe prima linie N. Pe următoarele N linii sunt date cele N operații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>În fișierul de ieșire <code>mset.out</code> se vor afișa pe câte o linie răspunsurile la operațiile de tip <code>3</code>.</p>",
      "text": "În fișierul de ieșire mset.out se vor afișa pe câte o linie răspunsurile la operațiile de tip 3."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 200 000</code></li>\n\t<li>Va exista cel puțin o operație de tip <code>3</code></li>\n\t<li>Valorile care se introduc în mulțime sunt numere naturale mai mici decât <code>2 000 000 000</code></li>\n</ul>",
      "text": "1 ≤ N ≤ 200 000 Va exista cel puțin o operație de tip 3 Valorile care se introduc în mulțime sunt numere naturale mai mici decât 2 000 000 000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>mset.in</code></p><pre>14\n3\n1 55\n1 55\n3\n1 40\n3\n1 7\n1 7\n3\n2 7 \n1 50\n3\n2 40\n3</pre><p><code>mset.out</code></p><pre>-1\n55 2\n40 1\n7 2\n40 1\n50 1</pre>",
      "text": "mset.in14 3 1 55 1 55 3 1 40 3 1 7 1 7 3 2 7 1 50 3 2 40 3mset.out-1 55 2 40 1 7 2 40 1 50 1"
    }
  ],
