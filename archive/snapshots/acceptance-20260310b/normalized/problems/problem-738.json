  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se cere să se facă o alegere a secvenţelor de pe fiecare linie a matricei respectând restricţiile precizate, astfel încât însumând elementele acestora să se obţină suma maximă posibilă.</p>",
      "text": "Se cere să se facă o alegere a secvenţelor de pe fiecare linie a matricei respectând restricţiile precizate, astfel încât însumând elementele acestora să se obţină suma maximă posibilă."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Prima linie a fişierului <code>left.in</code> conţine două numere naturale sunt <code>L</code> şi <code>C</code> separate printr-un spaţiu reprezentând în ordine numărul de linii şi numărul de coloane ale matricei date. Pe fiecare dintre următoarele <code>L</code> linii sunt câte <code>C</code> numere întregi, separate prin câte un spaţiu, reprezentând elementele matricei.</p>",
      "text": "Prima linie a fişierului left.in conţine două numere naturale sunt L şi C separate printr-un spaţiu reprezentând în ordine numărul de linii şi numărul de coloane ale matricei date. Pe fiecare dintre următoarele L linii sunt câte C numere întregi, separate prin câte un spaţiu, reprezentând elementele matricei."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Prima linie a fişierului <code>left.out</code> va conţine un singur număr întreg, reprezentând suma maximă cerută.</p>",
      "text": "Prima linie a fişierului left.out va conţine un singur număr întreg, reprezentând suma maximă cerută."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ L,C ≤ 1000</code></li>\n\t<li>Valorile din matrice sunt numere întregi pe <code>32</code> de biţi.</li>\n\t<li>Rezultatul este un număr întreg pe <code>32</code> de biţi.</li>\n\t<li>Suma elementelor oricărei submatrice este un număr întreg pe <code>32</code> de biţi.</li>\n</ul>",
      "text": "2 ≤ L,C ≤ 1000 Valorile din matrice sunt numere întregi pe 32 de biţi. Rezultatul este un număr întreg pe 32 de biţi. Suma elementelor oricărei submatrice este un număr întreg pe 32 de biţi."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>left.in</code></p><pre>3 3\n1 2 3\n1 2 -1\n-1 2 -2</pre><p><code>left.out</code></p><pre>10</pre>",
      "text": "left.in3 3 1 2 3 1 2 -1 -1 2 -2left.out10"
    },
    {
      "title": "Explicație",
      "html": "<p>De pe prima linie se aleg <code>3</code> numere iar de pe celelalte linii câte <code>2</code> numere.</p>",
      "text": "De pe prima linie se aleg 3 numere iar de pe celelalte linii câte 2 numere."
    }
  ],
