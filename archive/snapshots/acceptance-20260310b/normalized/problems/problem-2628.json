  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine cel mai mic număr care apare exact o dată în șir.</p>",
      "text": "Să se determine cel mai mic număr care apare exact o dată în șir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, apoi șirul <code>n</code> numere naturale, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, apoi șirul n numere naturale, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>m</code>, reprezentând numărul minim care apare exact o dată în șir.</p>",
      "text": "Programul va afișa pe ecran numărul m, reprezentând numărul minim care apare exact o dată în șir."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>10 ≤ n ≤ 1.000.000</code></li>\n\t<li><code>0 ≤ a[i] ≤ 2.000.000.000</code></li>\n\t<li>Se garantează că există cel puțin un număr care apare o singură dată.</li>\n</ul>",
      "text": "10 ≤ n ≤ 1.000.000 0 ≤ a[i] ≤ 2.000.000.000 Se garantează că există cel puțin un număr care apare o singură dată."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>10\n5 3 8 7 3 3 2 5 9 5</pre><p><strong>Ieșire</strong></p><pre>2</pre><h3>Explicație</h3><p>Numerele care apar o singură dată în șir sunt: <code>8</code>, <code>7</code>, <code>2</code>, <code>9</code>. Cel mai mic este <code>2</code>.</p>",
      "text": "Intrare10 5 3 8 7 3 3 2 5 9 5Ieșire2ExplicațieNumerele care apar o singură dată în șir sunt: 8, 7, 2, 9. Cel mai mic este 2."
    }
  ],
  "examples": [
    {
      "input": "10\n5 3 8 7 3 3 2 5 9 5",
      "output": "2",
      "explanation": "Numerele care apar o singură dată în șir sunt: 8, 7, 2, 9. Cel mai mic este 2."
    }
  ],
