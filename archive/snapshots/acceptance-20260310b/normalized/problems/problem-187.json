  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se scrie un program care citeşte cel mult <code>1.000.000</code> de numere naturale din intervalul închis <code>[0,9]</code> şi determină cel mai mare număr prim citit şi numărul său de apariții.</p>",
      "text": "Să se scrie un program care citeşte cel mult 1.000.000 de numere naturale din intervalul închis [0,9] şi determină cel mai mare număr prim citit şi numărul său de apariții."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>ciffrecv.in</code> conţine cel mult <code>1.000.000</code> numere naturale din intervalul închis <code>[0,9]</code>, dispuse pe mai multe linii şi separate prin spaţii.</p>",
      "text": "Fișierul de intrare ciffrecv.in conţine cel mult 1.000.000 numere naturale din intervalul închis [0,9], dispuse pe mai multe linii şi separate prin spaţii."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>ciffrecv.out</code> va conţine pe prima linie două numere naturale <code>MAX</code> şi <code>NR_AP</code>, cu semnificaţia din enunţ.</p>",
      "text": "Fişierul de ieşire ciffrecv.out va conţine pe prima linie două numere naturale MAX şi NR_AP, cu semnificaţia din enunţ."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>fişierul de intrare va conţine cel puţin un număr prim</li>\n</ul>",
      "text": "fişierul de intrare va conţine cel puţin un număr prim"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>ciffrecv.in</code></p><pre>5 8 9 1 9 5 \n1 1 2 2 </pre><p><code>ciffrecv.out</code></p><pre>5 2</pre>",
      "text": "ciffrecv.in5 8 9 1 9 5 1 1 2 2 ciffrecv.out5 2"
    }
  ],
  "examples": [],
  "constraints": [
    "fişierul de intrare va conţine cel puţin un număr prim"
  ],
