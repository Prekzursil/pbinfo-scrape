  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dorel şi consătenii lui, fiind în perioada de alertă, s-au aşezat la rând la magazin. Fiecare avea la el o sumă diferită de bani şi, mai mult, sumele de bani ale secvenţelor de oameni din rând erau diferite oricare două.<br>\nAflaţi ce sumă de bani avea fiecare sătean la el.</p>",
      "text": "Dorel şi consătenii lui, fiind în perioada de alertă, s-au aşezat la rând la magazin. Fiecare avea la el o sumă diferită de bani şi, mai mult, sumele de bani ale secvenţelor de oameni din rând erau diferite oricare două. Aflaţi ce sumă de bani avea fiecare sătean la el."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code> de săteni.</p>",
      "text": "Programul citește de la tastatură numărul n de săteni."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <code>n</code> numere, reprezentând sumele sătenilor.</p>",
      "text": "Programul va afișa pe ecran n numere, reprezentând sumele sătenilor."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 3000</code></li>\n\t<li>cele <code>n</code> numere vor fi naturale, mai mici decât <code>20.000</code></li>\n\t<li>există mai multe soluţii, orice soluţie fiind acceptată</li>\n</ul>",
      "text": "1 ≤ n ≤ 3000 cele n numere vor fi naturale, mai mici decât 20.000 există mai multe soluţii, orice soluţie fiind acceptată"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>3</pre><p><strong>Ieșire</strong></p><pre>1 3 9</pre><h3>Explicație</h3><p>Secvenţele au sumele: <code>1, 3, 9, 4, 12, 13</code>, care sunt distincte.</p>",
      "text": "Intrare3Ieșire1 3 9ExplicațieSecvenţele au sumele: 1, 3, 9, 4, 12, 13, care sunt distincte."
    }
  ],
