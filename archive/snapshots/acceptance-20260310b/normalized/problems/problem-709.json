  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieţi un program care să determine cel mai mic şir, din punct de vedere lexicografic, ce se poate obţine dintr-un şir dat, aplicând toate operaţiile de ştergere necesare.</p>",
      "text": "Scrieţi un program care să determine cel mai mic şir, din punct de vedere lexicografic, ce se poate obţine dintr-un şir dat, aplicând toate operaţiile de ştergere necesare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>cmmstr.in</code> conține pe prima linie un şir de litere mici.</p>",
      "text": "Fișierul de intrare cmmstr.in conține pe prima linie un şir de litere mici."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>cmmstr.out</code> va conține pe prima linie şirul minim obţinut.</p>",
      "text": "Fișierul de ieșire cmmstr.out va conține pe prima linie şirul minim obţinut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤</code> lungimea şirului <code>&lt; 3 000 000</code>;</li>\n\t<li>numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât <code>1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ lungimea şirului < 3 000 000; numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>cmmstr.in</code></p><pre>ccbaba</pre><p><code>cmmstr.out</code></p><pre>cab</pre>",
      "text": "cmmstr.inccbabacmmstr.outcab"
    },
    {
      "title": "Explicație",
      "html": "<p><code>c<u>c</u>baba → c<u>b</u>aba → cab<u>a</u> → cab</code>.</p>",
      "text": "ccbaba → cbaba → caba → cab."
    }
  ],
  "examples": [],
