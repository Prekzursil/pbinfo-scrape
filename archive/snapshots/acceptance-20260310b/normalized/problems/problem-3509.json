  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>2</code> numere naturale <code>s</code> și <code>n</code>. Aflați câte subsecvențe de cifre din <code>s</code> formează numere divizibile cu <code>n</code>.</p>",
      "text": "Se dau 2 numere naturale s și n. Aflați câte subsecvențe de cifre din s formează numere divizibile cu n."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>s</code> si <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numerele s si n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul cerut.</p>",
      "text": "Programul va afișa pe ecran numărul cerut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 2^50</code></li>\n\t<li><code>s</code> este format din cel mult <code>2^20</code> cifre nenule</li>\n\t<li>cele <code>2</code> numere sunt prime cu <code>10</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 2^50 s este format din cel mult 2^20 cifre nenule cele 2 numere sunt prime cu 10"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>27422 3</pre><p><strong>Ieșire</strong></p><pre>4</pre><h3>Explicație</h3><p>Cele <code>4</code> numere sunt <code>27</code>, <code>2742</code>, <code>7422</code>, <code>42</code>.</p>",
      "text": "Intrare27422 3Ieșire4ExplicațieCele 4 numere sunt 27, 2742, 7422, 42."
    }
  ],
  "examples": [
    {
      "input": "27422 3",
      "output": "4",
      "explanation": "Cele 4 numere sunt 27, 2742, 7422, 42."
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 2^50",
    "s este format din cel mult 2^20 cifre nenule",
    "cele 2 numere sunt prime cu 10"
  ],
