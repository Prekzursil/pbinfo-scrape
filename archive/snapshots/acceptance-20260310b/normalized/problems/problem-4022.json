  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dacă se dă un cuvânt, să se precizeze dacă poate fi codificat conform sistemului de codificare. În caz afirmativ să se precizeze codul său. </p>",
      "text": "Dacă se dă un cuvânt, să se precizeze dacă poate fi codificat conform sistemului de codificare. În caz afirmativ să se precizeze codul său."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>cod.in</code> conţine pe o linie un cuvânt.</p>",
      "text": "Fișierul de intrare cod.in conţine pe o linie un cuvânt."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>cod.out</code> va conţine codul cuvântului ce trebuie codificat, sau <code>0</code> în cazul în care cuvântul nu poate fi codificat.</p>",
      "text": "Fișierul de ieșire cod.out va conţine codul cuvântului ce trebuie codificat, sau 0 în cazul în care cuvântul nu poate fi codificat."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>Numărul maxim de litere ale unui cuvânt este <code>10</code></li>\n</ul>",
      "text": "Numărul maxim de litere ale unui cuvânt este 10"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>cod.in</code></p><pre>bf</pre><p><code>cod.out</code></p><pre>55</pre>",
      "text": "cod.inbfcod.out55"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>cod.in</code></p><pre>aab</pre><p><code>cod.out</code></p><pre>0</pre>",
      "text": "cod.inaabcod.out0"
    },
    {
      "title": "Exemplul 3:",
      "html": "<p><code>cod.in</code></p><pre>vwxyz</pre><p><code>cod.out</code></p><pre>83681</pre>",
      "text": "cod.invwxyzcod.out83681"
    }
  ],
