  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau două mulțimi de numere naturale. Să se afișeze reuniunea și intersecția lor.</p>",
      "text": "Se dau două mulțimi de numere naturale. Să se afișeze reuniunea și intersecția lor."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură, în ordine:</p><ul>\n\t<li>numărul <code>n</code> de elemente ale primei mulțimi</li>\n\t<li><code>n</code> numere naturale diferite, ordonate crescător, reprezentând elementele primei mulțimi</li>\n\t<li>numărul <code>m</code> de elemente ale celei de-a doua mulțimi</li>\n\t<li><code>m</code> numere naturale diferite, ordonate crescător, reprezentând elementele celei de-a doua mulțimi</li>\n</ul>",
      "text": "Programul citește de la tastatură, în ordine: numărul n de elemente ale primei mulțimi n numere naturale diferite, ordonate crescător, reprezentând elementele primei mulțimi numărul m de elemente ale celei de-a doua mulțimi m numere naturale diferite, ordonate crescător, reprezentând elementele celei de-a doua mulțimi"
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran elementele reuniunii celor două mulțimi, în ordine crescătoare, separate prin exact un spațiu, iar pe rândul următor elementele intersecției celor două mulțimi, în ordine crescătoare, separate de asemenea prin exact un spațiu.</p>",
      "text": "Programul va afișa pe ecran elementele reuniunii celor două mulțimi, în ordine crescătoare, separate prin exact un spațiu, iar pe rândul următor elementele intersecției celor două mulțimi, în ordine crescătoare, separate de asemenea prin exact un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n , m ≤ 100.000</code></li>\n\t<li>elementele celor două mulțimi vor fi mai mici decât <code>1.000.000.000</code></li>\n\t<li>cele două mulțimi date au cel puțin un element comun</li>\n</ul>",
      "text": "1 ≤ n , m ≤ 100.000 elementele celor două mulțimi vor fi mai mici decât 1.000.000.000 cele două mulțimi date au cel puțin un element comun"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n3 6 8 9 12\n7\n2 5 6 7 8 9 11</pre><p><strong>Ieșire</strong></p><pre>2 3 5 6 7 8 9 11 12 \n6 8 9 </pre>",
      "text": "Intrare5 3 6 8 9 12 7 2 5 6 7 8 9 11Ieșire2 3 5 6 7 8 9 11 12 6 8 9"
    }
  ],
  "examples": [
    {
      "input": "5\n3 6 8 9 12\n7\n2 5 6 7 8 9 11",
      "output": "2 3 5 6 7 8 9 11 12 \n6 8 9"
    }
  ],
