  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Determinaţi numărul format din ultimele <code>4</code> cifre ale numărului de <code>K</code>-şiruri distincte cu proprietatea că fiecare dintre ele are cel mai mic multiplu comun al termenilor egal cu <code>N</code>.</p>",
      "text": "Determinaţi numărul format din ultimele 4 cifre ale numărului de K-şiruri distincte cu proprietatea că fiecare dintre ele are cel mai mic multiplu comun al termenilor egal cu N."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>multiplu1.in</code> conține pe prima linie cele două numere <code>N</code> şi <code>K</code> separate printr-un singur spaţiu.</p>",
      "text": "Fișierul de intrare multiplu1.in conține pe prima linie cele două numere N şi K separate printr-un singur spaţiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>multiplu1.out</code> va conține pe prima linie un singur număr natural reprezentând rezultatul cerut.</p>",
      "text": "Fișierul de ieșire multiplu1.out va conține pe prima linie un singur număr natural reprezentând rezultatul cerut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 &lt; N ≤ 1 000 000 000</code></li>\n\t<li><code>0 &lt; K ≤ 1 000 000 000</code></li>\n</ul>",
      "text": "0 < N ≤ 1 000 000 000 0 < K ≤ 1 000 000 000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>multiplu1.in</code></p><pre>5 2</pre><p><code>multiplu1.out</code></p><pre>3</pre>",
      "text": "multiplu1.in5 2multiplu1.out3"
    },
    {
      "title": "Explicație",
      "html": "<p>Cele trei <code>2</code>-şiruri cu cel mai mic multiplu comun al termenilor egal cu <code>5</code> sunt&nbsp;: <code>(1,5)</code>, <code>(5,1)</code> şi <code>(5,5)</code>.</p>",
      "text": "Cele trei 2-şiruri cu cel mai mic multiplu comun al termenilor egal cu 5 sunt : (1,5), (5,1) şi (5,5)."
    }
  ],
  "examples": [],
  "constraints": [
    "0 < N ≤ 1 000 000 000",
    "0 < K ≤ 1 000 000 000"
