  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un șir cu <code>n</code> elemente numere naturale. Să se sorteze elementele din șir în ordine crescătoare a forței, iar acele elemente care au aceeași forță să apară în ordine inversă decât apăreau inițial în șir.</p>",
      "text": "Se dă un șir cu n elemente numere naturale. Să se sorteze elementele din șir în ordine crescătoare a forței, iar acele elemente care au aceeași forță să apară în ordine inversă decât apăreau inițial în șir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>forta.in</code> conține pe prima linie <code>n</code>, numărul de elemente din șir, iar pe a doua linie <code>n</code> numere naturale separate prin câte un spațiu, reprezentând elementele șirului.</p>",
      "text": "Fișierul de intrare forta.in conține pe prima linie n, numărul de elemente din șir, iar pe a doua linie n numere naturale separate prin câte un spațiu, reprezentând elementele șirului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>forta.out</code> va conține pe prima linie, separate prin câte un spațiu, elementele șirului în ordinea cerută.</p>",
      "text": "Fișierul de ieșire forta.out va conține pe prima linie, separate prin câte un spațiu, elementele șirului în ordinea cerută."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n\t<li>elementele șirului sunt numere naturale mai mici sau egale cu <code>10</code><sup><code>18</code></sup></li>\n\t<li>pentru teste în valoare de 30 de puncte elementele șirului vor avea forțe distincte</li>\n</ul>",
      "text": "1 ≤ n ≤ 1000 elementele șirului sunt numere naturale mai mici sau egale cu 1018 pentru teste în valoare de 30 de puncte elementele șirului vor avea forțe distincte"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>forta.in</code></p><pre>4\n123 121 12314 1234</pre><p><code>forta.out</code></p><pre>121 123 1234 12314</pre>",
      "text": "forta.in4 123 121 12314 1234forta.out121 123 1234 12314"
    }
  ],
