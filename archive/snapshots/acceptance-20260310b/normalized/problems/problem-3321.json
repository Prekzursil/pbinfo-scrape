  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Regele dorește să afle în câte moduri poate plasa soldații în zonele fără turnuri ale regatului astfel încât aceștia să nu fie atacați de turnuri.</p>",
      "text": "Regele dorește să afle în câte moduri poate plasa soldații în zonele fără turnuri ale regatului astfel încât aceștia să nu fie atacați de turnuri."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură dimensiunile <code>n</code> și <code>m</code> ale regatului, numărul de turnuri <code>k</code> și numărul de soldați <code>q</code>. Pe următoarele <code>k</code> linii se află câte două valori, reprezentând coordonatele turnurilor.</p>",
      "text": "Programul citește de la tastatură dimensiunile n și m ale regatului, numărul de turnuri k și numărul de soldați q. Pe următoarele k linii se află câte două valori, reprezentând coordonatele turnurilor."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>p</code>, reprezentând numărul de moduri în care pot fi plasați soldații regelui.</p>",
      "text": "Programul va afișa pe ecran numărul p, reprezentând numărul de moduri în care pot fi plasați soldații regelui."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n , m ≤ 4</code></li>\n\t<li><code>1 ≤ q , k ≤ n*m</code></li>\n\t<li>în cazul în care nu există niciun mod de plasare a soldaților se va afișa <code>0</code></li>\n\t<li>soldații sunt diferiți între ei; două moduri de plasare a soldaților pot să folosească aceleași zone, dar să fie diferite prin ordinea în care sunt plasați soldații în aceste zone.</li>\n</ul>",
      "text": "1 ≤ n , m ≤ 4 1 ≤ q , k ≤ n*m în cazul în care nu există niciun mod de plasare a soldaților se va afișa 0 soldații sunt diferiți între ei; două moduri de plasare a soldaților pot să folosească aceleași zone, dar să fie diferite prin ordinea în care sunt plasați soldații în aceste zone."
    },
    {
      "title": "Exemplu 1:",
      "html": "<p><strong>Intrare</strong></p><pre>3 3 1 1\n2 2</pre><p><strong>Ieșire</strong></p><pre>4</pre><h3>Explicație</h3><p>Zonele neatacate de turnuri au coordonatele <code>(1,1)</code>, <code>(1,3)</code>, <code>(3,1)</code>, <code>(3,3)</code>.</p>",
      "text": "Intrare3 3 1 1 2 2Ieșire4ExplicațieZonele neatacate de turnuri au coordonatele (1,1), (1,3), (3,1), (3,3)."
    },
    {
      "title": "Exemplu 2:",
      "html": "<p><strong>Intrare</strong></p><pre>4 4 1 9\n1 1</pre><p><strong>Ieșire</strong></p><pre>362880</pre><h3>Precizare</h3><p>Acesta este cel mai mare test.</p>",
      "text": "Intrare4 4 1 9 1 1Ieșire362880PrecizareAcesta este cel mai mare test."
    },
    {
      "title": "Exemplu 3:",
      "html": "<p><strong>Intrare</strong></p><pre>3 3 3 4\n1 1\n2 2\n3 3</pre><p><strong>Ieșire</strong></p><pre>0</pre><h3>Explicație</h3><p>Nu au rămas destule zone neatacate de turnuri.</p>",
      "text": "Intrare3 3 3 4 1 1 2 2 3 3Ieșire0ExplicațieNu au rămas destule zone neatacate de turnuri."
    }
  ],
  "examples": [
    {
      "input": "3 3 1 1\n2 2",
      "output": "4",
      "explanation": "Zonele neatacate de turnuri au coordonatele (1,1), (1,3), (3,1), (3,3)."
    },
    {
      "input": "4 4 1 9\n1 1",
      "output": "362880"
