  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un vector cu <code>n</code> elemente. Să se determine numărul de secvențe care au medianul valorilor egal cu <code>k</code>.</p>",
      "text": "Se dă un vector cu n elemente. Să se determine numărul de secvențe care au medianul valorilor egal cu k."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>medians.in</code> contine pe prima linie un număr <code>N</code> reprezentând numărul de elemente din vector și un număr <code>k</code> cu semnificația din enunț. Pe a doua linie se află <code>N</code> elemente , elementele vectorului.</p>",
      "text": "Fișierul de intrare medians.in contine pe prima linie un număr N reprezentând numărul de elemente din vector și un număr k cu semnificația din enunț. Pe a doua linie se află N elemente , elementele vectorului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>medians.out</code> contine pe prima linie răspunsul.</p>",
      "text": "Fișierul de ieșire medians.out contine pe prima linie răspunsul."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>N ≤ 100.000</code>, <code>K ≤ 1.000.000.000</code></li>\n\t<li>Pentru teste in valoare de 10 puncte, <code>N ≤ 100</code>.</li>\n\t<li>Pentru alte teste in valoare de 10 puncte, <code>N ≤ 1000</code>.</li>\n\t<li>Pentru restul de teste se respecta restrictiile initiale.</li>\n\t<li>Prin mediana unui vector de lungime <code>N</code> se intelege elementul de pe pozitia <code>[(N+1)/2]</code> dupa sortare.</li>\n</ul>",
      "text": "N ≤ 100.000, K ≤ 1.000.000.000 Pentru teste in valoare de 10 puncte, N ≤ 100. Pentru alte teste in valoare de 10 puncte, N ≤ 1000. Pentru restul de teste se respecta restrictiile initiale. Prin mediana unui vector de lungime N se intelege elementul de pe pozitia [(N+1)/2] dupa sortare."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>medians.in</code></p><pre>2 2\n1 2</pre><p><code>medians.out</code></p><pre>1</pre><p><code>medians.in</code></p><pre>3 5\n5 1 5 </pre><p><code>medians.out</code></p><pre>3</pre>",
      "text": "medians.in2 2 1 2medians.out1medians.in3 5 5 1 5 medians.out3"
    }
  ],
