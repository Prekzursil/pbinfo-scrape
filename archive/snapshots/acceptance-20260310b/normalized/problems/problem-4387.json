  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un număr natural \\(x\\). Afișează numărul obținut prin dublarea fiecărei cifre a numărului \\(x\\).</p>",
      "text": "Se dă un număr natural \\(x\\). Afișează numărul obținut prin dublarea fiecărei cifre a numărului \\(x\\)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Pe prima linie se va afla numărul natural \\(x\\).</p>",
      "text": "Pe prima linie se va afla numărul natural \\(x\\)."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Pe prima linie se va afișa numărul obținut prin dublarea fiecărei cifre a numărului \\(x\\).</p>",
      "text": "Pe prima linie se va afișa numărul obținut prin dublarea fiecărei cifre a numărului \\(x\\)."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>Pentru toate testele, se respectă \\(1 \\le x \\le 10^9\\)</li>\n\t<li>Subtask 1, <code>70p</code>: \\(1 \\le x \\le 10^4\\)</li>\n\t<li>Subtask 2, <code>30p</code>: restricțiile inițiale</li>\n</ul>",
      "text": "Pentru toate testele, se respectă \\(1 \\le x \\le 10^9\\) Subtask 1, 70p: \\(1 \\le x \\le 10^4\\) Subtask 2, 30p: restricțiile inițiale"
    },
    {
      "title": "Exemplu 1:",
      "html": "<p><strong>Intrare</strong></p><pre>102</pre><p><strong>Ieșire</strong></p><pre>110022</pre>",
