  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau trei numere naturale <code>n a b</code>, <code>1 ≤ a &lt; b &lt; n</code>. Să se determine o modalitate de a-l scrie pe <code>n</code> ca sumă de termeni egali cu <code>a</code> sau <code>b</code> în care numărul de termeni egali cu <code>a</code> este minim.</p>",
      "text": "Se dau trei numere naturale n a b, 1 ≤ a < b < n. Să se determine o modalitate de a-l scrie pe n ca sumă de termeni egali cu a sau b în care numărul de termeni egali cu a este minim."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n a b</code>.</p>",
      "text": "Programul citește de la tastatură numerele n a b."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran un șir de numere ordonate crescător, reprezentând termenii ceruți.</p>",
      "text": "Programul va afișa pe ecran un șir de numere ordonate crescător, reprezentând termenii ceruți."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n\t<li><code>1 ≤ a &lt; b ≤ 1000</code></li>\n\t<li>pentru toate datele de test <code>n</code> poate fi scris ca sumă de termeni egali cu <code>a</code> și <code>b</code>.</li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000 1 ≤ a < b ≤ 1000 pentru toate datele de test n poate fi scris ca sumă de termeni egali cu a și b."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>44 3 5</pre><p><strong>Ieșire</strong></p><pre>3 3 3 5 5 5 5 5 5 5</pre>",
      "text": "Intrare44 3 5Ieșire3 3 3 5 5 5 5 5 5 5"
    }
  ],
  "examples": [
    {
      "input": "44 3 5",
      "output": "3 3 3 5 5 5 5 5 5 5"
    }
  ],
