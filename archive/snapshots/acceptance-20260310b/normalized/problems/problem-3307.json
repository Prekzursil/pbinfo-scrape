  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un numar <code>n</code> și <code>n</code> perechi de numere naturale <code>a</code> și <code>b</code>.Să se determine dacă <code>a/b</code> este fracție finită sau periodică, iar dacă este fracție periodică să se determine dacă este fracție periodică simplă sau mixtă.</p>",
      "text": "Se dă un numar n și n perechi de numere naturale a și b.Să se determine dacă a/b este fracție finită sau periodică, iar dacă este fracție periodică să se determine dacă este fracție periodică simplă sau mixtă."
    },
    {
      "title": "Date de intrare.",
      "html": "<p>Se citește de la tastatură un număr <code>n</code> și apoi <code>n</code> perechi de numere <code>a b</code>.</p>",
      "text": "Se citește de la tastatură un număr n și apoi n perechi de numere a b."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul afișează pentru fiecare pereche citită, pe câte un rând, mesajul <code>fractie finita</code>, <code>fractie periodica simpla</code> sau <code>fractie periodica mixta</code> în funcție de caz.</p>",
      "text": "Programul afișează pentru fiecare pereche citită, pe câte un rând, mesajul fractie finita, fractie periodica simpla sau fractie periodica mixta în funcție de caz."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n\t<li><code>1 ≤ a , b ≤ 1.000.000.000</code>,  numere naturale</li>\n</ul>",
      "text": "1 ≤ n ≤ 100 1 ≤ a , b ≤ 1.000.000.000, numere naturale"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n2 5\n7 90\n90 270\n50 81000\n9 3</pre><p><strong>Ieșire</strong></p><pre>fractie finita\nfractie periodica mixta\nfractie periodica simpla\nfractie periodica mixta\nfractie finita</pre>",
      "text": "Intrare5 2 5 7 90 90 270 50 81000 9 3Ieșirefractie finita fractie periodica mixta fractie periodica simpla fractie periodica mixta fractie finita"
    }
  ],
  "examples": [
    {
      "input": "5\n2 5\n7 90\n90 270\n50 81000\n9 3",
      "output": "fractie finita\nfractie periodica mixta\nfractie periodica simpla\nfractie periodica mixta\nfractie finita"
    }
  ],
