  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Știind <code>x</code> și <code>y</code>, coordonatele inițiale ale focului și <code>n</code> și <code>m</code>, dimensiunile pădurii, ajutați pădurarii să determine numărul de zile după care va fi afectat fiecare copac al pădurii.</p>",
      "text": "Știind x și y, coordonatele inițiale ale focului și n și m, dimensiunile pădurii, ajutați pădurarii să determine numărul de zile după care va fi afectat fiecare copac al pădurii."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>x y n m</code>, cu semnificația de mai sus.</p>",
      "text": "Programul citește de la tastatură numerele x y n m, cu semnificația de mai sus."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <code>n•m</code> numere, reprezentând numărul de zile după care va fi afectat fiecare copac al pădurii.</p>",
      "text": "Programul va afișa pe ecran n•m numere, reprezentând numărul de zile după care va fi afectat fiecare copac al pădurii."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ x ≤ n ≤ 1.000</code></li>\n\t<li><code>1 ≤ y ≤ m ≤ 1.000</code></li>\n</ul>",
      "text": "1 ≤ x ≤ n ≤ 1.000 1 ≤ y ≤ m ≤ 1.000"
    },
    {
      "title": "Exemplu 1:",
      "html": "<p><strong>Intrare</strong></p><pre>2 2 4 5</pre><p><strong>Ieșire</strong></p><pre>3 2 3 4 5\n2 1 2 3 4\n3 2 3 4 5\n4 3 4 5 6</pre>",
      "text": "Intrare2 2 4 5Ieșire3 2 3 4 5 2 1 2 3 4 3 2 3 4 5 4 3 4 5 6"
    },
    {
      "title": "Exemplu 2:",
      "html": "<p><strong>Intrare</strong></p><pre>3 3 9 9</pre><p><strong>Ieșire</strong></p><pre>5 4 3 4 5 6 7 8 9\n4 3 2 3 4 5 6 7 8\n3 2 1 2 3 4 5 6 7\n4 3 2 3 4 5 6 7 8\n5 4 3 4 5 6 7 8 9\n6 5 4 5 6 7 8 9 10\n7 6 5 6 7 8 9 10 11\n8 7 6 7 8 9 10 11 12\n9 8 7 8 9 10 11 12 13</pre>",
      "text": "Intrare3 3 9 9Ieșire5 4 3 4 5 6 7 8 9 4 3 2 3 4 5 6 7 8 3 2 1 2 3 4 5 6 7 4 3 2 3 4 5 6 7 8 5 4 3 4 5 6 7 8 9 6 5 4 5 6 7 8 9 10 7 6 5 6 7 8 9 10 11 8 7 6 7 8 9 10 11 12 9 8 7 8 9 10 11 12 13"
    }
