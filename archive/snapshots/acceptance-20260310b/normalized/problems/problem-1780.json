  "tags": [
    "Descompunere in factori",
    "Factorialul unui numar"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau două numere naturale <code>n</code> și <code>m</code>, <code>m</code> fiind prim. Să se afle cel mai mare număr natural <code>x</code>, astfel încât numărul \\(\\frac{n!}{m^{x}}\\) să fie natural.</p>",
      "text": "Se dau două numere naturale n și m, m fiind prim. Să se afle cel mai mare număr natural x, astfel încât numărul \\(\\frac{n!}{m^{x}}\\) să fie natural."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> si <code>m</code>.</p>",
      "text": "Programul citește de la tastatură numerele n si m."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numarul <code>x</code>.</p>",
      "text": "Programul va afișa pe ecran numarul x."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ m ≤ n ≤ 10000</code></li>\n\t<li><code>m</code> este prim.</li>\n</ul>",
      "text": "2 ≤ m ≤ n ≤ 10000 m este prim."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 5</pre><p><strong>Ieșire</strong></p><pre>1</pre><h3>Explicație</h3><p><code>5! = 120</code>,  <code>120 = 5 * 2 * 2 * 2 * 3</code>.</p>",
      "text": "Intrare5 5Ieșire1Explicație5! = 120, 120 = 5 * 2 * 2 * 2 * 3."
    }
  ],
  "examples": [
    {
      "input": "5 5",
      "output": "1",
      "explanation": "5! = 120, 120 = 5 * 2 * 2 * 2 * 3."
    }
  ],
  "constraints": [
    "2 ≤ m ≤ n ≤ 10000",
    "m este prim."
  ],
