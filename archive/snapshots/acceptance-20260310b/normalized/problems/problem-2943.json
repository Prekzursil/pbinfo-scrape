  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine numărul submatricelor care au suma mai mică sau egală cu <code>T</code>.</p>",
      "text": "Să se determine numărul submatricelor care au suma mai mică sau egală cu T."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură, în această ordine, numerele <code>T n A B C D</code>. Elementele matricei se vor genera după formula: <code>a[i,j] = (A * i + B * j + C) % D</code>.</p>",
      "text": "Programul citește de la tastatură, în această ordine, numerele T n A B C D. Elementele matricei se vor genera după formula: a[i,j] = (A * i + B * j + C) % D."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>S</code>, reprezentând numărul submatricelor de sumă mai mică sau egală cu <code>T</code>.</p>",
      "text": "Programul va afișa pe ecran numărul S, reprezentând numărul submatricelor de sumă mai mică sau egală cu T."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n, A, B, C, D ≤ 400</code></li>\n\t<li><code>1 ≤ T ≤ 30.000</code></li>\n\t<li>O submatrice poate fi formată dintr-un singur element (este o submatrice cu o linie și o coloană).</li>\n</ul>",
      "text": "1 ≤ n, A, B, C, D ≤ 400 1 ≤ T ≤ 30.000 O submatrice poate fi formată dintr-un singur element (este o submatrice cu o linie și o coloană)."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>10 2 1 1 1 43</pre><p><strong>Ieșire</strong></p><pre>8</pre><h3>Explicație</h3><p>Matricea generată este:<br>\n<code>3 4</code><br>\n<code>4 5</code><br>\nSingura submatrice care nu are suma mai mică sau egală cu <code>T</code> este doar matricea întreagă.</p>",
      "text": "Intrare10 2 1 1 1 43Ieșire8ExplicațieMatricea generată este: 3 4 4 5 Singura submatrice care nu are suma mai mică sau egală cu T este doar matricea întreagă."
    }
  ],
