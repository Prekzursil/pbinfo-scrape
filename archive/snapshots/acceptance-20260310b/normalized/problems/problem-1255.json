  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n - 1</code> numere naturale distincte de la <code>1</code> la <code>n</code>. Să se gaseasca numărul lipsă.</p>",
      "text": "Se dau n - 1 numere naturale distincte de la 1 la n. Să se gaseasca numărul lipsă."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>lipsa.in</code> conține pe prima linie numărul <code>n</code>, iar pe a doua linie <code>n - 1</code> numere naturale separate prin spații.</p>",
      "text": "Fișierul de intrare lipsa.in conține pe prima linie numărul n, iar pe a doua linie n - 1 numere naturale separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>lipsa.out</code> va conține pe prima linie numărul căutat.</p>",
      "text": "Fișierul de ieșire lipsa.out va conține pe prima linie numărul căutat."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 1.000.000</code></li>\n</ul>",
      "text": "2 ≤ n ≤ 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>lipsa.in</code></p><pre>5\n5 3 1 2</pre><p><code>lipsa.out</code></p><pre>4</pre>",
      "text": "lipsa.in5 5 3 1 2lipsa.out4"
    }
  ],
