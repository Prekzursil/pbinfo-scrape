  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine cel mai mare divizor comun al lui <code>x</code> și <code>y</code>.</p>",
      "text": "Să se determine cel mai mare divizor comun al lui x și y."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>jumatate1.in</code> conține pe prima linie numărul <code>n</code>.</p>",
      "text": "Fișierul de intrare jumatate1.in conține pe prima linie numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>jumatate1.out</code> va conține pe prima linie cel mai mare divizor<br>\ncomun al lui <code>x</code> și <code>y</code>.</p>",
      "text": "Fișierul de ieșire jumatate1.out va conține pe prima linie cel mai mare divizor comun al lui x și y."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>Numărul <code>n</code> va avea cel mult <code>16</code> cifre.</li>\n</ul>",
      "text": "Numărul n va avea cel mult 16 cifre."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>jumatate1.in</code></p><pre>88132</pre><p><code>jumatate1.out</code></p><pre>44</pre><h3>Explicație</h3><p>Numărul <code>x</code> este <code>88</code> iar numărul <code>y</code> este <code>132</code>. Cel mai mare divizor comun al lor este <code>44</code>.</p>",
      "text": "jumatate1.in88132jumatate1.out44ExplicațieNumărul x este 88 iar numărul y este 132. Cel mai mare divizor comun al lor este 44."
    }
  ],
