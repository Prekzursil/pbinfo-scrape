  "tags": [
    "Numere prime"
  ],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se scrie un program care citește două numere naturale <code>a</code> și <code>b</code> și determină câte numere prime sunt în intervalul închis determinat de <code>a</code> și <code>b</code>.</p>",
      "text": "Să se scrie un program care citește două numere naturale a și b și determină câte numere prime sunt în intervalul închis determinat de a și b."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>a</code> și <code>b</code>.</p>",
      "text": "Programul citește de la tastatură numerele a și b."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran numărul <code>n</code>, reprezentând numărul de numere prime din intervalul închis determinat de <code>a</code> și <code>b</code>.</p>",
      "text": "Programul afișează pe ecran numărul n, reprezentând numărul de numere prime din intervalul închis determinat de a și b."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; a, b &lt; 100.000</code></li>\n\t<li>numerele citite nu respectă obligatoriu relația <code>a ≤ b</code></li>\n\t<li>un număr natural este <strong>prim</strong> dacă are exact doi divizori distincți: <code>1</code> și el însuși.</li>\n</ul>",
      "text": "0 < a, b < 100.000 numerele citite nu respectă obligatoriu relația a ≤ b un număr natural este prim dacă are exact doi divizori distincți: 1 și el însuși."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>10 20</pre><p><strong>Ieșire</strong></p><pre>4</pre>",
      "text": "Intrare10 20Ieșire4"
    },
    {
      "title": "Explicație",
      "html": "<p>în intervalul <code>[10,20]</code> sunt <code>4</code> numere prime: <code>11</code>, <code>13</code>, <code>17</code>, <code>19</code>.</p>",
      "text": "în intervalul [10,20] sunt 4 numere prime: 11, 13, 17, 19."
    }
  ],
  "examples": [
    {
      "input": "10 20",
      "output": "4"
    }
  ],
