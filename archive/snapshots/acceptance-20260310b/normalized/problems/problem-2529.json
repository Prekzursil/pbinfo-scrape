  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau două șiruri de caractere, litere mici ale alfabetului englez. Să se afișeze cel mai lung subșir comun al lor.</p>",
      "text": "Se dau două șiruri de caractere, litere mici ale alfabetului englez. Să se afișeze cel mai lung subșir comun al lor."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>subsircomunmaximal.in</code> conține cele două șiruri de caractere, unul pe prima linie, unul pe cea de-a doua.</p>",
      "text": "Fișierul de intrare subsircomunmaximal.in conține cele două șiruri de caractere, unul pe prima linie, unul pe cea de-a doua."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>subsircomunmaximal.out</code> va conține pe prima linie un șir de caractere, reprezentând cel mai lung subșir comun al celor două șiruri de caractere.</p>",
      "text": "Fișierul de ieșire subsircomunmaximal.out va conține pe prima linie un șir de caractere, reprezentând cel mai lung subșir comun al celor două șiruri de caractere."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ lungimea unui șir ≤ 1000</code></li>\n\t<li>dacă există mai multe subșiruri comune de lungime maximă, se poate afișa oricare dintre acestea.</li>\n</ul>",
      "text": "1 ≤ lungimea unui șir ≤ 1000 dacă există mai multe subșiruri comune de lungime maximă, se poate afișa oricare dintre acestea."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>subsircomunmaximal.in</code></p><pre>aaabcd\nagahbdert</pre><p><code>subsircomunmaximal.out</code></p><pre>aabd</pre>",
      "text": "subsircomunmaximal.inaaabcd agahbdertsubsircomunmaximal.outaabd"
    }
  ],
