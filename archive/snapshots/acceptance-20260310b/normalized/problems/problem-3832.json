  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se <code>N</code> puncte laticiale, care este distanța Manhattan de buget minimă dintre două puncte de coordonate <code>a b</code> respectiv <code>x y</code> cu proprietatea că <code>a-y &gt;= x-b</code>?</p>",
      "text": "Dându-se N puncte laticiale, care este distanța Manhattan de buget minimă dintre două puncte de coordonate a b respectiv x y cu proprietatea că a-y >= x-b?"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>mman.in</code> conține pe prima linie numărul <code>N</code>, iar pe următoarele <code>n</code> linii se află câte două numere, pe linia <code>i</code> se află coordonatele <code>x</code> respectiv <code>y</code> ale punctului <code>i</code>.</p>",
      "text": "Fișierul de intrare mman.in conține pe prima linie numărul N, iar pe următoarele n linii se află câte două numere, pe linia i se află coordonatele x respectiv y ale punctului i."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>mman.out</code> va conține pe prima linie numărul <code>M</code> reprezentând valoarea cerută.</p>",
      "text": "Fișierul de ieșire mman.out va conține pe prima linie numărul M reprezentând valoarea cerută."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 100.000</code></li>\n\t<li>coordonatele tuturor punctelor aparțin intervalului <code>[-1.000.000.000, 1.000.000.000]</code>.</li>\n\t<li>Distanța Manhattan de buget dintre punctul cu coordonate <code>a b</code> si punctul de coordonate <code>x y</code> este <code>a-x+b-y</code>.</li>\n</ul>",
      "text": "2 ≤ n ≤ 100.000 coordonatele tuturor punctelor aparțin intervalului [-1.000.000.000, 1.000.000.000]. Distanța Manhattan de buget dintre punctul cu coordonate a b si punctul de coordonate x y este a-x+b-y."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>mman.in</code></p><pre>3\n1 1\n2 3\n-1 -1</pre><p><code>mman.out</code></p><pre>3</pre><h3>Explicație</h3><p>Distanța minimă dintre două puncte se obține din punctele cu coordonate <code>1 1</code> și <code>2 3</code>.</p>",
      "text": "mman.in3 1 1 2 3 -1 -1mman.out3ExplicațieDistanța minimă dintre două puncte se obține din punctele cu coordonate 1 1 și 2 3."
    }
  ],
