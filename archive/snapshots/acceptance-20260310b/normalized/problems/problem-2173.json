  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieți un program care calculează numărul de posibilități modulo <code>30011</code> de a împărți morcovi la cei <code>N</code> iepuri știind că orice iepure poate mânca între <code>1</code> și <code>K</code> morcovi și trebuie să mănânce cu cel puțin un morcov mai puțin decât fiecare dintre iepurii care îi sunt subordonați direcți.</p>",
      "text": "Scrieți un program care calculează numărul de posibilități modulo 30011 de a împărți morcovi la cei N iepuri știind că orice iepure poate mânca între 1 și K morcovi și trebuie să mănânce cu cel puțin un morcov mai puțin decât fiecare dintre iepurii care îi sunt subordonați direcți."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>iepuri1.in</code> conține pe prima linie două numere naturale <code>N</code> şi <code>K</code>, separate printr-un spațiu, reprezentând numărul de iepuri, respectiv numărul maxim de morcovi ce pot fi mâncați de un iepure. Pe fiecare din următoarele <code>N-1</code> linii se află câte două numere naturale distincte <code>a</code> și <code>b</code>, cuprinse între <code>1</code> și <code>N</code>, separate printr-un spațiu, cu semnificația că iepurele <code>a</code> este șeful direct al iepurelui <code>b</code>.</p>",
      "text": "Fișierul de intrare iepuri1.in conține pe prima linie două numere naturale N şi K, separate printr-un spațiu, reprezentând numărul de iepuri, respectiv numărul maxim de morcovi ce pot fi mâncați de un iepure. Pe fiecare din următoarele N-1 linii se află câte două numere naturale distincte a și b, cuprinse între 1 și N, separate printr-un spațiu, cu semnificația că iepurele a este șeful direct al iepurelui b."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>iepuri1.out</code> va conține numărul de moduri de a împărți morcovii conform condițiilor specificate în enunț, modulo <code>30011</code>.</p>",
      "text": "Fișierul de ieșire iepuri1.out va conține numărul de moduri de a împărți morcovii conform condițiilor specificate în enunț, modulo 30011."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N, K ≤ 100</code></li>\n\t<li>Numărul ce trebuie scris în fişierul de ieşire va fi afişat modulo <code>30011</code>.</li>\n</ul>",
      "text": "1 ≤ N, K ≤ 100 Numărul ce trebuie scris în fişierul de ieşire va fi afişat modulo 30011."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>iepuri1.in</code></p><pre>9 4\n7 2\n7 3\n7 4\n3 5\n3 6\n5 8\n5 9\n6 1</pre><p><code>iepuri1.out</code></p><pre>9</pre>",
      "text": "iepuri1.in9 4 7 2 7 3 7 4 3 5 3 6 5 8 5 9 6 1iepuri1.out9"
    }
  ],
