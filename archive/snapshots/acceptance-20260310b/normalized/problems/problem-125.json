  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se citeşte un număr natural nenul <code>n</code>, apoi <code>n</code> numere naturale distincte. Să se afişeze, în ordine lexicografică, permutările mulţimii formate din cele <code>n</code> numere citite.</p>",
      "text": "Se citeşte un număr natural nenul n, apoi n numere naturale distincte. Să se afişeze, în ordine lexicografică, permutările mulţimii formate din cele n numere citite."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>permutari2.in</code> conţine pe prima linie numărul <code>n</code>, ia r pe a doua linie <code>n</code> numere naturale.</p>",
      "text": "Fişierul de intrare permutari2.in conţine pe prima linie numărul n, ia r pe a doua linie n numere naturale."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>permutari2.out</code> va conţine pe fiecare linie elementele unei permutări, separate prin câte un spaţiu.</p>",
      "text": "Fişierul de ieşire permutari2.out va conţine pe fiecare linie elementele unei permutări, separate prin câte un spaţiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n &lt; 9</code></li>\n\t<li>cele <code>n</code> numere de pe a doua linie a fişierului de intrare sunt mai mici decât <code>100</code></li>\n</ul>",
      "text": "0 < n < 9 cele n numere de pe a doua linie a fişierului de intrare sunt mai mici decât 100"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>permutari2.in</code></p><pre>3\n4 7 3</pre><p><code>permutari2.out</code></p><pre>3 4 7 \n3 7 4 \n4 3 7 \n4 7 3 \n7 3 4 \n7 4 3 </pre>",
      "text": "permutari2.in3 4 7 3permutari2.out3 4 7 3 7 4 4 3 7 4 7 3 7 3 4 7 4 3"
    }
  ],
  "examples": [],
