  "tags": [
    "Baze de numerație"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă numărul natural <code>n</code>. Calculați <code>2</code><sup><code>n</code></sup>, apoi afișați rezultatul în baza <code>2</code>.</p>",
      "text": "Se dă numărul natural n. Calculați 2n, apoi afișați rezultatul în baza 2."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>2</code><sup><code>n</code></sup>, conform cerinței.</p>",
      "text": "Programul va afișa pe ecran numărul 2n, conform cerinței."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 ≤ n ≤ 1000</code></li>\n</ul>",
      "text": "0 ≤ n ≤ 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>1</pre><p><strong>Ieșire</strong></p><pre>10</pre><h3>Explicație</h3><p><code>2</code><sup><code>1</code></sup><code> = 2 = 10</code><sub><code>(2)</code></sub>.</p>",
      "text": "Intrare1Ieșire10Explicație21 = 2 = 10(2)."
    }
  ],
  "examples": [
    {
      "input": "1",
      "output": "10",
      "explanation": "21 = 2 = 10(2)."
    }
  ],
  "constraints": [
    "0 ≤ n ≤ 1000"
  ],
