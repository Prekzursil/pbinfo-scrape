  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieți un program care determină numărul maxim de școli ce vor primi pachete, precum și câte tablete și laptop-uri se găsesc în fiecare pachet.</p>",
      "text": "Scrieți un program care determină numărul maxim de școli ce vor primi pachete, precum și câte tablete și laptop-uri se găsesc în fiecare pachet."
    },
    {
      "title": "Date de intrare",
      "html": "<p>De pe prima linie din fișierul de intrare  <code>daruri.in</code> se citesc două numere naturale <code>t</code> și <code>l</code> separate printr-un spațiu, având semnificația: <code>t</code> este numărul de tablete și <code>l</code> numărul de laptop-uri pe care le are moșul în stoc.</p>",
      "text": "De pe prima linie din fișierul de intrare daruri.in se citesc două numere naturale t și l separate printr-un spațiu, având semnificația: t este numărul de tablete și l numărul de laptop-uri pe care le are moșul în stoc."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Pe prima linie în fișierul <code>daruri.out</code> se va afișa un număr ce reprezintă numărul maxim de școli ce vor primi daruri de la Moș Crăciun, iar pe următoarea linie se vor afișa două numere separate printr-un spațiu reprezentând numărul de tablete și numărul de laptop-uri care intră în componența unui pachet. Dacă moșul nu reușește să facă cel puțin <code>2</code> pachete, el renunță la ideea sa și în fișierul de ieșire se va afișa pe primul rând <code>0</code>, iar pe al doilea rând <code>0 0</code>.</p>",
      "text": "Pe prima linie în fișierul daruri.out se va afișa un număr ce reprezintă numărul maxim de școli ce vor primi daruri de la Moș Crăciun, iar pe următoarea linie se vor afișa două numere separate printr-un spațiu reprezentând numărul de tablete și numărul de laptop-uri care intră în componența unui pachet. Dacă moșul nu reușește să facă cel puțin 2 pachete, el renunță la ideea sa și în fișierul de ieșire se va afișa pe primul rând 0, iar pe al doilea rând 0 0."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1≤t,l≤1000</code></li>\n</ul>",
      "text": "1≤t,l≤1000"
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>daruri.in</code></p><pre>10 15</pre><p><code>daruri.out</code></p><pre>5\n2 3</pre><h3>Explicație</h3><p>Se pot forma <code>5</code> pachete, fiecare pachet conținând <code>2</code> tablete și <code>3</code> laptopuri.</p>",
      "text": "daruri.in10 15daruri.out5 2 3ExplicațieSe pot forma 5 pachete, fiecare pachet conținând 2 tablete și 3 laptopuri."
    },
    {
      "title": "Exemplul 2",
      "html": "<p><code>daruri.in</code></p><pre>12 25</pre><p><code>daruri.out</code></p><pre>0\n0 0</pre><h3>Explicație</h3><p>Moșul nu reușește să facă cel puțin două pachete.</p>",
      "text": "daruri.in12 25daruri.out0 0 0ExplicațieMoșul nu reușește să facă cel puțin două pachete."
    }
  ],
