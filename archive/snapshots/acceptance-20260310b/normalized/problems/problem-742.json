  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Fie un număr natural <code>a</code> având <code>n</code> cifre. Scrieţi un program care să determine un număr natural <code>x</code> cu proprietatea că este cel mai mic număr mai mare decât <code>a</code>, care are exact aceleaşi cifre ca şi numărul <code>a</code>.</p>",
      "text": "Fie un număr natural a având n cifre. Scrieţi un program care să determine un număr natural x cu proprietatea că este cel mai mic număr mai mare decât a, care are exact aceleaşi cifre ca şi numărul a."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>numar2.in</code> conține două linii: </p><ul>\n\t<li>pe prima linie un număr natural reprezentând valoarea lui <code>n</code>;</li>\n\t<li>pe a doua linie, fără spaţii între ele, <code>n</code> cifre reprezentând numărul <code>a</code>.</li>\n</ul>",
      "text": "Fișierul de intrare numar2.in conține două linii: pe prima linie un număr natural reprezentând valoarea lui n; pe a doua linie, fără spaţii între ele, n cifre reprezentând numărul a."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>numar2.out</code> va conține o singură linie pe care se va afla numărul <code>x</code>.</p>",
      "text": "Fișierul de ieșire numar2.out va conține o singură linie pe care se va afla numărul x."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 5.000.000</code>;</li>\n\t<li>pentru <code>50%</code> dintre teste, <code>n ≤ 1.000.000</code>;</li>\n\t<li>pentru toate datele de test există soluţie.</li>\n</ul>",
      "text": "1 ≤ n ≤ 5.000.000; pentru 50% dintre teste, n ≤ 1.000.000; pentru toate datele de test există soluţie."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>numar2.in</code></p><pre>6\n204924</pre><p><code>numar2.out</code></p><pre>204942</pre>",
      "text": "numar2.in6 204924numar2.out204942"
    },
    {
      "title": "Explicație",
      "html": "<p>Există mai multe numere formate din exact aceleaşi cifre ca şi numărul <code>204924</code> mai mari decât el. Dintre acestea, <code>204942</code> este cel mai mic. </p>",
      "text": "Există mai multe numere formate din exact aceleaşi cifre ca şi numărul 204924 mai mari decât el. Dintre acestea, 204942 este cel mai mic."
    }
  ],
