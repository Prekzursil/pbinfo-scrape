  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând numărul <code>n</code> furnizat de bancă, să se determine numărul <code>TAN</code> obţinut de Petrică.</p>",
      "text": "Cunoscând numărul n furnizat de bancă, să se determine numărul TAN obţinut de Petrică."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul <code>tan.in</code> conţine pe prima linie numărul natural <code>n</code> cu semnificaţia din enunţ.</p>",
      "text": "Fişierul tan.in conţine pe prima linie numărul natural n cu semnificaţia din enunţ."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>tan.out</code> va conţine o singură linie pe care va fi scris numărul <code>TAN</code> cerut.</p>",
      "text": "Fişierul de ieşire tan.out va conţine o singură linie pe care va fi scris numărul TAN cerut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<p>• <code>0 &lt; n &lt; 18*10</code> <sup> <code>18</code> </sup><br>\n• <code>n</code> are cel puţin o cifră pară<br>\n• numărul <code>TAN</code> obţinut nu poate conţine zerouri nesemnificative</p>",
      "text": "• 0 < n < 18*10 18 • n are cel puţin o cifră pară • numărul TAN obţinut nu poate conţine zerouri nesemnificative"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>tan.in</code></p><pre>520</pre><p><code>tan.out</code></p><pre>250</pre><h3>Explicație</h3><p>Cel mai mic număr par format cu cifrele <code>5, 2, 0</code> este <code>250</code>.</p>",
      "text": "tan.in520tan.out250ExplicațieCel mai mic număr par format cu cifrele 5, 2, 0 este 250."
    }
  ],
