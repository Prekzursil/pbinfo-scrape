  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se scrie un program care citește un cuvânt și îl afișează după interschimbarea primei vocale cu ultima consoană.</p>",
      "text": "Să se scrie un program care citește un cuvânt și îl afișează după interschimbarea primei vocale cu ultima consoană."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citeşte de la tastatură un şir de caractere, reprezentând un cuvânt.</p>",
      "text": "Programul citeşte de la tastatură un şir de caractere, reprezentând un cuvânt."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afişează pe ecran cuvântul obținut prin interschimbarea primei vocale cu ultima consoană.</p>",
      "text": "Programul afişează pe ecran cuvântul obținut prin interschimbarea primei vocale cu ultima consoană."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>şirul de caractere citit va conţine cel mult <code>10</code> caractere,  litere mari și mici ale alfabetului englez</li>\n\t<li>se consideră vocale următoarele caractere: <code>a e i o u A E I O U</code>.</li>\n\t<li>dacă cuvântul conține doar vocale sau doar consoane se va afișa <code>IMPOSIBIL</code></li>\n</ul>",
      "text": "şirul de caractere citit va conţine cel mult 10 caractere, litere mari și mici ale alfabetului englez se consideră vocale următoarele caractere: a e i o u A E I O U. dacă cuvântul conține doar vocale sau doar consoane se va afișa IMPOSIBIL"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>PrograM</pre><p><strong>Date de ieşire</strong></p><pre>PrMgrao</pre>",
      "text": "Date de intrarePrograMDate de ieşirePrMgrao"
    }
  ],
  "examples": [
    {
      "input": "PrMgrao",
      "output": ""
    }
  ],
