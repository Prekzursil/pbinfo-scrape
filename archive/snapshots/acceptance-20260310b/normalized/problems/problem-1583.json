  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citesc de la tastatură <code>n</code> numere naturale. Să se determine numărul de numere prime formate din ultimele <code>2</code> cifre ale fiecărui număr.</p>",
      "text": "Se citesc de la tastatură n numere naturale. Să se determine numărul de numere prime formate din ultimele 2 cifre ale fiecărui număr."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>2prim.in</code> conține pe prima linie numărul <code>n</code>, iar pe a doua linie <code>n</code> numere naturale din intervalul <code>[10,10000]</code> separate printr-un spațiu.</p>",
      "text": "Fișierul de intrare 2prim.in conține pe prima linie numărul n, iar pe a doua linie n numere naturale din intervalul [10,10000] separate printr-un spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>2prim.out</code> va conține numărul de numere care au proprietatea de mai sus.</p>",
      "text": "Fișierul de ieșire 2prim.out va conține numărul de numere care au proprietatea de mai sus."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 10000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 10000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>2prim.in</code></p><pre>4 \n218 433 417 513</pre><p><code>2prim.out</code></p><pre>2</pre><h3>Explicație</h3><p><code>2</code><u><code>18</code></u> → <code>18</code> nu este prim<br>\n<code>43</code><u><code>33</code></u> → <code>33</code> nu este prim<br>\n<code>4</code><u><code>17</code></u> → <code>17</code> este prim<br>\n<code>5</code><u><code>13</code></u> → <code>13</code> este prim</p>",
      "text": "2prim.in4 218 433 417 5132prim.out2Explicație218 → 18 nu este prim 4333 → 33 nu este prim 417 → 17 este prim 513 → 13 este prim"
    }
  ],
