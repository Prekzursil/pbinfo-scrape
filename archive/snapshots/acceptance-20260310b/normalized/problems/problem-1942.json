  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se un număr natural <code>N</code>, aflaţi numărul de cicluri Hamiltoniene dintr-un graf complet cu <code>N</code> noduri. </p>",
      "text": "Dându-se un număr natural N, aflaţi numărul de cicluri Hamiltoniene dintr-un graf complet cu N noduri."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>N</code>.</p>",
      "text": "Programul citește de la tastatură numărul N."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul cerut.</p>",
      "text": "Programul va afișa pe ecran numărul cerut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ N ≤ 100</code></li>\n\t<li>două cicluri diferă dacă au cel puțin o muchie diferită</li>\n</ul>",
      "text": "3 ≤ N ≤ 100 două cicluri diferă dacă au cel puțin o muchie diferită"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>3</pre><p><strong>Ieșire</strong></p><pre>1</pre><h3>Explicație</h3><p>Un graf complet cu <code>3</code> noduri are un ciclu Hamiltonian.</p>",
      "text": "Intrare3Ieșire1ExplicațieUn graf complet cu 3 noduri are un ciclu Hamiltonian."
    }
  ],
  "examples": [
