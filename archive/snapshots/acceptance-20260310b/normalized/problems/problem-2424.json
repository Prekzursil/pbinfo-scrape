  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând coordonatele celor <code>n</code> puncte care erau iniţial roşii, aflaţi numărul maxim de puncte roşii care vor exista în final.</p>",
      "text": "Cunoscând coordonatele celor n puncte care erau iniţial roşii, aflaţi numărul maxim de puncte roşii care vor exista în final."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>puncte3.in</code> conține pe prima linie numărul <code>n</code>. Pe următoarele <code>n</code> linii sunt date coordonatele punctelor, separate printr-un singur spaţiu.</p>",
      "text": "Fișierul de intrare puncte3.in conține pe prima linie numărul n. Pe următoarele n linii sunt date coordonatele punctelor, separate printr-un singur spaţiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>puncte3.out</code> va conţine o singură linie pe care se află numărul maxim de puncte roşii existente în final.</p>",
      "text": "Fișierul de ieșire puncte3.out va conţine o singură linie pe care se află numărul maxim de puncte roşii existente în final."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 ≤ n ≤ 100000</code></li>\n\t<li>coordonatele sunt numere întregi din intervalul <code>[0,1000]</code></li>\n</ul>",
      "text": "0 ≤ n ≤ 100000 coordonatele sunt numere întregi din intervalul [0,1000]"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>puncte3.in</code></p><pre>4\n0 2\n3 1\n1 4\n4 4</pre><p><code>puncte3.out</code></p><pre>12</pre><h3>Explicație</h3><p><img alt=\"\" src=\"/resurse/16a4b0/puncte3.jpg\"></p>",
      "text": "puncte3.in4 0 2 3 1 1 4 4 4puncte3.out12Explicație"
    }
  ],
