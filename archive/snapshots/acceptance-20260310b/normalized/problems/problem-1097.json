  "tags": [],
  "sections": [
    {
      "title": "Cerinţă",
      "html": "<p>Cunoscând codificarea unei placări corecte a suprafeţei date să se obţină imaginea acestei placări (matricea de valori corespunzătoare codificării suprafeţei).</p>",
      "text": "Cunoscând codificarea unei placări corecte a suprafeţei date să se obţină imaginea acestei placări (matricea de valori corespunzătoare codificării suprafeţei)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>placare.in</code> are următoarea structură:</p><ul>\n\t<li>pe prima linie valorile naturale <code>N  M</code>, separate printr-un spaţiu, unde <code>N</code> este înălţimea suprafeţei, <code>M</code> este lăţimea suprafeţei.</li>\n\t<li>pe fiecare din următoarele <code>N</code> linii se află un şir de valori întregi, separate prin câte un spaţiu, reprezentând codificarea respectivei linii a placării.</li>\n</ul>",
      "text": "Fișierul de intrare placare.in are următoarea structură: pe prima linie valorile naturale N M, separate printr-un spaţiu, unde N este înălţimea suprafeţei, M este lăţimea suprafeţei. pe fiecare din următoarele N linii se află un şir de valori întregi, separate prin câte un spaţiu, reprezentând codificarea respectivei linii a placării."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>În fișierul de ieșire <code>placare.out</code> se va tipări tabloul bidimensional ce reprezintă imaginea placării, compus din <code>N</code> linii, pe fiecare dintre ele aflându-se <code>M</code> valori naturale separate prin câte un spaţiu, cu semnificaţia din enunţ.</p>",
      "text": "În fișierul de ieșire placare.out se va tipări tabloul bidimensional ce reprezintă imaginea placării, compus din N linii, pe fiecare dintre ele aflându-se M valori naturale separate prin câte un spaţiu, cu semnificaţia din enunţ."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N, M ≤ 300</code></li>\n\t<li>pentru 80% din teste, <code>1 ≤ N, M ≤ 100</code></li>\n\t<li>dimensiunea <code>P</code> sau <code>-P</code> a unei plăci este aleasă astfel încât acoperirea obţinută să nu depăşească înălţimea <code>N</code> sau latimea <code>M</code> a suprafeţei.</li>\n\t<li>datele din fişierul de intrare sunt corecte în sensul că reprezintă codificarea unei acoperiri a zonei dreptunghiulare de dimensiuni <code>N</code> şi <code>M</code>.</li>\n</ul>",
      "text": "1 ≤ N, M ≤ 300 pentru 80% din teste, 1 ≤ N, M ≤ 100 dimensiunea P sau -P a unei plăci este aleasă astfel încât acoperirea obţinută să nu depăşească înălţimea N sau latimea M a suprafeţei. datele din fişierul de intrare sunt corecte în sensul că reprezintă codificarea unei acoperiri a zonei dreptunghiulare de dimensiuni N şi M."
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>placare.in</code></p><pre>4 4\n-4 1 1 1\n1 2\n2 1\n3</pre><p><code>placare.out</code></p><pre>4 1 1 1\n4 1 2 2\n4 2 2 1\n4 3 3 3</pre>",
      "text": "placare.in4 4 -4 1 1 1 1 2 2 1 3placare.out4 1 1 1 4 1 2 2 4 2 2 1 4 3 3 3"
    },
    {
      "title": "Explicație",
      "html": "<p>Valoarea <code>-4</code> codifică o placă de înălţime <code>4</code> şi laţime <code>1</code> plasată începând din pătratul de coordonate <code>(1,1)</code> şi pînă în pătratul de coordonate <code>(4,1)</code></p><p>Valoarea <code>3</code> de pe ultima linie a codificării desemnează o placă de lăţime <code>3</code> şi înălţime <code>1</code>, plasată orizontal, începând din pătrăţelul de coordonate <code>(4,2)</code>.</p>",
      "text": "Valoarea -4 codifică o placă de înălţime 4 şi laţime 1 plasată începând din pătratul de coordonate (1,1) şi pînă în pătratul de coordonate (4,1)Valoarea 3 de pe ultima linie a codificării desemnează o placă de lăţime 3 şi înălţime 1, plasată orizontal, începând din pătrăţelul de coordonate (4,2)."
    },
    {
      "title": "Exemplul 2",
      "html": "<p><code>placare.in</code></p><pre>3 2\n-3 -2\n0\n1</pre><p><code>placare.out</code></p><pre>3 2\n3 2\n3 1</pre>",
      "text": "placare.in3 2 -3 -2 0 1placare.out3 2 3 2 3 1"
    }
  ],
  "examples": [],
  "constraints": [
    "1 ≤ N, M ≤ 300",
    "pentru 80% din teste, 1 ≤ N, M ≤ 100",
    "dimensiunea P sau -P a unei plăci este aleasă astfel încât acoperirea obţinută să nu depăşească înălţimea N sau latimea M a suprafeţei.",
    "datele din fişierul de intrare sunt corecte în sensul că reprezintă codificarea unei acoperiri a zonei dreptunghiulare de dimensiuni N şi M."
  ],
