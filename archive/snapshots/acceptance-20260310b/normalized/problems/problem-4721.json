  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se consideră următorul triunghi de numere:</p><pre>         1\n       1 2 1\n     1 2 3 2 1\n   1 2 3 4 3 2 1\n 1 2 3 4 5 4 3 2 1\n....................</pre><p>Să se determine:</p><ol>\n\t<li>Câte numere sunt pe linia <code>n</code>?</li>\n\t<li>De câte ori apare numărul <code>k</code> până la linia <code>n</code>?</li>\n</ol>",
      "text": "Se consideră următorul triunghi de numere: 1 1 2 1 1 2 3 2 1 1 2 3 4 3 2 1 1 2 3 4 5 4 3 2 1 ....................Să se determine: Câte numere sunt pe linia n? De câte ori apare numărul k până la linia n?"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură cerința <code>c</code> apoi numărul <code>n</code>, iar apoi numărul <code>k</code> .</p>",
      "text": "Programul citește de la tastatură cerința c apoi numărul n, iar apoi numărul k ."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran un numărul <code>S</code>, in funcție de cerință.</p>",
      "text": "Programul va afișa pe ecran un numărul S, in funcție de cerință."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ c ≤ 2</code></li>\n\t<li><code>1 ≤ n ≤ 10000</code></li>\n\t<li><code>1 ≤ k ≤ 10000</code></li>\n</ul>",
      "text": "1 ≤ c ≤ 2 1 ≤ n ≤ 10000 1 ≤ k ≤ 10000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>1 5 3</pre><p><strong>Ieșire</strong></p><pre>9</pre><h3>Explicație</h3><p>vezi triunghiul.<br>\n<strong>Intrare</strong></p><pre>2 5 3</pre><p><strong>Ieșire</strong></p><pre>5</pre><h3>Explicație</h3><p>vezi triunghiul.</p>",
      "text": "Intrare1 5 3Ieșire9Explicațievezi triunghiul. Intrare2 5 3Ieșire5Explicațievezi triunghiul."
    }
  ],
  "examples": [
    {
      "input": "2 5 3",
      "output": "5",
      "explanation": "vezi triunghiul."
    }
