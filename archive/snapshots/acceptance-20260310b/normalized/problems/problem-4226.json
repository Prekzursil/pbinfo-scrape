  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Teodora vă roagă sa o ajutați cu intrebările si va recompenseaza cu 100 de puncte. </p>",
      "text": "Teodora vă roagă sa o ajutați cu intrebările si va recompenseaza cu 100 de puncte."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>t</code> ce poate fi <code>1</code> sau <code>2</code>.<br>\nDacă  <code>t</code> este <code>1</code> se vor citi trei numere <code>n</code>, <code>c1</code>, <code>c2</code> cu semnificația din enunț.<br>\nDacă  <code>t</code> este <code>2</code> se vor citi patru numere <code>n</code>, <code>c1</code>, <code>c2</code>, <code>c3</code> cu semnificația din enunț.</p>",
      "text": "Programul citește de la tastatură numărul t ce poate fi 1 sau 2. Dacă t este 1 se vor citi trei numere n, c1, c2 cu semnificația din enunț. Dacă t este 2 se vor citi patru numere n, c1, c2, c3 cu semnificația din enunț."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>ct</code>, reprezentând numărul cerut.</p>",
      "text": "Programul va afișa pe ecran numărul ct, reprezentând numărul cerut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>t</code> poate fi <code>1</code> sau <code>2</code>.</li>\n\t<li><code>1 ≤ n ≤ 1000000000</code></li>\n\t<li><code>2 ≤ c1,c2,c3 ≤9</code></li>\n\t<li>oricare două cifre sunt prime intre ele</li>\n</ul>",
      "text": "t poate fi 1 sau 2. 1 ≤ n ≤ 1000000000 2 ≤ c1,c2,c3 ≤9 oricare două cifre sunt prime intre ele"
    },
    {
      "title": "Exemplu 1:",
      "html": "<p><strong>Intrare</strong></p><pre>1 10 2 3</pre><p><strong>Ieșire</strong></p><pre>3</pre><h3>Explicație</h3><p>Din cele <code>9</code> numere se scad <code>2,3,4,6,8,9</code>.</p>",
      "text": "Intrare1 10 2 3Ieșire3ExplicațieDin cele 9 numere se scad 2,3,4,6,8,9."
    },
    {
      "title": "Exemplu 2:",
      "html": "<p><strong>Intrare</strong></p><pre>2 10 3 5 7</pre><p><strong>Ieșire</strong></p><pre>4</pre><h3>Explicație</h3><p>Din cele <code>9</code> numere se scad <code>3,5,6,7,9</code>.</p>",
      "text": "Intrare2 10 3 5 7Ieșire4ExplicațieDin cele 9 numere se scad 3,5,6,7,9."
    }
  ],
