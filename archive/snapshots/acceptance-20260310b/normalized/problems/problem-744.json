  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Determinaţi numărul de variante distincte de acordare a recompenselor de către împăratul Napoleon.</p>",
      "text": "Determinaţi numărul de variante distincte de acordare a recompenselor de către împăratul Napoleon."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>rec.in</code> conține pe prima linie trei numere naturale <code>S</code>, <code>N</code> şi <code>F</code>, separate printr-un singur spaţiu, cu semnificaţia din enunţ. </p>",
      "text": "Fișierul de intrare rec.in conține pe prima linie trei numere naturale S, N şi F, separate printr-un singur spaţiu, cu semnificaţia din enunţ."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>rec.out</code> va conține pe prima linie un singur număr natural, reprezentând numărul de variante distincte de premiere.</p>",
      "text": "Fișierul de ieșire rec.out va conține pe prima linie un singur număr natural, reprezentând numărul de variante distincte de premiere."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ F ≤ S ≤ 400</code></li>\n\t<li><code>1 ≤ N ≤ 50</code></li>\n\t<li>Pentru <code>20%</code> din teste <code>S ≤ 80</code></li>\n\t<li>Pentru <code>80%</code> din teste <code>S ≤ 150</code></li>\n</ul>",
      "text": "2 ≤ F ≤ S ≤ 400 1 ≤ N ≤ 50 Pentru 20% din teste S ≤ 80 Pentru 80% din teste S ≤ 150"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>rec.in</code></p><pre>9 3 2</pre><p><code>rec.out</code></p><pre>3</pre>",
      "text": "rec.in9 3 2rec.out3"
    },
    {
      "title": "Explicație",
      "html": "<p>Sumele se pot acorda în următoarele variante:</p><p><code>5 2 2</code><br>\n<code>4 3 2</code><br>\n<code>3 3 3</code></p><p>Cea mai mai mică sumă platită unui general este <code>2</code>.</p>",
      "text": "Sumele se pot acorda în următoarele variante:5 2 2 4 3 2 3 3 3Cea mai mai mică sumă platită unui general este 2."
    }
  ],
