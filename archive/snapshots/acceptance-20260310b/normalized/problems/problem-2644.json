  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Într-o școală sunt <code>n</code> clase, fiecare având un număr diferit de elevi. Școală primește <code>m</code> pachete cu cărți, fiecare cu un număr diferit de cărți. Pentru ca o clasa să primească un pachet, numărul elevilor din acea clasa trebuie să fie egal cu numărul cărților din pachet. Să se determine câte clase primesc un pachet de cărți.</p>",
      "text": "Într-o școală sunt n clase, fiecare având un număr diferit de elevi. Școală primește m pachete cu cărți, fiecare cu un număr diferit de cărți. Pentru ca o clasa să primească un pachet, numărul elevilor din acea clasa trebuie să fie egal cu numărul cărților din pachet. Să se determine câte clase primesc un pachet de cărți."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>clase.in</code> va avea pe prima linie numărul <code>n</code>, iar pe următoarea linie <code>n</code> numere naturale ordonate crescător, separate prin spații, reprezentând numărul de elevi din fiecare clasa. Pe următoarea linie numărul <code>m</code>, și pe următoarea linie <code>m</code> numere, reprezentând numărul de cărți din fiecare pachet.</p>",
      "text": "Fișierul de intrare clase.in va avea pe prima linie numărul n, iar pe următoarea linie n numere naturale ordonate crescător, separate prin spații, reprezentând numărul de elevi din fiecare clasa. Pe următoarea linie numărul m, și pe următoarea linie m numere, reprezentând numărul de cărți din fiecare pachet."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>clase.out</code> va conține pe prima linie numărul de clase care primesc pachete cu cărți.</p>",
      "text": "Fișierul de ieșire clase.out va conține pe prima linie numărul de clase care primesc pachete cu cărți."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n, m ≤ 10.000</code></li>\n\t<li>într-un pachet sunt maximum <code>1.000.000.000.000</code> cărți.</li>\n\t<li>într-o clasă sunt maximum <code>1.000.000.000.000</code> elevi.</li>\n</ul>",
      "text": "1 ≤ n, m ≤ 10.000 într-un pachet sunt maximum 1.000.000.000.000 cărți. într-o clasă sunt maximum 1.000.000.000.000 elevi."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>clase.in</code></p><pre>5\n16 17 20 24 30\n4\n78 20 17 74</pre><p><code>clase.out</code></p><pre>2</pre><h3>Explicație</h3><p>Doar clasa cu <code>20</code> de elevi și cea cu <code>17</code> elevi vor primi pachete cu cărți.</p>",
      "text": "clase.in5 16 17 20 24 30 4 78 20 17 74clase.out2ExplicațieDoar clasa cu 20 de elevi și cea cu 17 elevi vor primi pachete cu cărți."
    }
  ],
