  ],
  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dă un vector cu  <code>n</code> elemente numere  naturale. Să se șteargă din vector toate elementele pare.</p>",
      "text": "Se dă un vector cu n elemente numere naturale. Să se șteargă din vector toate elementele pare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale, separate prin spaţii, reprezentând elementele vectorul.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale, separate prin spaţii, reprezentând elementele vectorul."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran, separate prin spații, elementele vectorului obținut prin ștergerea elementelor pare.</p>",
      "text": "Programul afișează pe ecran, separate prin spații, elementele vectorului obținut prin ștergerea elementelor pare."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n ≤ 1000</code></li>\n\t<li>elementele vectorului vor fi mai mici decât <code>2</code><sup><code>30</code></sup></li>\n</ul>",
      "text": "0 < n ≤ 1000 elementele vectorului vor fi mai mici decât 230"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>7\n7 9 4 2 1 6 5 </pre><p><strong>Ieșire</strong></p><pre>7 9 1 5</pre>",
      "text": "Intrare7 7 9 4 2 1 6 5 Ieșire7 9 1 5"
    }
  ],
  "examples": [
    {
      "input": "7\n7 9 4 2 1 6 5",
      "output": "7 9 1 5"
    }
  ],
