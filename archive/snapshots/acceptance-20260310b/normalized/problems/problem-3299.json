  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se pădurea moștenită de Fibocel sub forma unui dreptunghi cu <code>N</code> linii și <code>M</code> coloane având doar valori de <code>0</code> și <code>1</code>, unde <code>0</code> înseamnă suprafață fără copac iar <code>1</code> înseamnă suprafață cu copac, spuneți câte pădurici se regăsesc în interiorul pădurii moștenite.</p>",
      "text": "Dându-se pădurea moștenită de Fibocel sub forma unui dreptunghi cu N linii și M coloane având doar valori de 0 și 1, unde 0 înseamnă suprafață fără copac iar 1 înseamnă suprafață cu copac, spuneți câte pădurici se regăsesc în interiorul pădurii moștenite."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>mostenire.in</code> conține pe prima linie două numere naturale <code>N</code> și <code>M</code> separate prin exact un spațiu reprezentând dimensiunea pădurii. Pe fiecare dintre următoarele <code>N</code> linii se găsesc exact <code>M</code> caractere fără spațiu între ele, având doar valori de <code>0</code> și de <code>1</code>.</p>",
      "text": "Fișierul de intrare mostenire.in conține pe prima linie două numere naturale N și M separate prin exact un spațiu reprezentând dimensiunea pădurii. Pe fiecare dintre următoarele N linii se găsesc exact M caractere fără spațiu între ele, având doar valori de 0 și de 1."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>mostenire.out</code> va conține un număr reprezentând răspunsul cerut de Fibocel.</p>",
      "text": "Fișierul de ieșire mostenire.out va conține un număr reprezentând răspunsul cerut de Fibocel."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 100</code></li>\n\t<li><code>1 ≤ M ≤ 1000</code></li>\n\t<li>Păduricile se pot intersecta între ele.</li>\n\t<li>Pentru 15% dintre teste <code>N, M ≤ 30</code>.</li>\n\t<li>Pentru alte 35% dintre teste, <code>M ≤ 100</code>.</li>\n</ul>",
      "text": "1 ≤ N ≤ 100 1 ≤ M ≤ 1000 Păduricile se pot intersecta între ele. Pentru 15% dintre teste N, M ≤ 30. Pentru alte 35% dintre teste, M ≤ 100."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>mostenire.in</code></p><pre>5 4\n1111\n1010\n1111\n1010\n1110</pre><p><code>mostenire.out</code></p><pre>3</pre><h3>Explicație</h3><p>Cele trei pădurici sunt evidențiate mai jos:</p><p><img alt=\"\" src=\"/resurse/16a4b0/mostenire2.jpg\"></p>",
      "text": "mostenire.in5 4 1111 1010 1111 1010 1110mostenire.out3ExplicațieCele trei pădurici sunt evidențiate mai jos:"
    }
  ],
