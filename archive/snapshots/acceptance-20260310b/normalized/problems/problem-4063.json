  "tags": [
    "smaller-to-larger tehnique",
    "set"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Avem în cartier un arbore cu nodurile colorate și cu rădăcina nodul <code>1</code>. Pentru fiecare nod <code>i</code> al arborelui să se afișeze câte culori distincte sunt în subarborele cu rădăcina în <code>i</code>.</p>",
      "text": "Avem în cartier un arbore cu nodurile colorate și cu rădăcina nodul 1. Pentru fiecare nod i al arborelui să se afișeze câte culori distincte sunt în subarborele cu rădăcina în i."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, reprezentând numărul de noduri al arborelui. Pe a doua linie se vor afla <code>n</code> valori, cea de a <code>i</code> reprezentând culoarea nodului <code>i</code>. Urmează <code>n-1</code> linii, pe fiecare linie aflânduse <code>2</code> numere <code>a b</code> indicând faptul ca între <code>a</code> și <code>b</code> este muchie.</p>",
      "text": "Programul citește de la tastatură numărul n, reprezentând numărul de noduri al arborelui. Pe a doua linie se vor afla n valori, cea de a i reprezentând culoarea nodului i. Urmează n-1 linii, pe fiecare linie aflânduse 2 numere a b indicând faptul ca între a și b este muchie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <code>n</code> numere, cel de al <code>i</code>-lea fiind numărul de culori distincte din subarborele cu rădăcina în <code>i</code>.</p>",
      "text": "Programul va afișa pe ecran n numere, cel de al i-lea fiind numărul de culori distincte din subarborele cu rădăcina în i."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 200.000</code></li>\n\t<li>Culorile arborelui sunt numere naturale mai mici sau egale cu <code>1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 200.000 Culorile arborelui sunt numere naturale mai mici sau egale cu 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n2 3 2 2 1\n1 2\n1 3\n3 4\n3 5</pre><p><strong>Ieșire</strong></p><pre>3 1 2 1 1</pre>",
      "text": "Intrare5 2 3 2 2 1 1 2 1 3 3 4 3 5Ieșire3 1 2 1 1"
    }
  ],
  "examples": [
    {
      "input": "5\n2 3 2 2 1\n1 2\n1 3\n3 4\n3 5",
      "output": "3 1 2 1 1"
    }
  ],
