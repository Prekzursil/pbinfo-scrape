  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citește un număr natural, <code>n</code> (<code>n≥10</code>) și se cere să se scrie numărul obținut din <code>n</code> prin înlocuirea fiecărei secvențe <code>25</code> cu câte o secvență <code>26</code>. Dacă nu se înlocuiește nicio secvență, se scrie numărul nemodificat.</p>",
      "text": "Se citește un număr natural, n (n≥10) și se cere să se scrie numărul obținut din n prin înlocuirea fiecărei secvențe 25 cu câte o secvență 26. Dacă nu se înlocuiește nicio secvență, se scrie numărul nemodificat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatura numărul natural <code>n</code>.</p>",
      "text": "Programul citește de la tastatura numărul natural n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul afișează pe ecran numărul natural <code>n</code>, după transformare.</p>",
      "text": "Programul afișează pe ecran numărul natural n, după transformare."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>10 ≤ n ≤ 2000000000</code></li>\n</ul>",
      "text": "10 ≤ n ≤ 2000000000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>202535255</pre><p><strong>Ieșire</strong></p><pre>202635265</pre>",
      "text": "Intrare202535255Ieșire202635265"
    }
  ],
  "examples": [
    {
      "input": "202535255",
      "output": "202635265"
    }
  ],
  "constraints": [
    "10 ≤ n ≤ 2000000000"
  ],
