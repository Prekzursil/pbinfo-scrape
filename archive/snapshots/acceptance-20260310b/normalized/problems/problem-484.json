  ],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dă lista muchiilor unui graf neorientat și două vârfuri <code>p q</code> . Să se determine cel mai scurt lanț cu extremitățile <code>p q</code>.</p>",
      "text": "Se dă lista muchiilor unui graf neorientat și două vârfuri p q . Să se determine cel mai scurt lanț cu extremitățile p q."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>lantminim.in</code> conţine pe prima linie numerele <code>n p q</code>, reprezentând numărul de vârfuri ale grafului și cele două vârfuri date. Fiecare dintre următoarele linii conține câte o pereche de numere <code>i j</code>, cu semnificația că există muchie între <code>i</code> și <code>j</code>.</p>",
      "text": "Fişierul de intrare lantminim.in conţine pe prima linie numerele n p q, reprezentând numărul de vârfuri ale grafului și cele două vârfuri date. Fiecare dintre următoarele linii conține câte o pereche de numere i j, cu semnificația că există muchie între i și j."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>lantminim.out</code> va conţine pe prima linie numărul de vârfuri din lanțul determinat. A doua linie va conține vârfurile din acest lanț, separate prin exact un spațiu.</p>",
      "text": "Fişierul de ieşire lantminim.out va conţine pe prima linie numărul de vârfuri din lanțul determinat. A doua linie va conține vârfurile din acest lanț, separate prin exact un spațiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n\t<li><code>1 ≤ i , j ≤ n</code></li>\n\t<li>în fișierul de intrare muchiile se pot repeta;</li>\n\t<li>orice lanț de lungime minimă cu extremitățile <code>p q</code> este acceptat;</li>\n\t<li>pentru toate datele de test există cel puțin un lanț de la <code>p</code> la <code>q</code>;</li>\n</ul>",
      "text": "1 ≤ n ≤ 100 1 ≤ i , j ≤ n în fișierul de intrare muchiile se pot repeta; orice lanț de lungime minimă cu extremitățile p q este acceptat; pentru toate datele de test există cel puțin un lanț de la p la q;"
    },
    {
      "title": "Exemplu",
      "html": "<p><code>lantminim.in</code></p><pre>6 2 6\n1 2\n1 3\n1 4\n3 4\n4 5\n4 6\n5 6</pre><p><code>lantminim.out</code></p><pre>4\n2 1 4 6 </pre>",
      "text": "lantminim.in6 2 6 1 2 1 3 1 4 3 4 4 5 4 6 5 6lantminim.out4 2 1 4 6"
    }
  ],
