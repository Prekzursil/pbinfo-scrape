  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscându-se numrul <code>n</code> de cărţi şi numărul <code>p</code> de pagini ale fiecărei cărţi să se determine dacă cu cifrele cu care sunt numerotate paginile cărţilor se poate forma un palindrom.</p>",
      "text": "Cunoscându-se numrul n de cărţi şi numărul p de pagini ale fiecărei cărţi să se determine dacă cu cifrele cu care sunt numerotate paginile cărţilor se poate forma un palindrom."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>pagini.in</code> conţine pe prima linie numărul de teste <code>T</code>. Fiecare dintre următoarele <code>T</code> linii conţin câte <code>n+1</code> numere naturale; primul dintre acestea reprezintă numărul de cărţi <code>n</code>, următoarele <code>n</code> valori reprezintă numărul <code>p</code> de pagini pentru fiecare carte dintre cele <code>n</code>.</p>",
      "text": "Fişierul de intrare pagini.in conţine pe prima linie numărul de teste T. Fiecare dintre următoarele T linii conţin câte n+1 numere naturale; primul dintre acestea reprezintă numărul de cărţi n, următoarele n valori reprezintă numărul p de pagini pentru fiecare carte dintre cele n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>pagini.out</code> conţine <code>T</code> linii. Pe fiecare linie se va afla mesajul <code>DA</code> dacă cu cifrele cu care sunt numerotate paginile cărţilor de pe linia respectivă din fişierul de intrare se poate forma un palindrom sau mesajul <code>NU</code> în caz contrar.</p>",
      "text": "Fişierul de ieşire pagini.out conţine T linii. Pe fiecare linie se va afla mesajul DA dacă cu cifrele cu care sunt numerotate paginile cărţilor de pe linia respectivă din fişierul de intrare se poate forma un palindrom sau mesajul NU în caz contrar."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 &lt;= T &lt;= 3</code></li>\n\t<li><code>1 ≤ n ≤ 10.000</code></li>\n\t<li><code>10 ≤ p ≤ 1000</code></li>\n\t<li>Mesajele <code>DA/NU</code> sunt scrise cu majuscule</li>\n\t<li>Numerotarea paginilor începe pentru fiecare carte de la <code>1</code></li>\n</ul>",
      "text": "1 <= T <= 3 1 ≤ n ≤ 10.000 10 ≤ p ≤ 1000 Mesajele DA/NU sunt scrise cu majuscule Numerotarea paginilor începe pentru fiecare carte de la 1"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>pagini.in</code></p><pre>3\n1 19\n2 19 19\n1 18</pre><p><code>pagini.out</code></p><pre>DA\nDA\nNU</pre>",
      "text": "pagini.in3 1 19 2 19 19 1 18pagini.outDA DA NU"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>pagini.in</code></p><pre>1\n6 11 73 243 53 33 604</pre><p><code>pagini.out</code></p><pre>NU</pre>",
      "text": "pagini.in1 6 11 73 243 53 33 604pagini.outNU"
    },
    {
      "title": "Exemplul 3:",
      "html": "<p><code>pagini.in</code></p><pre>2\n5 199 929 325 299 325\n6 11 73 243 53 33 604</pre><p><code>pagini.out</code></p><pre>NU\nNU</pre>",
      "text": "pagini.in2 5 199 929 325 299 325 6 11 73 243 53 33 604pagini.outNU NU"
    }
  ],
