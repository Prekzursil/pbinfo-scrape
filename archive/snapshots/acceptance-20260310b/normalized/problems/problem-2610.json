  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Identificați toate discurile dispensabile din figură.</p>",
      "text": "Identificați toate discurile dispensabile din figură."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>discuri.in</code> conține prima linie numărul <code>N</code> de discuri, iar de pe următoarele <code>N</code> linii câte un număr real reprezentând razele discurilor în ordinea de așezare, câte unul pe linie.</p>",
      "text": "Fișierul de intrare discuri.in conține prima linie numărul N de discuri, iar de pe următoarele N linii câte un număr real reprezentând razele discurilor în ordinea de așezare, câte unul pe linie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>discuri.out</code> va conține pe prima linie numărul <code>K</code> de discuri dispensabile, iar pe următoarele <code>K</code> linii, câte un număr întreg reprezentând, în ordine crescătoare, numerele de ordine ale discurilor considerate, câte unul pe linie.</p>",
      "text": "Fișierul de ieșire discuri.out va conține pe prima linie numărul K de discuri dispensabile, iar pe următoarele K linii, câte un număr întreg reprezentând, în ordine crescătoare, numerele de ordine ale discurilor considerate, câte unul pe linie."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 10 000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 10 000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>discuri.in</code></p><pre>7\n4 \n0.1\n0.5\n3\n0.5\n4\n1</pre><p><code>discuri.out</code></p><pre>3\n2\n3\n5</pre><h3>Explicație</h3><p>Exemplul corespunde imaginii. Discurile hașurate sunt dispensabile.</p>",
      "text": "discuri.in7 4 0.1 0.5 3 0.5 4 1discuri.out3 2 3 5ExplicațieExemplul corespunde imaginii. Discurile hașurate sunt dispensabile."
    }
  ],
