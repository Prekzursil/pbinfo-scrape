  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Răspundeţi la cele <code>Q</code> întrebări.</p>",
      "text": "Răspundeţi la cele Q întrebări."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>divizori1.in</code> conține:</p><ul>\n\t<li>Pe prima linie <code>2</code> numere <code>N</code> și <code>Q</code>, reprezentând dimensiunea lui <code>X</code> şi numărul de întrebări;</li>\n\t<li>Pe a doua linie se găsesc <code>N</code> numere separate prin spaţiu, reprezentând elementele vectorului <code>X</code>.</li>\n\t<li>Pe următoarele <code>Q</code> linii se găsesc cele <code>Q</code> întrebări, reprezentate printr-un număr <code>Q</code><sub><code>i</code></sub> pe fiecare linie.</li>\n</ul>",
      "text": "Fișierul de intrare divizori1.in conține: Pe prima linie 2 numere N și Q, reprezentând dimensiunea lui X şi numărul de întrebări; Pe a doua linie se găsesc N numere separate prin spaţiu, reprezentând elementele vectorului X. Pe următoarele Q linii se găsesc cele Q întrebări, reprezentate printr-un număr Qi pe fiecare linie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>divizori1.out</code> va conține: </p><ul>\n\t<li><code>Q</code> linii, fiecare linie <code>i</code>, reprezentând răspunsul pentru <code>Qi</code>.</li>\n</ul>",
      "text": "Fișierul de ieșire divizori1.out va conține: Q linii, fiecare linie i, reprezentând răspunsul pentru Qi."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N, Q ≤ 10.000</code></li>\n\t<li><code>1 ≤ Qi, Xi ≤ 100.000</code></li>\n</ul>",
      "text": "1 ≤ N, Q ≤ 10.000 1 ≤ Qi, Xi ≤ 100.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>divizori1.in</code></p><pre>5 2\n6 2 3 12 4\n6\n12</pre><p><code>divizori1.out</code></p><pre>3\n5</pre><h3>Explicație</h3><p><code>6</code> conţine <code>3</code> divizori în şir(<code>6, 2, 3</code>).<br>\n<code>12</code> conţine <code>5</code> divizori în şir(<code>6, 2, 3, 12, 4</code>).</p>",
      "text": "divizori1.in5 2 6 2 3 12 4 6 12divizori1.out3 5Explicație6 conţine 3 divizori în şir(6, 2, 3). 12 conţine 5 divizori în şir(6, 2, 3, 12, 4)."
    }
  ],
