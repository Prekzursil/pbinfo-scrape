  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Având la dispoziţie un set de numere pe care le primeşte pentru verificare, Alina trebuie să spună câte dintre acestea sunt numere centrale.</p>",
      "text": "Având la dispoziţie un set de numere pe care le primeşte pentru verificare, Alina trebuie să spună câte dintre acestea sunt numere centrale."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>centrale.in</code> conţine pe prima linie, numărul natural <code>N</code> care reprezintă numărul de numere ce trebuie verificate. Pe următoarea linie se găsesc cele <code>N</code> numere naturale, separate prin câte un spaţiu.</p>",
      "text": "Fişierul de intrare centrale.in conţine pe prima linie, numărul natural N care reprezintă numărul de numere ce trebuie verificate. Pe următoarea linie se găsesc cele N numere naturale, separate prin câte un spaţiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>centrale.out</code> va conţine o singură linie pe care va fi scris numărul de numere centrale găsite între cele <code>N</code> numere ce trebuie verificate.</p>",
      "text": "Fişierul de ieşire centrale.out va conţine o singură linie pe care va fi scris numărul de numere centrale găsite între cele N numere ce trebuie verificate."
    },
    {
      "title": "Restricții și precizări",
      "html": "<p>• <code>1 ≤ N ≤ 100</code><br>\n• Fiecare număr din setul dat are cel puţin <code>3 cifre</code> şi cel mult <code>9 cifre</code></p>",
      "text": "• 1 ≤ N ≤ 100 • Fiecare număr din setul dat are cel puţin 3 cifre şi cel mult 9 cifre"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>centrale.in</code></p><pre>5 \n81318 71117 2258 933 21110</pre><p><code>centrale.out</code></p><pre>3</pre><h3>Explicație</h3><p>Dintre cele <code>5</code> numere din setul dat, sunt <code>3</code> numere centrale: <code>71117, 933 şi 21110</code>.</p>",
      "text": "centrale.in5 81318 71117 2258 933 21110centrale.out3ExplicațieDintre cele 5 numere din setul dat, sunt 3 numere centrale: 71117, 933 şi 21110."
    }
  ],
