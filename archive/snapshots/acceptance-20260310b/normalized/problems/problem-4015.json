  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se un șir de numere naturale, să se determine câte dintre ele apar o singură dată.</p>",
      "text": "Dându-se un șir de numere naturale, să se determine câte dintre ele apar o singură dată."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură cel mult <code>1.000.000</code> de numere naturale.</p>",
      "text": "Programul citește de la tastatură cel mult 1.000.000 de numere naturale."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul de numere care apar o singură dată în șir.</p>",
      "text": "Programul va afișa pe ecran numărul de numere care apar o singură dată în șir."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>numerele citite vor fi mai mici decât <code>200.000</code></li>\n\t<li>în șir sunt cel puțin un număr și cel mult <code>1.000.000</code> de numere naturale</li>\n</ul>",
      "text": "numerele citite vor fi mai mici decât 200.000 în șir sunt cel puțin un număr și cel mult 1.000.000 de numere naturale"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>5 4 3 2 3 3 5 6 4 3 3</pre><p><strong>Ieșire</strong></p><pre>2</pre><h3>Explicație</h3><p>Numerele care apar o singură dată sunt <code>2</code> și <code>6</code>.</p>",
      "text": "Intrare5 4 3 2 3 3 5 6 4 3 3Ieșire2ExplicațieNumerele care apar o singură dată sunt 2 și 6."
    }
  ],
  "examples": [
    {
      "input": "5 4 3 2 3 3 5 6 4 3 3",
      "output": "2",
      "explanation": "Numerele care apar o singură dată sunt 2 și 6."
    }
  ],
  "constraints": [
    "numerele citite vor fi mai mici decât 200.000",
