  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un șir cu <code>n</code> elemente, numere întregi. Folosind metoda MergeSort (Sortare prin interclasare), ordonați crescător elementele acestui șir.</p>",
      "text": "Se dă un șir cu n elemente, numere întregi. Folosind metoda MergeSort (Sortare prin interclasare), ordonați crescător elementele acestui șir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi cele <code>n</code> elemente ale șirului.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi cele n elemente ale șirului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran elementele șirului sortat, separate prin exact un spațiu.</p>",
      "text": "Programul va afișa pe ecran elementele șirului sortat, separate prin exact un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n\t<li>elementele șirului vor fi cuprinse între <code>-1.000.000.000</code> și <code>1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000 elementele șirului vor fi cuprinse între -1.000.000.000 și 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>12\n10 0 -1 -3 1 -4 9 3 -1 -4 3 -4 </pre><p><strong>Ieșire</strong></p><pre>-4 -4 -4 -3 -1 -1 0 1 3 3 9 10</pre>",
      "text": "Intrare12 10 0 -1 -3 1 -4 9 3 -1 -4 3 -4 Ieșire-4 -4 -4 -3 -1 -1 0 1 3 3 9 10"
    }
  ],
  "examples": [
    {
      "input": "12\n10 0 -1 -3 1 -4 9 3 -1 -4 3 -4",
      "output": "-4 -4 -4 -3 -1 -1 0 1 3 3 9 10"
    }
  ],
