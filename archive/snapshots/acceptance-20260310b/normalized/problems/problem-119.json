  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se scrie un program care citește un șir de <code>n</code> numere naturale şi determină cele mai mari două numere din şir.</p>",
      "text": "Să se scrie un program care citește un șir de n numere naturale şi determină cele mai mari două numere din şir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale nenule.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale nenule."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran numerele <code>x y</code>, reprezentând valorile cerute, separate prin exact un spaţiu.</p>",
      "text": "Programul afișează pe ecran numerele x y, reprezentând valorile cerute, separate prin exact un spaţiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 1000</code></li>\n\t<li>cele <code>n</code> numere citite vor fi mai mici decât <code>2.000.000.000</code></li>\n\t<li>valorile afişate respectă relaţia <code>x ≥ y</code></li>\n</ul>",
      "text": "2 ≤ n ≤ 1000 cele n numere citite vor fi mai mici decât 2.000.000.000 valorile afişate respectă relaţia x ≥ y"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n72 30 12 75 17</pre><p><strong>Ieșire</strong></p><pre>75 72</pre>",
      "text": "Intrare5 72 30 12 75 17Ieșire75 72"
    }
  ],
  "examples": [
    {
      "input": "5\n72 30 12 75 17",
      "output": "75 72"
    }
  ],
  "constraints": [
    "2 ≤ n ≤ 1000",
    "cele n numere citite vor fi mai mici decât 2.000.000.000",
