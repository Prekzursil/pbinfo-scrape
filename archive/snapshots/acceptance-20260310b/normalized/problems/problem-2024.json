  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un şir format din <code>n</code> numere naturale nenule. Aflaţi cel mai mic număr natural, diferit de <code>1</code>, care divide un număr maxim de numere din şir.</p>",
      "text": "Se dă un şir format din n numere naturale nenule. Aflaţi cel mai mic număr natural, diferit de 1, care divide un număr maxim de numere din şir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>divizor112.in</code> conține pe prima linie numărul <code>n</code>, iar pe a doua linie <code>n</code> numere naturale nenule separate prin spații.</p>",
      "text": "Fișierul de intrare divizor112.in conține pe prima linie numărul n, iar pe a doua linie n numere naturale nenule separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>divizor112.out</code> va conține pe prima linie cel mai mic număr natural, diferit de <code>1</code>, care divide un număr maxim de numere din şir.</p>",
      "text": "Fișierul de ieșire divizor112.out va conține pe prima linie cel mai mic număr natural, diferit de 1, care divide un număr maxim de numere din şir."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n\t<li>numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât <code>1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000 numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>divizor112.in</code></p><pre>5\n1 2 3 4 5</pre><p><code>divizor112.out</code></p><pre>2</pre><h3>Explicație</h3><p><code>2</code> divide două numere din şir.</p>",
      "text": "divizor112.in5 1 2 3 4 5divizor112.out2Explicație2 divide două numere din şir."
    }
  ],
