  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se ordoneze crescător elementele situate pe poziții pare în vector și descrescător elementele situate pe poziții impare.</p>",
      "text": "Să se ordoneze crescător elementele situate pe poziții pare în vector și descrescător elementele situate pe poziții impare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>halfsort2.in</code> conţine pe prima linie numărul <code>n</code> si pe a doua linie <code>n</code> numere întregi separate prin spaţii.</p>",
      "text": "Fişierul de intrare halfsort2.in conţine pe prima linie numărul n si pe a doua linie n numere întregi separate prin spaţii."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>halfsort2.out</code> va conţine pe prima linie cele <code>n</code> elemente ale vectorului, ordonate conform cerinței, separate printr-un spațiu.</p>",
      "text": "Fişierul de ieşire halfsort2.out va conţine pe prima linie cele n elemente ale vectorului, ordonate conform cerinței, separate printr-un spațiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n ≤ 100</code></li>\n\t<li>valoarea absolută a numerelor de pe a doua linie a fişierului de intrare va fi mai mică decât <code>2</code><sup><code>30</code></sup></li>\n\t<li>indicii elementelor vectorului sunt <code>1,2,...,n</code></li>\n</ul>",
      "text": "0 < n ≤ 100 valoarea absolută a numerelor de pe a doua linie a fişierului de intrare va fi mai mică decât 230 indicii elementelor vectorului sunt 1,2,...,n"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>halfsort2.in</code></p><pre>6\n8 9 9 4 5 7</pre><p><code>halfsort2.out</code></p><pre>9 4 8 7 5 9</pre>",
      "text": "halfsort2.in6 8 9 9 4 5 7halfsort2.out9 4 8 7 5 9"
    }
  ],
