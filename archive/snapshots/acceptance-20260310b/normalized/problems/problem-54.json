  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se citesc numere de la tastatură până la apariția lui zero. Să se determine cea mai mare valoare citită.</p>",
      "text": "Se citesc numere de la tastatură până la apariția lui zero. Să se determine cea mai mare valoare citită."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numere întregi. Citirea se încheie la introducerea valorii <code>0</code>.</p>",
      "text": "Programul citește de la tastatură numere întregi. Citirea se încheie la introducerea valorii 0."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran numărul <code>MAX</code>, reprezentând cea mai mare valoare citită.</p>",
      "text": "Programul afișează pe ecran numărul MAX, reprezentând cea mai mare valoare citită."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>numerele citite aparțin intervalului <code>(-1.000.000; 1.000.000)</code></li>\n\t<li>valoarea zero, care încheie citirile, nu se ia în considerare la determinarea maximului</li>\n\t<li>dacă prima valoare introdusă este zero, se va afișa mesajul <code>NU EXISTA</code></li>\n</ul>",
      "text": "numerele citite aparțin intervalului (-1.000.000; 1.000.000) valoarea zero, care încheie citirile, nu se ia în considerare la determinarea maximului dacă prima valoare introdusă este zero, se va afișa mesajul NU EXISTA"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 6 2 1 0</pre><p><strong>Ieșire</strong></p><pre>6</pre>",
      "text": "Intrare5 6 2 1 0Ieșire6"
    }
  ],
  "examples": [
    {
      "input": "5 6 2 1 0",
      "output": "6"
    }
  ],
  "constraints": [
