  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un vector cu <code>n</code> elemente, numere naturale și două numere <code>t</code> și <code>k</code>. Să se determine câte secvențe din șir au lungimea <code>k</code> și sunt formate din valori mai mici sau egale cu <code>t</code>.</p>",
      "text": "Se dă un vector cu n elemente, numere naturale și două numere t și k. Să se determine câte secvențe din șir au lungimea k și sunt formate din valori mai mici sau egale cu t."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n t k</code>, iar apoi cele <code>n</code> elemente ale vectorului.</p>",
      "text": "Programul citește de la tastatură numerele n t k, iar apoi cele n elemente ale vectorului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran valoarea cerută <code>C</code>.</p>",
      "text": "Programul va afișa pe ecran valoarea cerută C."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ k ≤ n ≤ 100.000</code></li>\n\t<li><code>t</code> și elementele vectorului vor fi mai mici decât <code>1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ k ≤ n ≤ 100.000 t și elementele vectorului vor fi mai mici decât 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>8 5 3\n1 4 3 5 7 3 4 2</pre><p><strong>Ieșire</strong></p><pre>3</pre>",
      "text": "Intrare8 5 3 1 4 3 5 7 3 4 2Ieșire3"
    },
    {
      "title": "Explicație",
      "html": "<p>Cele <code>3</code> secvențe sunt <code>(1 4 3)</code>, <code>(4 3 5)</code> și <code>(3 4 2)</code></p>",
      "text": "Cele 3 secvențe sunt (1 4 3), (4 3 5) și (3 4 2)"
    }
  ],
  "examples": [
    {
      "input": "8 5 3\n1 4 3 5 7 3 4 2",
      "output": "3"
    }
  ],
  "constraints": [
    "1 ≤ k ≤ n ≤ 100.000",
    "t și elementele vectorului vor fi mai mici decât 1.000.000.000"
  ],
