  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un număr natural <code>n</code>. Să se afișeze <code>DA</code> dacă numărul este prim altfel se afișează <code>NU</code>.</p>",
      "text": "Se dă un număr natural n. Să se afișeze DA dacă numărul este prim altfel se afișează NU."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>primexxl.in</code> conține pe prima linie numărul <code>n</code>.</p>",
      "text": "Fișierul de intrare primexxl.in conține pe prima linie numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>primexxl.out</code> va conține pe prima linie <code>DA</code> sau <code>NU</code> după caz.</p>",
      "text": "Fișierul de ieșire primexxl.out va conține pe prima linie DA sau NU după caz."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ nrcif(n) ≤ 1000</code></li>\n</ul>",
      "text": "1 ≤ nrcif(n) ≤ 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>primexxl.in</code></p><pre>5</pre><p><code>primexxl.out</code></p><pre>DA</pre>",
      "text": "primexxl.in5primexxl.outDA"
    }
  ],
