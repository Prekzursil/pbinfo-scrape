  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Fie <code>r</code> un număr real citit de la tastatură, care reprezintă lungimea razei unui cerc. Să se scrie un program care să calculeze și să afișeze aria și perimetrul discului de rază <code>r</code>.</p>",
      "text": "Fie r un număr real citit de la tastatură, care reprezintă lungimea razei unui cerc. Să se scrie un program care să calculeze și să afișeze aria și perimetrul discului de rază r."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul real <code>r</code>.</p>",
      "text": "Programul citește de la tastatură numărul real r."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran aria și perimetrul cercului de rază <code>r</code> separate prin spații.</p>",
      "text": "Programul va afișa pe ecran aria și perimetrul cercului de rază r separate prin spații."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ r ≤ 1000</code></li>\n\t<li>Se acceptă o eroare de maximum <code>0.01</code>.</li>\n</ul>",
      "text": "2 ≤ r ≤ 1000 Se acceptă o eroare de maximum 0.01."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5</pre><p><strong>Ieșire</strong></p><pre>78.539816 31.415927</pre>",
      "text": "Intrare5Ieșire78.539816 31.415927"
    }
  ],
