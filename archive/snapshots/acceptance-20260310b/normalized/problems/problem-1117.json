  "sections": [
    {
      "title": "Cerință",
      "html": "<p>Pentru <code>N</code>, <code>M</code> și gridul <code>A</code> date, să se determine volumul de apă care a rămas în piscină.</p>",
      "text": "Pentru N, M și gridul A date, să se determine volumul de apă care a rămas în piscină."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>volum.in</code> conține pe prima linie două numere naturale <code>N</code> și <code>M</code>, reprezentând dimensiunile grid-ului, iar pe fiecare dintre următoarele <code>N</code> linii se află câte <code>M</code> numere, reprezentând înălțimile terenului, separate prin câte un spațiu.</p>",
      "text": "Fișierul de intrare volum.in conține pe prima linie două numere naturale N și M, reprezentând dimensiunile grid-ului, iar pe fiecare dintre următoarele N linii se află câte M numere, reprezentând înălțimile terenului, separate prin câte un spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>volum.out</code> va conține un singur număr, reprezentând volumul de apă care a rămas în piscină.</p>",
      "text": "Fișierul de ieșire volum.out va conține un singur număr, reprezentând volumul de apă care a rămas în piscină."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ N, M ≤ 752</code></li>\n\t<li><code>0 ≤ A</code><sub><code>i,j</code></sub><code> ≤ 10</code><sup><code>9</code></sup><code> + 2</code></li>\n\t<li>Pentru 30% din punctaj, <code>3 ≤ N, M ≤ 82</code>.</li>\n\t<li>Pentru 40% din punctaj, <code>0 ≤ A</code><sub><code>i,j</code></sub><code> ≤ 10</code><sup><code>3</code></sup><code> + 2</code>.</li>\n\t<li>Volumul apei este suma unităţilor de apă care rămâne în celulele piscinei.</li>\n</ul>",
      "text": "3 ≤ N, M ≤ 752 0 ≤ Ai,j ≤ 109 + 2 Pentru 30% din punctaj, 3 ≤ N, M ≤ 82. Pentru 40% din punctaj, 0 ≤ Ai,j ≤ 103 + 2. Volumul apei este suma unităţilor de apă care rămâne în celulele piscinei."
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>volum.in</code></p><pre>3 3\n2 2 2\n2 0 2\n2 2 2</pre><p><code>volum.out</code></p><pre>2</pre>",
      "text": "volum.in3 3 2 2 2 2 0 2 2 2 2volum.out2"
    },
    {
      "title": "Explicație",
      "html": "<p>După ploaie rămân două unități de apă în celula cu înălțimea <code>0</code>. Nu pot rămâne <code>3</code> unități, deoarece o unitate s-ar scurge prin una din cele 4 celule vecine în exteriorul piscinei.</p>",
      "text": "După ploaie rămân două unități de apă în celula cu înălțimea 0. Nu pot rămâne 3 unități, deoarece o unitate s-ar scurge prin una din cele 4 celule vecine în exteriorul piscinei."
    },
    {
      "title": "Exemplul 2",
      "html": "<p><code>volum.in</code></p><pre>3 3\n3 3 3\n3 0 2\n3 3 3</pre><p><code>volum.out</code></p><pre>2</pre>",
      "text": "volum.in3 3 3 3 3 3 0 2 3 3 3volum.out2"
    },
    {
      "title": "Explicație",
      "html": "<p>După ploaie rămân două unități de apă în celula cu înălțimea <code>0</code>. Nu pot rămâne <code>3</code> unități, deoarece o unitate s-ar scurge prin celula vecină cu valoarea <code>2</code> în exteriorul piscinei.</p>",
      "text": "După ploaie rămân două unități de apă în celula cu înălțimea 0. Nu pot rămâne 3 unități, deoarece o unitate s-ar scurge prin celula vecină cu valoarea 2 în exteriorul piscinei."
    },
    {
      "title": "Exemplul 3",
      "html": "<p><code>volum.in</code></p><pre>5 5\n2 2 3 3 3\n2 2 3 1 3\n2 3 1 3 3\n2 2 3 2 2\n2 2 2 2 2</pre><p><code>volum.out</code></p><pre>4</pre>",
      "text": "volum.in5 5 2 2 3 3 3 2 2 3 1 3 2 3 1 3 3 2 2 3 2 2 2 2 2 2 2volum.out4"
    },
    {
      "title": "Explicație",
      "html": "<p>După ploaie rămân câte două unități de apă în celulele cu înălțimea <code>1</code>. Nu pot rămâne câte <code>3</code> unități. De exemplu, din celula <code>(2,4)</code> apa se poate scurge în celula <code>(2,5)</code> şi apoi în exterior, respectiv din celula <code>(3,3)</code> în şirul de celule <code>(4,3) - (5,3)</code> şi apoi în exterior.</p>",
      "text": "După ploaie rămân câte două unități de apă în celulele cu înălțimea 1. Nu pot rămâne câte 3 unități. De exemplu, din celula (2,4) apa se poate scurge în celula (2,5) şi apoi în exterior, respectiv din celula (3,3) în şirul de celule (4,3) - (5,3) şi apoi în exterior."
    }
  ],
