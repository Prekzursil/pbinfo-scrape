  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă numărul real <code>n</code>. Calculați \\( \\sqrt{n}  \\) cu <code>8</code> zecimale exacte. </p>",
      "text": "Se dă numărul real n. Calculați \\( \\sqrt{n} \\) cu 8 zecimale exacte."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran \\( \\sqrt{n}  \\) cu <code>8</code> zecimale exacte.</p>",
      "text": "Programul va afișa pe ecran \\( \\sqrt{n} \\) cu 8 zecimale exacte."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>Dacă numărul citit este negativ se calculează ca pentru un număr pozitiv și se afișează <code>i</code> după el.</li>\n\t<li><code>1 ≤ nrcif(n)+'.' ≤ 100.001</code></li>\n</ul>",
      "text": "Dacă numărul citit este negativ se calculează ca pentru un număr pozitiv și se afișează i după el. 1 ≤ nrcif(n)+'.' ≤ 100.001"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>26</pre><p><strong>Ieșire</strong></p><pre>5.09901951</pre>",
      "text": "Intrare26Ieșire5.09901951"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>-25</pre><p><strong>Ieșire</strong></p><pre>5.00000000i</pre>",
      "text": "Intrare-25Ieșire5.00000000i"
    }
  ],
  "examples": [
    {
      "input": "26",
      "output": "5.09901951"
    },
    {
      "input": "-25",
      "output": "5.00000000i"
