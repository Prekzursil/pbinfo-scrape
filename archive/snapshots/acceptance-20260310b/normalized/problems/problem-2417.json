  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Fiind date un cuvânt cheie şi un mesaj criptat, decodificaţi mesajul trimis de Mircea pentru Vasilică.</p>",
      "text": "Fiind date un cuvânt cheie şi un mesaj criptat, decodificaţi mesajul trimis de Mircea pentru Vasilică."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>criptare1.in</code> conţine pe prima linie mesajul criptat iar pe linia a doua cuvântul cheie.</p>",
      "text": "Fișierul de intrare criptare1.in conţine pe prima linie mesajul criptat iar pe linia a doua cuvântul cheie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>criptare1.out</code> va conţine pe prima linie mesajul decriptat.</p>",
      "text": "Fișierul de ieșire criptare1.out va conţine pe prima linie mesajul decriptat."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>lungimea mesajului este de minim <code>20</code> si maximum <code>1000</code> caractere</li>\n\t<li>cuvântul cheie are minimum <code>5</code> şi maximum <code>20</code> de caractere</li>\n\t<li>cuvântul cheie conţine numai litere mici ale alfabetului</li>\n</ul>",
      "text": "lungimea mesajului este de minim 20 si maximum 1000 caractere cuvântul cheie are minimum 5 şi maximum 20 de caractere cuvântul cheie conţine numai litere mici ale alfabetului"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>criptare1.in</code></p><pre>clcrr.Imc**pcsaoiaauuii*eamd*rn*rcstr**uci\ncriptam</pre><p><code>criptare1.out</code></p><pre>Incercam sa lucram cu coduri si criptari.</pre>",
      "text": "criptare1.inclcrr.Imc**pcsaoiaauuii*eamd*rn*rcstr**uci criptamcriptare1.outIncercam sa lucram cu coduri si criptari."
    }
  ],
