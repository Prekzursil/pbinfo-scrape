  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se consideră toate perechile de numere din șir, se calculează pentru fiecare prietenia, apoi se determină suma tuturor prieteniilor. Să se determine această sumă totală.</p>",
      "text": "Se consideră toate perechile de numere din șir, se calculează pentru fiecare prietenia, apoi se determină suma tuturor prieteniilor. Să se determine această sumă totală."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>x3.in</code> conține pe prima linie numărul <code>n</code>, iar pe următoarele <code>n</code> linii se află câte un număr natural reprezentând un număr din șir.</p>",
      "text": "Fișierul de intrare x3.in conține pe prima linie numărul n, iar pe următoarele n linii se află câte un număr natural reprezentând un număr din șir."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>x3.out</code> va conține pe prima linie un singur număr natural reprezentând suma tuturor prieteniilor.</p>",
      "text": "Fișierul de ieșire x3.out va conține pe prima linie un singur număr natural reprezentând suma tuturor prieteniilor."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 1.000.000</code></li>\n\t<li>numerele din șir sunt naturale și mai mici sau egale cu <code>1.000.000</code></li>\n</ul>",
      "text": "2 ≤ n ≤ 1.000.000 numerele din șir sunt naturale și mai mici sau egale cu 1.000.000"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>x3.in</code></p><pre>2\n19\n10 </pre><p><code>x3.out</code></p><pre>25</pre>",
      "text": "x3.in2 19 10 x3.out25"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>x3.in</code></p><pre>3\n7\n3\n5</pre><p><code>x3.out</code></p><pre>12</pre><h3>Explicație</h3><p>Șirul este <code>7,3,5</code>. Prietenia dintre <code>7</code> și <code>3</code> este <code>4</code>, dintre <code>7</code> și <code>5</code> este <code>2</code> și prietenia dintre <code>3</code> și <code>5</code> este <code>6</code>. Suma totală este deci <code>4 + 2 + 6 = 12</code>.</p>",
      "text": "x3.in3 7 3 5x3.out12ExplicațieȘirul este 7,3,5. Prietenia dintre 7 și 3 este 4, dintre 7 și 5 este 2 și prietenia dintre 3 și 5 este 6. Suma totală este deci 4 + 2 + 6 = 12."
    },
    {
      "title": "Exemplul 3:",
      "html": "<p><code>x3.in</code></p><pre>5\n9\n13\n1\n9\n6</pre><p><code>x3.out</code></p><pre>84</pre>",
      "text": "x3.in5 9 13 1 9 6x3.out84"
    }
  ],
