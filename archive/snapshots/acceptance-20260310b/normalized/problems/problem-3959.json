  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se consideră un șir <code>A</code> de <code>n</code> numere întregi. Pentru fiecare subsecvență de lungimea <code>k</code> să se afișeze valoarea maximă.</p>",
      "text": "Se consideră un șir A de n numere întregi. Pentru fiecare subsecvență de lungimea k să se afișeze valoarea maximă."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>maxsecvk.in</code> conține pe prima linie două numere naturale nenule <code>n</code> și <code>k</code>, iar pe a doua linie <code>n</code> numere întregi separate prin spații.</p>",
      "text": "Fișierul de intrare maxsecvk.in conține pe prima linie două numere naturale nenule n și k, iar pe a doua linie n numere întregi separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>maxsecvk.out</code> va conține <code>n–k+1</code> numere întregi ce reprezintă valoarea maximă a tuturor secvențelor de lungime <code>k</code>.</p>",
      "text": "Fișierul de ieșire maxsecvk.out va conține n–k+1 numere întregi ce reprezintă valoarea maximă a tuturor secvențelor de lungime k."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n\t<li><code>1 ≤ k ≤ n</code></li>\n\t<li><code>-1.000.000.000 ≤</code> <code>A</code><sub><code>i</code></sub> <code>≤ 1.000.000.000</code></li>\n\t<li>prin secvență înțelegem elemente aflate pe poziții consecutive în șir</li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000 1 ≤ k ≤ n -1.000.000.000 ≤ Ai ≤ 1.000.000.000 prin secvență înțelegem elemente aflate pe poziții consecutive în șir"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>maxsecvk.in</code></p><pre>9 3\n1 2 4 1 3 6 3 2 5</pre><p><code>maxsecvk.out</code></p><pre>4 4 4 6 6 6 5</pre><h3>Explicație</h3><p>Se vor afișa <code>7</code> numere. <br>\nMaximul secvenței <code>1 2 4</code> este <code>4</code><br>\nMaximul secvenței <code>2 4 1</code> este <code>4</code><br>\nMaximul secvenței <code>4 1 3</code> este <code>4</code><br>\nMaximul secvenței <code>1 3 6</code> este <code>6</code><br>\nMaximul secvenței <code>3 6 3</code> este <code>6</code><br>\nMaximul secvenței <code>6 3 2</code> este <code>6</code><br>\nMaximul secvenței <code>3 2 5</code> este <code>5</code></p>",
      "text": "maxsecvk.in9 3 1 2 4 1 3 6 3 2 5maxsecvk.out4 4 4 6 6 6 5ExplicațieSe vor afișa 7 numere. Maximul secvenței 1 2 4 este 4 Maximul secvenței 2 4 1 este 4 Maximul secvenței 4 1 3 este 4 Maximul secvenței 1 3 6 este 6 Maximul secvenței 3 6 3 este 6 Maximul secvenței 6 3 2 este 6 Maximul secvenței 3 2 5 este 5"
    }
  ],
