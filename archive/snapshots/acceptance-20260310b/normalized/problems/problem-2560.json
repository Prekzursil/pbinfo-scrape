  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Determinați valoarea unor anumiți biți din reprezentarea sa în baza 2.</p>",
      "text": "Determinați valoarea unor anumiți biți din reprezentarea sa în baza 2."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>bits.in</code> conține pe prima linie două numere naturale <code>N</code> și <code>Q</code> separate prin spațiu. Pe linia a doua se află <code>Q</code> numere naturale separate prin câte un spațiu.</p>",
      "text": "Fișierul de intrare bits.in conține pe prima linie două numere naturale N și Q separate prin spațiu. Pe linia a doua se află Q numere naturale separate prin câte un spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>bits.out</code> conține pe prima linie <code>Q</code> valori, neseparate prin spațiu, reprezentând, în ordine, răspunsurile la întrebări.</p>",
      "text": "Fișierul de ieșire bits.out conține pe prima linie Q valori, neseparate prin spațiu, reprezentând, în ordine, răspunsurile la întrebări."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 ≤ N ≤ 2</code><sup><code>63</code></sup><code>-1</code></li>\n\t<li><code>1 ≤ Q ≤ 63</code></li>\n\t<li>valorile de pe a doua linie a fișierului de intrare sunt distincte și cuprinse între <code>0</code> și <code>62</code> (inclusiv)</li>\n\t<li>biții se numerotează începând cu poziția <code>0</code> (cel mai puțin semnificativ)</li>\n\t<li>numărul <code>N</code> este reprezentat pe <code>64</code> de biți</li>\n</ul>",
      "text": "0 ≤ N ≤ 263-1 1 ≤ Q ≤ 63 valorile de pe a doua linie a fișierului de intrare sunt distincte și cuprinse între 0 și 62 (inclusiv) biții se numerotează începând cu poziția 0 (cel mai puțin semnificativ) numărul N este reprezentat pe 64 de biți"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>bits.in</code></p><pre>12 4\n2 0 3 20</pre><p><code>bits.out</code></p><pre>1010</pre><h3>Explicație</h3><p>Reprezentarea internă a valorii  <code>12</code> este <code>000...0001100</code>. Biții de pe pozițiile <code>0</code> și <code>20</code> au valoarea <code>0</code> iar cei de pe pozițiile <code>2</code> și <code>3</code> au valoarea <code>1</code>.</p>",
      "text": "bits.in12 4 2 0 3 20bits.out1010ExplicațieReprezentarea internă a valorii 12 este 000...0001100. Biții de pe pozițiile 0 și 20 au valoarea 0 iar cei de pe pozițiile 2 și 3 au valoarea 1."
    }
  ],
