  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se citesc două numere naturale. Să se afişeze numărul care are mai multe cifre egale cu <code>1</code> în reprezentarea în baza <code>2</code>.</p>",
      "text": "Se citesc două numere naturale. Să se afişeze numărul care are mai multe cifre egale cu 1 în reprezentarea în baza 2."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură două numere naturale.</p>",
      "text": "Programul citește de la tastatură două numere naturale."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran valoarea cerută.</p>",
      "text": "Programul afișează pe ecran valoarea cerută."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>cele două numere citite vor fi mai mici decât <code>2.000.000.000</code></li>\n\t<li>dacă cele două numere au acelaşi număr de cifre <code>1</code> în reprezentarea în baza <code>2</code> se va afişa cel mai mic dintre ele</li>\n</ul>",
      "text": "cele două numere citite vor fi mai mici decât 2.000.000.000 dacă cele două numere au acelaşi număr de cifre 1 în reprezentarea în baza 2 se va afişa cel mai mic dintre ele"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>125 1250</pre><p><strong>Ieșire</strong></p><pre>125</pre>",
      "text": "Intrare125 1250Ieșire125"
    },
    {
      "title": "Explicaţie",
      "html": "<p>Reprezentarea lui <code>125</code> în baza <code>2</code> este <code>1111101</code>, cu <code>6</code> cifre <code>1</code>, iar reprezentarea lui <code>1250</code> este <code>10011100010</code>, cu <code>5</code> cifre <code>1</code>. Astfel, <code>125</code> are mai multe cifre <code>1</code> în reprezentarea în baza <code>2</code>.</p>",
      "text": "Reprezentarea lui 125 în baza 2 este 1111101, cu 6 cifre 1, iar reprezentarea lui 1250 este 10011100010, cu 5 cifre 1. Astfel, 125 are mai multe cifre 1 în reprezentarea în baza 2."
    }
  ],
  "examples": [
    {
      "input": "125 1250",
      "output": "125"
    }
  ],
