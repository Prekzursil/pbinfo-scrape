  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine numărul <code>M</code> al pavărilor distincte cu dale dreptunghiulare care au lungimea egală cu un centimetru și lățimea egală cu <code>2</code> centimetri.</p>",
      "text": "Să se determine numărul M al pavărilor distincte cu dale dreptunghiulare care au lungimea egală cu un centimetru și lățimea egală cu 2 centimetri."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>pavare.in</code> conține pe prima linie numărul natural nenul <code>N</code>, reprezentând jumătatea lungimii dreptunghiului.</p>",
      "text": "Fișierul de intrare pavare.in conține pe prima linie numărul natural nenul N, reprezentând jumătatea lungimii dreptunghiului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>pavare.out</code> va conține pe prima linie numărul natural nenul, reprezentând numărul modalităților de a pava dreptunghiul.</p>",
      "text": "Fișierul de ieșire pavare.out va conține pe prima linie numărul natural nenul, reprezentând numărul modalităților de a pava dreptunghiul."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>pavare.in</code></p><pre>2</pre><p><code>pavare.out</code></p><pre>11</pre>",
      "text": "pavare.in2pavare.out11"
    }
  ],
  "examples": [],
  "constraints": [
    "1 ≤ n ≤ 100"
  ],
