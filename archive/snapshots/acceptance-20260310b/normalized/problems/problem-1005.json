  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă o listă cu numere naturale. Să se determine numerele naturale nenule cu cel mult patru cifre care nu apar în lista dată.</p>",
      "text": "Se dă o listă cu numere naturale. Să se determine numerele naturale nenule cu cel mult patru cifre care nu apar în lista dată."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>numere8.in</code> conține lista de numere, dispuse pe mai multe linii, separate prin spații.</p>",
      "text": "Fișierul de intrare numere8.in conține lista de numere, dispuse pe mai multe linii, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>numere8.out</code> va conține pe prima linie, în ordine descrescătoare, numerele nenule cu cel mult patru cifre care nu se află în listă, separate prin exact un spațiu.</p>",
      "text": "Fișierul de ieșire numere8.out va conține pe prima linie, în ordine descrescătoare, numerele nenule cu cel mult patru cifre care nu se află în listă, separate prin exact un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>numerele din lista vor fi mai mici decât <code>1 000 000 000</code></li>\n</ul>",
      "text": "numerele din lista vor fi mai mici decât 1 000 000 000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>numere8.in</code></p><pre>107 4 5 8 1 6 9</pre><p><code>numere8.out</code></p><pre>9999 9998 ... 108 106 105 ... 10 7 3 2</pre>",
      "text": "numere8.in107 4 5 8 1 6 9numere8.out9999 9998 ... 108 106 105 ... 10 7 3 2"
    },
    {
      "title": "Explicație",
      "html": "<p>Fișierul de ieșire din exemplu nu este complet :) …</p>",
      "text": "Fișierul de ieșire din exemplu nu este complet :) …"
    }
