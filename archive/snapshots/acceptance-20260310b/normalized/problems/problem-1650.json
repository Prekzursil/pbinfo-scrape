  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un număr întreg <code>n</code> și alte <code>k</code> numere întregi. Să se afle dacă, adunând toate cele <code>k</code> numere la <code>n</code> se obține o valoare egală cu valoarea inițială a lui <code>n</code>.</p>",
      "text": "Se dă un număr întreg n și alte k numere întregi. Să se afle dacă, adunând toate cele k numere la n se obține o valoare egală cu valoarea inițială a lui n."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n k</code>, iar apoi <code>k</code> numere întregi.</p>",
      "text": "Programul citește de la tastatură numerele n k, iar apoi k numere întregi."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran textul <b>“DA”</b> dacă numărul final este egal cu cel inițial sau textul <b>“NU”</b> în caz contrar.</p>",
      "text": "Programul va afișa pe ecran textul “DA” dacă numărul final este egal cu cel inițial sau textul “NU” în caz contrar."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code> -1000000 ≤ n ≤ 1000000</code></li>\n\t<li><code> 2 ≤ k ≤ 10</code></li>\n</ul>",
      "text": "-1000000 ≤ n ≤ 1000000 2 ≤ k ≤ 10"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>25\n3\n16 -9 3</pre><p><strong>Ieșire</strong></p><pre>NU</pre><h3>Explicație</h3><p><code>25 + 16 - 9 + 3 = 35</code>, număr diferit de cel inițial (<code>25</code>).</p>",
      "text": "Intrare25 3 16 -9 3IeșireNUExplicație25 + 16 - 9 + 3 = 35, număr diferit de cel inițial (25)."
    }
  ],
  "examples": [
    {
      "input": "25\n3\n16 -9 3",
      "output": "NU",
      "explanation": "25 + 16 - 9 + 3 = 35, număr diferit de cel inițial (25)."
    }
  ],
