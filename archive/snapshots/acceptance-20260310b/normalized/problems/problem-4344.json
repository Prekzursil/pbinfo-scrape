  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând numărul de persoane N precum și cele <code>N - 1</code> relații de prietenie, determinaţi pentru fiecare persoană distanţa socială maximă a persoanei respective.</p>",
      "text": "Cunoscând numărul de persoane N precum și cele N - 1 relații de prietenie, determinaţi pentru fiecare persoană distanţa socială maximă a persoanei respective."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>smallworld.in</code> conţine pe prima linie numărul natural <code>N</code> şi pe următoarele <code>N - 1</code> linii câte două numere <code>p</code> și <code>q</code>, care reprezintă faptul că între persoanele <code>p</code> și <code>q</code> există o relaţie de prietenie.</p>",
      "text": "Fișierul de intrare smallworld.in conţine pe prima linie numărul natural N şi pe următoarele N - 1 linii câte două numere p și q, care reprezintă faptul că între persoanele p și q există o relaţie de prietenie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>smallworld.out</code> va conţine <code>N</code> linii, pe linia <code>i</code> fiind scrisă distanța socială maximă pentru persoana <code>i</code> (<code>1 ≤ i ≤ N</code>).</p>",
      "text": "Fișierul de ieșire smallworld.out va conţine N linii, pe linia i fiind scrisă distanța socială maximă pentru persoana i (1 ≤ i ≤ N)."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ N ≤ 100.000</code></li>\n\t<li>Pentru teste în valoare de 52 de puncte, <code>N ≤ 1000</code>.</li>\n\t<li>10 puncte se acordă pentru exemplele din enunț.</li>\n</ul>",
      "text": "2 ≤ N ≤ 100.000 Pentru teste în valoare de 52 de puncte, N ≤ 1000. 10 puncte se acordă pentru exemplele din enunț."
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>smallworld.in</code></p><pre>3\n1 2\n1 3</pre><p><code>smallworld.out</code></p><pre>1\n2\n2</pre><h3>Explicație</h3><p><code>1</code> e la distanță maximă <code>1</code> atât de <code>2</code> cât și <code>3</code>. <code>2</code> e la distanță maximă <code>2</code> de <code>3</code>. <code>3</code> e la distanță maximă <code>2</code> de <code>2</code>.</p><p><img alt=\"\" src=\"/resurse/16a4b0/smallworld_1.jpg\"></p>",
      "text": "smallworld.in3 1 2 1 3smallworld.out1 2 2Explicație1 e la distanță maximă 1 atât de 2 cât și 3. 2 e la distanță maximă 2 de 3. 3 e la distanță maximă 2 de 2."
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>smallworld.in</code></p><pre>5\n2 3\n4 2\n5 1\n1 2</pre><p><code>smallworld.out</code></p><pre>2\n2\n3\n3\n3</pre><h3>Explicație</h3><p><code>1</code> e la distanță maximă <code>2</code> de <code>4</code> și <code>3</code>. <code>2</code> e la distanță maximă <code>2</code> de <code>5</code>. <code>3</code> e la distanță maximă <code>3</code> de <code>5</code>. <code>4</code> e la distanță maximă <code>3</code> de <code>5</code>. <code>5</code> e la distanță maximă <code>3</code> de <code>3</code> și <code>4</code>.</p><p><img alt=\"\" src=\"/resurse/16a4b0/smallworld_2.jpg\"></p>",
      "text": "smallworld.in5 2 3 4 2 5 1 1 2smallworld.out2 2 3 3 3Explicație1 e la distanță maximă 2 de 4 și 3. 2 e la distanță maximă 2 de 5. 3 e la distanță maximă 3 de 5. 4 e la distanță maximă 3 de 5. 5 e la distanță maximă 3 de 3 și 4."
    }
  ],
