  "sections": [
    {
      "title": "Afin",
      "html": "<p><em>Cifrul Afin</em> este un cifru unde fiecare literă este înlocuită cu o altă literă printr-o operație matematica. Fiecărei litere i se asociază un cod: <code>a-0</code>, <code>b-1</code>, <code>c-2</code>, … <code>z-25</code>. De asemenea, mai avem două numere <code>a</code> și <code>b</code>, numite chei. Fiecare literă se înlocuiește cu litera care are codul egal cu <code>(a*x+b)</code>mod. <code>26</code> , unde <code>x</code> este codul literei.</p>",
      "text": "Cifrul Afin este un cifru unde fiecare literă este înlocuită cu o altă literă printr-o operație matematica. Fiecărei litere i se asociază un cod: a-0, b-1, c-2, … z-25. De asemenea, mai avem două numere a și b, numite chei. Fiecare literă se înlocuiește cu litera care are codul egal cu (a*x+b)mod. 26 , unde x este codul literei."
    },
    {
      "title": "Cerinta",
      "html": "<p>Dându-se valoarea celor două chei și un mesaj să se afișeze mesajul criptat.</p>",
      "text": "Dându-se valoarea celor două chei și un mesaj să se afișeze mesajul criptat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>afin.in</code> conține pe prima linie numerele <code>a b</code> iar pe a doua linie un mesaj.</p>",
      "text": "Fișierul de intrare afin.in conține pe prima linie numerele a b iar pe a doua linie un mesaj."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>afin.out</code> va conține pe prima linie mesajul criptat.</p>",
      "text": "Fișierul de ieșire afin.out va conține pe prima linie mesajul criptat."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ a , b ≤ 26</code></li>\n\t<li><code>1 ≤</code> lungimea șirului <code>≤10000</code></li>\n\t<li>mesajul va conține doar litere mici ale alfabetului englez</li>\n</ul>",
      "text": "1 ≤ a , b ≤ 26 1 ≤ lungimea șirului ≤10000 mesajul va conține doar litere mici ale alfabetului englez"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>afin.in</code></p><pre>17 20\ntwentyfifteen</pre><p><code>afin.out</code></p><pre>fekhfmbabfkkh</pre>",
      "text": "afin.in17 20 twentyfifteenafin.outfekhfmbabfkkh"
    }
  ],
