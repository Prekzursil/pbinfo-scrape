    "Numarul lui Catalan"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieţi un program care să determine numărul de grafuri obținute de Florin.</p><ul>\n\t<li>Cerința1: Numărul de grafuri se va afișa modulo <code>20232029</code></li>\n\t<li>Cerința2: Numărul de grafuri se va afișa în întregime</li>\n</ul>",
      "text": "Scrieţi un program care să determine numărul de grafuri obținute de Florin. Cerința1: Numărul de grafuri se va afișa modulo 20232029 Cerința2: Numărul de grafuri se va afișa în întregime"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>planar.in</code> conține pe prima linie două numere naturale <code>C</code> și <code>NR</code> reprezentând cerința și numărul par de noduri ale grafului.</p>",
      "text": "Fișierul de intrare planar.in conține pe prima linie două numere naturale C și NR reprezentând cerința și numărul par de noduri ale grafului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>planar.out</code> va conține o singură linie pe care va fi scris rezultatul obținut.</p>",
      "text": "Fișierul de ieșire planar.out va conține o singură linie pe care va fi scris rezultatul obținut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ NR ≤ 10.000</code></li>\n\t<li><code>C = 1, 2</code></li>\n</ul>",
      "text": "1 ≤ NR ≤ 10.000 C = 1, 2"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>planar.in</code></p><pre>1 4</pre><p><code>planar.out</code></p><pre>2</pre>",
      "text": "planar.in1 4planar.out2"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>planar.in</code></p><pre>1 50</pre><p><code>planar.out</code></p><pre>7744491</pre><h3>Explicație</h3><p><code>4861946401452 % 20232029 = 7744491</code></p>",
      "text": "planar.in1 50planar.out7744491Explicație4861946401452 % 20232029 = 7744491"
    },
    {
      "title": "Exemplul 3:",
      "html": "<p><code>planar.in</code></p><pre>2 50</pre><p><code>planar.out</code></p><pre>4861946401452</pre>",
      "text": "planar.in2 50planar.out4861946401452"
    }
  ],
