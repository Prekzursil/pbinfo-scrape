  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând valoarea lui <code>n</code> ce reprezintă dimensiunea tablei şi un număr <code>p</code>, să se determine linia şi coloana căsuţei din tabelă unde este scris numărul <code>p</code>, după regulile de mai sus.</p>",
      "text": "Cunoscând valoarea lui n ce reprezintă dimensiunea tablei şi un număr p, să se determine linia şi coloana căsuţei din tabelă unde este scris numărul p, după regulile de mai sus."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul <code>horse.in</code> conţine două numere:</p><ul>\n\t<li><code>n</code> – numărul liniilor şi coloanelor tablei, pe prima linie</li>\n\t<li><code>p</code> – numărul dintr-o căsuţă a tablei, pe a doua linie</li>\n</ul>",
      "text": "Fişierul horse.in conţine două numere: n – numărul liniilor şi coloanelor tablei, pe prima linie p – numărul dintr-o căsuţă a tablei, pe a doua linie"
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul <code>horse.out</code> va conţine două numere: linia şi respectiv coloana căsuţei unde este scris numărul <code>p</code>, cu un spaţiu între ele. </p>",
      "text": "Fişierul horse.out va conţine două numere: linia şi respectiv coloana căsuţei unde este scris numărul p, cu un spaţiu între ele."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>4&lt;n&lt;46340</code></li>\n\t<li><code>n=4k+1</code></li>\n\t<li><code>1≤p≤n</code><sup><code style=\"font-size:0.8em;\">2</code></sup></li>\n\t<li>pentru <code>50%</code> dintre teste <code>n≤1000</code></li>\n</ul>",
      "text": "4<n<46340 n=4k+1 1≤p≤n2 pentru 50% dintre teste n≤1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>horse.in</code></p><pre>5\n24</pre><p><code>horse.out</code></p><pre>2 1</pre>",
      "text": "horse.in5 24horse.out2 1"
    },
    {
      "title": "Explicație",
      "html": "<p>Pe o tablă <code>5x5</code> numărul <code>24</code> va ajunge pe linia <code>2</code> şi coloana <code>1</code>.</p>",
      "text": "Pe o tablă 5x5 numărul 24 va ajunge pe linia 2 şi coloana 1."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>horse.in</code></p><pre>9\n36</pre><p><code>horse.out</code></p><pre>8 9</pre>",
      "text": "horse.in9 36horse.out8 9"
    },
    {
      "title": "Explicație",
      "html": "<p>Pe o tablă <code>9x9</code> numărul <code>36</code> va ajunge pe linia <code>8</code> şi coloana <code>9</code>.</p>",
      "text": "Pe o tablă 9x9 numărul 36 va ajunge pe linia 8 şi coloana 9."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>horse.in</code></p><pre>41\n1000</pre><p><code>horse.out</code></p><pre>14 7</pre>",
      "text": "horse.in41 1000horse.out14 7"
    },
    {
      "title": "Explicație",
      "html": "<p>Pe o tablă <code>41x41</code> numărul <code>1000</code> va ajunge pe linia <code>14</code> şi coloana <code>7</code>.</p>",
      "text": "Pe o tablă 41x41 numărul 1000 va ajunge pe linia 14 şi coloana 7."
    }
  ],
