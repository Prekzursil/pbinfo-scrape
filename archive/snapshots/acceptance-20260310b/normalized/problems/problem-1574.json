  "tags": [
    "Determinarea divizorilor"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau două numere naturale. Să se afle dacă aceste numere sunt prietene. Numerele prietene sunt perechile de numere în care fiecare număr în parte este suma tuturor divizorilor celuilalt număr, mai puțin acesta.</p>",
      "text": "Se dau două numere naturale. Să se afle dacă aceste numere sunt prietene. Numerele prietene sunt perechile de numere în care fiecare număr în parte este suma tuturor divizorilor celuilalt număr, mai puțin acesta."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură două numere <code>a</code> și <code>b</code>.</p>",
      "text": "Programul citește de la tastatură două numere a și b."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran mesajul <code>PRIETENE</code> dacă cele două numere sunt prietene, respectiv <code>NU SUNT PRIETENE</code> dacă aceste numere nu sunt prietene.</p>",
      "text": "Programul va afișa pe ecran mesajul PRIETENE dacă cele două numere sunt prietene, respectiv NU SUNT PRIETENE dacă aceste numere nu sunt prietene."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ a ≤ 100.000</code></li>\n\t<li><code>1 ≤ b ≤ 100.000</code></li>\n</ul>",
      "text": "1 ≤ a ≤ 100.000 1 ≤ b ≤ 100.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>220 284</pre><p><strong>Ieșire</strong></p><pre>PRIETENE</pre><h3>Explicație</h3><p>Divizorii lui <code>220</code> sunt <code>1</code>, <code>2</code>, <code>4</code>, <code>5</code>, <code>10</code>, <code>11</code>, <code>20</code>, <code>22</code>, <code>44</code>, <code>55</code> și <code>110</code>, iar suma acestora este <code>284</code>. Divizorii lui <code>284</code> sunt <code>1</code>, <code>2</code>, <code>4</code>, <code>71</code> și <code>142</code>, iar suma acestora este <code>220</code>.</p>",
      "text": "Intrare220 284IeșirePRIETENEExplicațieDivizorii lui 220 sunt 1, 2, 4, 5, 10, 11, 20, 22, 44, 55 și 110, iar suma acestora este 284. Divizorii lui 284 sunt 1, 2, 4, 71 și 142, iar suma acestora este 220."
    }
  ],
  "examples": [
    {
      "input": "220 284",
      "output": "PRIETENE",
      "explanation": "Divizorii lui 220 sunt 1, 2, 4, 5, 10, 11, 20, 22, 44, 55 și 110, iar suma acestora este 284. Divizorii lui 284 sunt 1, 2, 4, 71 și 142, iar suma acestora este 220."
    }
  ],
  "constraints": [
    "1 ≤ a ≤ 100.000",
    "1 ≤ b ≤ 100.000"
  ],
