  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dat fiind un număr natural <code>n</code>, să se determine numărul natural <code>m</code> care are are proprietatea că are în reprezentarea în baza <code>2</code> biți de <code>1</code> pe pozițiile unde <code>n</code> are biți de <code>0</code> și are biți de <code>0</code> pe pozițiile unde <code>n</code> are biți de <code>1</code>. De exemplu, dacă <code>n = 346</code>, atunci <code>m = 165</code>, deoarece <code>n</code> se reprezintă în baza <code>2</code> prin <code>101011010</code>, iar <code>m</code> prin <code>010100101</code>.</p>",
      "text": "Dat fiind un număr natural n, să se determine numărul natural m care are are proprietatea că are în reprezentarea în baza 2 biți de 1 pe pozițiile unde n are biți de 0 și are biți de 0 pe pozițiile unde n are biți de 1. De exemplu, dacă n = 346, atunci m = 165, deoarece n se reprezintă în baza 2 prin 101011010, iar m prin 010100101."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>m</code>.</p>",
      "text": "Programul va afișa pe ecran numărul m."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 ≤ n ≤ 1 000 000 000</code></li>\n</ul>",
      "text": "0 ≤ n ≤ 1 000 000 000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>346</pre><p><strong>Ieșire</strong></p><pre>165</pre>",
      "text": "Intrare346Ieșire165"
    }
  ],
  "examples": [
    {
      "input": "346",
      "output": "165"
    }
  ],
  "constraints": [
    "0 ≤ n ≤ 1 000 000 000"
  ],
