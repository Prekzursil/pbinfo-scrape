  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând numărul de ani vizibili și numărul de participanți din fiecare din acești ani, să se răspundă la mai multe afirmații de tipul enunțat mai sus. </p>",
      "text": "Cunoscând numărul de ani vizibili și numărul de participanți din fiecare din acești ani, să se răspundă la mai multe afirmații de tipul enunțat mai sus."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Pe prima linie a fișierului <code>empowermage.in</code> se va afla numărul natural <code>N</code>, reprezentând numărul de ani vizibili. Urmează apoi <code>N</code> linii a câte <code>2</code> valori separate prin spațiu: <code>a</code><sub><code>i</code></sub> <code>p</code><sub><code>i</code></sub> cu semnificația că în anul ai au participat pi participanți. Pe linia <code>N+2</code> se află numărul natural <code>M</code>, reprezentând numărul de afirmații la care trebuie să răspundeți. Urmează apoi <code>M</code> linii a câte două valori: <code>X Y</code> ce codifică afirmația “Anul <code>Y</code> a avut cei mai mulți participanți de la anul <code>X</code> incoace”.</p>",
      "text": "Pe prima linie a fișierului empowermage.in se va afla numărul natural N, reprezentând numărul de ani vizibili. Urmează apoi N linii a câte 2 valori separate prin spațiu: ai pi cu semnificația că în anul ai au participat pi participanți. Pe linia N+2 se află numărul natural M, reprezentând numărul de afirmații la care trebuie să răspundeți. Urmează apoi M linii a câte două valori: X Y ce codifică afirmația “Anul Y a avut cei mai mulți participanți de la anul X incoace”."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul empowermage.out  va conține <code>M</code> linii, pe linia <code>i</code> fiind răspunsul la afirmația <code>i</code>. Răspunsul poate fi <code>ADEVARAT</code>, <code>FALS</code> sau <code>POATE</code> (<b>CU <span class=\"caps\">MAJUSCULE</span></b>)</p>",
      "text": "Fișierul empowermage.out va conține M linii, pe linia i fiind răspunsul la afirmația i. Răspunsul poate fi ADEVARAT, FALS sau POATE (CU MAJUSCULE)"
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 50.000</code></li>\n\t<li><code>1 ≤ M ≤ 10.000</code></li>\n\t<li><code>-10</code><sup><code>9</code></sup> <code>≤ an ≤ 10</code><sup><code>9</code></sup></li>\n\t<li><code>1 ≤ participanti dintr-un an ≤ 10</code><sup><code>9</code></sup></li>\n\t<li><code>-10</code><sup><code>9</code></sup> <code>≤ X &lt; Y ≤ 10</code><sup><code>9</code></sup></li>\n\t<li>Cei <code>N</code> ani sunt dați în ordine cronologică</li>\n</ul>",
      "text": "1 ≤ N ≤ 50.000 1 ≤ M ≤ 10.000 -109 ≤ an ≤ 109 1 ≤ participanti dintr-un an ≤ 109 -109 ≤ X < Y ≤ 109 Cei N ani sunt dați în ordine cronologică"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>empowermage.in</code></p><pre>4\n2002 4920\n2003 5901\n2004 2832\n2005 3890\n2\n2002 2005\n2003 2005</pre><pre>3\n1985 5782\n1995 3048\n2005 4890\n2\n1985 2005\n2005 2015</pre><p><code>empowermage.out</code></p><pre>FALS\nADEVARAT</pre><pre>POATE\nPOATE</pre>",
      "text": "empowermage.in4 2002 4920 2003 5901 2004 2832 2005 3890 2 2002 2005 2003 20053 1985 5782 1995 3048 2005 4890 2 1985 2005 2005 2015empowermage.outFALS ADEVARATPOATE POATE"
    }
  ],
