  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se consideră fișierul <code>prosir.in</code> care conține pe primul rând un text format din cel mult <code>200</code> de caractere litere mici și spații. Cuvintele din text sunt separate prin unul sau mai multe spații. Să se modifice textul citit din fișier prin înlocuirea ultimei litere a fiecărui cuvânt cu cifra <code>5</code>. </p>",
      "text": "Se consideră fișierul prosir.in care conține pe primul rând un text format din cel mult 200 de caractere litere mici și spații. Cuvintele din text sunt separate prin unul sau mai multe spații. Să se modifice textul citit din fișier prin înlocuirea ultimei litere a fiecărui cuvânt cu cifra 5."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>prosir.in</code> conține pe prima linie șirul de caractere.</p>",
      "text": "Fișierul de intrare prosir.in conține pe prima linie șirul de caractere."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>prosir.out</code> va conține pe prima linie șirul modificat conform cerinței.</p>",
      "text": "Fișierul de ieșire prosir.out va conține pe prima linie șirul modificat conform cerinței."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>lugimea șirului citit este maximum <code>200</code></li>\n\t<li>ultimul cuvânt din text se termină cu caracterul <code>'.'</code></li>\n</ul>",
      "text": "lugimea șirului citit este maximum 200 ultimul cuvânt din text se termină cu caracterul '.'"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>prosir.in</code></p><pre>ana are   multe   mare si o gutuie.</pre><p><code>prosir.out</code></p><pre>an5 ar5   mult5   mar5 s5 5 gutui5.</pre>",
      "text": "prosir.inana are multe mare si o gutuie.prosir.outan5 ar5 mult5 mar5 s5 5 gutui5."
    }
  ],
