  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine o împărțire a unui șir în subșiruri zebră.</p>",
      "text": "Să se determine o împărțire a unui șir în subșiruri zebră."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură un șir de caractere format din <code>0</code> și <code>1</code>.</p>",
      "text": "Programul citește de la tastatură un șir de caractere format din 0 și 1."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <code>S</code>, numărul de subșiruri, iar apoi, pe următoarele <code>S</code> linii numărul de zile componente ale fiecărui subșir și pozițiile din șirul inițial la care se află acestea. Dacă șirul nu se poate împărții în subșiruri zebră, atunci se va afișa <code>-1</code>.</p>",
      "text": "Programul va afișa pe ecran S, numărul de subșiruri, iar apoi, pe următoarele S linii numărul de zile componente ale fiecărui subșir și pozițiile din șirul inițial la care se află acestea. Dacă șirul nu se poate împărții în subșiruri zebră, atunci se va afișa -1."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>Inputul conține cel mult <code>200.000</code> de caractere.</li>\n\t<li>Orice împărțire în subșiruri zebră este acceptată.</li>\n</ul>",
      "text": "Inputul conține cel mult 200.000 de caractere. Orice împărțire în subșiruri zebră este acceptată."
    },
    {
      "title": "Exemplu 1:",
      "html": "<p><strong>Intrare</strong></p><pre>0010100</pre><p><strong>Ieșire</strong></p><pre>3\n3 1 3 4\n3 2 5 6\n1 7</pre>",
      "text": "Intrare0010100Ieșire3 3 1 3 4 3 2 5 6 1 7"
    },
    {
      "title": "Exemplu 2:",
      "html": "<p><strong>Intrare</strong></p><pre>111</pre><p><strong>Ieșire</strong></p><pre>-1</pre>",
      "text": "Intrare111Ieșire-1"
    }
  ],
  "examples": [
