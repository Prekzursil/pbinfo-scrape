  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se calculeze pentru fiecare întrebare <code>p</code> minimum, pentru care relația este satisfăcută.</p>",
      "text": "Să se calculeze pentru fiecare întrebare p minimum, pentru care relația este satisfăcută."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>spp.in</code> conține pe prima linie un număr natural <code>Q</code>. Pe liniile <code>2</code>, <code>3</code>, …, <code>Q+1</code> se află câte o pereche <code>x p</code> care satisface restricțiile.</p>",
      "text": "Fișierul de intrare spp.in conține pe prima linie un număr natural Q. Pe liniile 2, 3, …, Q+1 se află câte o pereche x p care satisface restricțiile."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>spp.out</code> va conține răspunsul la fiecare întrebare.</p>",
      "text": "Fișierul de ieșire spp.out va conține răspunsul la fiecare întrebare."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>Q ≤ 100.000</code></li>\n\t<li><code>1 ≤ x ≤ 100.000</code></li>\n\t<li><code>1 ≤ p ≤ 1.000.000.000</code></li>\n\t<li>Pentru 30% din teste, <code>Q ≤ 100</code> sau <code>p ≤ 1000</code></li>\n</ul>",
      "text": "Q ≤ 100.000 1 ≤ x ≤ 100.000 1 ≤ p ≤ 1.000.000.000 Pentru 30% din teste, Q ≤ 100 sau p ≤ 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>spp.in</code></p><pre>2\n1 5\n10 19</pre><p><code>spp.out</code></p><pre>4\n12</pre><h3>Explicație</h3><p><code>1</code><sup><code>2</code></sup> <code>+ 2</code><sup><code>2</code></sup> <code>+ 3</code><sup><code>2</code></sup> <code>+ 4</code><sup><code>2</code></sup> <code>= 30 ≥ 5</code><sup><code>2</code></sup>.<br>\n<code>10</code><sup><code>2</code></sup> <code>+ 11</code><sup><code>2</code></sup> <code>+ 12</code><sup><code>2</code></sup> <code>= 365 ≥ 19</code><sup><code>2</code></sup>.</p>",
      "text": "spp.in2 1 5 10 19spp.out4 12Explicație12 + 22 + 32 + 42 = 30 ≥ 52. 102 + 112 + 122 = 365 ≥ 192."
    }
  ],
  "examples": [
    {
      "input": "",
      "output": "",
      "explanation": "12 + 22 + 32 + 42 = 30 ≥ 52. 102 + 112 + 122 = 365 ≥ 192."
    }
  ],
  "constraints": [
    "Q ≤ 100.000",
    "1 ≤ x ≤ 100.000",
    "1 ≤ p ≤ 1.000.000.000",
    "Pentru 30% din teste, Q ≤ 100 sau p ≤ 1000"
  ],
