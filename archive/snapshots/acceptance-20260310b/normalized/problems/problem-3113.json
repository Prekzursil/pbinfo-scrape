  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un șir de caractere care conține litere mici și mari ale alfabetului englez, spații și semne de punctuație. Să se afișeze fiecare cuvânt și frecvența de apariție a lui în șirul de caractere pe câte o linie fiecare pereche cuvânt-frecvență ordonate lexicografic.</p>",
      "text": "Se dă un șir de caractere care conține litere mici și mari ale alfabetului englez, spații și semne de punctuație. Să se afișeze fiecare cuvânt și frecvența de apariție a lui în șirul de caractere pe câte o linie fiecare pereche cuvânt-frecvență ordonate lexicografic."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură un șir de caractere.</p>",
      "text": "Programul citește de la tastatură un șir de caractere."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran pe câte o linie fiecare cuvânt și frecvența lui de apariție în șir.</p>",
      "text": "Programul va afișa pe ecran pe câte o linie fiecare cuvânt și frecvența lui de apariție în șir."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ strlen(sir) ≤ 10000</code></li>\n</ul>",
      "text": "1 ≤ strlen(sir) ≤ 10000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>Ana are mere si prune si pere, insa Ana nu are masina si casa.</pre><p><strong>Ieșire</strong></p><pre>Ana 2\nare 2\ncasa 1\ninsa 1\nmasina 1\nmere 1\nnu 1\npere 1\nprune 1\nsi 3</pre>",
      "text": "IntrareAna are mere si prune si pere, insa Ana nu are masina si casa.IeșireAna 2 are 2 casa 1 insa 1 masina 1 mere 1 nu 1 pere 1 prune 1 si 3"
    }
  ],
