  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se ordoneze crescător subșirul format din elementele pare din vector și descrescător subșirul format din elementele impare. Indicii subșirului format din elementele pare nu se vor schimba. La fel și indicii subșirului format din elementele impare.</p>",
      "text": "Să se ordoneze crescător subșirul format din elementele pare din vector și descrescător subșirul format din elementele impare. Indicii subșirului format din elementele pare nu se vor schimba. La fel și indicii subșirului format din elementele impare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>halfsort3.in</code> conţine pe prima linie numărul <code>n</code> si pe a doua linie <code>n</code> numere întregi separate prin spaţii.   </p>",
      "text": "Fişierul de intrare halfsort3.in conţine pe prima linie numărul n si pe a doua linie n numere întregi separate prin spaţii."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>halfsort3.out</code> va conţine pe prima linie cele <code>n</code> elemente ale vectorului, ordonate conform cerinței, separate printr-un spațiu.</p>",
      "text": "Fişierul de ieşire halfsort3.out va conţine pe prima linie cele n elemente ale vectorului, ordonate conform cerinței, separate printr-un spațiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n ≤ 1000</code></li>\n\t<li>valoarea absolută a numerelor de pe a doua linie a fişierului de intrare va fi mai mică decât <code>2</code><sup><code>30</code></sup></li>\n</ul>",
      "text": "0 < n ≤ 1000 valoarea absolută a numerelor de pe a doua linie a fişierului de intrare va fi mai mică decât 230"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>halfsort3.in</code></p><pre>6\n8 1 9 4 5 7</pre><p><code>halfsort3.out</code></p><pre>4 9 7 8 5 1 </pre>",
      "text": "halfsort3.in6 8 1 9 4 5 7halfsort3.out4 9 7 8 5 1"
    }
  ],
