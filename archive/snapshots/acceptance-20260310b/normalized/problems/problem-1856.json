  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Ştiind că el are în buzunar <code>S</code> euro şi că fiecare funcţionar îi ia taxa de cum intră în birou, se cere să se determine dacă el poate primi aprobările necesare şi, în caz afirmativ, care este suma maximă de bani care îi rămâne în buzunar la ieşirea din clădire.</p>",
      "text": "Ştiind că el are în buzunar S euro şi că fiecare funcţionar îi ia taxa de cum intră în birou, se cere să se determine dacă el poate primi aprobările necesare şi, în caz afirmativ, care este suma maximă de bani care îi rămâne în buzunar la ieşirea din clădire."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>taxe2.in</code> conţine pe prima linie cele două numere <code>S</code> şi <code>n</code> despărţite printr-un spaţiu, iar pe următoarele <code>n</code> linii câte <code>n</code> numere separate prin spaţii ce reprezintă taxele cerute de funcţionarii din fiecare birou.</p>",
      "text": "Fişierul de intrare taxe2.in conţine pe prima linie cele două numere S şi n despărţite printr-un spaţiu, iar pe următoarele n linii câte n numere separate prin spaţii ce reprezintă taxele cerute de funcţionarii din fiecare birou."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>taxe2.out</code> conţine o singură linie pe care se află numărul maxim de euro care îi rămân în buzunar sau valoarea <code>–1</code> dacă investitorului nu-i ajung banii pentru a obţine aprobarea.</p>",
      "text": "Fişierul de ieşire taxe2.out conţine o singură linie pe care se află numărul maxim de euro care îi rămân în buzunar sau valoarea –1 dacă investitorului nu-i ajung banii pentru a obţine aprobarea."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ N ≤ 100</code></li>\n\t<li><code>1 ≤ S ≤ 10000</code></li>\n\t<li>Valorile reprezentând taxele cerute de funcţionarii din birouri sunt numere naturale, o taxă nedepășind valoarea de <code>200</code> de euro.</li>\n</ul>",
      "text": "3 ≤ N ≤ 100 1 ≤ S ≤ 10000 Valorile reprezentând taxele cerute de funcţionarii din birouri sunt numere naturale, o taxă nedepășind valoarea de 200 de euro."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>taxe2.in</code></p><pre>10 3\n1 2 5\n1 3 1\n0 8 1</pre><p><code>taxe2.out</code></p><pre>3</pre>",
      "text": "taxe2.in10 3 1 2 5 1 3 1 0 8 1taxe2.out3"
    }
  ],
