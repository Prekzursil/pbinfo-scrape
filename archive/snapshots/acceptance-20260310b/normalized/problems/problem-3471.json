  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Determinați o atribuire de valori asupra șirului astfel încât acesta să respecte cele <code>M</code> restricții.</p>",
      "text": "Determinați o atribuire de valori asupra șirului astfel încât acesta să respecte cele M restricții."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Pe prima linie  din fișierul <code>valori.in</code> se află două numere naturale <code>N</code> și <code>M</code>. Pe a doua linie din fișierul de intrare se află cele <code>M</code> restricții. Primele <code>N</code> restricții (<code>N + 1</code> linii) reprezintă restricții de tipul <code>0</code>. Următoarele <code>M – N</code> linii sunt restricții de tipul <code>1</code>, <code>2</code>, sau <code>3</code>.</p>",
      "text": "Pe prima linie din fișierul valori.in se află două numere naturale N și M. Pe a doua linie din fișierul de intrare se află cele M restricții. Primele N restricții (N + 1 linii) reprezintă restricții de tipul 0. Următoarele M – N linii sunt restricții de tipul 1, 2, sau 3."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>valori.out</code> va conține valorile atribuite fiecărui element din șirul de lungime <code>N</code>.</p>",
      "text": "Fișierul de ieșire valori.out va conține valorile atribuite fiecărui element din șirul de lungime N."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 10.000</code></li>\n\t<li><code>1 ≤ M ≤ 40.000</code></li>\n\t<li>Toate valorile din input se vor încadra be 32 de biti.</li>\n\t<li>Se poate afișa orice soluție corectă.</li>\n\t<li>Se garantează ca există cel puțin o soluție.</li>\n</ul>",
      "text": "1 ≤ N ≤ 10.000 1 ≤ M ≤ 40.000 Toate valorile din input se vor încadra be 32 de biti. Se poate afișa orice soluție corectă. Se garantează ca există cel puțin o soluție."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>valori.in</code></p><pre>6 10\n0 0 1 2\n0 1 1 0\n0 2 3 2\n0 3 2 3\n0 4 1 0\n0 5 1 3\n1 2 3 2\n2 0 4\n3 1 0\n3 5 1</pre><p><code>valori.out</code></p><pre>1 1 3 2 0 1</pre>",
      "text": "valori.in6 10 0 0 1 2 0 1 1 0 0 2 3 2 0 3 2 3 0 4 1 0 0 5 1 3 1 2 3 2 2 0 4 3 1 0 3 5 1valori.out1 1 3 2 0 1"
    }
  ],
