  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând cifrele <code>a</code>, <code>b</code>, <code>c</code>, determinaţi valoarea obţinută în urma efectuării calculelor de mai sus.</p>",
      "text": "Cunoscând cifrele a, b, c, determinaţi valoarea obţinută în urma efectuării calculelor de mai sus."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>puteri5.in</code> conține pe prima linie trei cifre <code>a b c</code>, separate prin câte un spaţiu.</p>",
      "text": "Fișierul de intrare puteri5.in conține pe prima linie trei cifre a b c, separate prin câte un spaţiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>puteri5.out</code> va conține un număr natural ce reprezintă valoarea obţinută pentru expresia precizată anterior.</p>",
      "text": "Fișierul de ieșire puteri5.out va conține un număr natural ce reprezintă valoarea obţinută pentru expresia precizată anterior."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ a,b,c ≤ 5</code></li>\n</ul>",
      "text": "1 ≤ a,b,c ≤ 5"
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>puteri5.in</code></p><pre>2 1 3</pre><p><code>puteri5.out</code></p><pre>24</pre><h3>Explicație</h3><p>\\( 2^{1^3} + 2^{3^1} + 1^{2^3} + 1^{3^2} + 3^{2^1} + 3^{1^2} = 2^1 + 2^3 + 1^8 + 1^9 + 3^2 + 3^1 = 2 + 8 + 1 + 1 + 9 + 3 = 24 \\)</p>",
      "text": "puteri5.in2 1 3puteri5.out24Explicație\\( 2^{1^3} + 2^{3^1} + 1^{2^3} + 1^{3^2} + 3^{2^1} + 3^{1^2} = 2^1 + 2^3 + 1^8 + 1^9 + 3^2 + 3^1 = 2 + 8 + 1 + 1 + 9 + 3 = 24 \\)"
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>puteri5.in</code></p><pre>2 3 2</pre><p><code>puteri5.out</code></p><pre>1698</pre>",
      "text": "puteri5.in2 3 2puteri5.out1698"
    }
  ],
