    "Arbori de intervale"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un string <code>s</code> de lungime <code>n</code> și <code>q</code> query-uri de forma <code>(op, x, y)</code>, unde <code>op</code> poate fi <code>0</code> sau <code>1</code>. Dacă <code>op</code> este egal cu <code>1</code>, atunci caracterul de pe poziția <code>x</code> din <code>s</code> va deveni <code>y</code>. Dacă <code>op</code> este egal cu <code>0</code>, se va afișa numărul de caractere distincte ale lui <code>s</code> din intervalul <code>[x, y]</code>.</p>",
      "text": "Se dă un string s de lungime n și q query-uri de forma (op, x, y), unde op poate fi 0 sau 1. Dacă op este egal cu 1, atunci caracterul de pe poziția x din s va deveni y. Dacă op este egal cu 0, se va afișa numărul de caractere distincte ale lui s din intervalul [x, y]."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură <code>n</code>, <code>s</code>, <code>q</code> si cele <code>q</code> query-uri.</p>",
      "text": "Programul citește de la tastatură n, s, q si cele q query-uri."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran raspunsurile la query-urile de tipul <code>0</code>, fiecare pe linie nouă.</p>",
      "text": "Programul va afișa pe ecran raspunsurile la query-urile de tipul 0, fiecare pe linie nouă."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 5.000.000</code></li>\n\t<li><code>1 ≤ q ≤ 250.000</code></li>\n\t<li><code>s</code> este format doar din litere mici ale alfabetului englez</li>\n</ul>",
      "text": "1 ≤ n ≤ 5.000.000 1 ≤ q ≤ 250.000 s este format doar din litere mici ale alfabetului englez"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4\naaaa\n4\n1 2 b\n1 3 c\n0 1 2\n0 2 4</pre><p><strong>Ieșire</strong></p><pre>2\n3</pre><h3>Explicație</h3><p>După primele <code>2</code> operatii, <code>s</code> = <code>\"abca\"</code>.</p>",
      "text": "Intrare4 aaaa 4 1 2 b 1 3 c 0 1 2 0 2 4Ieșire2 3ExplicațieDupă primele 2 operatii, s = \"abca\"."
    }
  ],
  "examples": [
    {
      "input": "4\naaaa\n4\n1 2 b\n1 3 c\n0 1 2\n0 2 4",
      "output": "2\n3",
      "explanation": "După primele 2 operatii, s = \"abca\"."
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 5.000.000",
    "1 ≤ q ≤ 250.000",
    "s este format doar din litere mici ale alfabetului englez"
  ],
