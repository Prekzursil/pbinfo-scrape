  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând coordonatele pietrei (linie, coloană), calculaţi în a câta unitate de timp s-a întâmplat accidentul.</p>",
      "text": "Cunoscând coordonatele pietrei (linie, coloană), calculaţi în a câta unitate de timp s-a întâmplat accidentul."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>piatra.in</code> conține un rând, în care sunt scrise patru numere: <code>m</code>, <code>n</code>, <code>l</code>, <code>c</code> despărţite prin spaţiu cu semnificaţia: <code>m</code> şi <code>n</code> reprezintă dimensiunea gazonului (numărul de linii şi coloane) iar <code>l</code> şi <code>c</code> reprezintă coordonatele pietrei (linia şi coloana).</p>",
      "text": "Fișierul de intrare piatra.in conține un rând, în care sunt scrise patru numere: m, n, l, c despărţite prin spaţiu cu semnificaţia: m şi n reprezintă dimensiunea gazonului (numărul de linii şi coloane) iar l şi c reprezintă coordonatele pietrei (linia şi coloana)."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>piatra.out</code> va conține un singur număr reprezentând unitatea de timp la care s-a întâmplat accidentul.</p>",
      "text": "Fișierul de ieșire piatra.out va conține un singur număr reprezentând unitatea de timp la care s-a întâmplat accidentul."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1≤ m,n ≤40000</code>;</li>\n\t<li><code>1≤ l ≤ m</code>;</li>\n\t<li><code>1≤ c ≤ n</code>;</li>\n\t<li>Numerotarea rândurilor şi coloanelor începe de la <code>1</code>.</li>\n</ul>",
      "text": "1≤ m,n ≤40000; 1≤ l ≤ m; 1≤ c ≤ n; Numerotarea rândurilor şi coloanelor începe de la 1."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>piatra.in</code></p><pre>5 8 2 4</pre><p><code>piatra.out</code></p><pre>14</pre>",
      "text": "piatra.in5 8 2 4piatra.out14"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>piatra.in</code></p><pre>5 8 3 6</pre><p><code>piatra.out</code></p><pre>28</pre>",
      "text": "piatra.in5 8 3 6piatra.out28"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>piatra.in</code></p><pre>32000 38000 31678 37812</pre><p><code>piatra.out</code></p><pre>1215869507</pre>",
      "text": "piatra.in32000 38000 31678 37812piatra.out1215869507"
    }
  ],
