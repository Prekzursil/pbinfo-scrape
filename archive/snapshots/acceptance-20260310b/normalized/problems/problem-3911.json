  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă o mulțime cu <code>n</code> elemente, numere naturale. Afișați în ordine lexicografică toate permutările mulțimii date în care elementele prime sunt puncte fixe (nu își schimbă poziția).</p>",
      "text": "Se dă o mulțime cu n elemente, numere naturale. Afișați în ordine lexicografică toate permutările mulțimii date în care elementele prime sunt puncte fixe (nu își schimbă poziția)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code> și apoi <code>n</code> numere naturale, reprezentând elementele mulțimii.</p>",
      "text": "Programul citește de la tastatură numărul n și apoi n numere naturale, reprezentând elementele mulțimii."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran permutările cerute, câte una pe fiecare rând și având elementele separate prin câte un spaţiu.</p>",
      "text": "Programul va afișa pe ecran permutările cerute, câte una pe fiecare rând și având elementele separate prin câte un spaţiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 &lt; n ≤ 15</code></li>\n\t<li>numărul valorilor prime din șir va fi aproximativ egal cu cel al valorilor neprime</li>\n</ul>",
      "text": "1 < n ≤ 15 numărul valorilor prime din șir va fi aproximativ egal cu cel al valorilor neprime"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n9 7 1 2 8</pre><p><strong>Ieșire</strong></p><pre>1 7 8 2 9 \n1 7 9 2 8 \n8 7 1 2 9 \n8 7 9 2 1 \n9 7 1 2 8 \n9 7 8 2 1 </pre><h3>Explicație</h3><p>În permutările generate valorile prime (<code>7 2</code>) nu își modifică poziția (<code>2</code>, respectiv <code>4</code>).</p>",
      "text": "Intrare5 9 7 1 2 8Ieșire1 7 8 2 9 1 7 9 2 8 8 7 1 2 9 8 7 9 2 1 9 7 1 2 8 9 7 8 2 1 ExplicațieÎn permutările generate valorile prime (7 2) nu își modifică poziția (2, respectiv 4)."
    }
  ],
  "examples": [
    {
      "input": "5\n9 7 1 2 8",
      "output": "1 7 8 2 9 \n1 7 9 2 8 \n8 7 1 2 9 \n8 7 9 2 1 \n9 7 1 2 8 \n9 7 8 2 1",
      "explanation": "În permutările generate valorile prime (7 2) nu își modifică poziția (2, respectiv 4)."
    }
  ],
  "constraints": [
    "1 < n ≤ 15",
    "numărul valorilor prime din șir va fi aproximativ egal cu cel al valorilor neprime"
  ],
