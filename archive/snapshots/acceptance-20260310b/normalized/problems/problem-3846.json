  "sections": [
    {
      "title": "Cerința",
      "html": "<p>După ce Ionuț a învățat despre algoritmul lui Kadane își pune următoarea întrebare: se dă <code>N</code>, <code>K</code> și <code>W</code> apoi un vector cu <code>N</code> elemente, din acest vector care este suma maximă a unei secvențe (elemente adiacente) de lungime cel puțin <code>K</code> și cel mult <code>W</code>. A zis să vă întrebe pe voi cum se face.</p>",
      "text": "După ce Ionuț a învățat despre algoritmul lui Kadane își pune următoarea întrebare: se dă N, K și W apoi un vector cu N elemente, din acest vector care este suma maximă a unei secvențe (elemente adiacente) de lungime cel puțin K și cel mult W. A zis să vă întrebe pe voi cum se face."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>ksum2.in</code> conține pe prima linie numerele <code>N</code>, <code>K</code> și <code>W</code>, pe următoarea linie <code>N</code> elemente întregi reprezentând elementele vectorului.</p>",
      "text": "Fișierul de intrare ksum2.in conține pe prima linie numerele N, K și W, pe următoarea linie N elemente întregi reprezentând elementele vectorului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>ksum2.out</code> va conține pe prima linie numărul <code>S</code>, reprezentând suma maximă a unei secvențe (elemente adiacente) din vector de lungime cel puțin <code>K</code> și cel mult <code>W</code>.</p>",
      "text": "Fișierul de ieșire ksum2.out va conține pe prima linie numărul S, reprezentând suma maximă a unei secvențe (elemente adiacente) din vector de lungime cel puțin K și cel mult W."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ K ≤ W ≤ n ≤ 100.000</code></li>\n\t<li>numerele de pe a doua linie a fișierului de intrare vor fi din intervalul <code>[-1.000, 1.000]</code>.</li>\n</ul>",
      "text": "1 ≤ K ≤ W ≤ n ≤ 100.000 numerele de pe a doua linie a fișierului de intrare vor fi din intervalul [-1.000, 1.000]."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>ksum2.in</code></p><pre>6 3 4\n5 4 -10 1 2 3</pre><p><code>ksum2.out</code></p><pre>6</pre><h3>Explicație</h3><p>Secvența căutată este <code>[4, 6]</code> cu suma <code>1 + 2 + 3 = 6</code>.</p>",
      "text": "ksum2.in6 3 4 5 4 -10 1 2 3ksum2.out6ExplicațieSecvența căutată este [4, 6] cu suma 1 + 2 + 3 = 6."
    }
  ],
