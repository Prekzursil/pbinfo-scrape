  "sections": [
    {
      "title": "Cerinta",
      "html": "<p>Dându-se valoarea celor două chei și un mesaj criptat să se afișeze mesajul decriptat. Dacă <code>a</code> și <code>b</code> formează o pereche ineficientă atunci se afișează mesajul <code>-1</code>.</p>",
      "text": "Dându-se valoarea celor două chei și un mesaj criptat să se afișeze mesajul decriptat. Dacă a și b formează o pereche ineficientă atunci se afișează mesajul -1."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>afin1.in</code> conține pe prima linie numerele <code>a b</code> iar pe a doua linie mesajul criptat.</p>",
      "text": "Fișierul de intrare afin1.in conține pe prima linie numerele a b iar pe a doua linie mesajul criptat."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>afin1.out</code> va conține pe prima linie mesajul decriptat sau numarul <code>-1</code> daca <code>a</code> si <code>b</code> formeaza o pereche ineficienta.</p>",
      "text": "Fișierul de ieșire afin1.out va conține pe prima linie mesajul decriptat sau numarul -1 daca a si b formeaza o pereche ineficienta."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤</code> lungimea mesajului <code>≤ 10000</code></li>\n</ul>",
      "text": "1 ≤ lungimea mesajului ≤ 10000"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>afin1.in</code></p><pre>17 20\nfekhfmbabfkkh</pre><p><code>afin1.out</code></p><pre>twentyfifteen</pre>",
      "text": "afin1.in17 20 fekhfmbabfkkhafin1.outtwentyfifteen"
    },
    {
      "title": "Exemplul 2;",
      "html": "<p><code>afin1.in</code></p><pre>14 19\njvphxbxnzrtrldjplnzffdtvhbvhbnrzxpjrpnzlltfthbvdf</pre><p><code>afin1.out</code></p><pre>-1</pre>",
      "text": "afin1.in14 19 jvphxbxnzrtrldjplnzffdtvhbvhbnrzxpjrpnzlltfthbvdfafin1.out-1"
    }
  ],
