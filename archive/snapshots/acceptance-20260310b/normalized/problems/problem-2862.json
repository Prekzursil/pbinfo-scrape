  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dat fiind un șir format din litere mari, să se determine numărul minim de operații dintr-o secvență corecte care afișează șirul dat.</p>",
      "text": "Dat fiind un șir format din litere mari, să se determine numărul minim de operații dintr-o secvență corecte care afișează șirul dat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>stiva2.in</code> conține pe prima linie un șir format numai din litere mari.</p>",
      "text": "Fișierul de intrare stiva2.in conține pe prima linie un șir format numai din litere mari."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>stiva2.out</code> va conține o singură linie pe care va fi scris numărul minim de operații dintr-o secvență corecte care afișează șirul din fișierul de intrare.</p>",
      "text": "Fișierul de ieșire stiva2.out va conține o singură linie pe care va fi scris numărul minim de operații dintr-o secvență corecte care afișează șirul din fișierul de intrare."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>Lungimea șirului este de cel mult <code>500</code></li>\n</ul>",
      "text": "Lungimea șirului este de cel mult 500"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>stiva2.in</code></p><pre>ABCACBA</pre><p><code>stiva2.out</code></p><pre>15</pre>",
      "text": "stiva2.inABCACBAstiva2.out15"
    }
  ],
  "examples": [],
  "constraints": [
    "Lungimea șirului este de cel mult 500"
  ],
