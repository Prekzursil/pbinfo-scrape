  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Calculați suma valorilor <strong>third</strong> pentru toate secvențele de lungime <code>k</code> din șir.</p>",
      "text": "Calculați suma valorilor third pentru toate secvențele de lungime k din șir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>third.in</code> conține pe prima linie numerele <code>n</code> și <code>k</code>, iar pe a doua linie șirul de <code>n</code> numere naturale separate prin spații.</p>",
      "text": "Fișierul de intrare third.in conține pe prima linie numerele n și k, iar pe a doua linie șirul de n numere naturale separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>third.out</code> va conține pe prima linie numărul <code>S</code>, reprezentând suma valorilor <strong>third</strong> a tuturor secvențelor de lungime <code>k</code>.</p>",
      "text": "Fișierul de ieșire third.out va conține pe prima linie numărul S, reprezentând suma valorilor third a tuturor secvențelor de lungime k."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>4 ≤ n ≤ 100.000</code></li>\n\t<li><code>3 ≤ k ≤ n</code></li>\n\t<li>numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât <code>1.000.000.000</code></li>\n</ul>",
      "text": "4 ≤ n ≤ 100.000 3 ≤ k ≤ n numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>third.in</code></p><pre>10 5\n4 4 4 2 9 8 1 5 6 3</pre><p><code>third.out</code></p><pre>28</pre><h3>Explicație</h3><p>Prima secvență de lungime <code>5</code> este <code>4 4 4 2 9</code> și are ca third pe <code>4</code>.<br>\nA doua secvență de lungime <code>5</code> este <code>4 4 2 9 8</code> și are ca third pe <code>4</code>.<br>\nA treia secvență de lungime <code>5</code> este <code>4 2 9 8 1</code> și are ca third pe <code>4</code>.<br>\nA patra secvență de lungime <code>5</code> este <code>2 9 8 1 5</code> și are ca third pe <code>5</code>.<br>\nA cincea secvență de lungime <code>5</code> este <code>9 8 1 5 6</code> și are ca third pe <code>6</code>.<br>\nUltima secvență de lungime <code>5</code> este <code>8 1 5 6 3</code> și are ca third pe <code>5</code>.<br>\nSuma valorilor third este <code>4+4+4+5+6+5=28</code>.</p>",
      "text": "third.in10 5 4 4 4 2 9 8 1 5 6 3third.out28ExplicațiePrima secvență de lungime 5 este 4 4 4 2 9 și are ca third pe 4. A doua secvență de lungime 5 este 4 4 2 9 8 și are ca third pe 4. A treia secvență de lungime 5 este 4 2 9 8 1 și are ca third pe 4. A patra secvență de lungime 5 este 2 9 8 1 5 și are ca third pe 5. A cincea secvență de lungime 5 este 9 8 1 5 6 și are ca third pe 6. Ultima secvență de lungime 5 este 8 1 5 6 3 și are ca third pe 5. Suma valorilor third este 4+4+4+5+6+5=28."
    }
  ],
  "examples": [
    {
      "input": "",
      "output": "",
      "explanation": "Prima secvență de lungime 5 este 4 4 4 2 9 și are ca third pe 4. A doua secvență de lungime 5 este 4 4 2 9 8 și are ca third pe 4. A treia secvență de lungime 5 este 4 2 9 8 1 și are ca third pe 4. A patra secvență de lungime 5 este 2 9 8 1 5 și are ca third pe 5. A cincea secvență de lungime 5 este 9 8 1 5 6 și are ca third pe 6. Ultima secvență de lungime 5 este 8 1 5 6 3 și are ca third pe 5. Suma valorilor third este 4+4+4+5+6+5=28."
    }
  ],
