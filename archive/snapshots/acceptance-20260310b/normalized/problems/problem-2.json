  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Calculaţi suma celor <code>n</code> numere date.</p>",
      "text": "Calculaţi suma celor n numere date."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe prima linie a ecranului numărul <code>S</code>, reprezentând suma celor <code>n</code> numere.</p>",
      "text": "Programul afișează pe prima linie a ecranului numărul S, reprezentând suma celor n numere."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n &lt; 1000</code></li>\n\t<li>cele <code>n</code> numere citite vor fi mai mici decât <code>1000</code></li>\n</ul>",
      "text": "0 < n < 1000 cele n numere citite vor fi mai mici decât 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n6 2 0 4 1</pre><p><strong>Ieșire</strong></p><pre>13</pre>",
      "text": "Intrare5 6 2 0 4 1Ieșire13"
    }
  ],
