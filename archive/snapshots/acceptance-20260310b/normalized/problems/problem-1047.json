  "tags": [],
  "sections": [
    {
      "title": "Cerințe",
      "html": "<p>Scrieți un program care să determine:</p><p>a) Numărul stelelor  strălucitoare;<br>\nb) Numărul constelațiilor pătrate;<br>\nc) Lungimea laturii pătratului care reprezintă cea mai mare constelație pătrată.</p>",
      "text": "Scrieți un program care să determine:a) Numărul stelelor strălucitoare; b) Numărul constelațiilor pătrate; c) Lungimea laturii pătratului care reprezintă cea mai mare constelație pătrată."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>patrat2.in</code> conține pe prima linie două numere naturale <code>N</code> și <code>M</code>, separate printr-un spațiu, reprezentând dimensiunile tabloului bidimensional, iar de pe următoarele <code>N</code> linii, câte M numere naturale separate prin câte un spațiu,  reprezentând intensitatea luminoasă a stelelor.</p>",
      "text": "Fișierul de intrare patrat2.in conține pe prima linie două numere naturale N și M, separate printr-un spațiu, reprezentând dimensiunile tabloului bidimensional, iar de pe următoarele N linii, câte M numere naturale separate prin câte un spațiu, reprezentând intensitatea luminoasă a stelelor."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>patrat2.out</code> va conține pe prima linie un număr natural reprezentând răspunsul la cerința a). Pe cea de-a doua linie se va scrie un număr natural reprezentând răspunsul la cerința b). Pe a treia linie se va scrie un număr natural reprezentând răspunsul la cerința c).</p>",
      "text": "Fișierul de ieșire patrat2.out va conține pe prima linie un număr natural reprezentând răspunsul la cerința a). Pe cea de-a doua linie se va scrie un număr natural reprezentând răspunsul la cerința b). Pe a treia linie se va scrie un număr natural reprezentând răspunsul la cerința c)."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 &lt; N ≤ 200</code></li>\n\t<li><code>1 &lt; M ≤ 200 </code></li>\n\t<li><code>1 ≤</code> intensitatea unei stele <code>≤ 1000</code></li>\n\t<li>pentru rezolvarea corectă a cerinţei a) se acordă <code>40%</code> din punctajul fiecărui test, pentru rezolvarea corectă a cerinţei b) se acordă <code>40%</code> din punctajul fiecărui test iar pentru rezolvarea corectă a cerinţei c) se acordă <code>20%</code> din punctajul fiecărui test.</li>\n</ul>",
      "text": "1 < N ≤ 200 1 < M ≤ 200 1 ≤ intensitatea unei stele ≤ 1000 pentru rezolvarea corectă a cerinţei a) se acordă 40% din punctajul fiecărui test, pentru rezolvarea corectă a cerinţei b) se acordă 40% din punctajul fiecărui test iar pentru rezolvarea corectă a cerinţei c) se acordă 20% din punctajul fiecărui test."
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>patrat2.in</code></p><pre>6 8\n1 8 5 7 1 6 3 4 \n1 2 3 1 1 5 2 1\n1 7 1 9 1 1 8 1 \n6 3 5 1 6 4 3 1\n1 9 5 7 1 8 2 1 \n1 5 6 5 3 1 3 6</pre><p><code>patrat2.out</code></p><pre>11\n3\n5</pre>",
      "text": "patrat2.in6 8 1 8 5 7 1 6 3 4 1 2 3 1 1 5 2 1 1 7 1 9 1 1 8 1 6 3 5 1 6 4 3 1 1 9 5 7 1 8 2 1 1 5 6 5 3 1 3 6patrat2.out11 3 5"
    },
    {
      "title": "Explicație",
      "html": "<p>În tabloul bidimensional cu <code>6</code> linii și <code>8</code> coloane există <code>11</code> stele strălucitoare. Tabloul conține <code>3</code> constelații pătrate iar cea mai mare are latura pătratului de lungime <code>5</code>. </p>",
      "text": "În tabloul bidimensional cu 6 linii și 8 coloane există 11 stele strălucitoare. Tabloul conține 3 constelații pătrate iar cea mai mare are latura pătratului de lungime 5."
    },
    {
      "title": "Exemplul 2",
      "html": "<p><code>patrat2.in</code></p><pre>2 3\n1 1 1\n1 1 1</pre><p><code>patrat2.out</code></p><pre>0\n0\n0</pre>",
      "text": "patrat2.in2 3 1 1 1 1 1 1patrat2.out0 0 0"
    },
    {
      "title": "Explicație",
      "html": "<p>În tabloul bidimensional cu <code>2</code> linii și <code>3</code> coloane nu există nici o stele strălucitoare. Tabloul conține <code>0</code> constelații pătrate iar cea mai mare are latura pătratului de dimensiune <code>0</code>.</p>",
      "text": "În tabloul bidimensional cu 2 linii și 3 coloane nu există nici o stele strălucitoare. Tabloul conține 0 constelații pătrate iar cea mai mare are latura pătratului de dimensiune 0."
    }
  ],
