  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se numărul natural <code>n</code> ajutați-l pe Gigel să numere câte astfel de șiruri poate să construiască. </p>",
      "text": "Dându-se numărul natural n ajutați-l pe Gigel să numere câte astfel de șiruri poate să construiască."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>sir10.in</code> conține pe prima linie numărul <code>n</code>.</p>",
      "text": "Fișierul de intrare sir10.in conține pe prima linie numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>sir10.out</code> va conține pe prima linie numărul cerut.</p>",
      "text": "Fișierul de ieșire sir10.out va conține pe prima linie numărul cerut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ n ≤ 20000</code></li>\n\t<li><code>3 ≤ k ≤ n</code></li>\n</ul>",
      "text": "3 ≤ n ≤ 20000 3 ≤ k ≤ n"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>sir10.in</code></p><pre>3</pre><p><code>sir10.out</code></p><pre>1</pre>",
      "text": "sir10.in3sir10.out1"
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>sir10.in</code></p><pre>4</pre><p><code>sir10.out</code></p><pre>3</pre>",
      "text": "sir10.in4sir10.out3"
    },
    {
      "title": "Exemplul 3:",
      "html": "<p><code>sir10.in</code></p><pre>5</pre><p><code>sir10.out</code></p><pre>7</pre>",
      "text": "sir10.in5sir10.out7"
    }
  ],
