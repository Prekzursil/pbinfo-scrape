  "tags": [
    "Secventa de suma maxima"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine suma maximă posibilă care se poate obține din două secvențe disjuncte din șir.</p>",
      "text": "Să se determine suma maximă posibilă care se poate obține din două secvențe disjuncte din șir."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi șirul de <code>n</code> numere întregi, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi șirul de n numere întregi, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>S</code>, reprezentând suma maximă care se poate obține din două secvențe disjuncte.</p>",
      "text": "Programul va afișa pe ecran numărul S, reprezentând suma maximă care se poate obține din două secvențe disjuncte."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 100.000</code></li>\n\t<li><code>-100 ≤ a[i] ≤ 100</code></li>\n\t<li>Două secvențe sunt disjuncte dacă nu au niciun element comun.</li>\n</ul>",
      "text": "2 ≤ n ≤ 100.000 -100 ≤ a[i] ≤ 100 Două secvențe sunt disjuncte dacă nu au niciun element comun."
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>6\n2 -1 3 -8 4 -5</pre><p><strong>Ieșire</strong></p><pre>8</pre><h3>Explicație</h3><p>Cele două secvențe care dau suma maximă sunt <code>2 -1 3</code> și <code>4</code>.</p>",
      "text": "Intrare6 2 -1 3 -8 4 -5Ieșire8ExplicațieCele două secvențe care dau suma maximă sunt 2 -1 3 și 4."
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>4\n1 2 3 4</pre><p><strong>Ieșire</strong></p><pre>10</pre><h3>Explicație</h3><p>Secvențele pot fi <code>1 2</code> și <code>3 4</code>.</p>",
      "text": "Intrare4 1 2 3 4Ieșire10ExplicațieSecvențele pot fi 1 2 și 3 4."
    }
  ],
  "examples": [
    {
      "input": "6\n2 -1 3 -8 4 -5",
      "output": "8",
      "explanation": "Cele două secvențe care dau suma maximă sunt 2 -1 3 și 4."
    },
    {
      "input": "4\n1 2 3 4",
      "output": "10",
      "explanation": "Secvențele pot fi 1 2 și 3 4."
    }
  ],
  "constraints": [
    "2 ≤ n ≤ 100.000",
    "-100 ≤ a[i] ≤ 100",
    "Două secvențe sunt disjuncte dacă nu au niciun element comun."
