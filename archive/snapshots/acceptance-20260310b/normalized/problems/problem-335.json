  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se scrie un program care citește numărul natural <code>n</code> și determină suma <code>S=1*2-2*3+3*4-...±n*(n+1)</code>.</p>",
      "text": "Să se scrie un program care citește numărul natural n și determină suma S=1*2-2*3+3*4-...±n*(n+1)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran mesajul <code>Rezultatul este S</code>, unde <code>S</code> reprezintă valoarea calculată.</p>",
      "text": "Programul afișează pe ecran mesajul Rezultatul este S, unde S reprezintă valoarea calculată."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n ≤ 100</code></li>\n</ul>",
      "text": "0 < n ≤ 100"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4</pre><p><strong>Ieșire</strong></p><pre>Rezultatul este -12</pre>",
      "text": "Intrare4IeșireRezultatul este -12"
    }
  ],
