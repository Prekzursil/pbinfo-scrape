  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă o propoziție care conține numai litere mici ale alfabetului englez și spații. Să se afișeze cuvintele din propoziție care conțin numai vocale.</p>",
      "text": "Se dă o propoziție care conține numai litere mici ale alfabetului englez și spații. Să se afișeze cuvintele din propoziție care conțin numai vocale."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură șirul dat.</p>",
      "text": "Programul citește de la tastatură șirul dat."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran cuvintele cerute, în ordinea din propoziție, câte un cuvânt pe linie.</p>",
      "text": "Programul va afișa pe ecran cuvintele cerute, în ordinea din propoziție, câte un cuvânt pe linie."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>propoziția va conține cel mult <code>255</code> de caractere</li>\n</ul>",
      "text": "propoziția va conține cel mult 255 de caractere"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>ei pazesc o oaie</pre><p><strong>Ieșire</strong></p><pre>ei\no\noaie</pre>",
      "text": "Intrareei pazesc o oaieIeșireei o oaie"
    }
