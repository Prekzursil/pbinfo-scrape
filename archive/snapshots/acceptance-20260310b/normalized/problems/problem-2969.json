  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citesc pe rând numere naturale nenule. Să se determine câte din numerele citite sunt termeni ai șirului lui Fibonacci.</p>",
      "text": "Se citesc pe rând numere naturale nenule. Să se determine câte din numerele citite sunt termeni ai șirului lui Fibonacci."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>cautafibo.in</code> conține numere naturale nenule, separate prin spații.</p>",
      "text": "Fișierul de intrare cautafibo.in conține numere naturale nenule, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>cautafibo.out</code> va conține o singură valoare, reprezentând numărul termenilor Fibonacci care se regăsesc în fișierul de intrare.</p>",
      "text": "Fișierul de ieșire cautafibo.out va conține o singură valoare, reprezentând numărul termenilor Fibonacci care se regăsesc în fișierul de intrare."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>numerele din fișierul de intrare vor avea cel mult <code>10</code> cifre</li>\n\t<li>fișierul de intrare va conține cel mult <code>100.000</code> de numere naturale nenule</li>\n</ul>",
      "text": "numerele din fișierul de intrare vor avea cel mult 10 cifre fișierul de intrare va conține cel mult 100.000 de numere naturale nenule"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>cautafibo.in</code></p><pre>5 10 89 1 7 9 8 1 6 55 19 13 55</pre><p><code>cautafibo.out</code></p><pre>8</pre><h3>Explicație</h3><p>Numerele Fibonacci din fișierul de intrare sunt: <code>5 89 1 8 1 55 13 55</code></p>",
      "text": "cautafibo.in5 10 89 1 7 9 8 1 6 55 19 13 55cautafibo.out8ExplicațieNumerele Fibonacci din fișierul de intrare sunt: 5 89 1 8 1 55 13 55"
    }
  ],
