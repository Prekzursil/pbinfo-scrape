  ],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se citește numărul natural <code>n</code>. Să se afișeze primele <code>n</code> numere naturale prime.</p>",
      "text": "Se citește numărul natural n. Să se afișeze primele n numere naturale prime."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran primele <code>n</code> numere naturale prime, în ordine crescătoare, separate prin exact un spațiu.</p>",
      "text": "Programul afișează pe ecran primele n numere naturale prime, în ordine crescătoare, separate prin exact un spațiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>5</pre><p><strong>Date de ieșire</strong></p><pre>2 3 5 7 11</pre>",
      "text": "Date de intrare5Date de ieșire2 3 5 7 11"
    }
  ],
  "examples": [
