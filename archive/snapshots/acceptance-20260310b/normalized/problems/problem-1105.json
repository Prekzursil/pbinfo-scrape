  "tags": [
    "Descompunere in factori"
  ],
  "sections": [
    {
      "title": "Cerinţă",
      "html": "<p>Să se determine numărul tripletelor geometrice limitate de numărul natural <code>N</code>.</p>",
      "text": "Să se determine numărul tripletelor geometrice limitate de numărul natural N."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>tg.in</code> conţine pe prima linie un număr natural <code>N</code>.</p>",
      "text": "Fişierul de intrare tg.in conţine pe prima linie un număr natural N."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>În fişierul de ieşire <code>tg.out</code> se va scrie numărul tripletelor geometrice limitate de <code>N</code>.</p>",
      "text": "În fişierul de ieşire tg.out se va scrie numărul tripletelor geometrice limitate de N."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>4 ≤ N ≤ 4.000.000</code></li>\n</ul>",
      "text": "4 ≤ N ≤ 4.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>tg.in</code></p><pre>8</pre><p><code>tg.out</code></p><pre>2</pre>",
      "text": "tg.in8tg.out2"
    },
    {
      "title": "Explicație",
      "html": "<p> Cele două triplete sunt <code>(1, 2, 4)</code> și <code>(2, 4, 8)</code>.</p>",
      "text": "Cele două triplete sunt (1, 2, 4) și (2, 4, 8)."
    }
  ],
