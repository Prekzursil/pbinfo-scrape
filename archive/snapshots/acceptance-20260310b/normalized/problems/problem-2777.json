  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>p</code> și <code>q</code>, numere naturale. Aflați cel mai mic <code>n</code>, număr natural care satisface condițiile de mai sus.</p>",
      "text": "Se dau p și q, numere naturale. Aflați cel mai mic n, număr natural care satisface condițiile de mai sus."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>bomboane4.in</code> conține pe prima linie numerele <code>p</code> și <code>q</code>.</p>",
      "text": "Fișierul de intrare bomboane4.in conține pe prima linie numerele p și q."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul afișează în fișierul <code>bomboane4.out</code> numărul <code>n</code>.</p>",
      "text": "Programul afișează în fișierul bomboane4.out numărul n."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ p ≤ 10</code><sup><code>18</code></sup></li>\n\t<li><code>1 ≤ q ≤ 10</code><sup><code>18</code></sup></li>\n</ul>",
      "text": "1 ≤ p ≤ 1018 1 ≤ q ≤ 1018"
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>bomboane4.in</code></p><pre>4 7</pre><p><code>bomboane4.out</code></p><pre>27</pre><h3>Explicație</h3><p><code>27 = 4 * 6 + 3</code>. Dacă se împart <code>27</code> de bomboane la <code>4</code> copii, aceștia primesc câte <code>6</code> bomboane și rămân <code>3</code> bomboane.<br>\n<code>27 = 7 * 3 + 6</code>. Dacă se împart <code>27</code> de bomboane la <code>7</code> copii, aceștia primesc câte <code>3</code> bomboane și rămân <code>6</code> bomboane.</p>",
      "text": "bomboane4.in4 7bomboane4.out27Explicație27 = 4 * 6 + 3. Dacă se împart 27 de bomboane la 4 copii, aceștia primesc câte 6 bomboane și rămân 3 bomboane. 27 = 7 * 3 + 6. Dacă se împart 27 de bomboane la 7 copii, aceștia primesc câte 3 bomboane și rămân 6 bomboane."
    },
    {
      "title": "Exemplul 2",
      "html": "<p><code>bomboane4.in</code></p><pre>10 20</pre><p><code>bomboane4.out</code></p><pre>19</pre><h3>Explicație</h3><p><code>19 = 1 * 10 + 9</code>. Dacă se împart <code>19</code> bomboane la <code>10</code> copii, aceștia primesc câte o bomboană și rămân <code>9</code> bomboane.<br>\n<code>19 = 0 * 20 + 19</code>. Dacă se împart <code>19</code>  bomboane la <code>20</code> copii, aceștia primesc câte <code>0</code> bomboane și rămân <code>19</code> bomboane.</p>",
      "text": "bomboane4.in10 20bomboane4.out19Explicație19 = 1 * 10 + 9. Dacă se împart 19 bomboane la 10 copii, aceștia primesc câte o bomboană și rămân 9 bomboane. 19 = 0 * 20 + 19. Dacă se împart 19 bomboane la 20 copii, aceștia primesc câte 0 bomboane și rămân 19 bomboane."
    }
  ],
