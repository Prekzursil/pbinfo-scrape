  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un vector cu <code>n</code> elemente, numere naturale și un număr <code>k</code>. Ordonați crescător primele <code>k</code> elemente ale vectorului și descrescător ultimele <code>n-k</code> elemente.</p><p>Pentru sortare se va folosit metoda <strong>QuickSort</strong> sau <strong>MergeSort</strong>.</p>",
      "text": "Se dă un vector cu n elemente, numere naturale și un număr k. Ordonați crescător primele k elemente ale vectorului și descrescător ultimele n-k elemente.Pentru sortare se va folosit metoda QuickSort sau MergeSort."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> și <code>k</code>, iar apoi <code>n</code> numere naturale, reprezentând elementele vectorului.</p>",
      "text": "Programul citește de la tastatură numerele n și k, iar apoi n numere naturale, reprezentând elementele vectorului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran elementele vectorului, separate prin exact un spațiu, după efectuarea operațiilor cerute.</p>",
      "text": "Programul va afișa pe ecran elementele vectorului, separate prin exact un spațiu, după efectuarea operațiilor cerute."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ k &lt; n ≤ 200 000</code></li>\n\t<li>cele <code>n</code> numere citite vor fi mai mici decât <code>1 000 000 000</code></li>\n</ul>",
      "text": "1 ≤ k < n ≤ 200 000 cele n numere citite vor fi mai mici decât 1 000 000 000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>7 3\n13 1 10 15 3 7 11</pre><p><strong>Ieșire</strong></p><pre>1 10 13 15 11 7 3</pre>",
      "text": "Intrare7 3 13 1 10 15 3 7 11Ieșire1 10 13 15 11 7 3"
    }
  ],
  "examples": [
