  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se cere greutatea maxima pe care trebuie sa o ridice <em>Pagdan</em>.</p>",
      "text": "Se cere greutatea maxima pe care trebuie sa o ridice Pagdan."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>gr.in</code> conține pe prima linie <code>n</code> numărul de papuci, vor urma doua linii, fiecare cu <code>n</code> numere reprezentând greutățile papucilor.</p>",
      "text": "Fișierul de intrare gr.in conține pe prima linie n numărul de papuci, vor urma doua linii, fiecare cu n numere reprezentând greutățile papucilor."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>gr.out</code> va conține un singur număr, reprezentând greutatea maximă care trebuie ridicată.</p>",
      "text": "Fișierul de ieșire gr.out va conține un singur număr, reprezentând greutatea maximă care trebuie ridicată."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n\t<li>greutățile papucilor sunt numere naturale ≤ <code>10</code><sup><code>9</code></sup>.</li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000 greutățile papucilor sunt numere naturale ≤ 109."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>gr.in</code></p><pre>5              \n2 1 8 2 8\n9 9 4 1 4</pre><p><code>gr.out</code></p><pre>2</pre><h3>Explicație</h3><p>Acesta va muta papucul de greutate <code>1</code> de pe raftul <code>2</code> pe raftul <code>1</code> și papucul de greutate <code>2</code> aflat pe poziția <code>4</code> de pe raftul <code>1</code> lângă primul papuc de greutate <code>2</code>.</p>",
      "text": "gr.in5 2 1 8 2 8 9 9 4 1 4gr.out2ExplicațieAcesta va muta papucul de greutate 1 de pe raftul 2 pe raftul 1 și papucul de greutate 2 aflat pe poziția 4 de pe raftul 1 lângă primul papuc de greutate 2."
    }
  ],
