  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dă o matrice cu <code>n</code> linii şi <code>m</code> coloane şi elemente numere naturale. Determinați suma valorilor pare din matrice.</p>",
      "text": "Se dă o matrice cu n linii şi m coloane şi elemente numere naturale. Determinați suma valorilor pare din matrice."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> şi <code>m</code>, iar apoi <code>n*m</code> numere naturale, separate prin spaţii, reprezentând elementele matricei, linie cu linie.</p>",
      "text": "Programul citește de la tastatură numerele n şi m, iar apoi n*m numere naturale, separate prin spaţii, reprezentând elementele matricei, linie cu linie."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran suma căutată <code>S</code>.</p>",
      "text": "Programul afișează pe ecran suma căutată S."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ m,n ≤ 100</code></li>\n\t<li>elementele matricei vor fi mai mici decât <code>10000</code></li>\n</ul>",
      "text": "1 ≤ m,n ≤ 100 elementele matricei vor fi mai mici decât 10000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>4 6\n4 20 15 23 18 9 \n1 8 23 22 14 18 \n17 15 13 18 12 15 \n3 18 8 20 12 5 </pre><p><strong>Date de ieșire</strong></p><pre>192</pre>",
      "text": "Date de intrare4 6 4 20 15 23 18 9 1 8 23 22 14 18 17 15 13 18 12 15 3 18 8 20 12 5 Date de ieșire192"
    }
  ],
