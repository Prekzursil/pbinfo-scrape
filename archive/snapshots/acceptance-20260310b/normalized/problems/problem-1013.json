  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau datele de naștere a <code>n</code> persoane, numerotate de la <code>1</code> la <code>n</code>, în forma <code>an luna zi</code>. Să se determine numărul de ordine al celei mai tinere și al celei mai în vârstă persoană dintre cele date.</p>",
      "text": "Se dau datele de naștere a n persoane, numerotate de la 1 la n, în forma an luna zi. Să se determine numărul de ordine al celei mai tinere și al celei mai în vârstă persoană dintre cele date."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> triplete de numere naturale <code>a l z</code>, reprezentând anul, luna și ziua de naștere a fiecărei persoane.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n triplete de numere naturale a l z, reprezentând anul, luna și ziua de naștere a fiecărei persoane."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran două numere <code>p q</code>, reprezentând numărul de ordine al celei mai tinere, respectiv al celei mai în vârstă persoană.</p>",
      "text": "Programul va afișa pe ecran două numere p q, reprezentând numărul de ordine al celei mai tinere, respectiv al celei mai în vârstă persoană."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n\t<li>cele <code>n</code> date calendaristice sunt corecte</li>\n\t<li>dacă există două sau mai multe persoane cele mai tinere (în vârstă) se va afișa numărul de ordine mai mic</li>\n</ul>",
      "text": "1 ≤ n ≤ 1000 cele n date calendaristice sunt corecte dacă există două sau mai multe persoane cele mai tinere (în vârstă) se va afișa numărul de ordine mai mic"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n1998 5 26\n1987 12 18\n1987 9 25\n2015 1 16\n2015 1 8</pre><p><strong>Ieșire</strong></p><pre>4 3</pre>",
      "text": "Intrare5 1998 5 26 1987 12 18 1987 9 25 2015 1 16 2015 1 8Ieșire4 3"
    }
  ],
  "examples": [
    {
      "input": "5\n1998 5 26\n1987 12 18\n1987 9 25\n2015 1 16\n2015 1 8",
      "output": "4 3"
    }
  ],
