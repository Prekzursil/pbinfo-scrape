  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se scrie un program care citește numărul natural <code>N</code> și determină numărul <code>P</code> de partiții pe două linii ale numărului natural <code>N</code>.</p>",
      "text": "Să se scrie un program care citește numărul natural N și determină numărul P de partiții pe două linii ale numărului natural N."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>pdl.in</code> conţine pe prima linie numărul natural <code>N</code>.</p>",
      "text": "Fișierul de intrare pdl.in conţine pe prima linie numărul natural N."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>pdl.out</code> va conţine pe prima linie restul împărțirii numărul <code>P</code> la <code>3000017</code>.</p>",
      "text": "Fișierul de ieșire pdl.out va conţine pe prima linie restul împărțirii numărul P la 3000017."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 2000</code></li>\n\t<li>un șir de numere este nevid dacă conține cel puțin un element</li>\n</ul>",
      "text": "1 ≤ N ≤ 2000 un șir de numere este nevid dacă conține cel puțin un element"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>pdl.in</code></p><pre>6</pre><p><code>pdl.out</code></p><pre>7</pre><h3>Explicație</h3><p><code>N = 6</code>. Sunt <code>7</code> partiții pe două linii conform exemplului de mai sus.</p>",
      "text": "pdl.in6pdl.out7ExplicațieN = 6. Sunt 7 partiții pe două linii conform exemplului de mai sus."
    }
  ],
