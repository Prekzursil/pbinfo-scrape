  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un șir cu <code>n</code> elemente, numere întregi, și un număr natural <code>k ≤ n</code>. Calculați cea mai mare sumă care poate fi obținută schimbând semnul a exact <code>k</code> elemente aflate pe poziții distincte din șirul dat.</p>",
      "text": "Se dă un șir cu n elemente, numere întregi, și un număr natural k ≤ n. Calculați cea mai mare sumă care poate fi obținută schimbând semnul a exact k elemente aflate pe poziții distincte din șirul dat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi cele <code>n</code> elemente ale șirului, apoi numărul <code>k</code>.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi cele n elemente ale șirului, apoi numărul k."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>S</code>, reprezentând suma maximă determinată.</p>",
      "text": "Programul va afișa pe ecran numărul S, reprezentând suma maximă determinată."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n\t<li>elementele șirului vor fi cuprinse între <code>-1.000.000</code> și <code>1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1000 elementele șirului vor fi cuprinse între -1.000.000 și 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n5 -2 -3 4 1\n1</pre><p><strong>Ieșire</strong></p><pre>11</pre>",
      "text": "Intrare5 5 -2 -3 4 1 1Ieșire11"
    }
  ],
  "examples": [
    {
      "input": "5\n5 -2 -3 4 1\n1",
      "output": "11"
    }
  ],
