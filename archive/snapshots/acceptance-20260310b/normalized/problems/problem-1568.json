  "tags": [
    "Determinarea divizorilor"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citeşte de la tastatură un număr natural <code>n</code>. Să se calculeze şi să se afişeze media aritmetică a tuturor divizorilor săi. Media va fi cu fix <code>2</code> zecimale dupa virgula.</p>",
      "text": "Se citeşte de la tastatură un număr natural n. Să se calculeze şi să se afişeze media aritmetică a tuturor divizorilor săi. Media va fi cu fix 2 zecimale dupa virgula."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>S</code>, reprezentand media aritmetica.</p>",
      "text": "Programul va afișa pe ecran numărul S, reprezentand media aritmetica."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>9</pre><p><strong>Ieșire</strong></p><pre>4.33</pre><h3>Explicație</h3><p>Divizorii lui 9 sunt: <code>1</code>, <code>3</code> si <code>9</code>. Media aritmetica este <code>4.33</code>.</p>",
      "text": "Intrare9Ieșire4.33ExplicațieDivizorii lui 9 sunt: 1, 3 si 9. Media aritmetica este 4.33."
    }
  ],
  "examples": [
    {
