  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un șir de <code>N</code> caractere, format din <strong>litere mici ale alfabetului englez</strong>, din care trebuie eliminate <code>K</code> <strong>secvențe disjuncte</strong> de lungime <code>L</code>. Care este <strong>cel mai mic şir din punct de vedere lexicografic</strong> ce se poate obține după eliminarea celor <code>K</code> secvențe.  </p>",
      "text": "Se dă un șir de N caractere, format din litere mici ale alfabetului englez, din care trebuie eliminate K secvențe disjuncte de lungime L. Care este cel mai mic şir din punct de vedere lexicografic ce se poate obține după eliminarea celor K secvențe."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Prima linie conține numărul de caractere <code>N</code> al şirului, numărul <code>K</code> al secvențelor care trebuie eliminate şi numărul <code>L</code> al lungimii unei secvențe ce trebuie eliminate. Cea de-a doua linie conţine <code>N</code> <strong>litere mici ale alfabetului englez</strong>, neseparate prin spaţii.</p>",
      "text": "Prima linie conține numărul de caractere N al şirului, numărul K al secvențelor care trebuie eliminate şi numărul L al lungimii unei secvențe ce trebuie eliminate. Cea de-a doua linie conţine N litere mici ale alfabetului englez, neseparate prin spaţii."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <strong>cel mai mic şir din punct de vedere lexicografic</strong> ce se poate obține după eliminările făcute.</p>",
      "text": "Programul va afișa pe ecran cel mai mic şir din punct de vedere lexicografic ce se poate obține după eliminările făcute."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 2.000.000</code></li>\n\t<li><code>0 ≤ K * L &lt; N</code></li>\n\t<li><strong>șirul de caractere este format din litere mici ale alfabetului englez</strong></li>\n</ul>",
      "text": "1 ≤ N ≤ 2.000.000 0 ≤ K * L < N șirul de caractere este format din litere mici ale alfabetului englez"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>10 3 2\nanaaremere</pre><p><strong>Ieșire</strong></p><pre>aame</pre><h3>Explicație</h3><p>Se vor elimina secvențele <code>a</code><u><code>na</code></u><code>a</code><u><code>re</code></u><code>me</code><u><code>re</code></u> obținând : <code>aame</code>, acesta fiind <strong>cel mai mic şir din punct de vedere lexicografic</strong>.</p>",
      "text": "Intrare10 3 2 anaaremereIeșireaameExplicațieSe vor elimina secvențele anaaremere obținând : aame, acesta fiind cel mai mic şir din punct de vedere lexicografic."
    }
  ],
  "examples": [
    {
      "input": "10 3 2\nanaaremere",
      "output": "aame",
      "explanation": "Se vor elimina secvențele anaaremere obținând : aame, acesta fiind cel mai mic şir din punct de vedere lexicografic."
    }
  ],
