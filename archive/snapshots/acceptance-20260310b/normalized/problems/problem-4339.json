  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Stabiliți dacă dintre cele trei numere citite sunt mai multe numere pare sau mai multe impare.</p>",
      "text": "Stabiliți dacă dintre cele trei numere citite sunt mai multe numere pare sau mai multe impare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citeşte de la tastatură <code>3</code> numere întregi separate prin spaţii.</p>",
      "text": "Programul citeşte de la tastatură 3 numere întregi separate prin spaţii."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul va afişa pe ecran mesajul <code>pare</code> dacă sunt cel puțin două numere pare dintre cele trei citite, despectiv mesajul <code>impare</code> în caz contrar.</p>",
      "text": "Programul va afişa pe ecran mesajul pare dacă sunt cel puțin două numere pare dintre cele trei citite, despectiv mesajul impare în caz contrar."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>Numerele citite sunt mai mic decât <code>1.000.000.000</code></li>\n</ul>",
      "text": "Numerele citite sunt mai mic decât 1.000.000.000"
    },
    {
      "title": "Exemplu 1:",
      "html": "<p><strong>Intrare</strong></p><pre>125 68 200</pre><p><strong>Ieşire</strong></p><pre>pare</pre>",
      "text": "Intrare125 68 200Ieşirepare"
    },
    {
      "title": "Exemplu 2:",
      "html": "<p><strong>Intrare</strong></p><pre>125 681 2001</pre><p><strong>Ieşire</strong></p><pre>impare</pre>",
      "text": "Intrare125 681 2001Ieşireimpare"
    }
  ],
