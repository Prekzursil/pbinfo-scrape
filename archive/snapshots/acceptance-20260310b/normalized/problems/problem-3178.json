  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Într-o clasă sunt <code>F</code> fete și <code>B</code> băieți. Fiecare fată citește <code>3</code> pagini pe zi și fiecare băiat citește <code>2</code> pagini pe zi. Câte pagini vor citi copiii în <code>n</code> zile?</p>",
      "text": "Într-o clasă sunt F fete și B băieți. Fiecare fată citește 3 pagini pe zi și fiecare băiat citește 2 pagini pe zi. Câte pagini vor citi copiii în n zile?"
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele naturale <code>F B n</code>.</p>",
      "text": "Programul citește de la tastatură numerele naturale F B n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul total de pagini citite.</p>",
      "text": "Programul va afișa pe ecran numărul total de pagini citite."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ F , B , n ≤ 1000</code></li>\n</ul>",
      "text": "1 ≤ F , B , n ≤ 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>7 5 3</pre><p><strong>Ieșire</strong></p><pre>93</pre>",
      "text": "Intrare7 5 3Ieșire93"
    },
    {
      "title": "Explicație",
      "html": "<p>Sunt <code>F=7</code> fete, <code>B=5</code> băieți și citesc <code>n=3</code> zile. Împreună vor citi <code>93</code> de pagini.</p>",
      "text": "Sunt F=7 fete, B=5 băieți și citesc n=3 zile. Împreună vor citi 93 de pagini."
    }
  ],
  "examples": [
    {
      "input": "7 5 3",
      "output": "93"
    }
  ],
