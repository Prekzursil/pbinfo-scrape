  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se calculeze câte secvențe nevide au proprietatea că raportul dintre numărul elementelor pare din cadrul secvenței și lungimea secvenței este exact <code>D</code>.</p>",
      "text": "Să se calculeze câte secvențe nevide au proprietatea că raportul dintre numărul elementelor pare din cadrul secvenței și lungimea secvenței este exact D."
    },
    {
      "title": "Date de intrare",
      "html": "<p>În fișierul de intrare <code>densitate.in</code>, pe prima linie se află numărul <code>N</code>, ce reprezintă lungimea șirului de numere. Pe a doua linie se află, separate prin câte un spațiu, <code>N</code> numere naturale. Pe a treia linie se află densitatea <code>D</code>, reprezentată cu două zecimale exacte sub forma <code>0.ab</code>.</p>",
      "text": "În fișierul de intrare densitate.in, pe prima linie se află numărul N, ce reprezintă lungimea șirului de numere. Pe a doua linie se află, separate prin câte un spațiu, N numere naturale. Pe a treia linie se află densitatea D, reprezentată cu două zecimale exacte sub forma 0.ab."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>densitate.out</code> va conține o singură linie pe care se va afla numărul secvențelor ce respectă proprietatea din enunț.</p>",
      "text": "Fișierul de ieșire densitate.out va conține o singură linie pe care se va afla numărul secvențelor ce respectă proprietatea din enunț."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 100.000</code></li>\n\t<li><code>0 ≤ A[i] ≤ 1.000.000</code>, <code>1 ≤ i ≤ N</code>.</li>\n\t<li><code>0 ≤ D ≤ 0.99</code></li>\n\t<li>Prin secvență a șirului <code>A</code> se înțelege orice succesiune de elemente aflate pe poziții consecutive <code>A[j]</code>, <code>A[j+1]</code>, <code>A[j+2]</code>, …, <code>A[k]</code>, cu <code>1 ≤ j ≤ k ≤ N</code>.</li>\n</ul>",
      "text": "1 ≤ N ≤ 100.000 0 ≤ A[i] ≤ 1.000.000, 1 ≤ i ≤ N. 0 ≤ D ≤ 0.99 Prin secvență a șirului A se înțelege orice succesiune de elemente aflate pe poziții consecutive A[j], A[j+1], A[j+2], …, A[k], cu 1 ≤ j ≤ k ≤ N."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>densitate.in</code></p><pre>6\n1 0 3 5 2 7\n0.50</pre><p><code>densitate.out</code></p><pre>5</pre><h3>Explicație</h3><p>Sunt <code>5</code> secvențe cu densitate <code>0.50</code>: <code>1 0</code>; <code>0 3</code>; <code>5 2</code>; <code>2 7</code>; <code>0 3 5 2</code>.</p>",
      "text": "densitate.in6 1 0 3 5 2 7 0.50densitate.out5ExplicațieSunt 5 secvențe cu densitate 0.50: 1 0; 0 3; 5 2; 2 7; 0 3 5 2."
    }
  ],
