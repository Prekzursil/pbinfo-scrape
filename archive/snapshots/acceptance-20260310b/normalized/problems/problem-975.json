  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă o propoziție formată din litere mici ale alfabetului englez, spații și semnele de punctuație <code>,.</code>. Determinați un cuvânt palindrom din propoziție, primul în ordine alfabetică.</p>",
      "text": "Se dă o propoziție formată din litere mici ale alfabetului englez, spații și semnele de punctuație ,.. Determinați un cuvânt palindrom din propoziție, primul în ordine alfabetică."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură propoziția dată.</p>",
      "text": "Programul citește de la tastatură propoziția dată."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran cuvântul determinat, sau mesajul <code>IMPOSIBIL</code>, dacă în șir nu există niciun cuvânt palindrom.</p>",
      "text": "Programul va afișa pe ecran cuvântul determinat, sau mesajul IMPOSIBIL, dacă în șir nu există niciun cuvânt palindrom."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>propoziția citită va conține cel mult <code>255</code> de caractere</li>\n\t<li>cuvintele din propoziție vor avea maximum <code>10</code> litere</li>\n</ul>",
      "text": "propoziția citită va conține cel mult 255 de caractere cuvintele din propoziție vor avea maximum 10 litere"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>ele deschid un capac, aerisirea este ok</pre><p><strong>Ieșire</strong></p><pre>aerisirea</pre>",
      "text": "Intrareele deschid un capac, aerisirea este okIeșireaerisirea"
    }
  ],
