  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Un număr este special dacă are o cifră cu frecvența strict mai mare decât partea întreagă a jumătății lungimii numărului și nu conține cifra <code>0</code>. Câte numere speciale există respectiv care este suma tuturor numerelor speciale de lungime <code>N</code>.</p>",
      "text": "Un număr este special dacă are o cifră cu frecvența strict mai mare decât partea întreagă a jumătății lungimii numărului și nu conține cifra 0. Câte numere speciale există respectiv care este suma tuturor numerelor speciale de lungime N."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>spnum.in</code> conține pe prima linie numărul <code>N</code> cu semnificația din enunț.</p>",
      "text": "Fișierul de intrare spnum.in conține pe prima linie numărul N cu semnificația din enunț."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>spnum.out</code> va conține pe prima linie numărul <code>Nr S</code> numărul de numere speciale de lungime <code>N</code> și suma tuturor numerelor speciale de lungime <code>N</code> separate printr-un spațiu.</p>",
      "text": "Fișierul de ieșire spnum.out va conține pe prima linie numărul Nr S numărul de numere speciale de lungime N și suma tuturor numerelor speciale de lungime N separate printr-un spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 200</code></li>\n\t<li>Rezultatul se va tipări modulo <code>666013</code>.</li>\n\t<li>Pentru <code>15 puncte 1 &lt;= N &lt;= 7</code>.</li>\n</ul>",
      "text": "1 ≤ N ≤ 200 Rezultatul se va tipări modulo 666013. Pentru 15 puncte 1 <= N <= 7."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>spnum.in</code></p><pre>2</pre><p><code>spnum.out</code></p><pre>9 495</pre><h3>Explicație</h3><p>Sunt <code>9</code> numere speciale de lungime <code>2</code> : <code>11</code>, <code>22</code>, <code>33</code>, <code>44</code>, <code>55</code>, <code>66</code>, <code>77</code>, <code>88</code>, <code>99</code>, care au suma <code>495</code>.</p>",
      "text": "spnum.in2spnum.out9 495ExplicațieSunt 9 numere speciale de lungime 2 : 11, 22, 33, 44, 55, 66, 77, 88, 99, care au suma 495."
    }
  ],
