  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se consideră <code>n</code> tipuri de bancnote, cu valorile <code>v[1] v[2] ... v[n]</code>, ordonate strict crescător. Se cere să se determine o modalitate de a plăti integral o sumă dată <code>S</code> cu bancnotele disponibile, știind că se pot folosi oricâte bancnote de orice tip.</p>",
      "text": "Se consideră n tipuri de bancnote, cu valorile v[1] v[2] ... v[n], ordonate strict crescător. Se cere să se determine o modalitate de a plăti integral o sumă dată S cu bancnotele disponibile, știind că se pot folosi oricâte bancnote de orice tip."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n</code> și <code>S</code>, apoi valorile  <code>v[1] v[2] ... v[n]</code> ale bancnotelor.</p>",
      "text": "Programul citește de la tastatură numerele n și S, apoi valorile v[1] v[2] ... v[n] ale bancnotelor."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran <code>n</code> numere, reprezentând o modalitate de plată a sumei <code>S</code>. Fiecare număr <code>x[i]</code> va reprezenta numărul de bancnote de valoarea <code>v[i]</code> folosite pentru plata sumei <code>S</code>.</p>",
      "text": "Programul va afișa pe ecran n numere, reprezentând o modalitate de plată a sumei S. Fiecare număr x[i] va reprezenta numărul de bancnote de valoarea v[i] folosite pentru plata sumei S."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 6</code></li>\n\t<li><code>1 ≤ S ≤ 1000</code></li>\n\t<li><code>1 ≤ v[i] ≤ 100</code></li>\n\t<li>oricare variantă corectă de plată a sumei <code>S</code> va fi luată în considerare</li>\n\t<li>pentru toate seturile de date există soluție</li>\n</ul>",
      "text": "1 ≤ n ≤ 6 1 ≤ S ≤ 1000 1 ≤ v[i] ≤ 100 oricare variantă corectă de plată a sumei S va fi luată în considerare pentru toate seturile de date există soluție"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 375\n1 5 10 50 100</pre><p><strong>Ieșire</strong></p><pre>5 2 1 1 3 </pre><h3>Observații</h3><p>Există și alte soluții valide.</p>",
      "text": "Intrare5 375 1 5 10 50 100Ieșire5 2 1 1 3 ObservațiiExistă și alte soluții valide."
    }
  ],
