  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine cel mai mic număr natural care respectă condițiile lui Gigel.</p>",
      "text": "Să se determine cel mai mic număr natural care respectă condițiile lui Gigel."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>consecutive.in</code> conține pe prima linie numărul <code>N</code>, reprezentând numărul de moduri în care numărul găsit de Gigel să poată fi scris ca suma de numere consecutive</p>",
      "text": "Fișierul de intrare consecutive.in conține pe prima linie numărul N, reprezentând numărul de moduri în care numărul găsit de Gigel să poată fi scris ca suma de numere consecutive"
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>consecutive.out</code> va conține pe prima linie numărul <code>x</code>, reprezentând numărul găsit de Gigel, iar pe următoarele <code>N</code> linii va fi afișat câte un număr, reprezentând lungimea secvenţei.</p>",
      "text": "Fișierul de ieșire consecutive.out va conține pe prima linie numărul x, reprezentând numărul găsit de Gigel, iar pe următoarele N linii va fi afișat câte un număr, reprezentând lungimea secvenţei."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n\t<li>Se garantează că soluţia e mai mică decât <code>1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100 Se garantează că soluţia e mai mică decât 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>consecutive.in</code></p><pre>2</pre><p><code>consecutive.out</code></p><pre>9\n2\n3</pre><h3>Explicație</h3><p><code>9 = 4 + 5</code> (secventa de lungime <code>2</code> care incepe de la <code>4</code>)<br>\n<code>9 = 2 + 3 + 4</code> (secventa de lungime <code>3</code> care incepe de la <code>2</code>)</p>",
      "text": "consecutive.in2consecutive.out9 2 3Explicație9 = 4 + 5 (secventa de lungime 2 care incepe de la 4) 9 = 2 + 3 + 4 (secventa de lungime 3 care incepe de la 2)"
    }
  ],
