  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Să se scrie un program care citeşte de la tastatură un număr natural şi verifică dacă numărul este par sau impar.</p>",
      "text": "Să se scrie un program care citeşte de la tastatură un număr natural şi verifică dacă numărul este par sau impar."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul va citi de la tastatură un număr natural <code>n</code>.</p>",
      "text": "Programul va citi de la tastatură un număr natural n."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul va afişa pe ecran mesajul <code>n este par</code>, dacă numărul citit <code>n</code> este par, respectiv mesajul <code>n este impar</code> în caz contrar, <strong>ca în exemplu</strong>.</p>",
      "text": "Programul va afişa pe ecran mesajul n este par, dacă numărul citit n este par, respectiv mesajul n este impar în caz contrar, ca în exemplu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n &lt; 1.000.000.000</code></li>\n</ul>",
      "text": "0 < n < 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>2012</pre><p><strong>Ieşire</strong></p><pre>2012 este par</pre>",
      "text": "Intrare2012Ieşire2012 este par"
    }
  ],
  "examples": [
    {
      "input": "2012 este par",
      "output": ""
    }
  ],
  "constraints": [
    "0 < n < 1.000.000.000"
  ],
