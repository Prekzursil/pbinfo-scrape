  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dă o matrice cu <code>n</code> linii și <code>n</code> coloane și elemente numere naturale. Calculați diferența în valoare absolută dintre sumele elementelor de pe cele două diagonale.</p>",
      "text": "Se dă o matrice cu n linii și n coloane și elemente numere naturale. Calculați diferența în valoare absolută dintre sumele elementelor de pe cele două diagonale."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n*n</code> numere naturale, separate prin spații, reprezentând elementele matricei, linie cu linie.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n*n numere naturale, separate prin spații, reprezentând elementele matricei, linie cu linie."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul afișează pe ecran numărul <code>D</code>, reprezentând valoarea calculată.</p>",
      "text": "Programul afișează pe ecran numărul D, reprezentând valoarea calculată."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 20</code></li>\n\t<li>elementele matricei vor fi mai mici decât <code>10000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 20 elementele matricei vor fi mai mici decât 10000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>4\n8 3 3 7 \n1 1 6 5 \n8 7 1 1 \n9 8 7 1 </pre><p><strong>Date de ieșire</strong></p><pre>18</pre>",
      "text": "Date de intrare4 8 3 3 7 1 1 6 5 8 7 1 1 9 8 7 1 Date de ieșire18"
    },
    {
      "title": "Explicație",
      "html": "<p>Sumele elementelor pe cele două diagonale sunt: <code>11</code> și <code>29</code>. Diferența în valoare absolută este: <code>18</code></p>",
      "text": "Sumele elementelor pe cele două diagonale sunt: 11 și 29. Diferența în valoare absolută este: 18"
    }
  ],
  "examples": [
    {
      "input": "4\n8 3 3 7 \n1 1 6 5 \n8 7 1 1 \n9 8 7 1",
      "output": "18"
    }
  ],
