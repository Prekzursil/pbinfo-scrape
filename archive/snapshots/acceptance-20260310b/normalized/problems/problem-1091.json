  "sections": [
    {
      "title": "Cerinţă",
      "html": "<p>Cunoscând <code>n</code> numărul de scânduri din gard, <code>d</code> numărul desenelor originale şi <code>k</code> numărul minim de apariţii al fiecărui desen, să se determine în câte moduri poate fi aranjată expoziţia, ştiind că Ilinca are la dispoziţie oricâte copii doreşte.</p>",
      "text": "Cunoscând n numărul de scânduri din gard, d numărul desenelor originale şi k numărul minim de apariţii al fiecărui desen, să se determine în câte moduri poate fi aranjată expoziţia, ştiind că Ilinca are la dispoziţie oricâte copii doreşte."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>expozitie.in</code> conține <code>3</code> numere <code>n  d  k</code> – numărul de scânduri, numărul desenelor originale, respectiv numărul minim de aparţii</p>",
      "text": "Fișierul de intrare expozitie.in conține 3 numere n d k – numărul de scânduri, numărul desenelor originale, respectiv numărul minim de aparţii"
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>expozitie.out</code> va conține un singur număr <code>nr</code> – numărul modurilor distincte de aranjare a expoziţiei</p>",
      "text": "Fișierul de ieșire expozitie.out va conține un singur număr nr – numărul modurilor distincte de aranjare a expoziţiei"
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>n</code>, <code>k</code>, <code>d</code> sunt numere naturale</li>\n\t<li><code>1 ≤ n ≤ 500</code></li>\n\t<li><code>1 ≤ d ≤ 500</code></li>\n\t<li><code>0 ≤ k ≤ n</code></li>\n</ul>",
      "text": "n, k, d sunt numere naturale 1 ≤ n ≤ 500 1 ≤ d ≤ 500 0 ≤ k ≤ n"
    },
    {
      "title": "Exemplu",
      "html": "<p><code>expozitie.in</code></p><pre>3 2 1</pre><p><code>expozitie.out</code></p><pre>2</pre>",
      "text": "expozitie.in3 2 1expozitie.out2"
    },
    {
      "title": "Explicație",
      "html": "<p>Sunt <code>3</code> scânduri, <code>2</code> desene originale şi fiecare desen trebuie să apară cel puţin o data. Există <code>2</code> moduri de aranjare. Planşele ar putea fi aşezate astfel:<br>\n<code>1 2 1</code><br>\n<code>1 2 2</code></p>",
      "text": "Sunt 3 scânduri, 2 desene originale şi fiecare desen trebuie să apară cel puţin o data. Există 2 moduri de aranjare. Planşele ar putea fi aşezate astfel: 1 2 1 1 2 2"
    }
  ],
