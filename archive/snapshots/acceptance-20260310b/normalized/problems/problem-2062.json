  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând <code>n</code>, <code>T</code> și duratele pieselor, determinaţi numărul de variante distincte pe care le are Ion de a interpreta piese astfel încât durata lor să nu depăşească <code>T</code>.</p>",
      "text": "Cunoscând n, T și duratele pieselor, determinaţi numărul de variante distincte pe care le are Ion de a interpreta piese astfel încât durata lor să nu depăşească T."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>piese1.in</code> conține pe prima linie numerele <code>n</code> şi <code>T</code> având semnificaţia din enunţ. Pe linia a doua se găsesc n numere naturale <code>t[1]</code>, <code>t[2]</code>, …, <code>t[n]</code>, separate printr-un singur spaţiu, reprezentând duratele pieselor din repertoriul lui Ion.</p>",
      "text": "Fișierul de intrare piese1.in conține pe prima linie numerele n şi T având semnificaţia din enunţ. Pe linia a doua se găsesc n numere naturale t[1], t[2], …, t[n], separate printr-un singur spaţiu, reprezentând duratele pieselor din repertoriul lui Ion."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>piese1.out</code> va conţine pe o singură linie un număr natural ce reprezintă numărul de variante distincte pe care le are Ion de a interpreta piese din repertoriul său, astfel încât  durata lor să nu depăşească <code>T</code>.</p>",
      "text": "Fișierul de ieșire piese1.out va conţine pe o singură linie un număr natural ce reprezintă numărul de variante distincte pe care le are Ion de a interpreta piese din repertoriul său, astfel încât durata lor să nu depăşească T."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 30</code></li>\n\t<li><code>1 ≤ x1, x2, ..., xn, T ≤ 1 000 000 000</code></li>\n\t<li>Ordinea de prezentare a pieselor în spectacol nu este relevantă.</li>\n</ul>",
      "text": "2 ≤ n ≤ 30 1 ≤ x1, x2, ..., xn, T ≤ 1 000 000 000 Ordinea de prezentare a pieselor în spectacol nu este relevantă."
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><code>piese1.in</code></p><pre>3 2\n4 3 5</pre><p><code>piese1.out</code></p><pre>0</pre><h3>Explicație</h3><p>Nu există nicio variantă. Toate piesele durează mai mult de <code>T</code> unități de timp.</p>",
      "text": "piese1.in3 2 4 3 5piese1.out0ExplicațieNu există nicio variantă. Toate piesele durează mai mult de T unități de timp."
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><code>piese1.in</code></p><pre>4 6\n2 4 5 1</pre><p><code>piese1.out</code></p><pre>8</pre><h3>Explicație</h3><p>Sunt <code>8</code> variante posibile: <code>2</code>, <code>4</code>, <code>5</code>, <code>1</code>, <code>2+4</code>, <code>2+1</code>, <code>4+1</code>, <code>5+1</code>.</p>",
      "text": "piese1.in4 6 2 4 5 1piese1.out8ExplicațieSunt 8 variante posibile: 2, 4, 5, 1, 2+4, 2+1, 4+1, 5+1."
    }
  ],
