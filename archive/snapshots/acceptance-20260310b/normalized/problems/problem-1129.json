  "tags": [],
  "sections": [
    {
      "title": "Cerinţă",
      "html": "<p>Cunoscând n numărul de linii și de coloane ale țintei: </p><p><strong>a.</strong> Ajutați-l pe Alex să construiască ținta visată.<br>\n<strong>b.</strong> Câte punctaje distincte poate să obțină Alex dacă are o singură săgeată?<br>\n<strong>c.</strong> Afișați punctajele distincte găsite.</p>",
      "text": "Cunoscând n numărul de linii și de coloane ale țintei: a. Ajutați-l pe Alex să construiască ținta visată. b. Câte punctaje distincte poate să obțină Alex dacă are o singură săgeată? c. Afișați punctajele distincte găsite."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>tinta.in</code> conține pe prima linie numărul natural <code>n</code>, indicând numărul de linii și de coloane ale țintei.</p>",
      "text": "Fișierul de intrare tinta.in conține pe prima linie numărul natural n, indicând numărul de linii și de coloane ale țintei."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>tinta.out</code> va conține pe primele <code>n</code> linii câte <code>n</code> numere naturale, separate prin câte un spațiu, reprezentând numerele de pe cele <code>n</code> linii ale țintei. Pe linia <code>n+1</code> se va afișa un singur număr  <code>p</code> reprezentând  numărul de punctaje distincte. Pe linia <code>n+2</code> se vor afișa <code>p</code> numere naturale separate prin câte un spațiu și ordonate strict crescător, reprezentând punctajele distincte.</p>",
      "text": "Fișierul de ieșire tinta.out va conține pe primele n linii câte n numere naturale, separate prin câte un spațiu, reprezentând numerele de pe cele n linii ale țintei. Pe linia n+1 se va afișa un singur număr p reprezentând numărul de punctaje distincte. Pe linia n+2 se vor afișa p numere naturale separate prin câte un spațiu și ordonate strict crescător, reprezentând punctajele distincte."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ n ≤ 1000</code></li>\n\t<li>Pentru prima cerinţă afişată corect se va acorda 40% din punctaj; pentru a doua cerință se va acorda 20% din punctaj; pentru cea de-a treia cerință se va acorda 40% din punctaj.</li>\n</ul>",
      "text": "3 ≤ n ≤ 1000 Pentru prima cerinţă afişată corect se va acorda 40% din punctaj; pentru a doua cerință se va acorda 20% din punctaj; pentru cea de-a treia cerință se va acorda 40% din punctaj."
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>tinta.in</code></p><pre>3</pre><p><code>tinta.out</code></p><pre>1  2  6  \n3  5  7  \n4  8  9\n1\n40</pre>",
      "text": "tinta.in3tinta.out1 2 6 3 5 7 4 8 9 1 40"
    },
    {
      "title": "Explicație",
      "html": "<p>Alex poate ținti doar în pătrățelul interior (cel pe care avem <code>5</code>), deci obține un singur punctaj, iar suma este <code>40</code>.</p>",
      "text": "Alex poate ținti doar în pătrățelul interior (cel pe care avem 5), deci obține un singur punctaj, iar suma este 40."
    },
    {
      "title": "Exemplul 2",
      "html": "<p><code>tinta.in</code></p><pre>4</pre><p><code>tinta.out</code></p><pre>1 2 6 7\n3 5 8 13\n4 9 12 14\n10 11 15 16\n3\n45 68 91</pre>",
      "text": "tinta.in4tinta.out1 2 6 7 3 5 8 13 4 9 12 14 10 11 15 16 3 45 68 91"
    },
    {
      "title": "Explicație",
      "html": "<p>Alex poate ținti doar pătrăţelele <code>5</code>, <code>8</code>, <code>9</code> sau <code>12</code>.</p>",
      "text": "Alex poate ținti doar pătrăţelele 5, 8, 9 sau 12."
    }
  ],
