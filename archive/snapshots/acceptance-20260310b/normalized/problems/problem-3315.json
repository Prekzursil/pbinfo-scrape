  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n</code> numere naturale. Pentru fiecare număr aflaţi câţi divizori <i>liberi de pătrate</i> are acesta.</p>",
      "text": "Se dau n numere naturale. Pentru fiecare număr aflaţi câţi divizori liberi de pătrate are acesta."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>eratostene4.in</code> conține pe prima linie numărul <code>n</code>, iar pe a doua linie <code>n</code> numere naturale separate prin spații.</p>",
      "text": "Fișierul de intrare eratostene4.in conține pe prima linie numărul n, iar pe a doua linie n numere naturale separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>eratostene4.out</code> va conține pe prima linie, pentru fiecare număr din fişierul de intrare, numărul divizorilor liberi de pătrate ai acestuia. </p>",
      "text": "Fișierul de ieșire eratostene4.out va conține pe prima linie, pentru fiecare număr din fişierul de intrare, numărul divizorilor liberi de pătrate ai acestuia."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n\t<li>numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât <code>10.000.000</code></li>\n\t<li>un număr natural se numeşte <i>liber de pătrate</i> dacă nu se divide cu pătratul unui număr prim</li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000 numerele de pe a doua linie a fișierului de intrare vor fi mai mici decât 10.000.000 un număr natural se numeşte liber de pătrate dacă nu se divide cu pătratul unui număr prim"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>eratostene4.in</code></p><pre>3\n20 8 5</pre><p><code>eratostene4.out</code></p><pre>4 2 2</pre><h3>Explicație</h3><p>Divizorii lui <code>20</code>, liberi de pătrate, sunt: <code>1, 2, 5, 10</code>.<br>\nDivizorii lui <code>8</code>, liberi de pătrate, sunt: <code>1, 2</code>. <br>\nDivizorii lui <code>5</code>, liberi de pătrate, sunt: <code>1, 5</code>.</p>",
      "text": "eratostene4.in3 20 8 5eratostene4.out4 2 2ExplicațieDivizorii lui 20, liberi de pătrate, sunt: 1, 2, 5, 10. Divizorii lui 8, liberi de pătrate, sunt: 1, 2. Divizorii lui 5, liberi de pătrate, sunt: 1, 5."
    }
  ],
