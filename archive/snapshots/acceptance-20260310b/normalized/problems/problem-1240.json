  "tags": [
    "Cautare binara"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se se determine pentru <code>n</code> numere <code>a</code> valoarea <code>b</code> maximă astfel încât <code>b</code><sup><code>3</code></sup><code> + b ≤ a</code>.</p>",
      "text": "Se se determine pentru n numere a valoarea b maximă astfel încât b3 + b ≤ a."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>ab3.in</code> conține pe prima linie numărul <code>n</code>, iar pe următoarele <code>n</code> linii câte un număr <code>a</code>.</p>",
      "text": "Fișierul de intrare ab3.in conține pe prima linie numărul n, iar pe următoarele n linii câte un număr a."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>ab3.out</code> va conține <code>n</code> linii cu câte un număr fiecare, răspunsul la fiecare întrebare.</p>",
      "text": "Fișierul de ieșire ab3.out va conține n linii cu câte un număr fiecare, răspunsul la fiecare întrebare."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n\t<li><code>0 ≤ a ≤ 10</code><sup><code>18</code></sup></li>\n\t<li>Pentru <code>40%</code> din teste, se garantează că <code>n * b ≤ 10</code><sup><code>6</code></sup></li>\n\t<li><b>Atenție la limita de memorie!</b></li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000 0 ≤ a ≤ 1018 Pentru 40% din teste, se garantează că n * b ≤ 106 Atenție la limita de memorie!"
    },
    {
      "title": "Exemple:",
      "html": "<p><code>ab3.in</code></p><pre>5\n1 \n9 \n36\n27\n89</pre><p><code>ab3.out</code></p><pre>0\n1\n3\n2\n4</pre>",
      "text": "ab3.in5 1 9 36 27 89ab3.out0 1 3 2 4"
    },
    {
      "title": "Explicație",
      "html": "<p><code>1</code><sup><code>3</code></sup><code> + 1 = 2</code><br>\n<code>2</code><sup><code>3</code></sup><code> + 2 = 10</code><br>\n<code>3</code><sup><code>3</code></sup><code> + 3 = 30</code><br>\n<code>4</code><sup><code>3</code></sup><code> + 4 = 68</code><br>\n<code>5</code><sup><code>3</code></sup><code> + 5 = 130</code></p>",
      "text": "13 + 1 = 2 23 + 2 = 10 33 + 3 = 30 43 + 4 = 68 53 + 5 = 130"
    }
  ],
