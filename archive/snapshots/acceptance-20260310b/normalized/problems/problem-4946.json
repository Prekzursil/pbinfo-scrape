  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Ajută-l pe Robo-Bib să numere câte cărți speciale are în bibliotecă.</p>",
      "text": "Ajută-l pe Robo-Bib să numere câte cărți speciale are în bibliotecă."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>biblio.in</code> conține pe prima linie numărul <code>N</code> reprezentând numărul de cărți iar pe următoarele <code>N</code> linii câte un cod ce este asociat fiecărei cărți.</p>",
      "text": "Fișierul de intrare biblio.in conține pe prima linie numărul N reprezentând numărul de cărți iar pe următoarele N linii câte un cod ce este asociat fiecărei cărți."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>biblio.out</code> va conține o singură linie cu numărul total de cărți speciale.</p>",
      "text": "Fișierul de ieșire biblio.out va conține o singură linie cu numărul total de cărți speciale."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>N</code> este număr natural nenul de maximum <code>7</code> cifre</li>\n\t<li>fiecare cod are maximum <code>9</code> cifre.</li>\n</ul>",
      "text": "N este număr natural nenul de maximum 7 cifre fiecare cod are maximum 9 cifre."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>biblio.in</code></p><pre>6\n2\n11\n222\n2020\n123455\n20021332</pre><p><code>biblio.out</code></p><pre>3</pre><h3>Explicație</h3><p>Codurile cu valorile <code>11</code>, <code>222</code> și <code>20021332</code> respectă cerința.</p>",
      "text": "biblio.in6 2 11 222 2020 123455 20021332biblio.out3ExplicațieCodurile cu valorile 11, 222 și 20021332 respectă cerința."
    }
  ],
  "examples": [
