  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se scrie un program care citeşte numerele naturale <code>n</code> şi <code>p</code> și determină numărul <code>M(p)</code>.</p>",
      "text": "Să se scrie un program care citeşte numerele naturale n şi p și determină numărul M(p)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>pascal.in</code> conține pe prima linie numerele naturale <code>n</code> și <code>p</code> separate printr-un spațiu.</p>",
      "text": "Fișierul de intrare pascal.in conține pe prima linie numerele naturale n și p separate printr-un spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>pascal.out</code> va conține pe prima linie numărul <code>M(p)</code> cu semnificația de mai sus.</p>",
      "text": "Fișierul de ieșire pascal.out va conține pe prima linie numărul M(p) cu semnificația de mai sus."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 10</code><sup><code style=\"font-size:0.8em;\">9</code></sup></li>\n\t<li><code>2 ≤ p ≤ 10</code><sup><code style=\"font-size:0.8em;\">3</code></sup></li>\n\t<li><code>30%</code> din teste au <code>n ≤ 10</code><sup><code style=\"font-size:0.8em;\">4</code></sup></li>\n\t<li><code>50%</code> din teste au <code>n ≤ 10</code><sup><code style=\"font-size:0.8em;\">6</code></sup></li>\n</ul>",
      "text": "2 ≤ n ≤ 109 2 ≤ p ≤ 103 30% din teste au n ≤ 104 50% din teste au n ≤ 106"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>pascal.in</code></p><pre>7 2</pre><p><code>pascal.out</code></p><pre>9</pre>",
      "text": "pascal.in7 2pascal.out9"
    },
    {
      "title": "Explicație",
      "html": "<p>În primele <code>8</code> rânduri ale triunghiului se găsesc <code>9</code> multipli de <code>2</code>: <code>2,4,6,4,10,10,6,20,6</code>.</p>",
      "text": "În primele 8 rânduri ale triunghiului se găsesc 9 multipli de 2: 2,4,6,4,10,10,6,20,6."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>pascal.in</code></p><pre>2196 13</pre><p><code>pascal.out</code></p><pre>1660932</pre>",
      "text": "pascal.in2196 13pascal.out1660932"
    },
    {
      "title": "Explicație",
      "html": "<p>În primele <code>2197</code> rânduri ale triunghiului se găsesc <code>1660932</code> multipli de <code>13</code>.</p>",
      "text": "În primele 2197 rânduri ale triunghiului se găsesc 1660932 multipli de 13."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>pascal.in</code></p><pre>282475248 7</pre><p><code>pascal.out</code></p><pre>39599936523348201</pre>",
      "text": "pascal.in282475248 7pascal.out39599936523348201"
    },
    {
      "title": "Explicație",
      "html": "<p>În primele <code>282475249</code> rânduri ale triunghiului se găsesc <code>39599936523348201</code> multipli de <code>7</code>.</p>",
      "text": "În primele 282475249 rânduri ale triunghiului se găsesc 39599936523348201 multipli de 7."
    }
  ],
