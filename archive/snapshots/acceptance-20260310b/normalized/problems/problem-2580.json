  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau: <code>n</code> un număr întreg și <code>b</code> un număr natural. Setați la <code>0</code> bitul <code>b</code> al lui <code>n</code>.</p>",
      "text": "Se dau: n un număr întreg și b un număr natural. Setați la 0 bitul b al lui n."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code> și numărul <code>b</code>. Valoarea citită pentru <code>n</code> se presupune că se stochează într-o variabilă memorată pe <code>64</code> de biți cu semn.</p>",
      "text": "Programul citește de la tastatură numărul n și numărul b. Valoarea citită pentru n se presupune că se stochează într-o variabilă memorată pe 64 de biți cu semn."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Afișați valoarea variabilei după setarea valorii bitului conform cerinței.</p>",
      "text": "Afișați valoarea variabilei după setarea valorii bitului conform cerinței."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>prima valoare citită se poate memora pe <code>64</code> de biți cu semn</li>\n\t<li><code>0 ≤ b ≤ 63</code></li>\n\t<li>valorile celorlalți biți rămân nemodificate</li>\n</ul>",
      "text": "prima valoare citită se poate memora pe 64 de biți cu semn 0 ≤ b ≤ 63 valorile celorlalți biți rămân nemodificate"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 0</pre><p><strong>Ieșire</strong></p><pre>4</pre><h3>Explicație</h3><p>Prin setarea la <code>0</code> a ultimului bit al lui <code>5</code>, valoarea variabilei ce îl memora pe <code>5</code> devine <code>4</code>.</p>",
      "text": "Intrare5 0Ieșire4ExplicațiePrin setarea la 0 a ultimului bit al lui 5, valoarea variabilei ce îl memora pe 5 devine 4."
    }
  ],
  "examples": [
    {
      "input": "5 0",
      "output": "4",
      "explanation": "Prin setarea la 0 a ultimului bit al lui 5, valoarea variabilei ce îl memora pe 5 devine 4."
    }
  ],
