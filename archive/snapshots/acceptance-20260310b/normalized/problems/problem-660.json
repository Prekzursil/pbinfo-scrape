  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n</code> numere naturale distincte. Determinaţi câte triunghiuri distincte pot avea lungimile laturilor printre aceste numere.</p>",
      "text": "Se dau n numere naturale distincte. Determinaţi câte triunghiuri distincte pot avea lungimile laturilor printre aceste numere."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi cele <code>n</code> numere naturale.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi cele n numere naturale."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>C</code>, reprezentând numărul de triunghiuri determinate.</p>",
      "text": "Programul va afișa pe ecran numărul C, reprezentând numărul de triunghiuri determinate."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n\t<li>cele <code>n</code> numere citite vor fi mai mici decât <code>1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100 cele n numere citite vor fi mai mici decât 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n3 5 10 7 6 </pre><p><strong>Ieșire</strong></p><pre>7</pre>",
      "text": "Intrare5 3 5 10 7 6 Ieșire7"
    },
    {
      "title": "Explicație",
      "html": "<p>Cele <code>7</code> triunghiuri au lungimile laturilor:<br>\n<code>3 5 7</code><br>\n<code>3 5 6</code><br>\n<code>3 7 6</code><br>\n<code>5 7 6</code><br>\n<code>5 10 7</code><br>\n<code>5 10 6</code><br>\n<code>10 7 6</code></p>",
      "text": "Cele 7 triunghiuri au lungimile laturilor: 3 5 7 3 5 6 3 7 6 5 7 6 5 10 7 5 10 6 10 7 6"
    }
  ],
  "examples": [
    {
      "input": "5\n3 5 10 7 6",
      "output": "7"
    }
  ],
