  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă numărul natural <code>n</code>. Să se determine și să se afișeze al <code>n-lea</code> număr Catalan.</p>",
      "text": "Se dă numărul natural n. Să se determine și să se afișeze al n-lea număr Catalan."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran al <code>n-lea</code> număr Catalan.</p>",
      "text": "Programul va afișa pe ecran al n-lea număr Catalan."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 ≤ n ≤ 1000</code></li>\n</ul>",
      "text": "0 ≤ n ≤ 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5</pre><p><strong>Ieșire</strong></p><pre>42</pre>",
      "text": "Intrare5Ieșire42"
    }
  ],
