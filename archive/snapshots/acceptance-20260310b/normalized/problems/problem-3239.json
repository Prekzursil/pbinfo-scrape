  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieți un program care, pentru orice poziție <code>k</code> afișează lungimea secvenței chain corespunzătoare.</p>",
      "text": "Scrieți un program care, pentru orice poziție k afișează lungimea secvenței chain corespunzătoare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Pe prima linie a intrării standard se dă valoarea <code>N</code>. Pe a doua linie se dau elementele șirului, separate prin spații.</p>",
      "text": "Pe prima linie a intrării standard se dă valoarea N. Pe a doua linie se dau elementele șirului, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Pe o linie a ieșirii standard, programul va scrie șirul valorilor ce reprezintă lungimile secvențelor chain corespunzătoare elementelor șirului de intrare. Fiecare două numere consecutive trebuie separate printr-un singur spațiu.</p>",
      "text": "Pe o linie a ieșirii standard, programul va scrie șirul valorilor ce reprezintă lungimile secvențelor chain corespunzătoare elementelor șirului de intrare. Fiecare două numere consecutive trebuie separate printr-un singur spațiu."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>0 &lt; N &lt; 500.000</code></li>\n\t<li><code>0 &lt; a</code><sub><code>i</code></sub> <code>&lt; 1.000.000</code>, pentru fiecare <code>i = 1..N</code>.</li>\n</ul>",
      "text": "0 < N < 500.000 0 < ai < 1.000.000, pentru fiecare i = 1..N."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>11\n3 2 4 2 11 2 7 5 8 10 6</pre><p><strong>Ieșire</strong></p><pre>2 2 1 1 0 3 2 2 1 0 0</pre>",
      "text": "Intrare11 3 2 4 2 11 2 7 5 8 10 6Ieșire2 2 1 1 0 3 2 2 1 0 0"
    }
  ],
  "examples": [
