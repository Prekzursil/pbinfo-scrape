  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Date fiind codurile caracteristice ale două organisme vii diferite, scrieți un program care să determine codul caracteristic al celui mai evoluat strămoș comun al lor.</p>",
      "text": "Date fiind codurile caracteristice ale două organisme vii diferite, scrieți un program care să determine codul caracteristic al celui mai evoluat strămoș comun al lor."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>codul.in</code> conține pe prima linie <code>a</code>, codul caracteristic al primului organism, iar pe linia a doua <code>b</code>, codul caracteristic al celui de-al doilea organism.</p>",
      "text": "Fișierul de intrare codul.in conține pe prima linie a, codul caracteristic al primului organism, iar pe linia a doua b, codul caracteristic al celui de-al doilea organism."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>codul.out</code> conține pe prima linie <code>p</code>, codul celui mai evoluat strămoș comun al lui <code>a</code> şi <code>b</code>.</p>",
      "text": "Fișierul de ieșire codul.out conține pe prima linie p, codul celui mai evoluat strămoș comun al lui a şi b."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>lungimile celor două șiruri sunt numere naturale mai mici sau egale cu  <code>200</code></li>\n</ul>",
      "text": "lungimile celor două șiruri sunt numere naturale mai mici sau egale cu 200"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>codul.in</code></p><pre>7145\n847835</pre><p><code>codul.out</code></p><pre>75</pre>",
      "text": "codul.in7145 847835codul.out75"
    }
  ],
  "examples": [],
  "constraints": [
    "lungimile celor două șiruri sunt numere naturale mai mici sau egale cu 200"
  ],
