  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se citesc de la tastatură numere naturale până la apariția lui zero. Să se determine suma numerelor citite care au exact trei cifre și au prima cifră egală cu ultima (cifra sutelor egală cu cifra unităților).</p>",
      "text": "Se citesc de la tastatură numere naturale până la apariția lui zero. Să se determine suma numerelor citite care au exact trei cifre și au prima cifră egală cu ultima (cifra sutelor egală cu cifra unităților)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numere naturale. Citirea se încheie la introducerea valorii <code>0</code>.</p>",
      "text": "Programul citește de la tastatură numere naturale. Citirea se încheie la introducerea valorii 0."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran numărul <code>s</code>, reprezentând valoarea cerută.</p>",
      "text": "Programul afișează pe ecran numărul s, reprezentând valoarea cerută."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li>numerele citite au cel mult șase cifre;</li>\n\t<li>valoarea zero, care încheie citirile, nu se ia în considerare la determinarea rezultatului;</li>\n</ul>",
      "text": "numerele citite au cel mult șase cifre; valoarea zero, care încheie citirile, nu se ia în considerare la determinarea rezultatului;"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>505 600 22 6006 101 0</pre><p><strong>Ieșire</strong></p><pre>606</pre>",
      "text": "Intrare505 600 22 6006 101 0Ieșire606"
    },
    {
      "title": "Explicație:",
      "html": "<p>Dintre numerele citite, numerele 505 și 101 respectă regula din enunț. Suma lor este 606.</p>",
      "text": "Dintre numerele citite, numerele 505 și 101 respectă regula din enunț. Suma lor este 606."
    }
  ],
  "examples": [
    {
      "input": "505 600 22 6006 101 0",
      "output": "606"
    }
  ],
  "constraints": [
    "numerele citite au cel mult șase cifre;",
