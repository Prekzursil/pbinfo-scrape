  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se scrie un program care citeşte numărul natural <code>N</code> şi determină numărul <code>T</code> cu semnificaţia de mai sus.</p>",
      "text": "Să se scrie un program care citeşte numărul natural N şi determină numărul T cu semnificaţia de mai sus."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>perioada1.in</code> conţine pe prima linie numărul natural <code>N</code>.</p>",
      "text": "Fişierul de intrare perioada1.in conţine pe prima linie numărul natural N."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fişierul de ieşire <code>perioada1.out</code> va conţine pe prima linie numărul <code>T</code> cu semnificaţia de mai sus.</p>",
      "text": "Fişierul de ieşire perioada1.out va conţine pe prima linie numărul T cu semnificaţia de mai sus."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤</code> \\({10}^{12}\\)</li>\n\t<li><code>N</code> şi <code>10</code> prime între ele</li>\n</ul>",
      "text": "1 ≤ N ≤ \\({10}^{12}\\) N şi 10 prime între ele"
    },
    {
      "title": "Exemplu:",
      "html": "<table style=\"width:400px\">\n\n<tbody><tr>\n <th style=\"border-bottom:1px solid black\"> <code>perioada1.in</code>  </th>\n <th style=\"border-bottom:1px solid black\"> <code>perioada1.out</code>  </th>\n</tr>\n\n<tr>\n<td style=\"border-right:1px solid black;border-left:1px solid black;border-bottom:1px solid black\"> <code>3</code> </td>\n<td style=\"border-right:1px solid black;border-bottom:1px solid black\"> <code>1</code> </td>\n</tr>\n\n<tr>\n<td style=\"border-right:1px solid black;border-left:1px solid black;border-bottom:1px solid black\"> <code>21</code> </td>\n<td style=\"border-right:1px solid black;border-bottom:1px solid black\"> <code>6</code> </td>\n</tr>\n\n<tr>\n<td style=\"border-right:1px solid black;border-left:1px solid black;border-bottom:1px solid black\"> <code>31</code> </td>\n<td style=\"border-right:1px solid black;border-bottom:1px solid black\"> <code>15</code> </td>\n</tr>\n\n<tr>\n<td style=\"border-right:1px solid black;border-left:1px solid black;border-bottom:1px solid black\"> <code>363</code> </td>\n<td style=\"border-right:1px solid black;border-bottom:1px solid black\"> <code>22</code> </td>\n</tr>\n\n</tbody></table>",
      "text": "perioada1.in perioada1.out 3 1 21 6 31 15 363 22"
    }
  ],
