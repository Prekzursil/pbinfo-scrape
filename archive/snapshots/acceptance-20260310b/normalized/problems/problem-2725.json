  "tags": [
    "Arbori indexați binar",
    "Șmenul lui Batog (Square Root Decomposition)"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Pentru fiecare număr <code>a[i]</code> trebuie să determinați câte numere mai mici decât <code>a[i]</code> se află la stânga sa, adică în secvența <code>a[1], a[2], ..., a[i-1]</code>.</p>",
      "text": "Pentru fiecare număr a[i] trebuie să determinați câte numere mai mici decât a[i] se află la stânga sa, adică în secvența a[1], a[2], ..., a[i-1]."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale separate prin spații reprezentând permutarea.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale separate prin spații reprezentând permutarea."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran pentru fiecare <code>i=1..n</code> câte numere mai mici decât <code>a[i]</code> se află la stânga sa.</p>",
      "text": "Programul va afișa pe ecran pentru fiecare i=1..n câte numere mai mici decât a[i] se află la stânga sa."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>3 ≤ n ≤ 100.000</code></li>\n</ul>",
      "text": "3 ≤ n ≤ 100.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>7\n3 1 6 5 2 7 4</pre><p><strong>Ieșire</strong></p><pre>0 0 2 2 1 5 3</pre><h3>Explicație</h3><p>Sunt <code>0</code> numere mai mici decât <code>3</code> și aflate la stânga lui <code>3</code>.<br>\nSunt <code>0</code> numere mai mici decât <code>1</code> și aflate la stânga lui <code>1</code><br>\nSunt <code>2</code> numere mai mici decât <code>6</code> și aflate la stânga lui <code>6</code> (acestea sunt primele două numere din șir, adică <code>3</code> și <code>1</code>)<br>\nRestul e clar, da?</p>",
      "text": "Intrare7 3 1 6 5 2 7 4Ieșire0 0 2 2 1 5 3ExplicațieSunt 0 numere mai mici decât 3 și aflate la stânga lui 3. Sunt 0 numere mai mici decât 1 și aflate la stânga lui 1 Sunt 2 numere mai mici decât 6 și aflate la stânga lui 6 (acestea sunt primele două numere din șir, adică 3 și 1) Restul e clar, da?"
    }
  ],
  "examples": [
    {
      "input": "7\n3 1 6 5 2 7 4",
      "output": "0 0 2 2 1 5 3",
      "explanation": "Sunt 0 numere mai mici decât 3 și aflate la stânga lui 3. Sunt 0 numere mai mici decât 1 și aflate la stânga lui 1 Sunt 2 numere mai mici decât 6 și aflate la stânga lui 6 (acestea sunt primele două numere din șir, adică 3 și 1) Restul e clar, da?"
    }
  ],
  "constraints": [
    "3 ≤ n ≤ 100.000"
