  "tags": [
    "generare submultimi"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se împartă elementele șirului în două submulțimi astfel încât diferența în modul dintre sumele elementelor din cele două submulțimi să fie minimă.</p>",
      "text": "Să se împartă elementele șirului în două submulțimi astfel încât diferența în modul dintre sumele elementelor din cele două submulțimi să fie minimă."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi șirul de <code>n</code> numere naturale, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi șirul de n numere naturale, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran un singur număr natural <code>D</code>, reprezentând diferența în modul dintre sumele elementelor din cele două submulțimi alese.</p>",
      "text": "Programul va afișa pe ecran un singur număr natural D, reprezentând diferența în modul dintre sumele elementelor din cele două submulțimi alese."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ n ≤ 20</code></li>\n\t<li>cele <code>n</code> numere din șir vor fi nenule și mai mici decât <code>1.000.000.000</code></li>\n\t<li>fiecare număr din șir trebuie să fie într-o singură submulțime</li>\n</ul>",
      "text": "2 ≤ n ≤ 20 cele n numere din șir vor fi nenule și mai mici decât 1.000.000.000 fiecare număr din șir trebuie să fie într-o singură submulțime"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n4 2 7 6 5</pre><p><strong>Ieșire</strong></p><pre>0</pre><h3>Explicație</h3><p>Prima mulțime poate fi <code>{4, 2, 6}</code> și a doua <code>{7, 5}</code>. Sumele sunt <code>12</code> și <code>12</code> și au diferența <code>0</code>.</p>",
      "text": "Intrare5 4 2 7 6 5Ieșire0ExplicațiePrima mulțime poate fi {4, 2, 6} și a doua {7, 5}. Sumele sunt 12 și 12 și au diferența 0."
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n4 2 7 6 22</pre><p><strong>Ieșire</strong></p><pre>3</pre><h3>Explicație</h3><p>Prima mulțime va fi <code>{4, 2, 7, 6}</code> și a doua <code>{22}</code>. Sumele sunt <code>19</code> și <code>22</code> și au diferența în modul <code>3</code>.</p>",
      "text": "Intrare5 4 2 7 6 22Ieșire3ExplicațiePrima mulțime va fi {4, 2, 7, 6} și a doua {22}. Sumele sunt 19 și 22 și au diferența în modul 3."
    }
  ],
  "examples": [
