  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Verificați dacă un graf este arbore sau nu.</p>",
      "text": "Verificați dacă un graf este arbore sau nu."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>estearbore.in</code> conține pe prima linie numărul de noduri <code>n</code>, iar pe următoarele linii perechi de numere <code>x</code> <code>y</code>, separate printr-un spațiu, cu semnificația că există muchie de la nodul <code>x</code> la nodul <code>y</code>. </p>",
      "text": "Fișierul de intrare estearbore.in conține pe prima linie numărul de noduri n, iar pe următoarele linii perechi de numere x y, separate printr-un spațiu, cu semnificația că există muchie de la nodul x la nodul y."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>estearbore.out</code> va conține pe prima linie cuvântul <code>DA</code> dacă graful poate fi arbore, sau cuvântul <code>NU</code> dacă graful nu este arbore.</p>",
      "text": "Fișierul de ieșire estearbore.out va conține pe prima linie cuvântul DA dacă graful poate fi arbore, sau cuvântul NU dacă graful nu este arbore."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n\t<li><code>1 ≤ x, y ≤ n </code></li>\n\t<li>muchiile se pot repeta</li>\n</ul>",
      "text": "1 ≤ n ≤ 100 1 ≤ x, y ≤ n muchiile se pot repeta"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>estearbore.in</code></p><pre>5\n1 3\n2 4\n3 1\n3 5\n4 2\n4 5</pre><p><code>estearbore.out</code></p><pre>DA</pre><h3>Explicație</h3><p>Graful poate fi arbore.</p>",
      "text": "estearbore.in5 1 3 2 4 3 1 3 5 4 2 4 5estearbore.outDAExplicațieGraful poate fi arbore."
    }
  ],
