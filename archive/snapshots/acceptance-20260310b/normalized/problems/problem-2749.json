      "id": 64,
      "name": "Arbori cu rădăcină",
      "slug": "arbori-cu-r-d-cin",
      "href": "/?pagina=probleme-lista&tag=64"
    }
  ],
  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un vector <code>t=(t[1], t[2], ..., t[n])</code> care memorează numere naturale cuprinse între <code>0</code> și <code>n</code>. Să se verifice dacă <code>t</code> este sau nu vector de tați asociat unui arbore cu rădăcină.</p>",
      "text": "Se dă un vector t=(t[1], t[2], ..., t[n]) care memorează numere naturale cuprinse între 0 și n. Să se verifice dacă t este sau nu vector de tați asociat unui arbore cu rădăcină."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran mesajul <code>DA</code>, dacă <code>t</code> este vector de tați, sau mesajul <code>NU</code> în caz contrar.</p>",
      "text": "Programul va afișa pe ecran mesajul DA, dacă t este vector de tați, sau mesajul NU în caz contrar."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n\t<li><code>0 ≤ t[i] ≤ n</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000 0 ≤ t[i] ≤ n"
    },
    {
      "title": "Exemplul 1:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n0 1 1 3 3</pre><p><strong>Ieșire</strong></p><pre>DA</pre><h3>Explicație</h3><p>Vectorul corespunde arborelui cu rădăcină din imagine.</p><p><img alt=\"\" src=\"/resurse/16a4b0/tata_01.png\"></p>",
      "text": "Intrare5 0 1 1 3 3IeșireDAExplicațieVectorul corespunde arborelui cu rădăcină din imagine."
    },
    {
      "title": "Exemplul 2:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n2 0 2 5 4</pre><p><strong>Ieșire</strong></p><pre>NU</pre><h3>Explicație</h3><p>Nodul <code>4</code> are ca tată pe <code>5</code>, iar nodul <code>5</code> are ca tată pe <code>4</code> </p>",
      "text": "Intrare5 2 0 2 5 4IeșireNUExplicațieNodul 4 are ca tată pe 5, iar nodul 5 are ca tată pe 4"
    }
  ],
  "examples": [
    {
      "input": "5\n0 1 1 3 3",
      "output": "DA",
      "explanation": "Vectorul corespunde arborelui cu rădăcină din imagine."
    },
    {
      "input": "5\n2 0 2 5 4",
      "output": "NU",
      "explanation": "Nodul 4 are ca tată pe 5, iar nodul 5 are ca tată pe 4"
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 100.000",
    "0 ≤ t[i] ≤ n"
