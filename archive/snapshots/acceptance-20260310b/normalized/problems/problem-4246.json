  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Determinaţi numărul maxim de bananieri care se poate obţine prin conectarea a exact <code>K</code> zone.</p>",
      "text": "Determinaţi numărul maxim de bananieri care se poate obţine prin conectarea a exact K zone."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>banana.in</code> conține pe prima linie numerele <code>nr</code> și <code>K</code>, unde <code>nr</code> este numărul de bananieri, iar <code>K</code> numărul de zone ce pot fi conectate. Pe următoarele <code>nr</code> linii se găsesc câte două numere <code>x y</code> reprezentând linia și coloana unde se află un bananier.</p>",
      "text": "Fișierul de intrare banana.in conține pe prima linie numerele nr și K, unde nr este numărul de bananieri, iar K numărul de zone ce pot fi conectate. Pe următoarele nr linii se găsesc câte două numere x y reprezentând linia și coloana unde se află un bananier."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>banana.out</code> va conține pe prima linie numărul maxim de bananieri care se poate obţine prin conectarea zonelor.</p>",
      "text": "Fișierul de ieșire banana.out va conține pe prima linie numărul maxim de bananieri care se poate obţine prin conectarea zonelor."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ Nr ≤ 16.000</code></li>\n\t<li><code>1 ≤ x, y ≤ 10.000</code></li>\n\t<li>În testele utilizate <code>K</code> nu va depăşi numărul de zone.</li>\n\t<li>Două poziţii se învecinează pe orizontală dacă sunt pe aceeaşi linie şi pe coloane consecutive, respectiv pe verticală dacă sunt pe aceeaşi coloană şi pe linii consecutive.</li>\n</ul>",
      "text": "1 ≤ Nr ≤ 16.000 1 ≤ x, y ≤ 10.000 În testele utilizate K nu va depăşi numărul de zone. Două poziţii se învecinează pe orizontală dacă sunt pe aceeaşi linie şi pe coloane consecutive, respectiv pe verticală dacă sunt pe aceeaşi coloană şi pe linii consecutive."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>banana.in</code></p><pre>10 3\n7 10\n1 1\n101 1\n2 2\n102 1\n7 11\n200 202\n2 1\n3 2\n103 1</pre><p><code>banana.out</code></p><pre>9</pre>",
      "text": "banana.in10 3 7 10 1 1 101 1 2 2 102 1 7 11 200 202 2 1 3 2 103 1banana.out9"
    }
  ],
