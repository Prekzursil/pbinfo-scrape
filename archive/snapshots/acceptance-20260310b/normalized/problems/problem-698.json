  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Scrieţi un program care va determina numărul “gropilor” din  șirul dat.</p>",
      "text": "Scrieţi un program care va determina numărul “gropilor” din șirul dat."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>nrpits.in</code> conţine pe prima linie numărul natural N. Pe linia a doua se află scrise cele N numere naturale ale șirului, separate prin spațiu.</p>",
      "text": "Fișierul de intrare nrpits.in conţine pe prima linie numărul natural N. Pe linia a doua se află scrise cele N numere naturale ale șirului, separate prin spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>nrpits.out</code> va conține un singur număr reprezentând numărul de “gropi” ale șirului dat.</p>",
      "text": "Fișierul de ieșire nrpits.out va conține un singur număr reprezentând numărul de “gropi” ale șirului dat."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ N ≤ 1.000.000</code></li>\n\t<li><code>1 ≤ a[i] ≤ 1.000.000</code>, pentru fiecare <code>1 ≤ i ≤ N</code></li>\n\t<li>orice “groapă” are cel puțin trei elemente</li>\n</ul>",
      "text": "2 ≤ N ≤ 1.000.000 1 ≤ a[i] ≤ 1.000.000, pentru fiecare 1 ≤ i ≤ N orice “groapă” are cel puțin trei elemente"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>nrpits.in</code></p><pre>12\n12 1 10 3 4 11 5 8 7 9 2 6</pre><p><code>nrpits.out</code></p><pre>8</pre>",
      "text": "nrpits.in12 12 1 10 3 4 11 5 8 7 9 2 6nrpits.out8"
    },
    {
      "title": "Explicație",
      "html": "<p>Cele opt “gropi” sunt:  <br>\n<code>12 1 10</code><br>\n<code>10 3 4</code><br>\n<code>12 1 10 3 4 11</code><br>\n<code>10 3 4 11</code><br>\n<code>11 5 8</code><br>\n<code>8 7 9</code><br>\n<code>9 2 6</code><br>\n<code>11 5 8 7 9</code></p>",
      "text": "Cele opt “gropi” sunt: 12 1 10 10 3 4 12 1 10 3 4 11 10 3 4 11 11 5 8 8 7 9 9 2 6 11 5 8 7 9"
    }
  ],
