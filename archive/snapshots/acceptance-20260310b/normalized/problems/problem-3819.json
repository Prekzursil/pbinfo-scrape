  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau două șiruri de caractere <code>s</code> și <code>t</code>, să se calculeze câte subșiruri din <code>s</code> sunt anagrame ale șirului <code>t</code>.</p>",
      "text": "Se dau două șiruri de caractere s și t, să se calculeze câte subșiruri din s sunt anagrame ale șirului t."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură <code>s</code> și <code>t</code> fiecare pe câte un rând.</p>",
      "text": "Programul citește de la tastatură s și t fiecare pe câte un rând."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul de subșiruri din <code>s</code> anagrame ale lui <code>t</code>.</p>",
      "text": "Programul va afișa pe ecran numărul de subșiruri din s anagrame ale lui t."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ |t|, |s| &lt;= 100.000</code>, <code>|x|</code> reprezintă lungimea șirului de caractere <code>x</code>.</li>\n\t<li><code>a</code> este anagramă cu <code>b</code> dacă putem rearanja caracterele din <code>a</code> și să obținem șirul <code>b</code>.</li>\n\t<li>pentru <code>20</code> de puncte <code>1 &lt;= |t| &lt;= |s| &lt;= 1.000</code>.</li>\n\t<li>rezultatul se tipărește modulo <code>666013</code>.</li>\n\t<li><code>s</code> și <code>t</code> conțin doar litere mici din alfabetul englez.</li>\n</ul>",
      "text": "1 ≤ |t|, |s| <= 100.000, |x| reprezintă lungimea șirului de caractere x. a este anagramă cu b dacă putem rearanja caracterele din a și să obținem șirul b. pentru 20 de puncte 1 <= |t| <= |s| <= 1.000. rezultatul se tipărește modulo 666013. s și t conțin doar litere mici din alfabetul englez."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>bacb\nab</pre><p><strong>Ieșire</strong></p><pre>2</pre><h3>Explicație</h3><p>cele două subșiruri sunt: <code>ba</code>, <code>ab</code>.</p>",
      "text": "Intrarebacb abIeșire2Explicațiecele două subșiruri sunt: ba, ab."
    }
  ],
  "examples": [
    {
      "input": "bacb\nab",
      "output": "2",
      "explanation": "cele două subșiruri sunt: ba, ab."
    }
  ],
  "constraints": [
    "1 ≤ |t|, |s| <= 100.000, |x| reprezintă lungimea șirului de caractere x.",
    "a este anagramă cu b dacă putem rearanja caracterele din a și să obținem șirul b.",
    "pentru 20 de puncte 1 <= |t| <= |s| <= 1.000.",
    "rezultatul se tipărește modulo 666013.",
    "s și t conțin doar litere mici din alfabetul englez."
  ],
