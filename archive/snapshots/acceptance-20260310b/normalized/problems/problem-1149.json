  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dă un şir cu <code>n</code> elemente, numere  naturale. Folosind metoda <strong>Divide et Impera</strong> să se verifice dacă în şir există elemente prime.</p>",
      "text": "Se dă un şir cu n elemente, numere naturale. Folosind metoda Divide et Impera să se verifice dacă în şir există elemente prime."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi cele <code>n</code> elemente ale şirului.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi cele n elemente ale şirului."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul afișează pe ecran mesajul <code>DA</code>, dacă  şirul conţine elemente prime, respectiv <code>NU</code> în caz contrar.</p>",
      "text": "Programul afișează pe ecran mesajul DA, dacă şirul conţine elemente prime, respectiv NU în caz contrar."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 200</code></li>\n\t<li>elementele şirului vor fi mai mici decât <code>1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 200 elementele şirului vor fi mai mici decât 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Date de intrare</strong></p><pre>5\n21 8 6 10 8</pre><p><strong>Date de ieșire</strong></p><pre>NU</pre>",
      "text": "Date de intrare5 21 8 6 10 8Date de ieșireNU"
    }
  ],
  "examples": [
    {
      "input": "5\n21 8 6 10 8",
      "output": "NU"
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 200",
    "elementele şirului vor fi mai mici decât 1.000.000.000"
  ],
