  ],
  "sections": [
    {
      "title": "Cerinţă",
      "html": "<p>Scrieţi un program care să citească numerele naturale <code>N</code> și numărul de petale ale fiecărei flori  şi care să determine cantitatea maximă <code>C</code> de nectar pe care albinuţele o pot aduna din grădina fermecată.</p>",
      "text": "Scrieţi un program care să citească numerele naturale N și numărul de petale ale fiecărei flori şi care să determine cantitatea maximă C de nectar pe care albinuţele o pot aduna din grădina fermecată."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale, reprezentând numărul de petale ale fiecărei flori.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale, reprezentând numărul de petale ale fiecărei flori."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>C</code>.</p>",
      "text": "Programul va afișa pe ecran numărul C."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100 000</code></li>\n\t<li>fiecare floare are cel mult <code>10 000</code> petale</li>\n\t<li>Nectarul unei flori poate fi cules de o singură albină.</li>\n\t<li>Cantitatea maximă <code>C</code> de nectar culeasă este un număr natural, <code>C ≤ 2 000 000 000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100 000 fiecare floare are cel mult 10 000 petale Nectarul unei flori poate fi cules de o singură albină. Cantitatea maximă C de nectar culeasă este un număr natural, C ≤ 2 000 000 000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>8\n25 13 10 7 1 12 31 102</pre><p><strong>Ieșire</strong></p><pre>202</pre>",
      "text": "Intrare8 25 13 10 7 1 12 31 102Ieșire202"
    },
    {
      "title": "Explicație",
      "html": "<p>Cantitatea maximă de nectar se obţine din florile <code>1</code>, <code>3</code>, <code>5</code>, <code>6</code> şi <code>8</code>. <code>C=3x25+10+3x1+12+102=202</code></p>",
      "text": "Cantitatea maximă de nectar se obţine din florile 1, 3, 5, 6 şi 8. C=3x25+10+3x1+12+102=202"
    }
  ],
  "examples": [
    {
      "input": "8\n25 13 10 7 1 12 31 102",
      "output": "202"
    }
  ],
