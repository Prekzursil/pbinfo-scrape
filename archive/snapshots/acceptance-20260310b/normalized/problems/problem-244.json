  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dau <code>n</code> cifre zecimale. Să se afişeze aceste cifre în ordine crescătoare.</p>",
      "text": "Se dau n cifre zecimale. Să se afişeze aceste cifre în ordine crescătoare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>cifreord.in</code> conţine pe prima linie numărul <code>n</code>, iar pe următoarele linii <code>n</code> cifre zecimale separate prin spaţii.</p>",
      "text": "Fişierul de intrare cifreord.in conţine pe prima linie numărul n, iar pe următoarele linii n cifre zecimale separate prin spaţii."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>cifreord.out</code> va conţine cele <code>n</code> cifre ordonate crescător, câte <code>20</code> pe o linie, valorile de pe fiecare linie fiind separate prin spaţii. Ultima linie a fişierului poate conţine mai puţin de <code>20</code> de valori.</p>",
      "text": "Fişierul de ieşire cifreord.out va conţine cele n cifre ordonate crescător, câte 20 pe o linie, valorile de pe fiecare linie fiind separate prin spaţii. Ultima linie a fişierului poate conţine mai puţin de 20 de valori."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>cifreord.in</code></p><pre>25\n1 1 2 7 3 5 1 5\n3 6 7 8 0 1 0 5\n6 3 8 2\n9 7 9 5 7</pre><p><code>cifreord.out</code></p><pre>0 0 1 1 1 1 2 2 3 3 3 5 5 5 5 6 6 7 7 7 \n7 8 8 9 9 </pre>",
      "text": "cifreord.in25 1 1 2 7 3 5 1 5 3 6 7 8 0 1 0 5 6 3 8 2 9 7 9 5 7cifreord.out0 0 1 1 1 1 2 2 3 3 3 5 5 5 5 6 6 7 7 7 7 8 8 9 9"
    }
  ],
