  "tags": [
    "Descompunere in factori",
    "Numararea divizorilor"
  ],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un număr natural <code>n</code>. Să se afle numărul divizorilor naturali ai lui <code>n</code><sup><code>n</code></sup>.</p>",
      "text": "Se dă un număr natural n. Să se afle numărul divizorilor naturali ai lui nn."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>.</p>",
      "text": "Programul citește de la tastatură numărul n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul divizorilor lui  <code>n</code><sup><code>n</code></sup>, modulo <code>59999</code>.</p>",
      "text": "Programul va afișa pe ecran numărul divizorilor lui nn, modulo 59999."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 10</code><sup><code>13</code></sup></li>\n</ul>",
      "text": "1 ≤ n ≤ 1013"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4</pre><p><strong>Ieșire</strong></p><pre>9</pre><h3>Explicație</h3><p>Numărul <code>4</code><sup><code>4</code></sup><code>=256</code> are <code>9</code> divizori: <code>1,2,4,8,16,32,64,128,256</code>.</p>",
      "text": "Intrare4Ieșire9ExplicațieNumărul 44=256 are 9 divizori: 1,2,4,8,16,32,64,128,256."
    }
  ],
  "examples": [
    {
      "input": "4",
      "output": "9",
      "explanation": "Numărul 44=256 are 9 divizori: 1,2,4,8,16,32,64,128,256."
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 1013"
  ],
