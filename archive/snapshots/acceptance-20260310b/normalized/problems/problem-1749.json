  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă o matrice pătratică și un număr natural <code>Z</code>, reprezentând o zonă din matrice. Să se determine suma elementelor din zona <code>Z</code>.</p>",
      "text": "Se dă o matrice pătratică și un număr natural Z, reprezentând o zonă din matrice. Să se determine suma elementelor din zona Z."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>N Z</code>, iar apoi <code>N*N</code> numere naturale, reprezentând elementele matricei.</p>",
      "text": "Programul citește de la tastatură numerele N Z, iar apoi N*N numere naturale, reprezentând elementele matricei."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul <code>S</code>, reprezentând suma elementelor din zona <code>Z</code> a matricei.</p>",
      "text": "Programul va afișa pe ecran numărul S, reprezentând suma elementelor din zona Z a matricei."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 200</code></li>\n\t<li><code>1 ≤ Z ≤ 4</code></li>\n\t<li>elementele matricei vor fi mai mici decât <code>1000</code></li>\n</ul>",
      "text": "1 ≤ N ≤ 200 1 ≤ Z ≤ 4 elementele matricei vor fi mai mici decât 1000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 2\n7 4 8 5 10 \n7 7 10 2 2 \n1 2 8 8 4 \n9 9 5 3 2 \n3 6 7 1 7 </pre><p><strong>Ieșire</strong></p><pre>16</pre><h3>Explicație</h3><p>Elementele din zona <code>2</code> sunt <code>2 8 4 2</code>, cu suma <code>16</code>.</p>",
      "text": "Intrare5 2 7 4 8 5 10 7 7 10 2 2 1 2 8 8 4 9 9 5 3 2 3 6 7 1 7 Ieșire16ExplicațieElementele din zona 2 sunt 2 8 4 2, cu suma 16."
    }
  ],
