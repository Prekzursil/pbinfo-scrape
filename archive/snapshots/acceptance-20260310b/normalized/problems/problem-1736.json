  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Să se determine lungimea maximă – <code>L</code> a unei secvențe de cuie de aceeași înălțime în condițiile date și numărul minim de “bătăi” – <code>K</code> necesare obținerii acesteia.</p>",
      "text": "Să se determine lungimea maximă – L a unei secvențe de cuie de aceeași înălțime în condițiile date și numărul minim de “bătăi” – K necesare obținerii acesteia."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>cuie.in</code> conține pe prima linie două numere naturale nenule <code>N</code> și <code>M</code> și pe următoarea linie <code>N</code> valori naturale nenule ce reprezintă înălțimile celor <code>N</code> cuie măsurate în cm.</p>",
      "text": "Fișierul de intrare cuie.in conține pe prima linie două numere naturale nenule N și M și pe următoarea linie N valori naturale nenule ce reprezintă înălțimile celor N cuie măsurate în cm."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>cuie.out</code> va conține pe prima linie două numere naturale nenule <code>L</code> și <code>K</code>, separate printr-un spațiu, ce reprezintă: <code>L</code> – lungimea maximă a unei secvențe de cuie cu aceeași înălțime, respectiv <code>K</code> – numărul minim de ”bătăi” de ciocan necesare pentru obținerea secvenței maxime.</p>",
      "text": "Fișierul de ieșire cuie.out va conține pe prima linie două numere naturale nenule L și K, separate printr-un spațiu, ce reprezintă: L – lungimea maximă a unei secvențe de cuie cu aceeași înălțime, respectiv K – numărul minim de ”bătăi” de ciocan necesare pentru obținerea secvenței maxime."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ N ≤ 500.000</code></li>\n\t<li><code>1 ≤ M ≤ 500.000</code></li>\n\t<li><code>1 ≤ K ≤ M</code></li>\n\t<li><code>1 ≤</code> înălțime cui <code>≤ 100.000</code> cm</li>\n\t<li>înălțimea unui cui reprezintă lungimea părții aflate în afara scândurii.</li>\n</ul>",
      "text": "1 ≤ N ≤ 500.000 1 ≤ M ≤ 500.000 1 ≤ K ≤ M 1 ≤ înălțime cui ≤ 100.000 cm înălțimea unui cui reprezintă lungimea părții aflate în afara scândurii."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>cuie.in</code></p><pre>8 5\n3 2 4 3 3 5 3 1</pre><p><code>cuie.out</code></p><pre>5 3</pre><h3>Explicație</h3><p>Secvența de lungime maximă se obține după <code>3</code> “bătăi”, efectuate asupra cuielor <code>3</code> și <code>6</code>: <code>3 2 3 3 3 3 3 1</code>.</p>",
      "text": "cuie.in8 5 3 2 4 3 3 5 3 1cuie.out5 3ExplicațieSecvența de lungime maximă se obține după 3 “bătăi”, efectuate asupra cuielor 3 și 6: 3 2 3 3 3 3 3 1."
    }
  ],
