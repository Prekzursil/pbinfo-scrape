  ],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Se dau <code>k</code> perechi de vârfuri <code>x y</code>. Determinați pentru fiecare pereche distanța minimă dintre <code>x</code> și <code>y</code>.</p>",
      "text": "Se dau k perechi de vârfuri x y. Determinați pentru fiecare pereche distanța minimă dintre x și y."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fişierul de intrare <code>dmin.in</code> conţine pe prima linie două numere <code>n</code> şi <code>m</code>, reprezentând numărul de noduri, respectiv numărul de muchii. Fiecare dintre următoarele <code>m</code> linii va conţine câte două numere <code>x</code> şi <code>y</code>, separate printr-un spaţiu, cu semnificaţia: există o muchie între nodul <code>x</code> şi nodul <code>y</code>.</p><p>Următoarea linie conține un număr <code>k</code>, iar următoarele <code>k</code> linii câte două numere <code>x y</code>.</p>",
      "text": "Fişierul de intrare dmin.in conţine pe prima linie două numere n şi m, reprezentând numărul de noduri, respectiv numărul de muchii. Fiecare dintre următoarele m linii va conţine câte două numere x şi y, separate printr-un spaţiu, cu semnificaţia: există o muchie între nodul x şi nodul y.Următoarea linie conține un număr k, iar următoarele k linii câte două numere x y."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Fişierul de ieşire <code>dmin.out</code> va conţine <code>k</code> linii. Fiecare linie va conține distanța minimă dintre nodurile <code>x y</code> din fișierul de intrare, în ordinea din fișierul de intrare.</p>",
      "text": "Fişierul de ieşire dmin.out va conţine k linii. Fiecare linie va conține distanța minimă dintre nodurile x y din fișierul de intrare, în ordinea din fișierul de intrare."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>n ≤ 100</code></li>\n\t<li><code>k ≤ 100</code></li>\n\t<li>pentru toate perechile <code>x y</code> există cel puțin un lanț elementar de la <code>x</code> la <code>y</code>.</li>\n</ul>",
      "text": "n ≤ 100 k ≤ 100 pentru toate perechile x y există cel puțin un lanț elementar de la x la y."
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>dmin.in</code></p><pre>6 7\n1 3\n1 2\n2 3\n2 4\n3 4\n4 5\n5 6\n3\n1 6\n5 3\n2 5</pre><p><code>dmin.out</code></p><pre>4\n2\n2</pre>",
      "text": "dmin.in6 7 1 3 1 2 2 3 2 4 3 4 4 5 5 6 3 1 6 5 3 2 5dmin.out4 2 2"
    }
  ],
