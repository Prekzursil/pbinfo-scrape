  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Dându-se un număr natural nenul <code>n</code>, obţineţi în ordine crescătoare toate cele <code>2·n</code> numere, primele <code>n</code> numere care îi plac Mariei şi primele <code>n</code> care îi plac lui Mihai.</p>",
      "text": "Dându-se un număr natural nenul n, obţineţi în ordine crescătoare toate cele 2·n numere, primele n numere care îi plac Mariei şi primele n care îi plac lui Mihai."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>puteri35.in</code> conține pe prima linie un număr natural <code>n</code>.</p>",
      "text": "Fișierul de intrare puteri35.in conține pe prima linie un număr natural n."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>puteri35.out</code> va conține <code>2·n</code> numere, fiecare pe câte o linie, în ordine crescătoare, primele <code>n</code> numere care îi plac Mariei și primele <code>n</code> numere care îi plac lui Mihai.</p>",
      "text": "Fișierul de ieșire puteri35.out va conține 2·n numere, fiecare pe câte o linie, în ordine crescătoare, primele n numere care îi plac Mariei și primele n numere care îi plac lui Mihai."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>puteri35.in</code></p><pre>3</pre><p><code>puteri35.out</code></p><pre>1\n1\n3\n4\n5\n6</pre>",
      "text": "puteri35.in3puteri35.out1 1 3 4 5 6"
    },
    {
      "title": "Explicație",
      "html": "<p>Soluţia <code>1 3 4 1 5 6</code> nu este corectă pentru că numerele nu sunt în ordine crescătoare</p>",
      "text": "Soluţia 1 3 4 1 5 6 nu este corectă pentru că numerele nu sunt în ordine crescătoare"
    }
  ],
