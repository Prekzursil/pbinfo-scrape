  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se citește un număr natural <code>n</code> și un șir de <code>n</code> numere întregi. Să se aranjeze elementele astfel încât în prima parte a șirului să fie valorile pare în ordine crescătoare, iar în partea a doua valorile impare, de asemenea în ordine crescătoare.</p>",
      "text": "Se citește un număr natural n și un șir de n numere întregi. Să se aranjeze elementele astfel încât în prima parte a șirului să fie valorile pare în ordine crescătoare, iar în partea a doua valorile impare, de asemenea în ordine crescătoare."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code> și apoi cele <code>n</code> elemente ale șirului.</p>",
      "text": "Programul citește de la tastatură numărul n și apoi cele n elemente ale șirului."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul afișează pe ecran elementele șirului după prelucrare cu spații intre ele.</p>",
      "text": "Programul afișează pe ecran elementele șirului după prelucrare cu spații intre ele."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n\t<li>cele <code>n</code> numere pot fi reprezentate pe 32 de biți cu semn.</li>\n</ul>",
      "text": "1 ≤ n ≤ 1000 cele n numere pot fi reprezentate pe 32 de biți cu semn."
    },
    {
      "title": "Exemplu",
      "html": "<p><strong>Intrare</strong></p><pre>10\n5 4 3 2 1 6 7 8 9 18</pre><p><strong>Ieșire</strong></p><pre>2 4 6 8 18 1 3 5 7 9</pre>",
      "text": "Intrare10 5 4 3 2 1 6 7 8 9 18Ieșire2 4 6 8 18 1 3 5 7 9"
    }
  ],
  "examples": [
    {
      "input": "10\n5 4 3 2 1 6 7 8 9 18",
      "output": "2 4 6 8 18 1 3 5 7 9"
    }
  ],
