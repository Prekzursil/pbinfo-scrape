  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Pornind de la șirul <code>s</code> se cere să se obțină șirul <code>t</code> aplicând de un număr minim de ori operațiile date.</p>",
      "text": "Pornind de la șirul s se cere să se obțină șirul t aplicând de un număr minim de ori operațiile date."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură șirurile <code>s</code> și <code>t</code>, care se află pe aceeași linie, separate prin spațiu.</p>",
      "text": "Programul citește de la tastatură șirurile s și t, care se află pe aceeași linie, separate prin spațiu."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran numărul minim de operații necesar transformării lui <code>s</code> în <code>t</code>..</p>",
      "text": "Programul va afișa pe ecran numărul minim de operații necesar transformării lui s în t.."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>lungimile celor două șiruri sunt cuprinse între <code>1</code> și <code>100</code>.</li>\n\t<li>șirurile sunt formate numai din litere mari și mici</li>\n</ul>",
      "text": "lungimile celor două șiruri sunt cuprinse între 1 și 100. șirurile sunt formate numai din litere mari și mici"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>carte casete</pre><p><strong>Ieșire</strong></p><pre>2</pre><h3>Explicație</h3><p>Cele două operații sunt modificarea lui <code>r</code> în <code>s</code> și inserarea lui e înainte de litera <code>t</code>:<br>\n<code>carte -&gt; caste -&gt; casete</code></p>",
      "text": "Intrarecarte caseteIeșire2ExplicațieCele două operații sunt modificarea lui r în s și inserarea lui e înainte de litera t: carte -> caste -> casete"
    }
  ],
  "examples": [
    {
      "input": "carte casete",
      "output": "2",
      "explanation": "Cele două operații sunt modificarea lui r în s și inserarea lui e înainte de litera t: carte -> caste -> casete"
