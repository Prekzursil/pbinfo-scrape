  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă numărul natural <code>n</code> și <code>n</code> șiruri de caractere de tip secvență. Determinați pentru fiecare dintre cele <code>n</code> șiruri dacă ele sunt alcătuite prin repetiția a unui subșir de caractere din el. Dacă da se afișează subșirul care a generat secvența sau <code>-1</code> dacă secvența nu este alcătuită după aceste criterii.</p>",
      "text": "Se dă numărul natural n și n șiruri de caractere de tip secvență. Determinați pentru fiecare dintre cele n șiruri dacă ele sunt alcătuite prin repetiția a unui subșir de caractere din el. Dacă da se afișează subșirul care a generat secvența sau -1 dacă secvența nu este alcătuită după aceste criterii."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură pe primul rând numărul <code>n</code>, iar apoi <code>n</code> șiruri de caractere, pe linii diferite.</p>",
      "text": "Programul citește de la tastatură pe primul rând numărul n, iar apoi n șiruri de caractere, pe linii diferite."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran pe câte un rând secvența cerută sau <code>-1</code> conform enunțului.</p>",
      "text": "Programul va afișa pe ecran pe câte un rând secvența cerută sau -1 conform enunțului."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n\t<li>cele <code>n</code> șiruri de caractere citite vor avea maximum <code>1000</code> de caractere.</li>\n</ul>",
      "text": "1 ≤ n ≤ 1000 cele n șiruri de caractere citite vor avea maximum 1000 de caractere."
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\nabcabcabc abadabad aabaabaabaab abcdabc jbogzfcfndudqctnqcmzxypuzzlbxcnhddndipjxteakhuzzxlyujoqjncklfzsjdgnlxxjqbjciebhcngyxuohjrsvysoh</pre><p><strong>Ieșire</strong></p><pre>abc\nabad\naab\n-1\n-1</pre>",
      "text": "Intrare5 abcabcabc abadabad aabaabaabaab abcdabc jbogzfcfndudqctnqcmzxypuzzlbxcnhddndipjxteakhuzzxlyujoqjncklfzsjdgnlxxjqbjciebhcngyxuohjrsvysohIeșireabc abad aab -1 -1"
    }
  ],
  "examples": [
    {
      "input": "5\nabcabcabc abadabad aabaabaabaab abcdabc jbogzfcfndudqctnqcmzxypuzzlbxcnhddndipjxteakhuzzxlyujoqjncklfzsjdgnlxxjqbjciebhcngyxuohjrsvysoh",
      "output": "abc\nabad\naab\n-1\n-1"
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 1000",
    "cele n șiruri de caractere citite vor avea maximum 1000 de caractere."
  ],
