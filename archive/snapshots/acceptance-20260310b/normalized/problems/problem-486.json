  "tags": [],
  "sections": [
    {
      "title": "Cerinţa",
      "html": "<p>Calculaţi valoarea minimă <code>minim</code> și valoarea maximă <code>maxim</code> a valorilor elementelor vectorului.</p>",
      "text": "Calculaţi valoarea minimă minim și valoarea maximă maxim a valorilor elementelor vectorului."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură de numărul <code>n</code>, apoi încă <code>n</code> numere naturale, reprezentând elementele vectorului.</p>",
      "text": "Programul citește de la tastatură de numărul n, apoi încă n numere naturale, reprezentând elementele vectorului."
    },
    {
      "title": "Date de ieşire",
      "html": "<p>Programul va afișa pe ecran cele două numere <code>minim</code> şi <code>maxim</code>, separate printr-un singur spaţiu.</p>",
      "text": "Programul va afișa pe ecran cele două numere minim şi maxim, separate printr-un singur spaţiu."
    },
    {
      "title": "Restricţii şi precizări",
      "html": "<ul>\n\t<li><code>0 &lt; n &lt; 1000</code></li>\n\t<li>elementele vectorului vor fi mai mici decât <code>1.000.000</code></li>\n</ul>",
      "text": "0 < n < 1000 elementele vectorului vor fi mai mici decât 1.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5\n8 2 9 4 5 </pre><p><strong>Ieșire</strong></p><pre>2 9</pre>",
      "text": "Intrare5 8 2 9 4 5 Ieșire2 9"
    },
    {
      "title": "Explicație",
      "html": "<p>Vectorul conține <code>5</code> elemente. Valoarea maxima este <code>9</code>, iar valoarea minimă este <code>2</code>.\n\t\t</p>",
      "text": "Vectorul conține 5 elemente. Valoarea maxima este 9, iar valoarea minimă este 2."
    }
  ],
  "examples": [
    {
      "input": "5\n8 2 9 4 5",
      "output": "2 9"
    }
  ],
  "constraints": [
    "0 < n < 1000",
    "elementele vectorului vor fi mai mici decât 1.000.000"
  ],
