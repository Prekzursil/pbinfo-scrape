  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau <code>n</code> numere naturale. Să se calculeze produsul factorialelor acestora, modulo <code>1.000.000.007</code>.</p>",
      "text": "Se dau n numere naturale. Să se calculeze produsul factorialelor acestora, modulo 1.000.000.007."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numărul <code>n</code>, iar apoi <code>n</code> numere naturale, separate prin spații.</p>",
      "text": "Programul citește de la tastatură numărul n, iar apoi n numere naturale, separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran produsul factorialelor celor <code>n</code> numere citite.</p>",
      "text": "Programul va afișa pe ecran produsul factorialelor celor n numere citite."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1.000.000</code></li>\n\t<li>cele <code>n</code> numere sunt mai mici sau egale cu <code>10.000.000</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 1.000.000 cele n numere sunt mai mici sau egale cu 10.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>4\n4 2 1 3</pre><p><strong>Ieșire</strong></p><pre>288</pre>",
      "text": "Intrare4 4 2 1 3Ieșire288"
    }
  ],
  "examples": [
    {
      "input": "4\n4 2 1 3",
      "output": "288"
    }
  ],
  "constraints": [
    "1 ≤ n ≤ 1.000.000",
    "cele n numere sunt mai mici sau egale cu 10.000.000"
  ],
