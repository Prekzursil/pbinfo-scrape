  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă vectorul de tați al unui arbore cu rădăcină cu <code>n</code> noduri și o valoare <code>k</code>. Determinați nodurile situate pe nivelul <code>k</code> în arbore.</p>",
      "text": "Se dă vectorul de tați al unui arbore cu rădăcină cu n noduri și o valoare k. Determinați nodurile situate pe nivelul k în arbore."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>knivel.in</code> conține pe prima linie numărul de noduri <code>n</code> și valoarea <code>k</code>. Pe linia următoare se află vectorul de tați al arborelui, valorile fiind separate prin spații.</p>",
      "text": "Fișierul de intrare knivel.in conține pe prima linie numărul de noduri n și valoarea k. Pe linia următoare se află vectorul de tați al arborelui, valorile fiind separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>knivel.out</code> va conține pe prima linie, în ordine crescătoare, nodurile situate pe nivelul <code>k</code> în arbore.</p>",
      "text": "Fișierul de ieșire knivel.out va conține pe prima linie, în ordine crescătoare, nodurile situate pe nivelul k în arbore."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n\t<li>în vectorul de tați rădăcina este marcată cu <code>0</code></li>\n\t<li>pe nivelul <code>k</code> va exista cel puțin un nod</li>\n</ul>",
      "text": "1 ≤ n ≤ 100 în vectorul de tați rădăcina este marcată cu 0 pe nivelul k va exista cel puțin un nod"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>knivel.in</code></p><pre>8 3\n4 3 0 3 2 1 2 1</pre><p><code>knivel.out</code></p><pre>1 5 7</pre>",
      "text": "knivel.in8 3 4 3 0 3 2 1 2 1knivel.out1 5 7"
    }
  ],
