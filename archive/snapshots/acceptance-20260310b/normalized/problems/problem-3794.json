  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dau două șiruri de numere naturale, cu <code>n</code>, respectiv <code>m</code> elemente, <strong>ordonate crescător</strong>. Să se determine al treilea șir, care să conţină, în ordine crescătoare, elementele din primele două şiruri.</p>",
      "text": "Se dau două șiruri de numere naturale, cu n, respectiv m elemente, ordonate crescător. Să se determine al treilea șir, care să conţină, în ordine crescătoare, elementele din primele două şiruri."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>file.in</code> conține pe prima linie numerele naturale <code>n</code>, respectiv <code>m</code>, iar apoi pe a doua linie numerele primului șir, și pe a treia linie, numerele celui de-al doilea șir, elementele șirurilor fiind separate prin spații.</p>",
      "text": "Fișierul de intrare file.in conține pe prima linie numerele naturale n, respectiv m, iar apoi pe a doua linie numerele primului șir, și pe a treia linie, numerele celui de-al doilea șir, elementele șirurilor fiind separate prin spații."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>file.out</code> va conține numerele celui de-al treilea șir, separate prin spații.</p>",
      "text": "Fișierul de ieșire file.out va conține numerele celui de-al treilea șir, separate prin spații."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n, m ≤ 100.000</code></li>\n\t<li>elementele șirului vor fi mai mici decât <code>1.000.000.000</code></li>\n</ul>",
      "text": "1 ≤ n, m ≤ 100.000 elementele șirului vor fi mai mici decât 1.000.000.000"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>file.in</code></p><pre>7 8\n1 3 4 6 7 8 8 \n2 4 5 6 8 9 9 12</pre><p><code>file.out</code></p><pre>1 2 3 4 4 5 6 6 7 8 8 8 9 9 12 </pre>",
      "text": "file.in7 8 1 3 4 6 7 8 8 2 4 5 6 8 9 9 12file.out1 2 3 4 4 5 6 6 7 8 8 8 9 9 12"
    }
  ],
