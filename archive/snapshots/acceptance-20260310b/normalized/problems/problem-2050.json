  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Cunoscând <code>n</code> și <code>k</code>, lungimea maximă a unui cuvânt și respectiv lungimea unei secvenţe repetabilă maximală, să se determine numărul  de cuvinte care se pot forma, modulo <code>30011</code>.</p>",
      "text": "Cunoscând n și k, lungimea maximă a unui cuvânt și respectiv lungimea unei secvenţe repetabilă maximală, să se determine numărul de cuvinte care se pot forma, modulo 30011."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>nuz.in</code> conține pe prima linie numerele <code>n</code> şi <code>k</code> având semnificaţia din enunţ.</p>",
      "text": "Fișierul de intrare nuz.in conține pe prima linie numerele n şi k având semnificaţia din enunţ."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>nuz.out</code> va conţine pe o singură linie un număr natural ce reprezintă numărul de cuvinte ce se pot forma conform cerinţei.</p>",
      "text": "Fișierul de ieșire nuz.out va conţine pe o singură linie un număr natural ce reprezintă numărul de cuvinte ce se pot forma conform cerinţei."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>2 ≤ K ≤ N ≤ 100 000</code></li>\n\t<li>pentru <code>50%</code> din teste <code>N ≤ 1000</code></li>\n</ul>",
      "text": "2 ≤ K ≤ N ≤ 100 000 pentru 50% din teste N ≤ 1000"
    },
    {
      "title": "Exemplul 1",
      "html": "<p><code>nuz.in</code></p><pre>2 2</pre><p><code>nuz.out</code></p><pre>25</pre><h3>Explicație</h3><p>Exista 25 de secvenţe: AA, BB, CC, …., YY</p>",
      "text": "nuz.in2 2nuz.out25ExplicațieExista 25 de secvenţe: AA, BB, CC, …., YY"
    },
    {
      "title": "Exemplul 2",
      "html": "<p><code>nuz.in</code></p><pre>3 2</pre><p><code>nuz.out</code></p><pre>1275</pre>",
      "text": "nuz.in3 2nuz.out1275"
    }
  ],
