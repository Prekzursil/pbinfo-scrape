  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Pentru un număr oarecare <code>X</code>, natural, să se calculeze a <code>X</code>-a zecimală a numărului rațional \\( \\frac {1} {2 ^ X} \\).</p>",
      "text": "Pentru un număr oarecare X, natural, să se calculeze a X-a zecimală a numărului rațional \\( \\frac {1} {2 ^ X} \\)."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>zecimala.in</code> conține pe prima linie numărul natural <code>X</code>.</p>",
      "text": "Fișierul de intrare zecimala.in conține pe prima linie numărul natural X."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>zecimala.out</code> va conține pe prima linie un număr natural <code>c</code>, reprezentând  a <code>X</code> -a zecimală a numărului cerut.</p>",
      "text": "Fișierul de ieșire zecimala.out va conține pe prima linie un număr natural c, reprezentând a X -a zecimală a numărului cerut."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ X ≤ 10</code><sup><code>18</code></sup></li>\n</ul>",
      "text": "1 ≤ X ≤ 1018"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>zecimala.in</code></p><pre>5</pre><p><code>zecimala.out</code></p><pre>5</pre><h3>Explicație</h3><p><code>1/2</code><sup><code>5</code></sup><code> = 0.0312</code><u><strong><code>5</code></strong></u>. A <code>5</code>-a zecimală este <code>5</code>.</p>",
      "text": "zecimala.in5zecimala.out5Explicație1/25 = 0.03125. A 5-a zecimală este 5."
    }
  ],
  "examples": [
    {
      "input": "",
      "output": "",
      "explanation": "1/25 = 0.03125. A 5-a zecimală este 5."
