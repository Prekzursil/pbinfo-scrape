  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un număr natural <code>x</code> și un șir de numere naturale. Să se determine ultimul număr din șir care îl care ca sufix pe <code>x</code>.</p>",
      "text": "Se dă un număr natural x și un șir de numere naturale. Să se determine ultimul număr din șir care îl care ca sufix pe x."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>nrsufix.in</code> conține pe prima linie numărul <code>x</code>, iar pe următoarele linii numerele din șir.</p>",
      "text": "Fișierul de intrare nrsufix.in conține pe prima linie numărul x, iar pe următoarele linii numerele din șir."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>nrsufix.out</code> va conține pe prima linie ultimul număr din șir care îl care ca sufix pe <code>x</code>. Dacă în șir nu există nici un astfel de număr, se va afișa <code>nu exista</code>.</p>",
      "text": "Fișierul de ieșire nrsufix.out va conține pe prima linie ultimul număr din șir care îl care ca sufix pe x. Dacă în șir nu există nici un astfel de număr, se va afișa nu exista."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>toate numerele din fișierul de intrare au cel puțin una și cel mult nouă cifre</li>\n\t<li>șirul dat va conține cel puțin două și cel mult <code>1.000.000</code> de elemente</li>\n</ul>",
      "text": "toate numerele din fișierul de intrare au cel puțin una și cel mult nouă cifre șirul dat va conține cel puțin două și cel mult 1.000.000 de elemente"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>nrsufix.in</code></p><pre>12\n3445 89312 1245 12 67120 312 1234578</pre><p><code>nrsufix.out</code></p><pre>312</pre>",
      "text": "nrsufix.in12 3445 89312 1245 12 67120 312 1234578nrsufix.out312"
    }
  ],
  "examples": [],
