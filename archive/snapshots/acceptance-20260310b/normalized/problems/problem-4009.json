  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Moș Crăciun pregătește cadourile pentru acest an. El cunoaște prețurile a <code>n</code> cadouri și are la dispoziție o sumă de bani <code>S</code>. Ajutați-l să aleagă un număr maxim de cadouri a căror preț total să nu depășească <code>S</code> și determinați suma minimă de care mai are nevoie Moș Crăciun pentru a cumpăra încă un cadou.</p>",
      "text": "Moș Crăciun pregătește cadourile pentru acest an. El cunoaște prețurile a n cadouri și are la dispoziție o sumă de bani S. Ajutați-l să aleagă un număr maxim de cadouri a căror preț total să nu depășească S și determinați suma minimă de care mai are nevoie Moș Crăciun pentru a cumpăra încă un cadou."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură numerele <code>n S</code>, iar apoi <code>n</code> numere naturale, reprezentând prețurile cadourilor.</p>",
      "text": "Programul citește de la tastatură numerele n S, iar apoi n numere naturale, reprezentând prețurile cadourilor."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran două numere, <code>k p</code>, separate printr-un spațiu, reprezentând numărul maxim de cadouri pe care le poate cumpăra Moș Crăciun și suma minimă de care mai are nevoie pentru a cumpăra încă un cadou.</p>",
      "text": "Programul va afișa pe ecran două numere, k p, separate printr-un spațiu, reprezentând numărul maxim de cadouri pe care le poate cumpăra Moș Crăciun și suma minimă de care mai are nevoie pentru a cumpăra încă un cadou."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 1000</code></li>\n\t<li><code>1 ≤ S ≤ 1 000 000 000</code></li>\n\t<li>prețurile cadourilor vor fi mai mici decât <code>1 000 000</code></li>\n\t<li>Luca spune că dacă Moșul poate cumpăra toate cele <code>n</code> cadouri, nu mai plătește nimic pentru alt cadou!!!</li>\n</ul>",
      "text": "1 ≤ n ≤ 1000 1 ≤ S ≤ 1 000 000 000 prețurile cadourilor vor fi mai mici decât 1 000 000 Luca spune că dacă Moșul poate cumpăra toate cele n cadouri, nu mai plătește nimic pentru alt cadou!!!"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>5 10\n7 2 6 4 3</pre><p><strong>Ieșire</strong></p><pre>3 5</pre><h3>Explicație</h3><p>Cu suma dată Moș Crăciun va cumpăra trei cadouri, cele cu prețurile <code>2 4 3</code>. Mai are nevoie de încă <code>5</code> (bani) ppentru a putea cumăra și cadoul cu prețul <code>6</code>.</p>",
      "text": "Intrare5 10 7 2 6 4 3Ieșire3 5ExplicațieCu suma dată Moș Crăciun va cumpăra trei cadouri, cele cu prețurile 2 4 3. Mai are nevoie de încă 5 (bani) ppentru a putea cumăra și cadoul cu prețul 6."
    }
  ],
