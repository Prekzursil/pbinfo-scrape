  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se consideră un arbore binar cu <code>n</code> noduri numeroate de <code>1</code> la <code>n</code> pentru care se cunosc parcurgerile în preordine și inordine. Să se afișeze nodurile din arbore în urma parcurgerii în postordine.</p>",
      "text": "Se consideră un arbore binar cu n noduri numeroate de 1 la n pentru care se cunosc parcurgerile în preordine și inordine. Să se afișeze nodurile din arbore în urma parcurgerii în postordine."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Fișierul de intrare <code>construct_arbore.in</code> conține pe prima linie numărul <code>n</code>, reprezentând numărul de noduri ale arborelui. Pe următoarea linie se află nodurile arborelui, obținute în urma parcurgerii în preordine (rădăcină, stâng, drept), iar pe ultima linie se află nodurile arborelui, obținute în urma parcurgerii în inordine (stâng, rădăcină, drept).</p>",
      "text": "Fișierul de intrare construct_arbore.in conține pe prima linie numărul n, reprezentând numărul de noduri ale arborelui. Pe următoarea linie se află nodurile arborelui, obținute în urma parcurgerii în preordine (rădăcină, stâng, drept), iar pe ultima linie se află nodurile arborelui, obținute în urma parcurgerii în inordine (stâng, rădăcină, drept)."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Fișierul de ieșire <code>construct_arbore.out</code> va conține pe prima linie <code>n</code> numere, separate prin exact un spațiu, reprezentând nodurile arborelui, obținute în urma parcurgerii în postordine.</p>",
      "text": "Fișierul de ieșire construct_arbore.out va conține pe prima linie n numere, separate prin exact un spațiu, reprezentând nodurile arborelui, obținute în urma parcurgerii în postordine."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li><code>1 ≤ n ≤ 100</code></li>\n</ul>",
      "text": "1 ≤ n ≤ 100"
    },
    {
      "title": "Exemplu:",
      "html": "<p><code>construct_arbore.in</code></p><pre>5\n1 3 5 4 2\n3 1 4 5 2</pre><p><code>construct_arbore.out</code></p><pre>3 4 2 5 1 </pre><h3>Explicație</h3><p>Exemplul corespunde arborelui de mai jos:</p><img src=\"/resurse/193752/imagine/arbore_4860.png\" alt=\"Arbore\" style=\"size:25%; width:25%\">",
      "text": "construct_arbore.in5 1 3 5 4 2 3 1 4 5 2construct_arbore.out3 4 2 5 1 ExplicațieExemplul corespunde arborelui de mai jos:"
    }
