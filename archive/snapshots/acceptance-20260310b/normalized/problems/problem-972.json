  "tags": [],
  "sections": [
    {
      "title": "Cerința",
      "html": "<p>Se dă un șir de caractere. Să se determine câte vocale din șir sunt cuprinse între două consoane.</p>",
      "text": "Se dă un șir de caractere. Să se determine câte vocale din șir sunt cuprinse între două consoane."
    },
    {
      "title": "Date de intrare",
      "html": "<p>Programul citește de la tastatură un sir de caractere.</p>",
      "text": "Programul citește de la tastatură un sir de caractere."
    },
    {
      "title": "Date de ieșire",
      "html": "<p>Programul va afișa pe ecran valoarea cerută.</p>",
      "text": "Programul va afișa pe ecran valoarea cerută."
    },
    {
      "title": "Restricții și precizări",
      "html": "<ul>\n\t<li>șirul va avea cel mult <code>255</code> caractere</li>\n\t<li>șirul nu va conține litere mari</li>\n</ul>",
      "text": "șirul va avea cel mult 255 caractere șirul nu va conține litere mari"
    },
    {
      "title": "Exemplu:",
      "html": "<p><strong>Intrare</strong></p><pre>oasele sunt fragile</pre><p><strong>Ieșire</strong></p><pre>4</pre>",
      "text": "Intrareoasele sunt fragileIeșire4"
    },
    {
      "title": "Explicație",
      "html": "<p>Vocalele care respectă regula sunt:</p><p><code>oas</code><u><code>e</code></u><code>le s</code><u><code>u</code></u><code>nt fr</code><u><code>a</code></u><code>g</code><u><code>i</code></u><code>le</code></p>",
      "text": "Vocalele care respectă regula sunt:oasele sunt fragile"
    }
  ],
  "examples": [
    {
      "input": "oasele sunt fragile",
      "output": "4"
    }
  ],
