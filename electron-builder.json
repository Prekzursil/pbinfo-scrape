{
  "appId": "ro.pbinfo.problemarchivecrawler.desktop",
  "productName": "Problem Archive Crawler",
  "asar": false,
  "directories": {
    "output": "release-desktop"
  },
  "files": [
    "dist-desktop/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "assets/desktop",
      "to": "assets/desktop"
    }
  ],
  "win": {
    "icon": "assets/desktop/problem-archive-crawler.ico",
    "signAndEditExecutable": false,
    "target": [
      "portable"
    ]
  },
  "portable": {
    "unicode": true
  }
}
